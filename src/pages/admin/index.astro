---
import { supabaseAdmin } from '../../lib/supabase'
import { createHmac, timingSafeEqual } from 'crypto'
import * as dotenv from 'dotenv'
import { resolve } from 'path'

dotenv.config({ path: resolve(process.cwd(), '.env') })

const SALT      = process.env.ADMIN_SALT ?? 'protegecolitas2026'
const COOKIE_MS = 8 * 60 * 60 * 1000
const COOKIE_AGE = 8 * 60 * 60

function sign(s: string): string {
  return createHmac('sha256', SALT).update(s).digest('hex')
}

function validSession(raw: string): boolean {
  try {
    const parts = decodeURIComponent(raw).split('|')
    if (parts.length !== 3) return false
    const [email, exp, sig] = parts
    if (Date.now() > Number(exp)) return false
    const expected = sign(`${email}|${exp}`)
    return timingSafeEqual(Buffer.from(sig, 'hex'), Buffer.from(expected, 'hex'))
  } catch { return false }
}

function getCookie(header: string, name: string): string | null {
  return header.match(new RegExp(`(?:^|;\\s*)${name}=([^;]+)`))?.[1] ?? null
}

function rel(iso: string): string {
  const m = Math.floor((Date.now() - new Date(iso).getTime()) / 60000)
  if (m < 60) return `${m}m`
  if (m < 1440) return `${Math.floor(m / 60)}h`
  return `${Math.floor(m / 1440)}d`
}

function generarSlug(text: string): string {
  return text.toLowerCase()
    .normalize('NFD').replace(/[̀-ͯ]/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '')
    .slice(0, 60)
}

const cookies  = Astro.request.headers.get('cookie') ?? ''
const ck       = getCookie(cookies, 'admin_session')
const isAuth   = !!ck && validSession(ck)
const isSecure = Astro.url.protocol === 'https:'
let loginError = ''

if (Astro.request.method === 'POST') {
  const form   = await Astro.request.formData()
  const action = form.get('action')?.toString()

  if (action === 'login') {
    const email = form.get('email')?.toString().trim() ?? ''
    const pass  = form.get('password')?.toString() ?? ''
    const hash  = createHmac('sha256', SALT).update(pass).digest('hex')
    const { data: mod } = await supabaseAdmin
      .from('moderadores')
      .select('id, nombre, rol')
      .eq('email', email)
      .eq('password_hash', hash)
      .eq('activo', true)
      .maybeSingle()
    if (!mod) {
      loginError = 'Email o contraseña incorrectos'
    } else {
      const exp = Date.now() + COOKIE_MS
      const pl  = `${email}|${exp}`
      const val = encodeURIComponent(`${pl}|${sign(pl)}`)
      return new Response(null, {
        status: 302,
        headers: {
          Location: '/admin',
          'Set-Cookie': `admin_session=${val}; HttpOnly; Path=/; SameSite=Strict; Max-Age=${COOKIE_AGE}${isSecure ? '; Secure' : ''}`
        }
      })
    }
  }

  if (action === 'logout') {
    return new Response(null, {
      status: 302,
      headers: { Location: '/admin', 'Set-Cookie': 'admin_session=; HttpOnly; Path=/; Max-Age=0' }
    })
  }

  if (!isAuth) {
    return new Response(JSON.stringify({ ok: false, error: 'No autorizado' }), {
      status: 401, headers: { 'Content-Type': 'application/json' }
    })
  }

  const getId = (): string => form.get('id')?.toString() ?? ''
  const J = (ok: boolean, error?: string): Response =>
    new Response(JSON.stringify({ ok, error }), { headers: { 'Content-Type': 'application/json' } })

  if (action === 'aprobar') {
    const { error } = await supabaseAdmin.from('mascotas').update({ status: 'publicado', moderado_at: new Date().toISOString() }).eq('id', getId())
    return J(!error, error?.message)
  }
  if (action === 'rechazar') {
    const { error } = await supabaseAdmin.from('mascotas').update({ status: 'descartado', moderado_at: new Date().toISOString() }).eq('id', getId())
    return J(!error, error?.message)
  }
  if (action === 'reunir') {
    const { error } = await supabaseAdmin.from('mascotas').update({ status: 'reunido', moderado_at: new Date().toISOString() }).eq('id', getId())
    return J(!error, error?.message)
  }
  if (action === 'eliminar_mascota') {
    const { error } = await supabaseAdmin.from('mascotas').delete().eq('id', getId())
    return J(!error, error?.message)
  }
  if (action === 'adoptar_mascota') {
    const { error } = await supabaseAdmin.from('mascotas').update({ tipo: 'adopcion' }).eq('id', getId())
    return J(!error, error?.message)
  }
  if (action === 'nueva_mascota') {
    const nombre        = form.get('nombre')?.toString().trim()           || null
    const especie       = form.get('especie')?.toString()                  ?? 'Perro'
    const color         = form.get('color')?.toString().trim()             || null
    const tamanio       = form.get('tamanio')?.toString()                  || null
    const zona          = form.get('zona')?.toString().trim()              ?? ''
    const descripcion   = form.get('descripcion')?.toString().trim()       || null
    const senias        = form.get('senias')?.toString().trim()            || null
    const whatsapp      = form.get('whatsapp')?.toString().trim()          ?? ''
    const contacto_nombre = form.get('contacto_nombre')?.toString().trim() || null
    const tipo          = form.get('tipo')?.toString()                     ?? 'perdido'
    const status        = form.get('status')?.toString()                   ?? 'publicado'
    if (!especie || !zona || !whatsapp) return J(false, 'Especie, zona y WhatsApp son requeridos')
    const { data: nueva, error: insErr } = await supabaseAdmin
      .from('mascotas')
      .insert({ nombre, especie, color, tamanio, zona, descripcion, senias, whatsapp, contacto_nombre, tipo, status, created_at: new Date().toISOString() })
      .select('id')
      .single()
    if (insErr) return J(false, insErr.message)
    const foto = form.get('foto') as File | null
    if (foto && foto.size > 0 && nueva?.id) {
      const path = `${nueva.id}/foto_1.jpg`
      const { error: upErr } = await supabaseAdmin.storage
        .from('mascotas')
        .upload(path, await foto.arrayBuffer(), { contentType: foto.type, upsert: true })
      if (!upErr) {
        const { data: urlData } = supabaseAdmin.storage.from('mascotas').getPublicUrl(path)
        await supabaseAdmin.from('mascotas').update({ foto_url: urlData.publicUrl }).eq('id', nueva.id)
      }
    }
    return J(true, undefined)
  }
  if (action === 'aprobar_vet') {
    const { error } = await supabaseAdmin.from('vets').update({ aprobado: true }).eq('id', getId())
    return J(!error, error?.message)
  }
  if (action === 'rechazar_vet') {
    const { error } = await supabaseAdmin.from('vets').delete().eq('id', getId())
    return J(!error, error?.message)
  }
  if (action === 'feed') {
    const tipo   = form.get('tipo')?.toString() ?? 'info'
    const titulo = form.get('titulo')?.toString().trim() ?? ''
    const cuerpo = form.get('cuerpo')?.toString().trim() ?? ''
    if (!titulo || !cuerpo) return J(false, 'Faltan datos')
    const feedImg = form.get('feed_img') as File | null
    let imagen_url: string | null = null
    if (feedImg && feedImg.size > 0) {
      const fname = `feed/feed-${Date.now()}.${feedImg.type.includes('png') ? 'png' : 'jpg'}`
      const { error: upErr } = await supabaseAdmin.storage
        .from('banners')
        .upload(fname, await feedImg.arrayBuffer(), { contentType: feedImg.type, upsert: true })
      if (!upErr) {
        const { data: ud } = supabaseAdmin.storage.from('banners').getPublicUrl(fname)
        imagen_url = ud.publicUrl
      }
    }
    const slug = titulo.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9\s-]/g, '').trim().replace(/\s+/g, '-').slice(0, 80) + '-' + Date.now().toString(36)
    const { error } = await supabaseAdmin.from('feed').insert({ tipo, titulo, cuerpo, imagen_url, slug, published_at: new Date().toISOString() })
    return J(!error, error?.message)
  }
  if (action === 'eliminar_feed') {
    const { error } = await supabaseAdmin.from('feed').delete().eq('id', getId())
    return J(!error, error?.message)
  }
  if (action === 'editar_feed') {
    const id = form.get('id')?.toString() ?? ''
    if (!id) return J(false, 'ID requerido')
    const feedImg = form.get('feed_img_edit') as File | null
    let imagen_url_update: string | null = null
    if (feedImg && feedImg.size > 0) {
      const fname = `feed/feed-${Date.now()}.jpg`
      await supabaseAdmin.storage.from('banners').upload(fname, await feedImg.arrayBuffer(), { contentType: feedImg.type, upsert: true })
      const { data: ud } = supabaseAdmin.storage.from('banners').getPublicUrl(fname)
      imagen_url_update = ud.publicUrl
    }
    const updateData: Record<string, unknown> = {
      tipo:   form.get('tipo')?.toString() ?? 'info',
      titulo: form.get('titulo')?.toString().trim() ?? '',
      cuerpo: form.get('cuerpo')?.toString().trim() ?? '',
    }
    if (imagen_url_update) updateData.imagen_url = imagen_url_update
    const { error } = await supabaseAdmin.from('feed').update(updateData).eq('id', id)
    return J(!error, error?.message)
  }
  if (action === 'insumo') {
    const recibida  = parseInt(form.get('cantidad_recibida')?.toString() ?? '0', 10)
    const requerida = parseInt(form.get('cantidad_requerida')?.toString() ?? '1', 10)
    if (isNaN(recibida) || isNaN(requerida)) return J(false, 'Cantidades inválidas')
    const { error } = await supabaseAdmin.from('necesidades').update({
      cantidad_recibida: recibida,
      cantidad_requerida: requerida,
      updated_at: new Date().toISOString()
    }).eq('id', getId())
    return J(!error, error?.message)
  }
  if (action === 'nuevo_insumo') {
    const item      = form.get('item')?.toString().trim() ?? ''
    const requerida = parseInt(form.get('cantidad_requerida')?.toString() ?? '0', 10)
    const prioridad = form.get('prioridad')?.toString() ?? 'urgente'
    if (!item || isNaN(requerida) || requerida < 1) return J(false, 'Datos inválidos')
    const { error } = await supabaseAdmin.from('necesidades').insert({
      item, cantidad_requerida: requerida, cantidad_recibida: 0, prioridad
    })
    return J(!error, error?.message)
  }
  if (action === 'nuevo_vet') {
    const nombre    = form.get('nombre')?.toString().trim() ?? ''
    const zona      = form.get('zona')?.toString().trim() ?? ''
    const whatsapp  = form.get('whatsapp')?.toString().trim() ?? ''
    const servicios = form.get('servicios')?.toString().trim() || null
    const horario   = form.get('horario')?.toString().trim() || null
    if (!nombre || !zona || !whatsapp) return J(false, 'Faltan datos requeridos')
    const { error } = await supabaseAdmin.from('vets').insert({
      nombre, zona, whatsapp, servicios, horario, gratuito: true
    })
    return J(!error, error?.message)
  }
  if (action === 'editar_mascota') {
    const id = getId()
    const fotoUpdate: { foto_url?: string; foto_url_2?: string; foto_url_3?: string } = {}
    for (let i = 1; i <= 3; i++) {
      const foto = form.get(`foto_nueva_${i}`) as File | null
      if (foto && foto.size > 0) {
        const path = `${id}/foto_${i}.jpg`
        await supabaseAdmin.storage.from('mascotas').upload(path, await foto.arrayBuffer(), { contentType: 'image/jpeg', upsert: true })
        const { data: urlData } = supabaseAdmin.storage.from('mascotas').getPublicUrl(path)
        if (urlData.publicUrl) {
          if (i === 1) fotoUpdate.foto_url   = urlData.publicUrl
          if (i === 2) fotoUpdate.foto_url_2 = urlData.publicUrl
          if (i === 3) fotoUpdate.foto_url_3 = urlData.publicUrl
        }
      }
    }
    const { error } = await supabaseAdmin.from('mascotas').update({
      nombre:     form.get('nombre')?.toString().trim()     || null,
      especie:    form.get('especie')?.toString()            ?? '',
      tipo:       form.get('tipo')?.toString()               || null,
      zona:       form.get('zona')?.toString().trim()        ?? '',
      color:      form.get('color')?.toString().trim()       || null,
      tamanio:    form.get('tamanio')?.toString()            || null,
      descripcion:form.get('descripcion')?.toString().trim() || null,
      whatsapp:   form.get('whatsapp')?.toString().trim()    ?? '',
      ...fotoUpdate,
    }).eq('id', id)
    return J(!error, error?.message)
  }
  if (action === 'editar_vet') {
    const { error } = await supabaseAdmin.from('vets').update({
      nombre:    form.get('nombre')?.toString().trim()    ?? '',
      zona:      form.get('zona')?.toString().trim()      ?? '',
      whatsapp:  form.get('whatsapp')?.toString().trim()  ?? '',
      servicios: form.get('servicios')?.toString().trim() || null,
      horario:   form.get('horario')?.toString().trim()   || null,
    }).eq('id', getId())
    return J(!error, error?.message)
  }
  if (action === 'editar_insumo') {
    const item      = form.get('item')?.toString().trim()
    const recibida  = parseInt(form.get('cantidad_recibida')?.toString()  ?? '0', 10)
    const requerida = parseInt(form.get('cantidad_requerida')?.toString() ?? '1', 10)
    const prioridad = form.get('prioridad')?.toString() ?? 'urgente'
    if (!item || isNaN(recibida) || isNaN(requerida)) return J(false, 'Datos inválidos')
    const { error } = await supabaseAdmin.from('necesidades').update({
      item, cantidad_recibida: recibida, cantidad_requerida: requerida, prioridad,
      updated_at: new Date().toISOString()
    }).eq('id', getId())
    return J(!error, error?.message)
  }
  if (action === 'eliminar_insumo') {
    const { error } = await supabaseAdmin.from('necesidades').delete().eq('id', getId())
    return J(!error, error?.message)
  }

  // IMPORTANTE: crear bucket 'banners' en Supabase Storage → public
  // IMPORTANTE: crear bucket 'mascotas' en Supabase Storage → public
  if (action === 'banner') {
    const titulo      = form.get('titulo')?.toString().trim() ?? ''
    const descripcion = form.get('descripcion')?.toString().trim() || null
    const link        = form.get('link')?.toString().trim() || null
    const activo      = form.get('activo') === 'on'
    if (!titulo) return J(false, 'Título requerido')

    const uploadImg = async (field: string): Promise<string | null> => {
      const file = form.get(field) as File | null
      if (!file || file.size === 0) return null
      const ext = file.name.split('.').pop() ?? 'jpg'
      const filename = `${field}-${Date.now()}.${ext}`
      const buffer = await file.arrayBuffer()
      const { data: upload } = await supabaseAdmin.storage
        .from('banners')
        .upload(filename, buffer, { contentType: file.type, upsert: true })
      if (!upload) return null
      const { data: urlData } = supabaseAdmin.storage.from('banners').getPublicUrl(filename)
      return urlData.publicUrl
    }

    const imagen_url        = await uploadImg('banner_img')
    const imagen_url_mobile = await uploadImg('banner_img_mobile')

    const { error } = await supabaseAdmin.from('banners').insert({
      titulo, descripcion, link, imagen_url, imagen_url_mobile, activo
    })
    return J(!error, error?.message)
  }
  if (action === 'toggle_banner') {
    const activo = form.get('activo') === 'true'
    const { error } = await supabaseAdmin.from('banners').update({ activo }).eq('id', getId())
    return J(!error, error?.message)
  }
  if (action === 'eliminar_banner') {
    const { error } = await supabaseAdmin.from('banners').delete().eq('id', getId())
    return J(!error, error?.message)
  }
  if (action === 'publicar_gemini') {
    const statusVal      = form.get('status')?.toString() || 'pendiente'
    const senias         = form.get('senias')?.toString().trim() || null
    const contactoNombre = form.get('contacto_nombre')?.toString().trim() || null
    const descripBase    = form.get('descripcion')?.toString().trim() || null
    const partes         = [descripBase, senias ? `Señas: ${senias}` : null, contactoNombre ? `Contacto: ${contactoNombre}` : null].filter(Boolean)
    const { error } = await supabaseAdmin.from('mascotas').insert({
      nombre:      form.get('nombre')?.toString().trim() || null,
      especie:     form.get('especie')?.toString() || 'Otro',
      color:       form.get('color')?.toString().trim() || null,
      zona:        form.get('zona')?.toString().trim() || '',
      descripcion: partes.length ? partes.join(' | ') : null,
      whatsapp:    form.get('whatsapp')?.toString().trim() || '',
      tipo:        form.get('tipo')?.toString() || 'perdido',
      status:      statusVal,
    })
    if (error) return J(false, error.message)
    return new Response(null, { status: 302, headers: { Location: '/admin#tab-gemini' } })
  }
  if (action === 'feed_gemini') {
    const titulo = form.get('titulo')?.toString().trim() || ''
    const cuerpo = form.get('cuerpo')?.toString().trim() || ''
    const tipo   = form.get('tipo')?.toString() || 'info'
    if (!titulo || !cuerpo) return J(false, 'Título y cuerpo son obligatorios')
    const slug = generarSlug(titulo) + '-' + Date.now().toString(36)
    const { error } = await supabaseAdmin.from('feed').insert({ tipo, titulo, cuerpo, slug })
    if (error) return J(false, error.message)
    return new Response(null, { status: 302, headers: { Location: '/admin#tab-gemini' } })
  }
  if (action === 'insumo_gemini') {
    const item               = form.get('item')?.toString().trim() || ''
    const cantidad_requerida = parseInt(form.get('cantidad_requerida')?.toString() || '0', 10)
    const cantidad_recibida  = parseInt(form.get('cantidad_recibida')?.toString()  || '0', 10)
    const prioridad          = form.get('prioridad')?.toString() || 'urgente'
    if (!item || !cantidad_requerida) return J(false, 'Ítem y cantidad requerida son obligatorios')
    const { error } = await supabaseAdmin.from('necesidades').insert({ item, cantidad_requerida, cantidad_recibida, prioridad })
    if (error) return J(false, error.message)
    return new Response(null, { status: 302, headers: { Location: '/admin#tab-gemini' } })
  }
}

type Mascota = {
  id: string; nombre: string | null; especie: string; zona: string
  tipo: string | null; whatsapp: string | null; foto_url: string | null
  color: string | null; descripcion: string | null
  status: string; created_at: string; moderado_at: string | null
}
type Vet = {
  id: string; nombre: string; zona: string; whatsapp: string | null
  servicios: string | null; horario: string | null; gratuito: boolean; created_at: string
}
type FeedItem    = { id: string; tipo: string; titulo: string; cuerpo: string; published_at: string }
type Necesidad   = { id: string; item: string; cantidad_requerida: number; cantidad_recibida: number; prioridad: string }
type Banner      = { id: string; titulo: string; descripcion: string | null; imagen_url: string | null; imagen_url_mobile: string | null; link: string | null; activo: boolean; created_at: string }
type VisitaCount = { key: string; count: number }

function groupCount(rows: any[] | null | undefined, key: string): VisitaCount[] {
  const counts: Record<string, number> = {}
  rows?.forEach((r: Record<string, string | null>) => {
    const k = r[key] || 'Otro'
    counts[k] = (counts[k] ?? 0) + 1
  })
  return Object.entries(counts).map(([k, c]) => ({ key: k, count: c })).sort((a, b) => b.count - a.count)
}

let pendientes:  Mascota[]   = []
let publicadas:  Mascota[]   = []
let reunidas:    Mascota[]   = []
let vets:        Vet[]       = []
let feedItems:   FeedItem[]  = []
let necesidades: Necesidad[] = []
let banners:     Banner[]    = []
let adopcion:    Mascota[]   = []
let stats = { pendientes: 0, publicadas: 0, reunidas: 0, vets: 0 }

let visitasHoy:    number         = 0
let visitasSemana: number         = 0
let visitasTotal:  number         = 0
let porDispositivo: VisitaCount[] = []
let porOs:          VisitaCount[] = []
let porBrowser:     VisitaCount[] = []
let porPagina:      VisitaCount[] = []
let porFuente:      VisitaCount[] = []

if (isAuth) {
  const [mp, mpub, mreu, mv, mf, mn, sp, spub, sreu, sv, mb] = await Promise.all([
    supabaseAdmin.from('mascotas').select('id,nombre,especie,zona,tipo,whatsapp,foto_url,color,descripcion,status,created_at,moderado_at').eq('status','pendiente').order('created_at',{ascending:true}),
    supabaseAdmin.from('mascotas').select('id,nombre,especie,zona,tipo,whatsapp,foto_url,color,descripcion,status,created_at,moderado_at').eq('status','publicado').order('created_at',{ascending:false}).limit(50),
    supabaseAdmin.from('mascotas').select('id,nombre,especie,zona,tipo,foto_url,status,created_at,moderado_at').eq('status','reunido').order('moderado_at',{ascending:false}).limit(20),
    supabaseAdmin.from('vets').select('id,nombre,zona,whatsapp,servicios,horario,gratuito,created_at').order('created_at',{ascending:false}),
    supabaseAdmin.from('feed').select('id,tipo,titulo,cuerpo,published_at').order('published_at',{ascending:false}).limit(50),
    supabaseAdmin.from('necesidades').select('*').order('prioridad'),
    supabaseAdmin.from('mascotas').select('*',{count:'exact',head:true}).eq('status','pendiente'),
    supabaseAdmin.from('mascotas').select('*',{count:'exact',head:true}).eq('status','publicado'),
    supabaseAdmin.from('mascotas').select('*',{count:'exact',head:true}).eq('status','reunido'),
    supabaseAdmin.from('vets').select('*',{count:'exact',head:true}),
    supabaseAdmin.from('banners').select('id,titulo,descripcion,imagen_url,imagen_url_mobile,link,activo,created_at').order('created_at',{ascending:false}),
  ])
  pendientes  = (mp.data   ?? []) as Mascota[]
  publicadas  = (mpub.data ?? []) as Mascota[]
  reunidas    = (mreu.data ?? []) as Mascota[]
  vets        = (mv.data   ?? []) as Vet[]
  feedItems   = (mf.data   ?? []) as FeedItem[]
  necesidades = (mn.data   ?? []) as Necesidad[]
  banners     = (mb.data   ?? []) as Banner[]
  stats = { pendientes: sp.count ?? 0, publicadas: spub.count ?? 0, reunidas: sreu.count ?? 0, vets: sv.count ?? 0 }
  adopcion = publicadas.filter((m: Mascota) => m.tipo === 'adopcion')

  // Analytics queries
  const now     = new Date()
  const dayAgo  = new Date(now.getTime() - 86_400_000).toISOString()
  const weekAgo = new Date(now.getTime() - 7 * 86_400_000).toISOString()

  const [vaHoy, vaSem, vaTotal, vaDisp, vaOs, vaBro, vaPag, vaFue] = await Promise.all([
    supabaseAdmin.from('visitas').select('*', { count: 'exact', head: true }).gte('created_at', dayAgo),
    supabaseAdmin.from('visitas').select('*', { count: 'exact', head: true }).gte('created_at', weekAgo),
    supabaseAdmin.from('visitas').select('*', { count: 'exact', head: true }),
    supabaseAdmin.from('visitas').select('dispositivo').limit(5000),
    supabaseAdmin.from('visitas').select('os').limit(5000),
    supabaseAdmin.from('visitas').select('browser').limit(5000),
    supabaseAdmin.from('visitas').select('pagina').limit(10000),
    supabaseAdmin.from('visitas').select('referrer').not('referrer', 'is', null).limit(5000),
  ])

  visitasHoy    = vaHoy.count   ?? 0
  visitasSemana = vaSem.count   ?? 0
  visitasTotal  = vaTotal.count ?? 0

  porDispositivo = groupCount(vaDisp.data, 'dispositivo')
  porOs          = groupCount(vaOs.data,   'os')
  porBrowser     = groupCount(vaBro.data,  'browser')
  porPagina      = groupCount(vaPag.data,  'pagina').slice(0, 10)
  porFuente      = groupCount(vaFue.data,  'referrer').slice(0, 5)
}
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin — Protege Colitas</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>

{!isAuth ? (
  <div class="login-wrap">
    <div class="login-box">
      <img src="/logo.png" alt="Protege Colitas" width="80" style="display:block;margin:0 auto 16px" />
      <h1 class="login-title">Protege Colitas</h1>
      <p class="login-sub">Centro de control</p>
      {loginError && <p class="login-err" role="alert">{loginError}</p>}
      <form method="POST" autocomplete="off">
        <input type="hidden" name="action" value="login" />
        <input type="email" name="email" placeholder="Email" required autocomplete="email" />
        <input type="password" name="password" placeholder="Contraseña" required autofocus />
        <button type="submit" class="btn-login">Entrar →</button>
      </form>
    </div>
  </div>
) : (
  <div class="panel">

    <!-- ═══ HOME: GRID DE TILES ═══ -->
    <div id="home">
      <header class="hdr">
        <div class="hdr-left">
          <span class="hdr-logo">🐾</span>
          <span class="hdr-title">Centro de Control</span>
        </div>
        <div class="hdr-badges">
          {stats.pendientes > 0 && <span class="hdr-badge badge-rojo">{stats.pendientes} pendientes</span>}
          <span class="hdr-badge badge-verde">{stats.publicadas} publicadas</span>
          <span class="hdr-badge badge-azul">{stats.reunidas} reunidas</span>
        </div>
        <div class="hdr-right">
          <a href="https://protegecolitas.org" target="_blank" rel="noopener" class="btn-sitio">Ver sitio →</a>
          <form method="POST" style="display:inline">
            <input type="hidden" name="action" value="logout" />
            <button type="submit" class="btn-salir">Salir</button>
          </form>
        </div>
      </header>

      <div class="tile-grid">
        <!-- 1. Pendientes -->
        <button class="tile tile-pendiente" onclick="showModule('pendientes')">
          <span class="tile-icon">⏳</span>
          <span class="tile-label">Pendientes</span>
          <span class="tile-count">
            {stats.pendientes}
            {stats.pendientes > 0 && <span class="pulse-dot"></span>}
          </span>
        </button>

        <!-- 2. Publicadas -->
        <button class="tile tile-publicadas" onclick="showModule('publicadas')">
          <span class="tile-icon">🐾</span>
          <span class="tile-label">Publicadas</span>
          <span class="tile-count">{stats.publicadas}</span>
        </button>

        <!-- 3. Adopción -->
        <button class="tile tile-adopcion" onclick="showModule('adopcion')">
          <span class="tile-icon">🏠</span>
          <span class="tile-label">En adopción</span>
          <span class="tile-count">{adopcion.length}</span>
        </button>

        <!-- 4. Agregar -->
        <button class="tile tile-agregar" onclick="showModule('agregar')">
          <span class="tile-icon">➕</span>
          <span class="tile-label">Agregar</span>
          <span class="tile-sub">mascota directa</span>
        </button>

        <!-- 5. Gemini -->
        <button class="tile tile-gemini" onclick="showModule('gemini')">
          <span class="tile-icon">📸</span>
          <span class="tile-label">Gemini</span>
          <span class="tile-sub">desde foto</span>
        </button>

        <!-- 6. Vets -->
        <button class="tile tile-vets" onclick="showModule('vets')">
          <span class="tile-icon">🩺</span>
          <span class="tile-label">Veterinarios</span>
          <span class="tile-count">{stats.vets}</span>
        </button>

        <!-- 7. Feed -->
        <button class="tile tile-feed" onclick="showModule('feed')">
          <span class="tile-icon">📰</span>
          <span class="tile-label">Feed</span>
          <span class="tile-sub">noticias</span>
        </button>

        <!-- 8. Insumos -->
        <button class="tile tile-insumos" onclick="showModule('insumos')">
          <span class="tile-icon">📦</span>
          <span class="tile-label">Insumos</span>
          <span class="tile-count">{necesidades.length}</span>
        </button>

        <!-- 9. Analíticas -->
        <button class="tile tile-analiticas" onclick="showModule('analiticas')">
          <span class="tile-icon">📊</span>
          <span class="tile-label">Analíticas</span>
          <span class="tile-sub">hoy: {visitasHoy}</span>
        </button>

        <!-- 10. Banners -->
        <button class="tile tile-banners" onclick="showModule('banners')">
          <span class="tile-icon">🖼️</span>
          <span class="tile-label">Banners</span>
          <span class="tile-count">{banners.length}</span>
        </button>
      </div>
    </div>

    <!-- ═══ MÓDULO: PENDIENTES ═══ -->
    <div id="mod-pendientes" class="module" hidden>
      <div class="mod-hdr">
        <button class="btn-back" onclick="showHome()">← Inicio</button>
        <span class="mod-title">⏳ Pendientes</span>
        <span></span>
      </div>
      <div class="mod-body">
        {pendientes.length === 0
          ? <p class="empty-msg">No hay mascotas pendientes ✓</p>
          : <Fragment>
              <div class="search-bar">
                <input type="text" id="searchPendientes" placeholder="Buscar por nombre, zona, especie…" class="search-input" oninput="filterCards('searchPendientes','pendiente-card')" />
              </div>
              <div class="card-list" id="listaPendientes">
                {pendientes.map(m => (
                  <div id={`row-${m.id}`} class="mcard pendiente-card">
                    <div class="mcard-media">
                      {m.foto_url
                        ? <a href={m.foto_url} target="_blank" rel="noreferrer">
                            <img src={m.foto_url} alt="" class="mcard-img" loading="lazy" />
                          </a>
                        : <div class="mcard-nofoto">🐾</div>
                      }
                    </div>
                    <div class="mcard-info">
                      <span class="mcard-name">{m.nombre ?? 'Sin nombre'}</span>
                      <span class="mcard-meta">{m.especie} · {m.zona} · hace {rel(m.created_at)}</span>
                      <div class="mcard-badges">
                        {m.tipo === 'perdido' && <span class="badge badge-rojo">perdido</span>}
                        {m.tipo === 'encontrado' && <span class="badge badge-verde">encontrado</span>}
                        {m.tipo === 'adopcion' && <span class="badge badge-azul">adopción</span>}
                        {m.descripcion && <span class="mcard-desc">{m.descripcion.slice(0,60)}{m.descripcion.length > 60 ? '…' : ''}</span>}
                      </div>
                    </div>
                    <div class="mcard-actions">
                      <button class="btn btn-verde" data-action="aprobar" data-id={m.id} data-row={`row-${m.id}`}>✓ Aprobar</button>
                      <button class="btn btn-rojo" data-action="rechazar" data-id={m.id} data-row={`row-${m.id}`} data-confirm="¿Rechazar este reporte?">✗ Rechazar</button>
                      <button class="btn btn-outline btn-icon btn-edit-mascota"
                        data-id={m.id}
                        data-nombre={m.nombre ?? ''}
                        data-especie={m.especie}
                        data-tipo={m.tipo ?? 'perdido'}
                        data-zona={m.zona}
                        data-color={m.color ?? ''}
                        data-tamanio={m.tamanio ?? ''}
                        data-descripcion={m.descripcion ?? ''}
                        data-whatsapp={m.whatsapp ?? ''}
                        data-fotourl={m.foto_url ?? ''}
                        title="Editar"
                      >✏️</button>
                      {m.whatsapp && <a href={`https://wa.me/58${m.whatsapp.slice(1)}`} class="btn btn-wa" target="_blank" rel="noreferrer">💬</a>}
                      <a href={`/mascota/${m.id}`} target="_blank" class="btn btn-outline btn-sm">Ver →</a>
                    </div>
                  </div>
                ))}
              </div>
            </Fragment>
        }
      </div>
    </div>

    <!-- ═══ MÓDULO: PUBLICADAS ═══ -->
    <div id="mod-publicadas" class="module" hidden>
      <div class="mod-hdr">
        <button class="btn-back" onclick="showHome()">← Inicio</button>
        <span class="mod-title">🐾 Publicadas ({publicadas.length})</span>
        <span></span>
      </div>
      <div class="mod-body">
        {publicadas.length === 0
          ? <p class="empty-msg">No hay mascotas publicadas</p>
          : <Fragment>
              <div class="search-bar">
                <input type="text" id="searchPublicadas" placeholder="Buscar por nombre, zona, especie…" class="search-input" oninput="filterCards('searchPublicadas','publicada-card')" />
              </div>
              <div class="card-list">
                {publicadas.map(m => (
                  <div id={`row-${m.id}`} class="mcard publicada-card">
                    <div class="mcard-media">
                      {m.foto_url
                        ? <a href={m.foto_url} target="_blank" rel="noreferrer">
                            <img src={m.foto_url} alt="" class="mcard-img" loading="lazy" />
                          </a>
                        : <div class="mcard-nofoto">🐾</div>
                      }
                    </div>
                    <div class="mcard-info">
                      <span class="mcard-name">{m.nombre ?? 'Sin nombre'}</span>
                      <span class="mcard-meta">{m.especie} · {m.zona} · hace {rel(m.created_at)}</span>
                      <div class="mcard-badges">
                        {m.tipo === 'perdido' && <span class="badge badge-rojo">perdido</span>}
                        {m.tipo === 'encontrado' && <span class="badge badge-verde">encontrado</span>}
                        {m.tipo === 'adopcion' && <span class="badge badge-azul">adopción</span>}
                      </div>
                    </div>
                    <div class="mcard-actions">
                      <button class="btn btn-azul" data-action="reunir" data-id={m.id} data-row={`row-${m.id}`} data-confirm="¿Marcar como reunida?">🤝 Reunida</button>
                      <button class="btn btn-outline btn-icon btn-edit-mascota"
                        data-id={m.id}
                        data-nombre={m.nombre ?? ''}
                        data-especie={m.especie}
                        data-tipo={m.tipo ?? 'perdido'}
                        data-zona={m.zona}
                        data-color={m.color ?? ''}
                        data-tamanio={m.tamanio ?? ''}
                        data-descripcion={m.descripcion ?? ''}
                        data-whatsapp={m.whatsapp ?? ''}
                        data-fotourl={m.foto_url ?? ''}
                        title="Editar"
                      >✏️</button>
                      <button class="btn btn-rojo btn-icon" data-action="eliminar_mascota" data-id={m.id} data-row={`row-${m.id}`} data-confirm="¿Eliminar esta mascota?">✕</button>
                      {m.whatsapp && <a href={`https://wa.me/58${m.whatsapp.slice(1)}`} class="btn btn-wa" target="_blank" rel="noreferrer">💬</a>}
                      <a href={`/mascota/${m.id}`} target="_blank" class="btn btn-outline btn-sm">Ver →</a>
                    </div>
                  </div>
                ))}
              </div>
            </Fragment>
        }
        {reunidas.length > 0 && (
          <Fragment>
            <h3 class="section-divider">✅ Reunidas ({reunidas.length})</h3>
            <div class="card-list">
              {reunidas.map(m => (
                <div id={`row-${m.id}`} class="mcard mcard-reunida">
                  <div class="mcard-media">
                    {m.foto_url
                      ? <img src={m.foto_url} alt="" class="mcard-img" loading="lazy" />
                      : <div class="mcard-nofoto">✅</div>
                    }
                  </div>
                  <div class="mcard-info">
                    <span class="mcard-name">{m.nombre ?? 'Sin nombre'}</span>
                    <span class="mcard-meta">{m.especie} · {m.zona} · reunida hace {m.moderado_at ? rel(m.moderado_at) : '—'}</span>
                  </div>
                  <div class="mcard-actions">
                    <button class="btn btn-rojo btn-icon" data-action="eliminar_mascota" data-id={m.id} data-row={`row-${m.id}`} data-confirm="¿Eliminar mascota reunida?">✕</button>
                    <a href={`/mascota/${m.id}`} target="_blank" class="btn btn-outline btn-sm">Ver →</a>
                  </div>
                </div>
              ))}
            </div>
          </Fragment>
        )}
      </div>
    </div>

    <!-- ═══ MÓDULO: ADOPCIÓN ═══ -->
    <div id="mod-adopcion" class="module" hidden>
      <div class="mod-hdr">
        <button class="btn-back" onclick="showHome()">← Inicio</button>
        <span class="mod-title">🏠 En adopción ({adopcion.length})</span>
        <span></span>
      </div>
      <div class="mod-body">
        {adopcion.length === 0
          ? <p class="empty-msg">No hay mascotas en adopción publicadas</p>
          : <div class="card-list">
              {adopcion.map(m => (
                <div id={`row-adop-${m.id}`} class="mcard">
                  <div class="mcard-media">
                    {m.foto_url
                      ? <a href={m.foto_url} target="_blank" rel="noreferrer">
                          <img src={m.foto_url} alt="" class="mcard-img" loading="lazy" />
                        </a>
                      : <div class="mcard-nofoto">🏠</div>
                    }
                  </div>
                  <div class="mcard-info">
                    <span class="mcard-name">{m.nombre ?? 'Sin nombre'}</span>
                    <span class="mcard-meta">{m.especie} · {m.zona} · hace {rel(m.created_at)}</span>
                    {m.descripcion && <span class="mcard-desc">{m.descripcion.slice(0,80)}{m.descripcion.length > 80 ? '…' : ''}</span>}
                  </div>
                  <div class="mcard-actions">
                    <button class="btn btn-azul" data-action="reunir" data-id={m.id} data-row={`row-${m.id}`} data-confirm="¿Marcar como reunida (adoptada)?">🤝 Adoptada</button>
                    <button class="btn btn-outline btn-icon btn-edit-mascota"
                      data-id={m.id}
                      data-nombre={m.nombre ?? ''}
                      data-especie={m.especie}
                      data-tipo={m.tipo ?? 'adopcion'}
                      data-zona={m.zona}
                      data-color={m.color ?? ''}
                      data-tamanio={m.tamanio ?? ''}
                      data-descripcion={m.descripcion ?? ''}
                      data-whatsapp={m.whatsapp ?? ''}
                      data-fotourl={m.foto_url ?? ''}
                      title="Editar"
                    >✏️</button>
                    {m.whatsapp && <a href={`https://wa.me/58${m.whatsapp.slice(1)}`} class="btn btn-wa" target="_blank" rel="noreferrer">💬</a>}
                    <a href={`/mascota/${m.id}`} target="_blank" class="btn btn-outline btn-sm">Ver →</a>
                  </div>
                </div>
              ))}
            </div>
        }
      </div>
    </div>

    <!-- ═══ MÓDULO: AGREGAR MASCOTA ═══ -->
    <div id="mod-agregar" class="module" hidden>
      <div class="mod-hdr">
        <button class="btn-back" onclick="showHome()">← Inicio</button>
        <span class="mod-title">➕ Agregar mascota</span>
        <span></span>
      </div>
      <div class="mod-body">
        <div class="form-wrap">
          <form id="form-nueva-mascota" class="nuevo-form" enctype="multipart/form-data">
            <div class="nuevo-form-grid">
              <label class="form-field">
                <span class="form-lbl">Especie *</span>
                <select name="especie" required class="feed-select">
                  <option value="Perro">🐕 Perro</option>
                  <option value="Gato">🐈 Gato</option>
                  <option value="Ave">🐦 Ave</option>
                  <option value="Otro">🐾 Otro</option>
                </select>
              </label>
              <label class="form-field">
                <span class="form-lbl">Tipo *</span>
                <select name="tipo" required class="feed-select">
                  <option value="perdido">🔴 Perdido</option>
                  <option value="encontrado">🔵 Encontrado</option>
                  <option value="adopcion">🏠 En adopción</option>
                </select>
              </label>
              <label class="form-field">
                <span class="form-lbl">Estado</span>
                <select name="status" class="feed-select">
                  <option value="publicado">✓ Publicado</option>
                  <option value="pendiente">⏳ Pendiente</option>
                </select>
              </label>
            </div>
            <div class="nuevo-form-grid">
              <label class="form-field">
                <span class="form-lbl">Nombre</span>
                <input type="text" name="nombre" maxlength="100" placeholder="Toby, Luna…" class="feed-input" />
              </label>
              <label class="form-field">
                <span class="form-lbl">Color</span>
                <input type="text" name="color" maxlength="80" placeholder="Marrón, blanco y negro…" class="feed-input" />
              </label>
              <label class="form-field">
                <span class="form-lbl">Tamaño</span>
                <select name="tamanio" class="feed-select">
                  <option value="">— sin especificar —</option>
                  <option value="Pequeño">Pequeño</option>
                  <option value="Mediano">Mediano</option>
                  <option value="Grande">Grande</option>
                </select>
              </label>
            </div>
            <label class="form-field" style="width:100%">
              <span class="form-lbl">Zona * (mín. 5 caracteres)</span>
              <input type="text" name="zona" required minlength="5" maxlength="120" placeholder="Porlamar, Nueva Esparta" class="feed-input" />
            </label>
            <div class="nuevo-form-grid">
              <label class="form-field">
                <span class="form-lbl">WhatsApp * (04XX-XXXXXXX)</span>
                <input type="tel" name="whatsapp" required pattern="04[0-9]{2}[0-9]{7}" maxlength="11" placeholder="04140000000" class="feed-input" id="nm-wa" />
              </label>
              <label class="form-field">
                <span class="form-lbl">Nombre del contacto</span>
                <input type="text" name="contacto_nombre" maxlength="100" placeholder="María, Cruz Roja…" class="feed-input" />
              </label>
            </div>
            <p id="nm-wa-hint" class="nm-hint" aria-live="polite"></p>
            <label class="form-field" style="width:100%">
              <span class="form-lbl">Descripción</span>
              <textarea name="descripcion" rows="3" maxlength="600" placeholder="Características físicas, comportamiento…" class="feed-textarea"></textarea>
            </label>
            <label class="form-field" style="width:100%">
              <span class="form-lbl">Señas particulares</span>
              <textarea name="senias" rows="2" maxlength="300" placeholder="Cicatriz en la pata, collar rojo…" class="feed-textarea"></textarea>
            </label>
            <label class="form-field" style="width:100%">
              <span class="form-lbl">Foto principal (opcional · máx 5MB)</span>
              <input type="file" name="foto" accept="image/*" class="upload-input" id="nm-foto" />
            </label>
            <div id="nm-preview-wrap" style="display:none">
              <img id="nm-preview" alt="Vista previa" class="nm-preview-img" />
            </div>
            <div style="display:flex;align-items:center;gap:1rem;margin-top:.25rem">
              <button type="submit" class="btn-submit" id="nm-submit">Crear mascota</button>
              <span id="nm-msg" class="nm-success" aria-live="polite"></span>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- ═══ MÓDULO: GEMINI ═══ -->
    <div id="mod-gemini" class="module" hidden>
      <div class="mod-hdr">
        <button class="btn-back" onclick="showHome()">← Inicio</button>
        <span class="mod-title">📸 Gemini Vision</span>
        <span></span>
      </div>
      <div class="mod-body">
        <div class="form-wrap">
          <p class="form-hint">Sube una foto y Gemini extrae los datos automáticamente.</p>
          <div class="gemini-actions" role="group" aria-label="Tipo de registro">
            <button class="gem-action active" data-action="mascota" type="button">🐾 Mascota</button>
            <button class="gem-action" data-action="feed" type="button">📰 Noticia</button>
            <button class="gem-action" data-action="insumo" type="button">📦 Insumo</button>
          </div>
          <input type="file" id="geminiImg" accept="image/*" style="display:none" />
          <div id="geminiPreview" class="gemini-preview" tabindex="0" role="button" aria-label="Seleccionar imagen">
            <span id="geminiPlaceholder" class="gemini-placeholder">📷 Toca para seleccionar imagen</span>
            <img id="geminiPreviewImg" src="" alt="Vista previa" style="display:none;width:100%;height:100%;object-fit:contain;border-radius:6px" />
          </div>
          <div style="display:flex;gap:.75rem;margin-top:.75rem">
            <button type="button" id="btnSeleccionar" class="btn btn-outline" style="flex:1">📷 Seleccionar foto</button>
            <button type="button" id="btnExtraer" class="btn-submit" style="flex:1" disabled>🔍 Extraer datos</button>
          </div>
          <div id="geminiMsg" style="display:none;padding:.625rem .875rem;border-radius:8px;margin:.875rem 0 0;font-size:.8rem;background:#1a2a1a;color:#e5e7eb;border:1px solid #374151"></div>

          <form id="geminiFormMascota" method="POST" action="/admin" style="display:none;margin-top:1.5rem">
            <input type="hidden" name="action" value="publicar_gemini" />
            <input type="hidden" id="g-status-field" name="status" value="pendiente" />
            <div class="nuevo-form-grid">
              <label class="form-field"><span class="form-lbl">Nombre</span><input type="text" name="nombre" id="g-nombre" class="feed-input" /></label>
              <label class="form-field"><span class="form-lbl">Especie *</span><select name="especie" id="g-especie" class="feed-input" required><option value="Perro">Perro</option><option value="Gato">Gato</option><option value="Ave">Ave</option><option value="Otro">Otro</option></select></label>
              <label class="form-field"><span class="form-lbl">Color</span><input type="text" name="color" id="g-color" class="feed-input" /></label>
              <label class="form-field"><span class="form-lbl">Zona *</span><input type="text" name="zona" id="g-zona" class="feed-input" required minlength="5" /></label>
              <label class="form-field"><span class="form-lbl">Tipo</span><select name="tipo" id="g-tipo" class="feed-input"><option value="perdido">Perdido</option><option value="encontrado">Encontrado</option><option value="adopcion">En adopción</option></select></label>
              <label class="form-field"><span class="form-lbl">WhatsApp</span><input type="tel" name="whatsapp" id="g-whatsapp" class="feed-input" pattern="04[0-9]{9}" /></label>
              <label class="form-field"><span class="form-lbl">Contacto</span><input type="text" name="contacto_nombre" id="g-contacto-nombre" class="feed-input" /></label>
              <label class="form-field"><span class="form-lbl">Señas</span><input type="text" name="senias" id="g-senias" class="feed-input" /></label>
