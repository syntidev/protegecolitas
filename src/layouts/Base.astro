---
import '../styles/global.css'
export interface Props { title?: string }
const { title = 'Protege Colitas' } = Astro.props
const path = Astro.url?.pathname ?? '/'
const active = (href: string) => href === '/' ? path === '/' : path.startsWith(href)
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
  <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@700&family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
</head>
<body>

  <a href="#main-content" class="skip-link">Saltar al contenido principal</a>

  <!-- ── Top nav ──────────────────────────────────────────────────── -->
  <header class="top-nav" role="banner">
    <div class="top-nav__inner">
      <a href="/" class="top-nav__brand" aria-label="Protege Colitas — Ir al inicio">
        <span aria-hidden="true">🐾</span>
        <span>Protege Colitas</span>
      </a>
      <nav class="top-nav__links" aria-label="Navegación principal">
        <a
          href="/mascotas"
          class={`top-link${active('/mascotas') ? ' top-link--active' : ''}`}
          aria-current={active('/mascotas') ? 'page' : undefined}
          aria-label="Ver mascotas reportadas"
        >Mascotas</a>
        <a
          href="/veterinarios"
          class={`top-link${active('/veterinarios') ? ' top-link--active' : ''}`}
          aria-current={active('/veterinarios') ? 'page' : undefined}
          aria-label="Directorio de veterinarios voluntarios"
        >Vets</a>
        <a
          href="/insumos"
          class={`top-link${active('/insumos') ? ' top-link--active' : ''}`}
          aria-current={active('/insumos') ? 'page' : undefined}
          aria-label="Ver insumos necesarios"
        >Insumos</a>
        <a
          href="/reportar"
          class="top-cta"
          aria-label="Reportar una mascota perdida o encontrada"
        >Reportar</a>
      </nav>
    </div>
  </header>

  <!-- ── Contenido principal ──────────────────────────────────────── -->
  <div id="main-content" tabindex="-1">
    <slot />
  </div>

  <!-- ── Bottom nav (solo mobile) ────────────────────────────────── -->
  <nav class="bottom-nav" aria-label="Navegación por secciones">

    <a
      href="/"
      class={`nav-item${active('/') ? ' nav-active' : ''}`}
      aria-label="Inicio"
      aria-current={active('/') ? 'page' : undefined}
    >
      <svg class="nav-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M3 10.5L12 3l9 7.5V20a1 1 0 01-1 1H5a1 1 0 01-1-1v-9.5z" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M9 21v-8h6v8" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="nav-label">Inicio</span>
    </a>

    <a
      href="/mascotas"
      class={`nav-item${active('/mascotas') ? ' nav-active' : ''}`}
      aria-label="Ver mascotas reportadas"
      aria-current={active('/mascotas') ? 'page' : undefined}
    >
      <svg class="nav-icon" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <circle cx="8.5"  cy="7"   r="1.8"/>
        <circle cx="13"   cy="5.2" r="1.8"/>
        <circle cx="17.5" cy="7"   r="1.8"/>
        <circle cx="6"    cy="12"  r="1.4"/>
        <path d="M12 10c-3.5 0-6.5 2.2-6.5 5.5 0 2.3 2.2 4 6.5 4s6.5-1.7 6.5-4c0-3.3-3-5.5-6.5-5.5z"/>
      </svg>
      <span class="nav-label">Mascotas</span>
    </a>

    <a
      href="/reportar"
      class={`nav-item nav-item-cta${active('/reportar') ? ' nav-active' : ''}`}
      aria-label="Reportar mascota perdida o encontrada"
      aria-current={active('/reportar') ? 'page' : undefined}
    >
      <span class="nav-cta-circle" aria-hidden="true">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
          <line x1="5"  y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
        </svg>
      </span>
      <span class="nav-label">Reportar</span>
    </a>

    <a
      href="/veterinarios"
      class={`nav-item${active('/veterinarios') ? ' nav-active' : ''}`}
      aria-label="Veterinarios voluntarios"
      aria-current={active('/veterinarios') ? 'page' : undefined}
    >
      <svg class="nav-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M7 3v5a5 5 0 0010 0V3" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
        <line x1="12" y1="13" x2="12" y2="15.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
        <circle cx="12" cy="18.5" r="2.5" stroke="currentColor" stroke-width="1.75"/>
      </svg>
      <span class="nav-label">Vets</span>
    </a>

    <a
      href="/insumos"
      class={`nav-item${active('/insumos') ? ' nav-active' : ''}`}
      aria-label="Insumos necesarios"
      aria-current={active('/insumos') ? 'page' : undefined}
    >
      <svg class="nav-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M20 8L12 3 4 8v8l8 5 8-5V8z" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M4 8l8 5 8-5M12 13v8" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
      </svg>
      <span class="nav-label">Insumos</span>
    </a>

  </nav>

</body>
</html>

<style>
  /* ── CSS Custom Properties ─────────────────────────────────────── */
  :root {
    --amarillo: #F5A623;
    --marron:   #3D1C02;
    --rojo:     #CC1F1F;
    --verde:    #16A34A;
    --crema:    #FDF8F0;
    --blanco:   #FFFFFF;
    --border:   #E5DDD0;
    --gris-txt: #6B7280;
    --gris-bg:  #F9F6F0;
  }

  /* ── Body offsets para navs fijas ──────────────────────────────── */
  body {
    padding-top: 56px;
    padding-bottom: 64px;
  }
  @media (min-width: 640px) {
    body { padding-bottom: 0; }
  }

  /* ── Scroll offset para la sticky nav ─────────────────────────── */
  html { scroll-padding-top: 64px; }

  /* ── Focus visible global ──────────────────────────────────────── */
  :focus            { outline: none; }
  :focus-visible    {
    outline: 2px solid var(--amarillo);
    outline-offset: 3px;
    border-radius: 3px;
  }

  /* ── Skip link ─────────────────────────────────────────────────── */
  .skip-link {
    position: fixed;
    top: -120%;
    left: 1rem;
    z-index: 9999;
    background: var(--marron);
    color: var(--crema);
    padding: 0.5rem 1.25rem;
    border-radius: 0 0 8px 8px;
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: top 0.15s ease-out;
    white-space: nowrap;
  }
  .skip-link:focus-visible {
    top: 0;
    outline: 2px solid var(--amarillo);
    outline-offset: 2px;
  }

  /* Evitar outline en el contenedor skip-target */
  #main-content { outline: none; }

  /* ── Top nav ───────────────────────────────────────────────────── */
  .top-nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: 56px;
    background: var(--crema);
    border-bottom: 1px solid rgba(61, 28, 2, 0.12);
    z-index: 200;
  }
  .top-nav__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
    height: 100%;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  /* Brand / logo */
  .top-nav__brand {
    font-family: 'Fredoka', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--marron);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    min-height: 44px;
    min-width: 44px;
    transition: opacity 0.15s;
  }
  .top-nav__brand:hover { opacity: 0.75; }

  /* Desktop links (ocultos en mobile) */
  .top-nav__links {
    display: none;
    align-items: center;
    gap: 0.25rem;
    flex: 1;
  }
  @media (min-width: 640px) {
    .top-nav__links { display: flex; }
  }

  .top-link {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--marron);
    text-decoration: none;
    padding: 0.375rem 0.75rem;
    border-radius: 6px;
    display: flex;
    align-items: center;
    min-height: 36px;
    transition: background-color 0.15s;
  }
  .top-link:hover        { background: rgba(61, 28, 2, 0.07); }
  .top-link--active      { color: var(--amarillo); font-weight: 700; }

  /* CTA desktop */
  .top-cta {
    margin-left: auto;
    flex-shrink: 0;
    background: var(--amarillo);
    color: var(--marron);
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    text-decoration: none;
    padding: 0 1rem;
    height: 36px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    white-space: nowrap;
    transition: opacity 0.15s;
  }
  .top-cta:hover { opacity: 0.85; }

  /* ── Bottom nav ────────────────────────────────────────────────── */
  .bottom-nav {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    height: 64px;
    display: flex;
    align-items: stretch;
    background: var(--blanco);
    border-top: 1px solid var(--border);
    z-index: 100;
    padding-bottom: env(safe-area-inset-bottom, 0);
    overflow: visible; /* permite que el CTA se eleve */
  }
  @media (min-width: 640px) {
    .bottom-nav { display: none; }
  }

  /* Items base */
  .nav-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3px;
    padding: 8px 4px 10px;
    text-decoration: none;
    color: var(--gris-txt);
    min-height: 44px;
    -webkit-tap-highlight-color: transparent;
    transition: color 0.15s;
  }
  .nav-item:hover,
  .nav-active { color: var(--amarillo); }

  .nav-icon  { display: block; flex-shrink: 0; }
  .nav-label {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    font-weight: 600;
    line-height: 1;
    text-align: center;
  }
  .nav-active .nav-label { font-weight: 700; }

  /* ── CTA central elevado ───────────────────────────────────────── */
  .nav-item-cta {
    flex: 1;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding-bottom: 8px;
    gap: 0;
    text-decoration: none;
    color: var(--marron);
    -webkit-tap-highlight-color: transparent;
    overflow: visible;
  }
  .nav-item-cta:hover { color: var(--marron); }

  .nav-cta-circle {
    position: absolute;
    top: -14px; /* eleva el círculo sobre la línea del nav */
    left: 50%;
    transform: translateX(-50%);
    width: 52px;
    height: 52px;
    background: var(--amarillo);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--marron);
    box-shadow:
      0 -2px 8px rgba(0, 0, 0, 0.06),
      0 4px 16px rgba(245, 166, 35, 0.45);
    transition: transform 0.15s ease-out, box-shadow 0.15s ease-out;
    pointer-events: none; /* el <a> padre maneja el click */
  }
  .nav-item-cta:hover .nav-cta-circle,
  .nav-item-cta:focus-visible .nav-cta-circle {
    transform: translateX(-50%) scale(1.08);
    box-shadow:
      0 -2px 8px rgba(0, 0, 0, 0.08),
      0 6px 20px rgba(245, 166, 35, 0.55);
  }

  /* La label queda justo bajo el círculo */
  .nav-item-cta .nav-label {
    margin-top: 44px; /* empuja la label por debajo del círculo (52px - ~8px padding) */
  }

  /* ── Reduced motion ────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .skip-link,
    .top-nav__brand,
    .top-link,
    .top-cta,
    .nav-item,
    .nav-cta-circle { transition: none; }
  }
</style>
