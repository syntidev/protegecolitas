                const pct = visitasTotal > 0 ? Math.round((item.count / visitasTotal) * 100) : 0
                const color = item.key === 'mobile' ? '#3B82F6' : item.key === 'desktop' ? '#F59E0B' : '#22C55E'
                return (
                  <div class="an-bar-row">
                    <span class="an-bar-label">{item.key}</span>
                    <div class="an-bar-track"><div class="an-bar-fill" style={`width:${pct}%;background:${color}`}></div></div>
                    <span class="an-bar-pct">{pct}%</span>
                    <span class="an-bar-count">{item.count}</span>
                  </div>
                )
              })}
            </div>
          ) : <p class="an-empty">Sin datos aún</p>}
        </div>
