<body>

  <!-- BANNER -->
  {banner && (
    <div class="site-banner">
      <picture>
        <source media="(min-width: 768px)" srcset={banner.imagen_desktop_url ?? banner.imagen_url} />
        <img src={banner.imagen_url} alt={banner.texto ?? 'Aviso de emergencia'} />
      </picture>
    </div>
  )}

  <!-- HEADER -->
  <header class="site-header">
    <a href="/" class="header-logo">
      <img src="/logo.png" alt="Protege Colitas" width="32" height="32" />
      <span class="header-brand">Protege Colitas</span>
    </a>
    <form class="header-search" action="/mascotas" method="get" role="search">
      <input type="search" name="q" placeholder="Buscar mascota por nombre o zona…" aria-label="Buscar mascota" />
    </form>
    <nav class="header-nav-links">
      <a href="/mascotas">Mascotas</a>
      <a href="/veterinarios">Vets</a>
