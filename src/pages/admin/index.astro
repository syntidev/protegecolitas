                    <div class="an-bar-track an-bar-track--sm"><div class="an-bar-fill" style={`width:${Math.round((item.count/max)*100)}%;background:#22C55E`}></div></div>
                    <span class="an-list-count">{item.count}</span>
                  </div>
                ))})()}
              </div>
            ) : <p class="an-empty">Sin datos</p>}
