        <div class="modal-actions">
          <button type="submit" class="btn-submit">Guardar cambios</button>
          <button type="button" class="modal-cancel btn btn-outline">Cancelar</button>
        </div>
      </form>

      <!-- Veterinario -->
      <form id="modal-vet" class="modal-form" style="display:none">
        <input type="hidden" name="action" value="editar_vet" />
        <input type="hidden" name="id" id="ev-id" />
        <div class="modal-grid">
          <label class="modal-field">
            <span class="modal-lbl">Nombre *</span>
            <input type="text" name="nombre" id="ev-nombre" class="modal-input" required />
          </label>
          <label class="modal-field">
            <span class="modal-lbl">Zona *</span>
            <input type="text" name="zona" id="ev-zona" class="modal-input" required />
          </label>
          <label class="modal-field">
            <span class="modal-lbl">WhatsApp *</span>
            <input type="text" name="whatsapp" id="ev-whatsapp" class="modal-input" required />
          </label>
          <label class="modal-field">
            <span class="modal-lbl">Servicios</span>
            <input type="text" name="servicios" id="ev-servicios" class="modal-input" />
          </label>
          <label class="modal-field modal-field--full">
            <span class="modal-lbl">Horario</span>
            <input type="text" name="horario" id="ev-horario" class="modal-input" />
          </label>
        </div>
        <div class="modal-actions">
          <button type="submit" class="btn-submit">Guardar cambios</button>
          <button type="button" class="modal-cancel btn btn-outline">Cancelar</button>
        </div>
      </form>

      <!-- Insumo -->
      <form id="modal-insumo" class="modal-form" style="display:none">
        <input type="hidden" name="action" value="editar_insumo" />
        <input type="hidden" name="id" id="ei-id" />
        <div class="modal-grid">
          <label class="modal-field modal-field--full">
            <span class="modal-lbl">Nombre del insumo *</span>
            <input type="text" name="item" id="ei-item" class="modal-input" required />
          </label>
          <label class="modal-field">
            <span class="modal-lbl">Cant. recibida</span>
            <input type="number" name="cantidad_recibida" id="ei-recibida" class="modal-input" min="0" />
          </label>
          <label class="modal-field">
            <span class="modal-lbl">Cant. requerida *</span>
            <input type="number" name="cantidad_requerida" id="ei-requerida" class="modal-input" min="1" required />
          </label>
          <label class="modal-field modal-field--full">
            <span class="modal-lbl">Prioridad</span>
            <select name="prioridad" id="ei-prioridad" class="modal-input">
              <option value="critico">🔴 Crítico</option>
              <option value="urgente">🟡 Urgente</option>
              <option value="cubierto">🟢 Cubierto</option>
            </select>
          </label>
        </div>
        <div class="modal-actions">
          <button type="submit" class="btn-submit">Guardar cambios</button>
          <button type="button" class="modal-cancel btn btn-outline">Cancelar</button>
        </div>
      </form>

      <!-- Feed edit -->
      <form id="modal-feed" class="modal-form" enctype="multipart/form-data" style="display:none">
        <input type="hidden" name="action" value="editar_feed" />
        <input type="hidden" name="id" id="ef-id" />
        <div class="modal-grid">
          <label class="modal-field">
            <span class="modal-lbl">Tipo</span>
            <select name="tipo" id="ef-tipo" class="modal-input">
              <option value="info">Info</option>
              <option value="alerta">Alerta</option>
              <option value="rescate">Rescate</option>
              <option value="buenas">Buenas</option>
              <option value="voluntario">Voluntarios</option>
            </select>
          </label>
          <label class="modal-field">
            <span class="modal-lbl">Título *</span>
            <input type="text" name="titulo" id="ef-titulo" class="modal-input" required maxlength="150" />
          </label>
          <label class="modal-field modal-field--full">
            <span class="modal-lbl">Texto *</span>
            <textarea name="cuerpo" id="ef-cuerpo" class="modal-input modal-textarea" rows="4" required></textarea>
          </label>
          <label class="modal-field modal-field--full">
            <span class="modal-lbl">Imagen nueva (opcional)</span>
            <input type="file" name="feed_img_edit" accept="image/*" class="upload-input" />
          </label>
        </div>
        <div class="modal-actions">
          <button type="submit" class="btn-submit">Guardar cambios</button>
          <button type="button" class="modal-cancel btn btn-outline">Cancelar</button>
        </div>
      </form>

    </div>

  </div>

  </div>

)}

</body>
</html>

<style>
  :root {
    --bg:       #0F1117;
    --surface:  #1A1D27;
    --border:   #2D3148;
    --texto:    #F1F5F9;
    --gris:     #94A3B8;
    --verde:    #22C55E;
    --rojo:     #EF4444;
    --amarillo: #F59E0B;
    --azul:     #3B82F6;
    --naranja:  #F97316;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--texto);
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 13px;
    line-height: 1.5;
    min-height: 100vh;
  }

  /* ── Login ────────────────────────────────────────────────────────── */
  .login-wrap {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 1rem;
  }
  .login-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem;
    width: min(100%, 320px);
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }
  .login-logo  { font-size: 2rem; text-align: center; }  /* fallback, replaced by img */
  .login-title { font-size: 1.25rem; font-weight: 700; text-align: center; }
  .login-sub   { font-size: .8rem; color: var(--gris); text-align: center; }
  .login-err   { background: rgba(239,68,68,.12); color: var(--rojo); border: 1px solid rgba(239,68,68,.35); border-radius: 6px; padding: .625rem .875rem; font-size: .8rem; }
  .login-box form { display: flex; flex-direction: column; gap: .625rem; }
  .login-box input {
    background: var(--bg); border: 1px solid var(--border); border-radius: 6px;
    color: var(--texto); padding: .625rem .875rem; font-size: .875rem;
    width: 100%; font-family: inherit;
  }
  .login-box input:focus { outline: none; border-color: var(--azul); }
  .btn-login {
    background: var(--azul); color: #fff; border: none; border-radius: 6px;
    padding: .625rem; font-size: .875rem; font-weight: 600; cursor: pointer;
    font-family: inherit; transition: opacity .15s;
  }
  .btn-login:hover { opacity: .85; }

  /* ── Header ───────────────────────────────────────────────────────── */
  .hdr {
    display: flex; align-items: center; gap: .625rem;
    padding: .875rem 1.5rem;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
    position: sticky; top: 0; z-index: 100;
  }
  .hdr-title  { font-weight: 700; font-size: 1rem; flex-shrink: 0; }
  .hdr-stats  { display: flex; gap: .375rem; flex-wrap: wrap; flex: 1; min-width: 0; }
  .stat-pill  { font-size: .7rem; font-weight: 600; padding: .2rem .625rem; border-radius: 999px; }
  .stat-naranja { background: rgba(249,115,22,.2);  color: #FB923C; }
  .stat-verde   { background: rgba(34,197,94,.2);   color: #4ADE80; }
  .stat-azul    { background: rgba(59,130,246,.2);  color: #60A5FA; }
  .stat-gris    { background: rgba(148,163,184,.15); color: var(--gris); }
  .logout-form  { flex-shrink: 0; }
  .btn-logout {
    background: transparent; border: 1px solid var(--border); color: var(--gris);
    border-radius: 6px; padding: .3rem .75rem; cursor: pointer;
    font-size: .75rem; font-family: inherit; transition: border-color .15s, color .15s;
  }
  .btn-logout:hover { border-color: var(--rojo); color: var(--rojo); }
  .hdr-ver-sitio {
    flex-shrink: 0;
    font-size: .72rem; font-weight: 600;
    color: #F5A623; text-decoration: none;
    border: 1px solid #F5A623;
    padding: .3rem .75rem; border-radius: 6px;
    white-space: nowrap;
    transition: background .15s, color .15s;
  }
  .hdr-ver-sitio:hover { background: #F5A623; color: #3D1C02; }

  /* ── Tabs nav ─────────────────────────────────────────────────────── */
  .tabs-nav {
    display: flex; background: var(--surface);
    border-bottom: 1px solid var(--border);
    overflow-x: auto; scrollbar-width: none;
    padding: .5rem .75rem;
    gap: .375rem;
  }
  .tabs-nav::-webkit-scrollbar { display: none; }
  .tab {
    background: #1f2937; border: none;
    border-radius: 100px;
    color: #94a3b8; padding: .5rem 1rem;
    font-size: .8rem; font-weight: 600; cursor: pointer;
    font-family: inherit; white-space: nowrap;
    transition: background .15s, color .15s;
    display: flex; align-items: center; gap: .35rem;
    min-height: 38px; flex-shrink: 0;
  }
  .tab:hover { background: #374151; color: #e5e7eb; }
  .tab.active { background: #F5A623; color: #3D1C02; }
  .tab-badge {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 22px; height: 22px; border-radius: 11px;
    font-size: 11px; font-weight: 700;
    background: #EF4444; color: white;
    animation: pulse-badge 2s infinite;
  }
  @keyframes pulse-badge {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: .8; transform: scale(1.1); }
  }
  .tab-badge.zero { background: #22C55E; animation: none; }
  @media (prefers-reduced-motion: reduce) {
    .tab-badge { animation: none; }
  }

  /* ── Tab panes ────────────────────────────────────────────────────── */
  .tab-pane { display: none; padding: 1.5rem; }
  .tab-pane.active { display: block; }

  /* ── Tables ───────────────────────────────────────────────────────── */
  .table-wrap { overflow-x: auto; border-radius: 10px; border: 1px solid var(--border); }
  table { width: 100%; border-collapse: collapse; font-size: .85rem; }
  th {
    text-align: left; padding: .75rem 1rem;
    font-size: .7rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: .05em; color: var(--gris);
    border-bottom: 1px solid var(--border);
    background: #0d1117; white-space: nowrap;
  }
  tr:last-child td { border-bottom: none; }
  tr:nth-child(even) td { background: rgba(255,255,255,.02); }
  tr:hover td { background: rgba(59,130,246,.05); }

  .td-photo { width: 88px; padding: .875rem 1rem; }
  .thumb {
    width: 72px; height: 72px; object-fit: cover; border-radius: 8px;
    display: block; cursor: zoom-in; transition: opacity .15s;
  }
  .thumb:hover { opacity: .85; }
  .thumb-empty {
    display: flex; align-items: center; justify-content: center;
    width: 72px; height: 72px; border-radius: 8px;
    background: #1f2937; font-size: 1.75rem; flex-shrink: 0;
  }
  td { padding: 1rem; border-bottom: 1px solid var(--border); vertical-align: middle; height: 88px; }
  .td-name     { font-weight: 700; font-size: 15px; max-width: 200px; }
  .td-zona     { max-width: 140px; color: var(--gris); font-size: .8rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .td-time     { color: var(--gris); font-size: .75rem; white-space: nowrap; }
  .td-gris     { color: var(--gris); }
  .td-truncate { max-width: 160px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: var(--gris); }
  .td-actions  { white-space: nowrap; }
  .link-wa     { font-size: 1.1rem; text-decoration: none; }
  .link-wa-txt { font-size: .8rem; color: #4ADE80; text-decoration: none; white-space: nowrap; }
  .link-wa-txt:hover { text-decoration: underline; }

  /* ── Buttons ──────────────────────────────────────────────────────── */
  .btn {
    border: none; border-radius: 6px;
    padding: .5rem .875rem; font-size: .8rem; font-weight: 600;
    cursor: pointer; font-family: inherit; transition: opacity .15s;
    min-height: 36px; min-width: 80px;
    display: inline-flex; align-items: center; justify-content: center;
    text-decoration: none; white-space: nowrap;
  }
  .btn + .btn { margin-left: .375rem; }
  .btn:hover    { opacity: .8; }
  .btn:disabled { opacity: .35; cursor: not-allowed; }
  .btn-verde    { background: var(--verde);   color: #fff; }
  .btn-rojo     { background: var(--rojo);    color: #fff; }
  .btn-azul     { background: var(--azul);    color: #fff; }
  .btn-amarillo { background: var(--amarillo); color: #000; }
  .btn-gris     { background: rgba(148,163,184,.2); color: var(--gris); }
  .btn-outline  { background: transparent; border: 1px solid var(--border); color: var(--gris); }
  .btn-outline:hover { border-color: var(--gris); color: var(--texto); opacity: 1; }
  .btn-icon     { min-width: auto; padding: .5rem .625rem; }
  .btn-sm       { padding: .3rem .625rem; min-height: 30px; min-width: 60px; font-size: .75rem; }

  /* ── Badges ───────────────────────────────────────────────────────── */
  .badge {
    display: inline-block; font-size: .65rem; font-weight: 700;
    padding: .15rem .45rem; border-radius: 4px; text-transform: capitalize;
  }
  .badge-rojo  { background: rgba(239,68,68,.2);  color: #FCA5A5; }
  .badge-verde { background: rgba(34,197,94,.2);  color: #86EFAC; }
  .badge-azul  { background: rgba(59,130,246,.2); color: #93C5FD; }
  .badge-gris  { background: rgba(148,163,184,.1); color: var(--gris); }
  .badge-tipo-info       { background: rgba(59,130,246,.2);  color: #93C5FD; }
  .badge-tipo-alerta     { background: rgba(239,68,68,.2);   color: #FCA5A5; }
  .badge-tipo-rescate    { background: rgba(245,158,11,.2);  color: #FCD34D; }
  .badge-tipo-buenas     { background: rgba(34,197,94,.2);   color: #86EFAC; }
  .badge-tipo-voluntario { background: rgba(139,92,246,.2);  color: #C4B5FD; }

  /* ── Sub-titles ───────────────────────────────────────────────────── */
  .sub-title {
    font-size: .72rem; font-weight: 700; color: var(--gris);
    text-transform: uppercase; letter-spacing: .05em; margin-bottom: .75rem;
  }
  .mt    { margin-top: 1.5rem; }
  .mt-sm { margin-top: .75rem; }
  .empty-msg { color: var(--gris); padding: 2rem; text-align: center; font-size: .875rem; }

  /* ── Tab badge con fondo activo ────────────────────────────────────── */
  .tab.active .tab-badge { background: rgba(61,28,2,.3); color: #3D1C02; }

  /* ── Tab agregar highlight ─────────────────────────────────────────── */
  .tab-agregar { color: #4ADE80; }
  .tab-agregar.active { background: #4ADE80; color: #052e16; }

  /* ── Nueva mascota form extras ────────────────────────────────────── */
  .nm-hint {
    font-size: .72rem; color: var(--gris); margin-top: -.375rem;
    min-height: 1rem;
  }
  .nm-hint.valid { color: #4ADE80; }
  .nm-hint.invalid { color: #FCA5A5; }
  .nm-success { font-size: .8rem; font-weight: 700; color: #4ADE80; }
  .nm-preview-img {
    width: 140px; height: 140px; object-fit: cover;
    border-radius: 10px; border: 2px solid #374151;
  }

  /* ── Feed form ────────────────────────────────────────────────────── */
  .feed-form {
    display: flex; flex-direction: column; gap: .75rem; max-width: 680px;
    background: #111827; border: 1px solid var(--border);
    border-radius: 12px; padding: 20px;
  }
  .feed-row  { display: flex; gap: .625rem; }
  .feed-select, .feed-input, .feed-textarea {
    background: #1f2937; border: 1px solid #374151;
    border-radius: 8px; color: #fff;
    padding: 12px 14px; font-size: 1rem; font-family: inherit;
    min-height: 48px;
  }
  .feed-select { flex-shrink: 0; }
  .feed-input  { flex: 1; }
  .feed-textarea { resize: vertical; width: 100%; }
  .feed-select:focus, .feed-input:focus, .feed-textarea:focus { outline: none; border-color: #F5A623; }
  .feed-select option { background: #1f2937; }

  /* Label encima de cada campo */
  .form-field { display: flex; flex-direction: column; gap: .3rem; flex: 1; min-width: 160px; }
  .form-field .form-lbl {
    font-size: .7rem; font-weight: 700; color: #94A3B8;
    text-transform: uppercase; letter-spacing: .05em;
  }
  .form-field .feed-input,
  .form-field .feed-select { width: 100%; }

  /* "Ver ficha" link en celdas */
  .ficha-link {
    display: block; margin-top: 3px;
    color: #F5A623; font-size: .72rem; font-weight: 600; text-decoration: none;
  }
  .ficha-link:hover { text-decoration: underline; }

  /* Botón submit amarillo */
  .btn-submit {
    background: #F5A623; color: #3D1C02; font-weight: 700;
    border: none; border-radius: 10px;
    padding: .625rem 1rem; font-size: .9375rem; font-family: inherit;
    cursor: pointer; min-height: 44px; transition: opacity .15s;
  }
  .btn-submit:hover { opacity: .85; }

  /* ── Insumos ──────────────────────────────────────────────────────── */
  .insumos-list { display: flex; flex-direction: column; gap: .25rem; max-width: 520px; }
  .insumo-row {
    display: flex; align-items: center; gap: .75rem;
    padding: .5rem .25rem; border-bottom: 1px solid var(--border);
  }
  .prio-dot    { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .prio-critico  { background: var(--rojo); }
  .prio-urgente  { background: var(--amarillo); }
  .prio-cubierto { background: var(--verde); }
  .insumo-name     { flex: 1; font-weight: 500; font-size: .85rem; }
  .insumo-progress { font-size: .75rem; color: var(--gris); white-space: nowrap; }
  .insumo-form     { display: flex; align-items: center; gap: .375rem; }
  .insumo-input {
    width: 64px; background: var(--surface); border: 1px solid var(--border);
    border-radius: 4px; color: var(--texto); padding: .3rem .5rem;
    font-family: inherit; font-size: .8rem; text-align: center;
  }
  .insumo-input:focus { outline: none; border-color: var(--azul); }

  /* ── Banners ─────────────────────────────────────────────────────── */
  .btn-gris { background: rgba(148,163,184,.2); color: var(--gris); }
  .banner-uploads { display: flex; flex-wrap: wrap; gap: .75rem; margin-top: .5rem; }
  .upload-label { display: flex; flex-direction: column; gap: .25rem; flex: 1; min-width: 200px; }
  .upload-lbl-txt { font-size: .72rem; font-weight: 600; color: var(--gris); }
  .upload-input {
    background: var(--surface); border: 1px dashed var(--border);
    border-radius: 6px; color: var(--gris);
    padding: .5rem; font-size: .8rem; font-family: inherit; cursor: pointer;
    width: 100%;
  }
  .upload-input:hover { border-color: var(--azul); }

  /* ── Nuevo forms ─────────────────────────────────────────────────── */
  .nuevo-section {
    background: #111827; border: 1px solid var(--border);
    border-radius: 12px; padding: 20px; max-width: 680px;
  }
  .form-section-title {
    font-size: 1rem; font-weight: 700; color: #F5A623; margin-bottom: 1rem;
  }
  .nuevo-form { display: flex; flex-direction: column; gap: .625rem; }
  .nuevo-form-grid { display: flex; flex-wrap: wrap; gap: .625rem; }
  .nuevo-form-grid .feed-input { flex: 1; min-width: 140px; }
  .insumo-lbl {
    font-size: .72rem; font-weight: 600; color: var(--gris);
    white-space: nowrap; align-self: center;
  }
  .insumo-input-lg { width: 100px; }

  /* ── Panel wrapper ────────────────────────────────────────────────── */
  .panel { max-width: 1200px; margin: 0 auto; }

  /* ── Responsive — Mobile-first cards ─────────────────────────────── */
  @media (max-width: 767px) {
    .tab-pane { padding: 1rem; }
    .hdr { padding: .625rem 1rem; gap: .5rem; }
    .tabs-nav { padding: .375rem .5rem; }
    .nuevo-section { max-width: 100%; }
    .feed-form { max-width: 100%; }

    /* ── Table → Card layout ────────────────────────────────────────── */
    .table-wrap { border: none; overflow: visible; border-radius: 0; }
    table { display: flex; flex-direction: column; gap: 10px; width: 100%; }
    thead { display: none; }
    tbody { display: contents; }

    tr {
      display: flex;
      flex-wrap: wrap;
      align-content: flex-start;
      gap: 6px;
      padding: 14px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      height: auto !important;
    }
    /* Reset alternating/hover tints inside cards */
    tr:nth-child(even) td { background: transparent; }
    tr:hover td { background: transparent; }

    td {
      height: auto !important;
      border: none;
      padding: 0;
      display: flex;
      align-items: center;
    }

    /* Photo — fixed 88px column */
    .td-photo { width: 88px; flex-shrink: 0; align-self: flex-start; padding: 0; }
    .thumb { width: 80px !important; height: 80px !important; }
    .thumb-empty { width: 80px !important; height: 80px !important; font-size: 1.75rem; }

    /* Name — fills space next to photo */
    .td-name {
      width: calc(100% - 100px);
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 2px;
      font-size: .9375rem;
      max-width: none;
      padding-bottom: 2px;
      height: auto;
    }

    /* Especie chip */
    .td-especie {
      font-size: .75rem;
      background: rgba(148,163,184,.12);
      border-radius: 6px;
      padding: 3px 8px;
      color: var(--gris);
      height: auto;
    }

    /* Tipo badge cell */
    .td-tipo { height: auto; }

    /* Zona — full width */
    .td-zona {
      width: 100%;
      flex-shrink: 0;
      max-width: 100%;
      overflow: visible;
      white-space: normal;
      font-size: .8125rem;
      padding: 2px 0;
    }

    /* WA */
