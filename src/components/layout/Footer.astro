<style>
.site-footer {
  background: #3B2A1A;
  color: #fff;
}
.footer-body { padding-top: 3rem; padding-bottom: 3rem; }

/* Override grid-4 gap inside footer for better density */
.footer-grid { gap: 2rem; }

.footer-brand { grid-column: span 2; }
@media (min-width: 768px) { .footer-brand { grid-column: span 1; } }

.brand-row {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 0.75rem;
}
.brand-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  border-radius: 8px;
  background: rgba(255,255,255,0.1);
  flex-shrink: 0;
}
.brand-name { font-weight: 700; font-size: 0.9375rem; }
.brand-desc {
  font-size: 0.8125rem;
  color: rgba(255,255,255,0.65);
  line-height: 1.5;
  margin: 0 0 1.25rem;
}
.social-row { display: flex; gap: 0.5rem; }
.social-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  color: #fff;
  text-decoration: none;
  transition: background .15s;
}
.social-btn:hover { background: rgba(255,255,255,0.2); }
.col-title {
  font-size: 0.6875rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: rgba(255,255,255,0.45);
  margin: 0 0 1rem;
}
.col-links {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.625rem;
}
.col-links a {
  font-size: 0.8125rem;
  color: rgba(255,255,255,0.7);
  text-decoration: none;
  transition: color .15s;
}
.col-links a:hover { color: #fff; }
.contact-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}
.contact-list li {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.8125rem;
  color: rgba(255,255,255,0.7);
}
.contact-list li svg { flex-shrink: 0; color: rgba(255,255,255,0.35); }
.contact-list a {
  color: rgba(255,255,255,0.7);
  text-decoration: none;
  transition: color .15s;
}
.contact-list a:hover { color: #fff; }
.footer-bottom {
  margin-top: 2.5rem;
  padding-top: 1.5rem;
  border-top: 1px solid rgba(255,255,255,0.1);
  text-align: center;
  font-size: 0.8125rem;
  color: rgba(255,255,255,0.35);
}
</style>
