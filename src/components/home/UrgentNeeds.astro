---
import { supabase } from '../../lib/supabase'

const { data: necesidades } = await supabase
  .from('necesidades')
  .select('id, item, cantidad_requerida, cantidad_recibida, prioridad')
  .order('prioridad', { ascending: true })
  .limit(3)

function pct(recibida: number, requerida: number): number {
  if (!requerida) return 0
  return Math.min(Math.round((recibida / requerida) * 100), 100)
}

function barColor(p: number): string {
  if (p > 70) return '#34A853'
  if (p > 40) return '#F59E0B'
  return '#E5484D'
}

function prioLabel(p: string): string {
  if (p === 'critico') return 'Crítico'
  if (p === 'cubierto') return 'Cubierto'
  return 'Urgente'
}

function prioColor(p: string): string {
  if (p === 'critico') return '#E5484D'
  if (p === 'cubierto') return '#34A853'
  return '#F59E0B'
}
---
<section aria-labelledby="urgent-needs-heading">
  <div class="section-header">
    <h2 id="urgent-needs-heading" class="section-title">Necesidades urgentes</h2>
    <a href="/insumos" class="view-all">Ver todas</a>
  </div>

  {!necesidades?.length ? (
    <p class="empty-msg">Todo cubierto por ahora. ¡Gracias por la solidaridad!</p>
  ) : (
    <div class="grid-3">
      {necesidades.map((n) => {
        const p = pct(n.cantidad_recibida ?? 0, n.cantidad_requerida)
        return (
          <div class="needs-card">
            <div class="center-meta">
              <div class="center-icon" aria-hidden="true">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--marron)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 7H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z"/>
                  <path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/>
                </svg>
              </div>
              <div>
                <h3 class="center-name">{n.item}</h3>
                <div class="center-loc">
                  <span style={`color: ${prioColor(n.prioridad)}; font-weight: 600;`}>
                    {prioLabel(n.prioridad)}
                  </span>
                </div>
              </div>
            </div>
            <div class="needs-list">
              <div class="need-row">
                <div class="need-labels">
                  <span class="need-label">{n.cantidad_recibida ?? 0} / {n.cantidad_requerida} uds.</span>
                  <span class="need-pct">{p}%</span>
                </div>
                <div class="progress-track">
                  <div
                    class="progress-bar"
                    style={`width: ${p}%; background: ${barColor(p)}`}
                    role="progressbar"
                    aria-valuenow={p}
                    aria-valuemin={0}
                    aria-valuemax={100}
                    aria-label={`${n.item}: ${p}% cubierto`}
                  ></div>
                </div>
              </div>
            </div>
          </div>
        )
      })}
    </div>
  )}
</section>

<style>
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1rem;
}
.section-title {
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--texto);
  margin: 0;
}
.view-all {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--accion);
  text-decoration: none;
}
.view-all:hover { color: var(--accion-hover); }

.empty-msg {
  font-size: 0.875rem;
  color: var(--texto-sec);
  text-align: center;
  padding: 2rem;
  background: var(--card);
  border-radius: 1rem;
}

.needs-card {
  background: var(--card);
  border-radius: 1rem;
  padding: 1.25rem;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
}
.center-meta {
  display: flex;
  align-items: flex-start;
  gap: 0.625rem;
  margin-bottom: 1rem;
}
.center-icon {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  background: var(--arena);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 1px;
}
.center-name {
  font-weight: 600;
  font-size: 0.875rem;
  color: var(--texto);
  line-height: 1.3;
  margin: 0 0 2px;
}
.center-loc {
  display: flex;
  align-items: center;
  gap: 3px;
  color: var(--texto-muted);
  font-size: 0.6875rem;
}
.needs-list { display: flex; flex-direction: column; gap: 0.75rem; }
.need-labels {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4px;
}
.need-label {
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--texto);
}
.need-pct { font-size: 0.75rem; color: var(--texto-muted); }
.progress-track {
  width: 100%;
  height: 6px;
  background: #F3EDE6;
  border-radius: 9999px;
  overflow: hidden;
}
.progress-bar {
  height: 100%;
  border-radius: 9999px;
  transition: width .3s ease;
}
</style>
