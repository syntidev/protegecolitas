---
// CTA de compartir — sección de cierre
---
<section class="share-section" aria-labelledby="share-cta-heading">
  <div class="share-inner">
    <div class="share-icon-wrap" aria-hidden="true">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--marron)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="18" cy="5" r="3"/>
        <circle cx="6" cy="12" r="3"/>
        <circle cx="18" cy="19" r="3"/>
        <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
        <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
      </svg>
    </div>
    <h2 id="share-cta-heading" class="share-heading">
      Cada publicación puede significar un reencuentro
    </h2>
    <p class="share-desc">
      Comparte, reporta y ayuda. Juntos podemos reunir más familias con sus mascotas.
    </p>
    <button
      id="share-btn"
      class="share-btn"
      aria-label="Compartir Protege Colitas"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="18" cy="5" r="3"/>
        <circle cx="6" cy="12" r="3"/>
        <circle cx="18" cy="19" r="3"/>
        <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
        <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
      </svg>
      Compartir esta página
    </button>
    <p id="share-feedback" class="share-feedback" hidden>Enlace copiado al portapapeles</p>
  </div>
</section>

<script>
  const btn = document.getElementById('share-btn') as HTMLButtonElement | null
  const feedback = document.getElementById('share-feedback') as HTMLParagraphElement | null

  btn?.addEventListener('click', async () => {
    const shareData = {
      title: 'Protege Colitas — Reuniendo mascotas con sus familias',
      text: 'Ayuda a reunir mascotas perdidas con sus familias tras el terremoto de Venezuela.',
      url: window.location.href,
    }
    try {
      if (navigator.share) {
        await navigator.share(shareData)
      } else {
        await navigator.clipboard.writeText(window.location.href)
        if (feedback) {
          feedback.hidden = false
          setTimeout(() => { if (feedback) feedback.hidden = true }, 3000)
        }
      }
    } catch {
      try {
        await navigator.clipboard.writeText(window.location.href)
        if (feedback) {
          feedback.hidden = false
          setTimeout(() => { if (feedback) feedback.hidden = true }, 3000)
        }
      } catch {
        // Sin acceso al portapapeles
      }
    }
  })
</script>

<style>
.share-section {
  background: var(--arena);
  padding: 4rem 1rem;
}
.share-inner {
  max-width: 36rem;
  margin: 0 auto;
  text-align: center;
}
.share-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64px;
  height: 64px;
  border-radius: 16px;
  background: rgba(255,255,255,0.6);
  margin: 0 auto 1.25rem;
}
.share-heading {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--texto);
  margin: 0 0 0.75rem;
  text-wrap: balance;
}
.share-desc {
  color: var(--texto-sec);
  font-size: 1rem;
  line-height: 1.6;
  max-width: 28rem;
  margin: 0 auto 2rem;
}
.share-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.625rem;
  background: var(--marron);
  color: #fff;
  font-size: 1rem;
  font-weight: 600;
  font-family: 'Inter', sans-serif;
  padding: 1rem 2rem;
  border-radius: 1rem;
  border: none;
  cursor: pointer;
  box-shadow: 0 4px 20px rgba(122,74,36,0.25);
  transition: background .15s;
  min-height: 52px;
}
.share-btn:hover { background: #5E3518; }
.share-feedback {
  margin-top: 1rem;
  font-size: 0.875rem;
  color: var(--verde);
  font-weight: 500;
}
</style>
