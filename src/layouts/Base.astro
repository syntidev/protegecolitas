---
import '../styles/global.css'
export interface Props {
  title?: string
  ogTitle?: string
  ogDescription?: string
  ogImage?: string
  ogUrl?: string
}
const { title = 'Protege Colitas', ogTitle, ogDescription, ogImage, ogUrl } = Astro.props
const path = Astro.url?.pathname ?? '/'
const active = (href: string) => href === '/' ? path === '/' : path.startsWith(href)
const _ogTitle = ogTitle ?? 'Protege Colitas · Emergencia Venezuela 2026'
const _ogDesc  = ogDescription ?? 'Reporta mascotas perdidas o encontradas tras el terremoto. Juntos los reunimos.'
const _ogImg   = ogImage ?? 'https://protegecolitas.org/banner_mobile.png'
const _ogUrl   = ogUrl ?? 'https://protegecolitas.org'
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta property="og:title" content={_ogTitle} />
  <meta property="og:description" content={_ogDesc} />
  <meta property="og:image" content={_ogImg} />
  <meta property="og:image:width" content="390" />
  <meta property="og:image:height" content="200" />
  <meta property="og:url" content={_ogUrl} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={_ogImg} />
  <meta name="description" content={_ogDesc} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
  <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
<!-- Cloudflare Web Analytics --><script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "bdc12cd3439647ad970370f044e3ba0b"}'></script><!-- End Cloudflare Web Analytics -->
</head>
<body>

  <a href="#main-content" class="skip-link">Saltar al contenido principal</a>

  <!-- Top nav -->
  <header class="top-nav" role="banner">
    <div class="top-nav__inner">
      <a href="/" class="top-nav__brand" aria-label="Protege Colitas — Inicio">
        <img src="/logo.png" alt="" width="28" height="28" class="brand-logo" aria-hidden="true" />
        <span class="brand-name">Protege Colitas</span>
      </a>
      <nav class="top-nav__links" aria-label="Navegación principal">
        <a href="/"             class={`top-link${active('/')             ? ' top-link--on' : ''}`} aria-current={active('/')             ? 'page' : undefined}>Inicio</a>
        <a href="/mascotas"     class={`top-link${active('/mascotas')     ? ' top-link--on' : ''}`} aria-current={active('/mascotas')     ? 'page' : undefined}>Mascotas</a>
        <a href="/adoptar"      class={`top-link${active('/adoptar')      ? ' top-link--on' : ''}`} aria-current={active('/adoptar')      ? 'page' : undefined}>Adoptar</a>
        <a href="/veterinarios" class={`top-link${active('/veterinarios') ? ' top-link--on' : ''}`} aria-current={active('/veterinarios') ? 'page' : undefined}>Vets</a>
        <a href="/insumos"      class={`top-link${active('/insumos')      ? ' top-link--on' : ''}`} aria-current={active('/insumos')      ? 'page' : undefined}>Insumos</a>
        <a href="/noticias"     class={`top-link${active('/noticias')     ? ' top-link--on' : ''}`} aria-current={active('/noticias')     ? 'page' : undefined}>Noticias</a>
        <a href="/acopio"       class={`top-link${active('/acopio')       ? ' top-link--on' : ''}`} aria-current={active('/acopio')       ? 'page' : undefined}>Acopio</a>
        <a href="/reportar" class="top-cta">Reportar</a>
      </nav>
      <div class="nav-badge" role="status" aria-live="polite">
        <span class="nav-badge-dot" aria-hidden="true"></span>
        <span class="nav-badge-txt">EMERGENCIA ACTIVA</span>
      </div>
    </div>
  </header>

  <div id="main-content" tabindex="-1">
    <slot />
  </div>

  <footer class="site-footer">
    🐾 Protege Colitas · Centro de Emergencia Animal · Venezuela 2026<br>
    <a href="https://synti.dev" target="_blank" rel="noopener" class="footer-link">
      Desarrollado por SyntiDev como servicio social · synti.dev
    </a>
  </footer>

  <!-- Bottom nav — mobile only, scroll horizontal con los 8 enlaces -->
  <nav class="bottom-nav" aria-label="Secciones">

    <a href="/" class={`bnav-item${active('/') ? ' bnav-on' : ''}`} aria-current={active('/') ? 'page' : undefined}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 10.5L12 3l9 7.5V20a1 1 0 01-1 1H5a1 1 0 01-1-1v-9.5z"/><path d="M9 21v-8h6v8"/></svg>
      <span class="bnav-label">Inicio</span>
    </a>

    <a href="/mascotas" class={`bnav-item${active('/mascotas') ? ' bnav-on' : ''}`} aria-current={active('/mascotas') ? 'page' : undefined}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      <span class="bnav-label">Mascotas</span>
    </a>

    <a href="/adoptar" class={`bnav-item${active('/adoptar') ? ' bnav-on' : ''}`} aria-current={active('/adoptar') ? 'page' : undefined}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      <span class="bnav-label">Adoptar</span>
    </a>

    <a href="/veterinarios" class={`bnav-item${active('/veterinarios') ? ' bnav-on' : ''}`} aria-current={active('/veterinarios') ? 'page' : undefined}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
      <span class="bnav-label">Vets</span>
    </a>

    <a href="/insumos" class={`bnav-item${active('/insumos') ? ' bnav-on' : ''}`} aria-current={active('/insumos') ? 'page' : undefined}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
      <span class="bnav-label">Insumos</span>
    </a>

    <a href="/noticias" class={`bnav-item${active('/noticias') ? ' bnav-on' : ''}`} aria-current={active('/noticias') ? 'page' : undefined}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="7" y1="8" x2="17" y2="8"/><line x1="7" y1="12" x2="17" y2="12"/><line x1="7" y1="16" x2="13" y2="16"/></svg>
      <span class="bnav-label">Noticias</span>
    </a>

    <a href="/acopio" class={`bnav-item${active('/acopio') ? ' bnav-on' : ''}`} aria-current={active('/acopio') ? 'page' : undefined}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="21 8 21 21 3 21 3 8"/><rect x="1" y="3" width="22" height="5"/><line x1="10" y1="12" x2="14" y2="12"/></svg>
      <span class="bnav-label">Acopio</span>
    </a>

    <a href="/reportar" class={`bnav-item bnav-reportar${active('/reportar') ? ' bnav-on' : ''}`} aria-current={active('/reportar') ? 'page' : undefined}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      <span class="bnav-label">Reportar</span>
    </a>

  </nav>



</body>
</html>

<style>
  /* Body offsets */
  body { padding-top: 60px; padding-bottom: 80px; }
  @media (min-width: 640px) { body { padding-bottom: 0; } }

  /* Skip link */
  .skip-link {
    position: fixed; top: -120%; left: 1rem; z-index: 9999;
    background: var(--marron); color: #fff;
    padding: 0.5rem 1.25rem; border-radius: 0 0 8px 8px;
    font-family: 'Inter', sans-serif; font-size: 0.875rem; font-weight: 600;
    text-decoration: none; transition: top 0.15s ease-out; white-space: nowrap;
  }
  .skip-link:focus-visible { top: 0; }
  #main-content { outline: none; }

  /* Top nav */
  .top-nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 200;
    height: 60px;
    background: rgba(255,255,255,0.85);
    backdrop-filter: blur(12px) saturate(160%);
    -webkit-backdrop-filter: blur(12px) saturate(160%);
    border-bottom: 1px solid rgba(255,255,255,0.5);
  }
  .top-nav__inner {
    max-width: 1200px; margin: 0 auto; padding: 0 1.25rem;
    height: 100%; display: flex; align-items: center; gap: 1rem;
  }

  /* Brand */
  .top-nav__brand {
    display: flex; align-items: center; gap: 8px;
    text-decoration: none; flex-shrink: 0;
    min-height: 44px; transition: opacity 0.15s;
  }
  .top-nav__brand:hover { opacity: 0.75; }
  .brand-logo { border-radius: 6px; width: 28px; height: 28px; object-fit: cover; }
  .brand-name {
    font-family: 'Fredoka', sans-serif; font-weight: 700;
    font-size: 1.05rem; color: var(--marron); white-space: nowrap;
  }

  /* Desktop nav links */
  .top-nav__links { display: none; align-items: center; gap: 2px; flex: 1; }
  @media (min-width: 640px) { .top-nav__links { display: flex; } }

  .top-link {
    font-family: 'Inter', sans-serif; font-weight: 600; font-size: 0.875rem;
    color: var(--marron); text-decoration: none;
    padding: 0.375rem 0.65rem; border-radius: 8px; min-height: 36px;
    display: flex; align-items: center;
    transition: background 0.15s;
  }
  .top-link:hover     { background: rgba(61,28,2,0.07); }
  .top-link--on       { color: var(--amarillo); font-weight: 700; }

  /* CTA */
  .top-cta {
    margin-left: auto; flex-shrink: 0;
    background: var(--marron); color: #fff;
    font-family: 'Inter', sans-serif; font-weight: 700; font-size: 0.875rem;
    text-decoration: none; padding: 0 1rem; height: 36px; border-radius: 8px;
    display: flex; align-items: center; transition: opacity 0.15s;
    white-space: nowrap;
  }
  .top-cta:hover { opacity: 0.85; }

  /* Emergency badge */
  .nav-badge {
    display: none; align-items: center; gap: 6px;
    font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 700;
    color: var(--rojo); white-space: nowrap; flex-shrink: 0;
  }
  @media (min-width: 640px) { .nav-badge { display: flex; } }
  @keyframes blink { 0%,100%{opacity:1}50%{opacity:.4} }
  .nav-badge-dot {
    width: 7px; height: 7px; border-radius: 50%; background: #22c55e;
    animation: blink 2s ease-in-out infinite; flex-shrink: 0;
  }

  /* Bottom nav */
  .bottom-nav {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 100;
    height: 64px;
    display: flex; align-items: stretch; flex-wrap: nowrap;
    overflow-x: auto; scrollbar-width: none;
    background: rgba(61,28,2,0.95);
    backdrop-filter: blur(8px) saturate(140%);
    -webkit-backdrop-filter: blur(8px) saturate(140%);
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-bottom: env(safe-area-inset-bottom, 0);
  }
  .bottom-nav::-webkit-scrollbar { display: none; }
  @media (min-width: 640px) { .bottom-nav { display: none; } }

  .bnav-item {
    flex: 0 0 auto; min-width: 64px; display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 3px;
    text-decoration: none; color: rgba(255,255,255,0.5);
    padding: 8px 6px 10px; min-height: 44px;
    -webkit-tap-highlight-color: transparent; transition: color 0.15s;
  }
  .bnav-item:hover, .bnav-on { color: var(--amarillo); }
  .bnav-label {
    font-family: 'Inter', sans-serif; font-size: 10px; font-weight: 600;
    line-height: 1; text-align: center;
  }

  .bnav-reportar { color: var(--amarillo); font-weight: 700; }
  .bnav-reportar:hover, .bnav-reportar.bnav-on { color: var(--amarillo); opacity: 0.85; }

  /* Footer */
  .site-footer {
    text-align: center;
    padding: 20px 16px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    line-height: 1.7;
    color: #6B7280;
    border-top: 1px solid #E5E7EB;
    margin-bottom: 70px;
  }
  @media (min-width: 640px) { .site-footer { margin-bottom: 0; } }
  .footer-link {
    color: var(--amarillo);
    text-decoration: none;
    font-weight: 600;
  }
  .footer-link:hover { text-decoration: underline; }

  @media (prefers-reduced-motion: reduce) {
    .skip-link, .top-nav__brand, .top-link, .top-cta, .bnav-item, .bnav-cta { transition: none; }
    .nav-badge-dot { animation: none; }
  }
</style>
