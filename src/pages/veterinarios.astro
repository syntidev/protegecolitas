---
import Base from '../layouts/Base.astro'
import { supabase } from '../lib/supabase'

const { data: vets } = await supabase
  .from('vets')
  .select('id, nombre, zona, servicios, horario, whatsapp, gratuito, created_at')
  .order('created_at', { ascending: false })

const WA_BASE = 'https://wa.me/'

function initials(nombre: string) {
  return nombre.split(' ').map(w => w[0]).filter(Boolean).join('').slice(0,2).toUpperCase()
}
---

<Base title="Veterinarios — Protege Colitas">
  <div class="page-inner">
    <div class="page-hero">
      <h1 class="page-title">Veterinarios <em>voluntarios</em></h1>
      <p class="page-sub">Atención voluntaria durante la emergencia.</p>
    </div>

    {vets && vets.length > 0 ? (
      <div class="vets-list">
        {vets.map((v) => {
          const waNum = v.whatsapp?.replace(/\D/g, '')
          const waLink = waNum
            ? `${WA_BASE}58${waNum.slice(1)}?text=${encodeURIComponent(`Hola ${v.nombre}, vi tu info en Protege Colitas y necesito atención para mi mascota`)}`
            : null
          return (
            <div class="vet-card">
              <div class="vet-top">
                <div class="vet-avatar" aria-hidden="true">{initials(v.nombre)}</div>
                <div class="vet-info">
                  <div class="vet-name-row">
                    <span class="vet-name">{v.nombre}</span>
                    {v.gratuito && <span class="badge-free">Gratuito</span>}
                  </div>
                  <div class="vet-zona">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
                    {v.zona}
                  </div>
                </div>
              </div>

              {v.servicios && (
                <div class="vet-detail">
                  <span class="detail-label">Servicios:</span>
                  <span class="detail-val">{v.servicios}</span>
                </div>
              )}
              {v.horario && (
                <div class="vet-detail">
                  <span class="detail-label">Horario:</span>
                  <span class="detail-val">{v.horario}</span>
                </div>
              )}

              {waLink && (
                <a href={waLink} class="btn-wa" target="_blank" rel="noopener noreferrer">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.119.553 4.107 1.516 5.836L.057 23.447a.5.5 0 00.611.612l5.638-1.471A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.891 0-3.666-.5-5.197-1.373l-.371-.22-3.847 1.003 1.022-3.737-.242-.384A9.942 9.942 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
                  WhatsApp directo
                </a>
              )}
            </div>
          )
        })}
      </div>
    ) : (
      <div class="empty-state">
        <div class="empty-icon" aria-hidden="true">🩺</div>
        <p class="empty-msg">Pronto habrá veterinarios disponibles.</p>
        <p class="empty-sub">¿Eres vet? Regístrate abajo y te publicamos.</p>
      </div>
    )}

    <section class="register-section">
      <h2 class="register-title">¿Eres veterinario/a?</h2>

      <div class="form-card">
        <form id="vetForm" action="/api/vets" method="post" novalidate>
          <div class="form-fields">
            <div class="field-group">
              <label class="field-label" for="vet-nombre">
                Nombre completo <span class="req" aria-hidden="true">*</span>
              </label>
              <input
                type="text" id="vet-nombre" name="nombre"
                class="form-input" placeholder="Dr. Pérez González"
                autocomplete="name" required
              />
              <p class="field-error" id="err-nombre" role="alert"></p>
            </div>

            <div class="field-group">
              <label class="field-label" for="vet-zona">
                Zona donde atiendes <span class="req" aria-hidden="true">*</span>
              </label>
              <input
                type="text" id="vet-zona" name="zona"
                class="form-input" placeholder="Ej: Porlamar, Nueva Esparta"
                autocomplete="off" required
              />
              <p class="field-error" id="err-zona" role="alert"></p>
            </div>

            <div class="field-group">
              <label class="field-label" for="vet-servicios">Servicios que ofreces</label>
              <textarea
                id="vet-servicios" name="servicios"
                class="form-input form-textarea"
                placeholder="Ej: Consulta general, cirugía menor, vacunas"
                rows="3" autocomplete="off"
              ></textarea>
            </div>

            <div class="field-group">
              <label class="field-label" for="vet-horario">Horario disponible</label>
              <input
                type="text" id="vet-horario" name="horario"
                class="form-input" placeholder="Ej: Lun–Vie 8am–4pm"
                autocomplete="off"
              />
            </div>

            <div class="field-group">
              <label class="field-label" for="vet-whatsapp">
                WhatsApp <span class="req" aria-hidden="true">*</span>
                <span class="field-note">04XX-XXXXXXX</span>
              </label>
              <div class="wa-wrap" id="waWrap">
                <span class="wa-prefix" aria-hidden="true">🇻🇪</span>
                <input
                  type="tel" id="vet-whatsapp" name="whatsapp"
                  class="form-input wa-input"
                  placeholder="04141234567" maxlength="11"
                  autocomplete="tel" inputmode="numeric" required
                />
                <span class="wa-status" id="waStatus" aria-live="polite"></span>
              </div>
              <p class="field-error" id="err-whatsapp" role="alert"></p>
            </div>

            <label class="checkbox-label">
              <input type="checkbox" name="gratuito" value="true" class="checkbox-input" id="vet-gratuito" />
              <span class="checkbox-box" aria-hidden="true"></span>
              <span>Atención gratuita</span>
            </label>
          </div>

          <p class="field-error form-error" id="formError" role="alert"></p>

          <button type="submit" class="btn-submit" id="vetSubmit">
            <span id="btnLabel">Registrarme →</span>
            <span id="btnSpinner" class="spinner" aria-hidden="true" style="display:none"></span>
          </button>
        </form>

        <div id="vetSuccess" class="success-banner" style="display:none" role="status">
          <span class="success-icon" aria-hidden="true">✓</span>
          <div>
            <strong>¡Recibimos tu registro!</strong>
            <p>Lo revisamos y te publicamos pronto. Gracias por ayudar.</p>
          </div>
        </div>
      </div>
    </section>
  </div>
</Base>

<style>
.page-inner {
  max-width: 600px;
  margin: 0 auto;
  padding: 24px 16px 100px;
  width: 100%;
}

/* Hero */
.page-hero { padding: 8px 0 28px; }
.page-title {
  font-family: 'Fredoka', sans-serif;
  font-weight: 700;
  font-size: clamp(28px, 7vw, 40px);
  line-height: 1.05;
  color: var(--marron);
  margin-bottom: 8px;
  text-wrap: balance;
}
.page-title em { font-style: normal; color: var(--amarillo); }
.page-sub { font-size: 15px; color: var(--gris-txt); }

/* Vet list */
.vets-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-bottom: 48px;
}

/* Glass card */
.vet-card {
  background: rgba(255,255,255,0.75);
  backdrop-filter: blur(16px) saturate(180%);
  -webkit-backdrop-filter: blur(16px) saturate(180%);
  border: 1px solid rgba(255,255,255,0.9);
  border-radius: 18px;
  box-shadow: 0 8px 32px rgba(61,28,2,0.10);
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

/* Top row */
.vet-top { display: flex; gap: 14px; align-items: flex-start; }

.vet-avatar {
  width: 52px;
  height: 52px;
  border-radius: 50%;
  background: var(--amarillo);
  color: var(--marron);
  font-family: 'Fredoka', sans-serif;
  font-weight: 700;
  font-size: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  letter-spacing: .02em;
}

.vet-info { flex: 1; min-width: 0; }

.vet-name-row {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 4px;
}

.vet-name {
  font-family: 'Inter', sans-serif;
  font-weight: 600;
  font-size: 16px;
  color: var(--marron);
  line-height: 1.2;
}

.badge-free {
  display: inline-flex;
  align-items: center;
  padding: 2px 9px;
  border-radius: 20px;
  font-family: 'Inter', sans-serif;
  font-size: 11px;
  font-weight: 700;
  background: rgba(22,163,74,0.12);
  color: var(--verde);
  white-space: nowrap;
}

.vet-zona {
  display: flex;
  align-items: center;
  gap: 4px;
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  color: var(--gris);
}

/* Detail rows */
.vet-detail { display: flex; flex-direction: column; gap: 2px; }
.detail-label {
  font-family: 'Inter', sans-serif;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .06em;
  color: var(--gris);
}
.detail-val {
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  color: var(--marron);
}

/* WA button */
.btn-wa {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 100%;
  min-height: 44px;
  padding: 10px 16px;
  border-radius: 10px;
  background: #25D366;
  color: #fff;
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  font-weight: 600;
  text-decoration: none;
  transition: opacity .15s;
  -webkit-tap-highlight-color: transparent;
}
.btn-wa:hover { opacity: .9; }

/* Empty state */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48px 20px;
  text-align: center;
  margin-bottom: 40px;
}
.empty-icon { font-size: 52px; margin-bottom: 14px; }
.empty-msg { font-size: 17px; font-weight: 700; color: var(--marron); margin-bottom: 6px; }
.empty-sub { font-size: 14px; color: var(--gris-txt); }

/* Register section */
.register-section { border-top: 1px solid var(--border); padding-top: 36px; }
.register-title {
  font-family: 'Fredoka', sans-serif;
  font-weight: 700;
  font-size: 20px;
  color: var(--marron);
  margin-bottom: 16px;
}

/* Form card (same glassmorphism) */
.form-card {
  background: rgba(255,255,255,0.75);
  backdrop-filter: blur(16px) saturate(180%);
  -webkit-backdrop-filter: blur(16px) saturate(180%);
  border: 1px solid rgba(255,255,255,0.9);
  border-radius: 18px;
  box-shadow: 0 8px 32px rgba(61,28,2,0.10);
  padding: 24px 20px;
}

.form-fields { display: flex; flex-direction: column; gap: 18px; margin-bottom: 20px; }

.field-group { display: flex; flex-direction: column; gap: 6px; }

.field-label {
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  font-weight: 700;
  color: var(--marron);
  display: flex;
  align-items: center;
  gap: 4px;
  flex-wrap: wrap;
}
.req { color: var(--rojo); font-size: 14px; }
.field-note { font-size: 11px; font-weight: 500; color: var(--gris-txt); }

/* Glass inputs */
.form-input {
  width: 100%;
  padding: 13px 14px;
  background: rgba(255,255,255,0.85);
  border: 1.5px solid rgba(255,255,255,0.9);
  border-radius: var(--radius-sm, 10px);
  font-family: 'Inter', sans-serif;
  font-size: 15px;
  color: var(--marron);
  outline: none;
  transition: border-color .15s;
  -webkit-appearance: none;
  appearance: none;
  box-sizing: border-box;
}
.form-input:focus { border-color: var(--amarillo); }
.form-input.error { border-color: var(--rojo); }
.form-textarea { resize: vertical; min-height: 80px; }

/* WA input group */
.wa-wrap {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.85);
  border: 1.5px solid rgba(255,255,255,0.9);
  border-radius: var(--radius-sm, 10px);
  overflow: hidden;
  transition: border-color .15s;
}
.wa-wrap:focus-within { border-color: var(--amarillo); }
.wa-wrap.valid { border-color: var(--verde); }
.wa-wrap.invalid { border-color: var(--rojo); }
.wa-prefix { padding: 0 10px 0 14px; font-size: 18px; flex-shrink: 0; }
.wa-input {
  flex: 1;
  border: none !important;
  border-radius: 0 !important;
  padding: 13px 0;
  background: transparent;
}
.wa-input:focus { border: none; }
.wa-status { padding: 0 12px; font-size: 16px; flex-shrink: 0; }

/* Checkbox */
.checkbox-label {
  display: flex;
  align-items: center;
  gap: 10px;
  cursor: pointer;
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  color: var(--marron);
  user-select: none;
}
.checkbox-input { position: absolute; opacity: 0; width: 0; height: 0; }
.checkbox-box {
  width: 20px;
  height: 20px;
  border-radius: 6px;
  border: 1.5px solid rgba(255,255,255,0.9);
  background: rgba(255,255,255,0.85);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background .15s, border-color .15s;
}
.checkbox-input:checked + .checkbox-box {
  background: var(--amarillo);
  border-color: var(--amarillo);
}
.checkbox-input:checked + .checkbox-box::after {
  content: '';
  display: block;
  width: 5px;
  height: 9px;
  border: 2px solid var(--marron);
  border-top: none;
  border-left: none;
  transform: rotate(45deg) translate(-1px, -1px);
}
.checkbox-input:focus-visible + .checkbox-box { outline: 2px solid var(--amarillo); outline-offset: 2px; }

/* Errors */
.field-error { font-size: 12px; font-weight: 600; color: var(--rojo); min-height: 16px; }
.form-error { font-size: 13px; text-align: center; padding: 10px; background: #fef2f2; border-radius: 10px; margin-bottom: 12px; }

/* Submit */
.btn-submit {
  width: 100%;
  min-height: 48px;
  background: var(--marron);
  color: #fff;
  border: none;
  border-radius: 10px;
  font-family: 'Inter', sans-serif;
  font-size: 16px;
  font-weight: 700;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  transition: opacity .15s, transform .1s;
  -webkit-tap-highlight-color: transparent;
}
.btn-submit:disabled { opacity: .6; cursor: not-allowed; }
.btn-submit:active:not(:disabled) { transform: scale(.98); }

.spinner {
  width: 20px;
  height: 20px;
  border: 2.5px solid rgba(255,255,255,.35);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin .7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* Success */
.success-banner {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 16px;
  border-radius: 14px;
  background: #f0fdf4;
  border: 1.5px solid #bbf7d0;
}
.success-icon {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--verde);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 700;
  flex-shrink: 0;
}
.success-banner strong { display: block; font-size: 15px; color: var(--verde); margin-bottom: 4px; }
.success-banner p { font-size: 13px; color: #166534; }

@media (prefers-reduced-motion: reduce) {
  .spinner { animation: none; }
}
</style>

<script>
(function () {
  const WA_RE = /^04[0-9]{2}[0-9]{7}$/
  const form     = document.getElementById('vetForm')
  const waInput  = document.getElementById('vet-whatsapp')
  const waWrap   = document.getElementById('waWrap')
  const waStatus = document.getElementById('waStatus')
  const submit   = document.getElementById('vetSubmit')
  const btnLabel = document.getElementById('btnLabel')
  const spinner  = document.getElementById('btnSpinner')
  const formErr  = document.getElementById('formError')
  const success  = document.getElementById('vetSuccess')

  if (!form || !waInput || !waWrap || !submit) return

  /* Live WA validation */
  waInput.addEventListener('input', () => {
    const val = waInput.value.replace(/\D/g, '').slice(0, 11)
    waInput.value = val
    if (!val) {
      waWrap.classList.remove('valid', 'invalid')
      waStatus.textContent = ''
    } else if (WA_RE.test(val)) {
      waWrap.classList.remove('invalid'); waWrap.classList.add('valid')
      waStatus.textContent = '✓'
      clearErr('whatsapp')
    } else {
      waWrap.classList.remove('valid'); waWrap.classList.add('invalid')
      waStatus.textContent = ''
    }
  })

  function setErr(key, msg) {
    const el = document.getElementById('err-' + key)
    const inp = document.getElementById('vet-' + key)
    if (el) el.textContent = msg
    if (inp) inp.classList.add('error')
  }
  function clearErr(key) {
    const el = document.getElementById('err-' + key)
    const inp = document.getElementById('vet-' + key)
    if (el) el.textContent = ''
    if (inp) inp.classList.remove('error')
  }

  function validate() {
    let ok = true
    const nombre = document.getElementById('vet-nombre').value.trim()
    if (!nombre) { setErr('nombre', '¿Cuál es tu nombre?'); ok = false }
    const zona = document.getElementById('vet-zona').value.trim()
    if (zona.length < 5) { setErr('zona', 'Escribe la zona (mínimo 5 caracteres)'); ok = false }
    const wa = waInput.value.trim()
    if (!WA_RE.test(wa)) { setErr('whatsapp', 'Número venezolano: 04XX + 7 dígitos'); ok = false }
    return ok
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    formErr.textContent = ''
    ;['nombre', 'zona', 'whatsapp'].forEach(clearErr)
    if (!validate()) return

    submit.disabled = true
    btnLabel.style.display = 'none'
    spinner.style.display = ''

    const payload = {
      nombre:    document.getElementById('vet-nombre').value.trim(),
      zona:      document.getElementById('vet-zona').value.trim(),
      servicios: document.getElementById('vet-servicios').value.trim() || null,
      horario:   document.getElementById('vet-horario').value.trim() || null,
      whatsapp:  waInput.value.trim(),
      gratuito:  document.getElementById('vet-gratuito').checked
    }

    try {
      const res  = await fetch('/api/vets', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      })
      const data = await res.json().catch(() => ({}))
      if (!res.ok) throw new Error(data.error || 'Error al enviar. Intenta de nuevo.')
      form.style.display = 'none'
      success.style.display = 'flex'
    } catch (err) {
      formErr.textContent = err.message
      submit.disabled = false
      btnLabel.style.display = ''
      spinner.style.display = 'none'
    }
  })
})()
</script>
