<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Protege Colitas — Centro de Emergencia Animal Venezuela</title>
  <meta name="description" content="Ayudamos a reunir mascotas perdidas con sus familias tras el terremoto en Venezuela. Reporta, busca y ayuda." />
  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --amarillo: #F5A623;
      --marron:   #3D1C02;
      --rojo:     #CC1F1F;
      --verde:    #16A34A;
      --crema:    #FDF8F0;
      --blanco:   #FFFFFF;
      --gris:     #6B7280;
      --border:   #E8DDD0;
    }

    html { font-family: 'Inter', sans-serif; font-size: 16px; color: var(--marron); background: var(--blanco); }
    body { min-height: 100dvh; }
    img { display: block; max-width: 100%; }
    a { color: inherit; text-decoration: none; }
    button { font-family: inherit; cursor: pointer; border: none; background: none; }

    /* ── HEADER ── */
    .site-header {
      position: sticky; top: 0; z-index: 50;
      background: var(--blanco); border-bottom: 1px solid var(--border);
      height: 60px;
      display: flex; align-items: center;
      padding: 0 16px; gap: 12px;
    }
    .header-logo {
      display: flex; align-items: center; gap: 10px; flex-shrink: 0;
      text-decoration: none;
    }
    .header-logo img { width: 32px; height: 32px; border-radius: 6px; }
    .header-brand {
      font-family: 'Fredoka', sans-serif; font-weight: 700; font-size: 18px;
      color: var(--marron); white-space: nowrap;
    }
    .header-search {
      flex: 1; max-width: 320px; margin: 0 auto;
      display: none;
    }
    .header-search input {
      width: 100%; height: 36px; padding: 0 14px;
      border: 1.5px solid var(--border); border-radius: 18px;
      font-family: 'Inter', sans-serif; font-size: 14px; color: var(--marron);
      background: var(--crema); outline: none;
    }
    .header-search input:focus { border-color: var(--amarillo); }
    .header-nav-links { display: none; }
    @media (min-width: 768px) {
      .header-nav-links { display: flex; align-items: center; gap: 20px; }
      .header-nav-links a { font-size: 14px; font-weight: 600; color: var(--marron); text-decoration: none; }
      .header-nav-links a:hover { color: var(--amarillo); }
      .header-nav-cta { background: var(--marron); color: white !important; padding: 8px 16px; border-radius: 8px; }
      .header-nav-sep { color: #E5DDD0; font-size: 18px; margin: 0 4px; }
      .header-icon { color: var(--marron); display: flex; align-items: center; transition: color 0.15s; }
      .header-icon:hover { color: var(--amarillo); }
    }
    .header-badge {
      margin-left: auto; display: flex; align-items: center; gap: 6px;
      font-size: 11px; font-weight: 700; color: var(--rojo);
      white-space: nowrap; flex-shrink: 0;
    }
    .badge-dot {
      width: 8px; height: 8px; border-radius: 50%; background: #22c55e;
      animation: pulse 1.8s ease-in-out infinite;
      flex-shrink: 0;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50%       { opacity: .5; transform: scale(.75); }
    }

    /* ── BANNER ── */
    .site-banner { width: 100%; display: block; }
    .site-banner img { width: 100%; object-fit: cover; max-height: 220px; }

    /* ── CONTADORES ── */
    .stats-bar {
      background: var(--crema); padding: 20px 16px;
      border-bottom: 1px solid var(--border);
    }
    .stats-inner {
      display: flex; overflow-x: auto; gap: 0;
      scrollbar-width: none; -ms-overflow-style: none;
      max-width: 1100px; margin: 0 auto;
    }
    .stats-inner::-webkit-scrollbar { display: none; }
    .stat-item {
      flex: 1; min-width: 60px;
      display: flex; flex-direction: column; align-items: center;
      padding: 4px 6px; position: relative;
    }
    .stat-item + .stat-item::before {
      content: ''; position: absolute; left: 0; top: 8px; bottom: 8px;
      width: 1px; background: var(--border);
    }
    .stat-num {
      font-family: 'Fredoka', sans-serif; font-weight: 800; font-size: 24px;
      line-height: 1; color: var(--marron);
    }
    .stat-label {
      font-size: 9px; font-weight: 700; text-transform: uppercase;
      letter-spacing: .04em; color: var(--gris); margin-top: 4px;
      text-align: center; white-space: nowrap;
    }
    .stat-adopt-link {
      display: flex; flex-direction: column; align-items: center;
      text-decoration: none; gap: 0;
    }
    .stat-adopt-link:hover .stat-num { opacity: 0.75; }

    /* ── HERO ── */
    .hero {
      background: var(--blanco); padding: 40px 16px 36px;
      text-align: center; max-width: 520px; margin: 0 auto;
    }
    .hero-title {
      font-family: 'Fredoka', sans-serif; font-weight: 700;
      font-size: clamp(28px, 7vw, 40px);
      color: var(--marron); line-height: 1.15;
      text-wrap: balance; margin-bottom: 12px;
    }
    .hero-sub {
      font-size: 15px; color: var(--gris); line-height: 1.55;
      margin-bottom: 28px; text-wrap: pretty;
    }
    .hero-actions { display: flex; flex-direction: column; gap: 12px; }
    .btn-hero {
      display: flex; align-items: center; justify-content: center;
      height: 52px; border-radius: 12px;
      font-size: 16px; font-weight: 700; text-decoration: none;
      transition: opacity .15s;
    }
    .btn-hero:active { opacity: .85; }
    .btn-hero-primary { background: var(--marron); color: var(--blanco); }
    .btn-hero-secondary {
      background: var(--blanco); color: var(--marron);
      border: 2px solid var(--marron);
    }

    /* ── HERO TYPE CARDS ── */
    .hero-type-cards {
      display: grid; grid-template-columns: 1fr 1fr; gap: 12px;
      width: 100%;
    }
    .type-card {
      display: flex; flex-direction: column; align-items: center;
      padding: 20px 14px 16px; border-radius: 18px;
      text-decoration: none; gap: 8px;
      transition: transform .18s ease, box-shadow .18s ease;
      -webkit-tap-highlight-color: transparent;
    }
    .type-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(61,28,2,0.10); }
    .type-card:active { transform: scale(.97); }
    .type-card-perdido {
      background: #FFFAF5;
      border: 2px solid #F5A623;
      box-shadow: 0 4px 16px rgba(245,166,35,0.12);
    }
    .type-card-encontrado {
      background: #F0FDF4;
      border: 2px solid #16A34A;
      box-shadow: 0 4px 16px rgba(22,163,74,0.12);
    }
    .type-card-icon { font-size: 40px; line-height: 1; }
    .type-card-title {
      font-family: 'Fredoka', sans-serif; font-weight: 700;
      font-size: 16px; color: var(--marron);
      text-align: center; line-height: 1.2; text-wrap: balance;
    }
    .type-card-sub {
      font-size: 12px; color: var(--gris);
      text-align: center; line-height: 1.4;
    }
    .type-card-btn {
      display: flex; align-items: center; justify-content: center;
      width: 100%; min-height: 48px; border-radius: 12px;
      font-family: 'Inter', sans-serif;
      font-size: 14px; font-weight: 700; color: #fff;
      margin-top: 6px; background: var(--marron);
    }
    .type-card-encontrado .type-card-btn { background: var(--verde); }

    /* ── SECTION WRAPPER ── */
    .section { padding: 32px 16px; }
    .section-crema { background: var(--crema); }
    .section-white { background: var(--blanco); }
    .section-inner { max-width: 1100px; margin: 0 auto; }
    .section-head {
      display: flex; align-items: baseline; justify-content: space-between;
      margin-bottom: 20px;
    }
    .section-title {
      font-family: 'Fredoka', sans-serif; font-weight: 700;
      font-size: 22px; color: var(--marron);
    }
    .section-link {
      font-size: 13px; font-weight: 600; color: var(--marron);
      text-decoration: none; border: 1.5px solid var(--marron);
      padding: 5px 12px; border-radius: 20px;
      transition: background 0.15s, color 0.15s;
      white-space: nowrap;
    }
    .section-link:hover { background: var(--marron); color: var(--blanco); }

    /* ── MASCOTAS LIST ── */
    .mascotas-list { display: flex; flex-direction: column; }
    .pet-row {
      display: flex; align-items: center; gap: 12px;
      padding: 14px 0; border-bottom: 1px solid var(--border);
      text-decoration: none; color: inherit;
      position: relative;
    }
    .pet-row:last-child { border-bottom: none; }
    .pet-photo-wrap {
      position: relative; flex-shrink: 0;
      width: 64px; height: 64px;
    }
    .pet-stripe {
      position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
      border-radius: 2px 0 0 2px;
    }
    .pet-photo {
      width: 64px; height: 64px; border-radius: 10px;
      object-fit: cover; flex-shrink: 0;
    }
    .pet-emoji {
      width: 64px; height: 64px; border-radius: 10px;
      background: var(--crema); display: flex; align-items: center;
      justify-content: center; font-size: 28px; flex-shrink: 0;
    }
    .pet-info { flex: 1; min-width: 0; }
    .pet-name {
      font-family: 'Fredoka', sans-serif; font-weight: 600;
      font-size: 15px; color: var(--marron);
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .pet-meta { font-size: 13px; color: var(--gris); margin-top: 2px; }
    .pet-badge {
      font-size: 10px; font-weight: 700; letter-spacing: .06em;
      padding: 3px 8px; border-radius: 4px; text-transform: uppercase;
      flex-shrink: 0;
    }
    .badge-perdido  { background: #fef2f2; color: var(--rojo); }
    .badge-encontrado { background: #f0fdf4; color: var(--verde); }
    .pet-cta {
      font-size: 13px; font-weight: 600; color: var(--marron);
      white-space: nowrap; flex-shrink: 0;
    }

    /* ── INSUMOS ── */
    .insumos-list { display: flex; flex-direction: column; gap: 16px; }
    .insumo-item {}
    .insumo-top {
      display: flex; justify-content: space-between; align-items: baseline;
      margin-bottom: 6px;
    }
    .insumo-name { font-size: 15px; font-weight: 600; color: var(--marron); }
    .insumo-right { display: flex; align-items: center; gap: 10px; }
    .insumo-pct { font-size: 13px; font-weight: 700; }
    .insumo-link {
      font-size: 13px; font-weight: 600; color: var(--verde);
      text-decoration: none;
    }
    .insumo-link:hover { text-decoration: underline; }
    .prog-bar { height: 6px; border-radius: 3px; background: var(--border); }
    .prog-fill { height: 100%; border-radius: 3px; transition: width .4s ease; }

    /* ── VETS ── */
    .vets-list { display: flex; flex-direction: column; gap: 12px; }
    .vet-row {
      display: flex; align-items: center; gap: 12px;
      padding: 14px; border-radius: 12px;
      background: var(--crema); border: 1px solid var(--border);
    }
    .vet-avatar {
      width: 40px; height: 40px; border-radius: 50%;
      background: var(--marron); color: var(--blanco);
      display: flex; align-items: center; justify-content: center;
      font-family: 'Fredoka', sans-serif; font-weight: 700; font-size: 15px;
      flex-shrink: 0;
    }
    .vet-info { flex: 1; min-width: 0; }
    .vet-name { font-size: 14px; font-weight: 700; color: var(--marron); }
    .vet-zona { font-size: 13px; color: var(--gris); }
    .btn-vet-wa {
      display: flex; align-items: center; justify-content: center;
      width: 36px; height: 36px; border-radius: 8px;
      background: #25D366; color: #fff; flex-shrink: 0;
    }

    /* ── NOTICIAS ── */
    .feed-list { display: flex; flex-direction: column; gap: 0; }
    .feed-row {
      display: flex; gap: 16px; padding: 16px 0;
      border-bottom: 1px solid var(--border); align-items: flex-start;
      text-decoration: none; color: inherit; cursor: pointer;
      transition: background 0.15s;
    }
    .feed-row:hover .feed-titulo { color: var(--amarillo); }
    .feed-row:last-child { border-bottom: none; }
    .feed-date {
      flex-shrink: 0; text-align: center; min-width: 36px;
    }
    .feed-day {
      font-family: 'Fredoka', sans-serif; font-weight: 700;
      font-size: 22px; color: var(--amarillo); line-height: 1;
    }
    .feed-mon {
      font-size: 10px; font-weight: 700; color: var(--gris);
      text-transform: uppercase; letter-spacing: .05em;
    }
    .feed-content { flex: 1; min-width: 0; }
    .feed-titulo {
      font-size: 15px; font-weight: 600; color: var(--marron);
      margin-bottom: 4px; line-height: 1.35;
    }
    .feed-cuerpo {
      font-size: 13px; color: var(--gris); line-height: 1.5;
      display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .feed-thumb {
      width: 60px; height: 60px; object-fit: cover;
      border-radius: 8px; flex-shrink: 0; display: block; align-self: center;
    }

    /* ── FOOTER ── */
    .site-footer {
      background: var(--marron); color: rgba(255,255,255,.85);
      padding: 40px 16px 32px;
    }
    .footer-inner {
      max-width: 1100px; margin: 0 auto;
      display: grid; grid-template-columns: 1fr;
      gap: 32px;
    }
    .footer-brand-logo {
      display: flex; align-items: center; gap: 10px; margin-bottom: 10px;
    }
    .footer-brand-logo img { width: 32px; height: 32px; border-radius: 6px; }
    .footer-brand-name {
      font-family: 'Fredoka', sans-serif; font-weight: 700;
      font-size: 18px; color: #fff;
    }
    .footer-tagline { font-size: 13px; color: rgba(255,255,255,.6); line-height: 1.5; }
    .footer-col-title {
      font-size: 12px; font-weight: 700; text-transform: uppercase;
      letter-spacing: .08em; color: rgba(255,255,255,.45); margin-bottom: 12px;
    }
    .footer-links { list-style: none; display: flex; flex-direction: column; gap: 8px; }
    .footer-links a {
      font-size: 14px; color: rgba(255,255,255,.75);
      text-decoration: none; transition: color .15s;
    }
    .footer-links a:hover { color: #fff; }
    .footer-contact-item {
      display: flex; align-items: center; gap: 8px;
      font-size: 14px; color: rgba(255,255,255,.75); margin-bottom: 8px;
    }
    .footer-contact-item a { color: rgba(255,255,255,.75); }
    .footer-contact-item a:hover { color: #fff; }
    .footer-redes {
      display: flex; justify-content: center; gap: 20px;
      padding: 16px 0 8px; border-top: 1px solid rgba(255,255,255,0.1);
    }
    .footer-redes a { color: rgba(255,255,255,0.7); transition: color 0.15s; }
    .footer-redes a:hover { color: #F5A623; }
    .footer-bottom { padding-bottom: 80px;
      max-width: 1100px; margin: 28px auto 0;
      padding-top: 20px; border-top: 1px solid rgba(255,255,255,.12);
      font-size: 12px; color: rgba(255,255,255,.4); text-align: center;
    }
    .footer-bottom a { color: rgba(255,255,255,.55); }
    .footer-bottom a:hover { color: #fff; }

    /* ── BOTTOM NAV (mobile only) ── */
    .bottom-nav {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 40;
      background: var(--marron); height: 60px;
      display: flex; align-items: stretch;
      border-top: 1px solid rgba(255,255,255,.1);
    }
    .nav-tab {
      flex: 1; display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 3px;
      text-decoration: none; color: rgba(255,255,255,.55);
      font-size: 10px; font-weight: 600; transition: color .15s;
      -webkit-tap-highlight-color: transparent;
    }
    .nav-tab:hover, .nav-tab.active { color: #fff; }
    .nav-tab svg { flex-shrink: 0; }
    .nav-tab-center {
      flex: 1; display: flex; align-items: center; justify-content: center;
      position: relative;
    }
    .nav-tab-center-btn {
      position: absolute; bottom: 10px;
      width: 52px; height: 52px; border-radius: 50%;
      background: var(--amarillo); color: var(--marron);
      display: flex; align-items: center; justify-content: center;
      text-decoration: none; box-shadow: 0 2px 12px rgba(0,0,0,.25);
      transition: transform .15s;
      -webkit-tap-highlight-color: transparent;
    }
    .nav-tab-center-btn:active { transform: scale(.92); }

    /* ── MAIN PADDING FOR BOTTOM NAV ── */
    main { padding-bottom: 72px; }

    /* ── DESKTOP ── */
    @media (min-width: 768px) {
      .site-header { height: 68px; padding: 0 32px; }
      .header-search { display: block; }
      .header-brand { font-size: 20px; }

      main { padding-bottom: 0; }
      .bottom-nav { display: none; }

      .stats-inner { gap: 0; }
      .stat-num { font-size: 32px; }

      .hero { padding: 56px 32px 48px; max-width: 600px; }
      .hero-actions { flex-direction: row; justify-content: center; }
      .btn-hero { width: 220px; }

      .section { padding: 48px 32px; }

      .mascotas-list { display: grid; grid-template-columns: 1fr 1fr; gap: 0 32px; }
      .pet-row { border-bottom: 1px solid var(--border); }

      .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; }

      .footer-inner { grid-template-columns: 1.5fr 1fr 1fr; }
    }

    @media (prefers-reduced-motion: reduce) {
      .badge-dot { animation: none; }
      .btn-hero, .nav-tab, .nav-tab-center-btn { transition: none; }
    }
  </style>
