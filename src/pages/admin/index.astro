  }

  /* ── Gemini Vision tab ───────────────────────────────────────── */
  .gemini-actions {
    display: flex;
    gap: .5rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .gem-action {
    flex: 1;
    min-width: 90px;
    padding: .5rem .75rem;
    background: #1f2937;
    color: #9ca3af;
    border: 1px solid #374151;
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    font-size: .8125rem;
    font-weight: 600;
    cursor: pointer;
    transition: background .15s, color .15s, border-color .15s;
    white-space: nowrap;
  }
  .gem-action:hover { background: #374151; color: #e5e7eb; }
  .gem-action.active {
    background: #F5A623;
    color: #1a1a1a;
    border-color: #F5A623;
  }
  .gemini-preview {
    height: 200px;
    background: #1f2937;
    border: 2px dashed #374151;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    overflow: hidden;
    transition: border-color .15s;
  }
  .gemini-preview:hover { border-color: #F5A623; }
  .gemini-preview:focus-visible { outline: 2px solid #F5A623; outline-offset: 2px; }
  .gemini-placeholder { color: #9ca3af; font-size: .875rem; text-align: center; pointer-events: none; }
</style>

<script>
  // ── Tab switching
  document.querySelectorAll('.tab').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.tab').forEach(function(b) {
        b.classList.remove('active')
        b.setAttribute('aria-selected', 'false')
      })
      document.querySelectorAll('.tab-pane').forEach(function(p) {
        p.classList.remove('active')
      })
      btn.classList.add('active')
      btn.setAttribute('aria-selected', 'true')
      var pane = document.getElementById('tab-' + btn.dataset.tab)
      if (pane) pane.classList.add('active')
    })
  })

  // ── Generic fetch action
  async function doAction(params, rowId, confirmMsg) {
    if (confirmMsg && !confirm(confirmMsg)) return false
    var fd = new FormData()
    Object.keys(params).forEach(function(k) { fd.append(k, String(params[k])) })
    try {
      var r = await fetch('/admin', { method: 'POST', body: fd })
      var j = await r.json()
      if (!j.ok) { alert('Error: ' + (j.error || 'desconocido')); return false }
      if (rowId) {
        var el = document.getElementById(rowId)
        if (el) {
          el.style.transition = 'opacity .2s'
          el.style.opacity = '0'
          setTimeout(function() { el.remove() }, 200)
        }
      }
      return true
    } catch(e) {
      alert('Error de red')
      return false
    }
  }

  // ── Data-attribute buttons
  document.querySelectorAll('[data-action]').forEach(function(btn) {
    btn.addEventListener('click', async function() {
      var action = btn.dataset.action
      var id     = btn.dataset.id
      var row    = btn.dataset.row
      var conf   = btn.dataset.confirm
      if (!action || !id) return
      btn.disabled = true
      var params = { action: action, id: id }
      if (btn.dataset.activo !== undefined) params.activo = btn.dataset.activo
      var ok = await doAction(params, row, conf || null)
      if (ok && btn.dataset.reload) { location.reload() }
      else if (!ok) btn.disabled = false
    })
  })

  // ── Feed form
  var formFeed = document.getElementById('form-feed')
  if (formFeed) {
    formFeed.addEventListener('submit', async function(e) {
      e.preventDefault()
      var fd  = new FormData(formFeed)
      fd.append('action', 'feed')
      var btn = formFeed.querySelector('button[type="submit"]')
      if (btn) btn.disabled = true
      try {
        var r = await fetch('/admin', { method: 'POST', body: fd })
        var j = await r.json()
        if (!j.ok) {
          alert('Error: ' + (j.error || 'desconocido'))
          if (btn) btn.disabled = false
        } else {
          formFeed.reset()
          if (btn) btn.disabled = false
          var msg = document.createElement('p')
          msg.textContent = '✓ Publicado'
          msg.style.cssText = 'color:#22C55E;font-size:.8rem;margin-top:.375rem;'
          formFeed.appendChild(msg)
          setTimeout(function() { msg.remove() }, 2500)
        }
      } catch(e) {
        alert('Error de red')
        if (btn) btn.disabled = false
      }
    })
  }

  // ── Insumo forms (editar cantidad_recibida Y cantidad_requerida)
  document.querySelectorAll('.insumo-form').forEach(function(form) {
    form.addEventListener('submit', async function(e) {
      e.preventDefault()
      var id       = form.dataset.id
      var inputRec = form.querySelector('input[name="cantidad_recibida"]')
      var inputReq = form.querySelector('input[name="cantidad_requerida"]')
      var cantRec  = inputRec ? inputRec.value : '0'
      var cantReq  = inputReq ? inputReq.value : '1'
      var btn      = form.querySelector('button')
      if (btn) btn.disabled = true
      var ok = await doAction({ action: 'insumo', id: id, cantidad_recibida: cantRec, cantidad_requerida: cantReq }, null, null)
      if (btn) btn.disabled = false
    })
  })

  // ── Banner form (multipart con archivo)
  var formBanner = document.getElementById('form-banner')
  if (formBanner) {
    formBanner.addEventListener('submit', async function(e) {
      e.preventDefault()
      var fd  = new FormData(formBanner)
      fd.append('action', 'banner')
      var btn = formBanner.querySelector('button[type="submit"]')
      if (btn) btn.disabled = true
      try {
        var r = await fetch('/admin', { method: 'POST', body: fd })
        var j = await r.json()
        if (!j.ok) { alert('Error: ' + (j.error || 'desconocido')); if (btn) btn.disabled = false }
        else { window.location.reload() }
      } catch(e) { alert('Error de red'); if (btn) btn.disabled = false }
    })
  }

  // ── Nueva mascota form
  var formNuevaMascota = document.getElementById('form-nueva-mascota')
  if (formNuevaMascota) {
    // WA live validator
    var nmWa = document.getElementById('nm-wa')
    var nmHint = document.getElementById('nm-wa-hint')
    if (nmWa && nmHint) {
      nmWa.addEventListener('input', function() {
        var val = nmWa.value.replace(/\D/g, '')
        if (val.length === 0) {
          nmHint.textContent = ''
          nmHint.className = 'nm-hint'
        } else if (/^04[0-9]{9}$/.test(val)) {
          nmHint.textContent = '✓ Formato válido'
          nmHint.className = 'nm-hint valid'
        } else {
          nmHint.textContent = 'Debe ser 04XXXXXXXXX (11 dígitos)'
          nmHint.className = 'nm-hint invalid'
        }
      })
    }
    // Photo preview
    var nmFoto = document.getElementById('nm-foto')
    var nmPreviewWrap = document.getElementById('nm-preview-wrap')
    var nmPreview = document.getElementById('nm-preview')
    if (nmFoto && nmPreviewWrap && nmPreview) {
      nmFoto.addEventListener('change', function() {
        var file = nmFoto.files && nmFoto.files[0]
        if (file) {
          var reader = new FileReader()
          reader.onload = function(e) {
            nmPreview.src = e.target.result
            nmPreviewWrap.style.display = 'block'
          }
          reader.readAsDataURL(file)
        } else {
          nmPreviewWrap.style.display = 'none'
        }
      })
    }
    // Submit
    formNuevaMascota.addEventListener('submit', async function(e) {
      e.preventDefault()
      var fd  = new FormData(formNuevaMascota)
      fd.append('action', 'nueva_mascota')
      var btn = document.getElementById('nm-submit')
      var msg = document.getElementById('nm-msg')
      if (btn) { btn.disabled = true; btn.textContent = 'Guardando…' }
      if (msg) msg.textContent = ''
      try {
        var r = await fetch('/admin', { method: 'POST', body: fd })
        var j = await r.json()
        if (!j.ok) {
          alert('Error: ' + (j.error || 'desconocido'))
          if (btn) { btn.disabled = false; btn.textContent = 'Crear mascota' }
        } else {
          formNuevaMascota.reset()
          if (nmPreviewWrap) nmPreviewWrap.style.display = 'none'
          if (nmHint) { nmHint.textContent = ''; nmHint.className = 'nm-hint' }
          if (btn) { btn.disabled = false; btn.textContent = 'Crear mascota' }
          if (msg) {
            msg.textContent = '✓ Mascota creada'
            setTimeout(function() { if (msg) msg.textContent = '' }, 3000)
          }
        }
      } catch(err) {
        alert('Error de red')
        if (btn) { btn.disabled = false; btn.textContent = 'Crear mascota' }
      }
    })
  }

  // ── Nuevo insumo
  var formNuevoInsumo = document.getElementById('form-nuevo-insumo')
  if (formNuevoInsumo) {
    formNuevoInsumo.addEventListener('submit', async function(e) {
      e.preventDefault()
      var fd  = new FormData(formNuevoInsumo)
      fd.append('action', 'nuevo_insumo')
      var btn = formNuevoInsumo.querySelector('button[type="submit"]')
      if (btn) btn.disabled = true
      try {
        var r = await fetch('/admin', { method: 'POST', body: fd })
        var j = await r.json()
        if (!j.ok) { alert('Error: ' + (j.error || 'desconocido')); if (btn) btn.disabled = false }
        else { window.location.reload() }
      } catch(e) { alert('Error de red'); if (btn) btn.disabled = false }
    })
  }

  // ── Nuevo vet
  var formNuevoVet = document.getElementById('form-nuevo-vet')
  if (formNuevoVet) {
    formNuevoVet.addEventListener('submit', async function(e) {
      e.preventDefault()
      var fd  = new FormData(formNuevoVet)
      fd.append('action', 'nuevo_vet')
      var btn = formNuevoVet.querySelector('button[type="submit"]')
      if (btn) btn.disabled = true
      try {
        var r = await fetch('/admin', { method: 'POST', body: fd })
        var j = await r.json()
        if (!j.ok) { alert('Error: ' + (j.error || 'desconocido')); if (btn) btn.disabled = false }
        else { window.location.reload() }
      } catch(e) { alert('Error de red'); if (btn) btn.disabled = false }
    })
  }

  // ── Edit Modal ────────────────────────────────────────────
  var modal        = document.getElementById('edit-modal')
  var modalClose   = document.getElementById('modal-close')
  var formMascota  = document.getElementById('modal-mascota')
  var formVet      = document.getElementById('modal-vet')
  var formInsumo   = document.getElementById('modal-insumo')
  var formFeedEdit = document.getElementById('modal-feed')

  function openModal(type) {
    [formMascota, formVet, formInsumo, formFeedEdit].forEach(function(f) { if (f) f.style.display = 'none' })
    if      (type === 'mascota' && formMascota)  formMascota.style.display  = 'flex'
    else if (type === 'vet'     && formVet)      formVet.style.display      = 'flex'
    else if (type === 'insumo'  && formInsumo)   formInsumo.style.display   = 'flex'
    else if (type === 'feed'    && formFeedEdit) formFeedEdit.style.display  = 'flex'
    modal.style.display = 'flex'
    var first = modal.querySelector('.modal-input, button')
    if (first) first.focus()
  }

  function closeModal() {
    modal.style.display = 'none'
    ;[formMascota, formVet, formInsumo, formFeedEdit].forEach(function(f) { if (f) f.style.display = 'none' })
  }

  if (modalClose) modalClose.addEventListener('click', closeModal)
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal && modal.style.display !== 'none') closeModal()
  })
  document.querySelectorAll('.modal-cancel').forEach(function(b) {
    b.addEventListener('click', closeModal)
  })

  // Abrir modal de mascota
  document.querySelectorAll('.btn-edit-mascota').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.getElementById('em-id').value          = btn.dataset.id        || ''
      document.getElementById('em-nombre').value      = btn.dataset.nombre    || ''
      document.getElementById('em-zona').value        = btn.dataset.zona      || ''
      document.getElementById('em-color').value       = btn.dataset.color     || ''
      document.getElementById('em-whatsapp').value    = btn.dataset.whatsapp  || ''

      document.getElementById('em-descripcion').value = btn.dataset.descripcion || ''
      var selEsp = document.getElementById('em-especie')
      var selTip = document.getElementById('em-tipo')
      var selTam = document.getElementById('em-tamanio')
      for (var i = 0; i < selEsp.options.length; i++) {
        if (selEsp.options[i].value === btn.dataset.especie) { selEsp.selectedIndex = i; break }
      }
      for (var j = 0; j < selTip.options.length; j++) {
        if (selTip.options[j].value === btn.dataset.tipo) { selTip.selectedIndex = j; break }
      }
      for (var k = 0; k < selTam.options.length; k++) {
        if (selTam.options[k].value === btn.dataset.tamanio) { selTam.selectedIndex = k; break }
      }
      openModal('mascota')
    })
  })

  // Abrir modal de vet
  document.querySelectorAll('.btn-edit-vet').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.getElementById('ev-id').value        = btn.dataset.id        || ''
      document.getElementById('ev-nombre').value    = btn.dataset.nombre    || ''
      document.getElementById('ev-zona').value      = btn.dataset.zona      || ''
      document.getElementById('ev-whatsapp').value  = btn.dataset.whatsapp  || ''
      document.getElementById('ev-servicios').value = btn.dataset.servicios || ''
      document.getElementById('ev-horario').value   = btn.dataset.horario   || ''
      openModal('vet')
    })
  })

  // Abrir modal de insumo
  document.querySelectorAll('.btn-edit-insumo').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.getElementById('ei-id').value        = btn.dataset.id                 || ''
      document.getElementById('ei-item').value      = btn.dataset.item               || ''
      document.getElementById('ei-recibida').value  = btn.dataset.cantidad_recibida  || '0'
      document.getElementById('ei-requerida').value = btn.dataset.cantidad_requerida || '1'
      var selPrio = document.getElementById('ei-prioridad')
      for (var i = 0; i < selPrio.options.length; i++) {
        if (selPrio.options[i].value === btn.dataset.prioridad) { selPrio.selectedIndex = i; break }
      }
      openModal('insumo')
    })
  })

  // Submit handler genérico para los tres formularios del modal
  function handleModalForm(form) {
    if (!form) return
    form.addEventListener('submit', async function(e) {
      e.preventDefault()
      var fd  = new FormData(form)
      var btn = form.querySelector('button[type="submit"]')
      if (btn) btn.disabled = true
      try {
        var r = await fetch('/admin', { method: 'POST', body: fd })
        var j = await r.json()
        if (!j.ok) {
          alert('Error: ' + (j.error || 'desconocido'))
          if (btn) btn.disabled = false
        } else {
          closeModal()
          window.location.reload()
        }
      } catch(err) {
        alert('Error de red')
        if (btn) btn.disabled = false
      }
    })
  }
  handleModalForm(formMascota)
  handleModalForm(formVet)
  handleModalForm(formInsumo)
  handleModalForm(formFeedEdit)

  // Abrir modal de feed
  document.querySelectorAll('.btn-edit-feed').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.getElementById('ef-id').value    = btn.dataset.id     || ''
      document.getElementById('ef-titulo').value = btn.dataset.titulo || ''
      document.getElementById('ef-cuerpo').value = btn.dataset.cuerpo || ''
      var selTipo = document.getElementById('ef-tipo')
      for (var i = 0; i < selTipo.options.length; i++) {
        if (selTipo.options[i].value === btn.dataset.tipo) { selTipo.selectedIndex = i; break }
      }
      openModal('feed')
    })
  })

  // ── Search filters (tiempo real, sin reload)
  function setupSearch(inputId, tbodyId, rowClass) {
    var inp = document.getElementById(inputId)
    if (!inp) return
    inp.addEventListener('input', function() {
      var q = this.value.toLowerCase()
      document.querySelectorAll('#' + tbodyId + ' tr.' + rowClass).forEach(function(row) {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none'
      })
    })
  }
  setupSearch('searchPendientes', 'tablaPendientes', 'pendiente-row')
  setupSearch('searchPublicadas', 'tablaPublicadas', 'mascota-row')
  setupSearch('searchVets',       'tablaVets',       'vet-row')

  // ── Gemini Vision tab
  ;(function() {
    var geminiImg    = document.getElementById('geminiImg')
    if (!geminiImg) return
    var btnSel       = document.getElementById('btnSeleccionar')
    var btnExtraer   = document.getElementById('btnExtraer')
    var preview      = document.getElementById('geminiPreview')
    var previewImg   = document.getElementById('geminiPreviewImg')
    var placeholder  = document.getElementById('geminiPlaceholder')
    var geminiMsg    = document.getElementById('geminiMsg')
    var formMascota  = document.getElementById('geminiFormMascota')
    var formFeed     = document.getElementById('geminiFormFeed')
    var formInsumo   = document.getElementById('geminiFormInsumo')
    var currentAction = 'mascota'

    function hideAllForms() {
      formMascota.style.display = 'none'
      formFeed.style.display    = 'none'
      formInsumo.style.display  = 'none'
    }

    document.querySelectorAll('.gem-action').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.gem-action').forEach(function(b) { b.classList.remove('active') })
        btn.classList.add('active')
        currentAction = btn.dataset.action
        hideAllForms()
        geminiMsg.style.display = 'none'
      })
    })

    function showMsg(text, ok) {
      geminiMsg.style.display     = 'block'
      geminiMsg.textContent       = text
      geminiMsg.style.background  = ok ? '#064e3b' : '#1f2937'
      geminiMsg.style.borderColor = ok ? '#16a34a' : '#374151'
    }

    function loadPreview(file) {
      var reader = new FileReader()
      reader.onload = function(e) {
        previewImg.src            = e.target.result
        previewImg.style.display  = 'block'
        placeholder.style.display = 'none'
        btnExtraer.disabled       = false
      }
      reader.readAsDataURL(file)
    }

    btnSel.addEventListener('click', function() { geminiImg.click() })
    preview.addEventListener('click', function() { geminiImg.click() })
    preview.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); geminiImg.click() }
    })
    geminiImg.addEventListener('change', function() {
      if (this.files[0]) loadPreview(this.files[0])
    })

    function setVal(id, val) { if (val) { var el = document.getElementById(id); if (el) el.value = val } }
    function setSelect(id, val) {
      if (!val) return
      var sel = document.getElementById(id)
      if (!sel) return
      for (var i = 0; i < sel.options.length; i++) {
        if (sel.options[i].value === val) { sel.selectedIndex = i; break }
      }
    }
    function fillMascota(data) {
      setVal('g-nombre', data.nombre)
      setSelect('g-especie', data.especie)
      setVal('g-color', data.color)
      setVal('g-zona', data.zona)
      setVal('g-descripcion', data.descripcion)
      setVal('g-senias', data.senias)
      setVal('g-contacto-nombre', data.contacto_nombre)
      setVal('g-whatsapp', data.whatsapp)
      setSelect('g-tipo', data.tipo)
    }
    function fillFeed(data) {
      setSelect('gf-tipo', data.tipo)
      setVal('gf-titulo', data.titulo)
      setVal('gf-cuerpo', data.cuerpo)
    }
    function fillInsumo(data) {
      setVal('gi-item', data.item)
      if (data.cantidad_requerida) { var elReq = document.getElementById('gi-cantidad-req'); if (elReq) elReq.value = data.cantidad_requerida }
      if (data.cantidad_recibida !== undefined) { var elRec = document.getElementById('gi-cantidad-rec'); if (elRec) elRec.value = data.cantidad_recibida }
      setSelect('gi-prioridad', data.prioridad)
    }

    btnExtraer.addEventListener('click', async function() {
      var file = geminiImg.files[0]
      if (!file) return
      btnExtraer.disabled = true
      showMsg('⏳ Analizando imagen con Gemini Vision...', false)

      var reader = new FileReader()
      reader.onload = async function(e) {
        var base64 = e.target.result.split(',')[1]
        var mime   = file.type || 'image/jpeg'
        try {
          var r = await fetch('/api/gemini-extract', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ base64: base64, mime: mime, action: currentAction })
          })
          var data = await r.json()
          if (!r.ok || data.error) {
            showMsg('❌ ' + (data.error || 'Error al extraer datos'), false)
            btnExtraer.disabled = false
            return
          }
          hideAllForms()
          if (currentAction === 'mascota') {
            fillMascota(data)
            formMascota.style.display = 'block'
            formMascota.scrollIntoView({ behavior: 'smooth', block: 'start' })
          } else if (currentAction === 'feed') {
            fillFeed(data)
            formFeed.style.display = 'block'
            formFeed.scrollIntoView({ behavior: 'smooth', block: 'start' })
          } else if (currentAction === 'insumo') {
            fillInsumo(data)
            formInsumo.style.display = 'block'
            formInsumo.scrollIntoView({ behavior: 'smooth', block: 'start' })
          }
          showMsg('✓ Datos extraídos. Revisa y edita antes de guardar.', true)
          btnExtraer.disabled = false
        } catch(err) {
          showMsg('❌ Error de red: ' + err.message, false)
          btnExtraer.disabled = false
        }
      }
      reader.readAsDataURL(file)
    })
  })()
</script>
