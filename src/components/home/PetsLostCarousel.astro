---
// TODO: conectar con Supabase — mascotas con tipo='perdido' y status='publicado'
const pets = [
  { name: 'Bobby', city: 'Caracas', timeAgo: 'Hace 15 min', img: 'https://placedog.net/300/300?id=6', alt: 'Perro Bobby perdido en Caracas' },
  { name: 'Nala', city: 'La California', timeAgo: 'Hace 22 min', img: 'https://placekitten.com/300/301', alt: 'Gata Nala perdida en La California' },
  { name: 'Thor', city: 'Petare', timeAgo: 'Hace 35 min', img: 'https://placedog.net/300/300?id=8', alt: 'Perro Thor perdido en Petare' },
  { name: 'Coco', city: 'Los Teques', timeAgo: 'Hace 40 min', img: 'https://placedog.net/300/300?id=9', alt: 'Perro Coco perdido en Los Teques' },
  { name: 'Kira', city: 'Guarenas', timeAgo: 'Hace 52 min', img: 'https://placedog.net/300/300?id=10', alt: 'Perro Kira perdida en Guarenas' },
]
---
<section aria-labelledby="pets-lost-heading">
  <div class="flex items-center justify-between mb-4">
    <h2 id="pets-lost-heading" class="text-lg font-bold text-[#3B2A1A]">Se buscan activamente</h2>
    <a href="/mascotas" class="text-sm text-[#C96A1B] hover:text-[#A85514] font-medium transition-colors">Ver todas</a>
  </div>
  <div class="carousel-container">
    {pets.map((pet) => (
      <div class="carousel-item bg-white rounded-2xl overflow-hidden shadow-[0_2px_10px_rgba(0,0,0,0.06)] w-[calc(66vw)] sm:w-[calc(33vw-1rem)] lg:w-56 max-w-[240px]">
        <div class="relative">
          <img src={pet.img} alt={pet.alt} class="w-full aspect-square object-cover" loading="lazy" />
          <span class="absolute top-2 left-2 inline-flex items-center font-semibold rounded-full bg-white/90 text-[#B91C1C] text-xs px-2.5 py-1 shadow-sm">
            Perdida
          </span>
        </div>
        <div class="p-3">
          <p class="font-semibold text-[#3B2A1A] text-sm">{pet.name}</p>
          <div class="flex items-center gap-1 mt-0.5">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <p class="text-xs text-[#9CA3AF]">{pet.city}</p>
          </div>
          <p class="text-xs text-[#9CA3AF] mt-0.5">{pet.timeAgo}</p>
          <a href="#" class="mt-2 inline-block text-xs font-semibold text-[#C96A1B] hover:text-[#A85514] transition-colors">Ver ficha</a>
        </div>
      </div>
    ))}
  </div>
</section>
