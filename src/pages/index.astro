---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
import GlobalStats from '../components/home/GlobalStats.astro'
import QuickActions from '../components/home/QuickActions.astro'
import LiveFeed from '../components/home/LiveFeed.astro'
import PetsFoundCarousel from '../components/home/PetsFoundCarousel.astro'
import PetsLostCarousel from '../components/home/PetsLostCarousel.astro'
import UrgentNeeds from '../components/home/UrgentNeeds.astro'
import VetsList from '../components/home/VetsList.astro'
import HelpCenters from '../components/home/HelpCenters.astro'
import HopeStories from '../components/home/HopeStories.astro'
import NewsSection from '../components/home/NewsSection.astro'
import ShareCTA from '../components/home/ShareCTA.astro'
---
<BaseLayout
  title="Protege Colitas — Reuniendo mascotas con sus familias | Venezuela 2026"
  description="Plataforma de emergencia para reunir mascotas perdidas con sus familias tras el terremoto de Venezuela del 25 de junio de 2026."
>
  <Header />
  <main>
    <div class="home-wrap">
      <GlobalStats />
      <QuickActions />
      <LiveFeed />
      <div class="grid-2col">
        <PetsFoundCarousel />
        <PetsLostCarousel />
      </div>
      <div class="grid-3col">
        <div class="col-main"><UrgentNeeds /></div>
        <div class="col-side"><VetsList /></div>
      </div>
      <HelpCenters />
      <div class="grid-3col">
        <div class="col-main"><HopeStories /></div>
        <div class="col-side"><NewsSection /></div>
      </div>
    </div>
    <ShareCTA />
  </main>
  <Footer />
</BaseLayout>

<style>
.home-wrap {
  max-width: 80rem;
  margin: 0 auto;
  padding: 1.5rem 1rem;
  display: flex;
  flex-direction: column;
  gap: 3rem;
}
@media (min-width: 768px) {
  .home-wrap { padding: 2rem; }
}
.grid-2col {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2rem;
}
@media (min-width: 1024px) {
  .grid-2col { grid-template-columns: 1fr 1fr; }
}
.grid-3col {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2rem;
}
@media (min-width: 1024px) {
  .grid-3col { grid-template-columns: 2fr 1fr; }
}
</style>
