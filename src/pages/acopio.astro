---
import Base from '../layouts/Base.astro'

const WA_LLAMADAS = 'https://wa.me/584142494136'
const WA_MENSAJES = 'https://wa.me/584222494136'
const WA_DIRECCION = `${WA_MENSAJES}?text=${encodeURIComponent('Necesito la dirección del centro de acopio')}`
const WA_GENERAL = `${WA_LLAMADAS}?text=${encodeURIComponent('Quiero ser voluntario en Protege Colitas')}`

const items = [
  { icon: '🥫', label: 'Alimento húmedo', note: 'Para perros y gatos' },
  { icon: '🩹', label: 'Gasas', note: 'Para tratar heridas' },
  { icon: '🩺', label: 'Vendas', note: 'Para heridas y lesiones' },
  { icon: '💊', label: 'Cremas antibiótico', note: 'Cualquier presentación' },
  { icon: '🧴', label: 'Cremas cicatrizantes', note: 'Cualquier presentación' },
  { icon: '💧', label: 'Solución salina 0.9%', note: 'Para limpiar heridas' },
  { icon: '🚰', label: 'Agua', note: 'Botellones o botellas' },
  { icon: '🧣', label: 'Cobijas', note: 'Para abrigo de los animales' },
  { icon: '🛏️', label: 'Sábanas', note: 'Para camillas y colchonetas' },
]
---
<Base title="Centro de Acopio — Protege Colitas">
  <div class="page">
    <header class="page-header">
      <a href="/" class="back-btn" aria-label="Volver al inicio">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M12 4L6 10l6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <div class="header-text">
        <span class="brand">Protege Colitas</span>
      </div>
    </header>

    <main class="content">
      <div class="hero-section">
        <h1 class="page-title">Centro de acopio<br /><em>· Rita Ferrer</em></h1>
        <p class="page-sub">Punto de recepción de donaciones para mascotas afectadas.</p>
      </div>

      <!-- Ubicación -->
      <section class="location-card">
        <div class="location-icon" aria-hidden="true">📍</div>
        <div class="location-body">
          <span class="location-label">Rita Ferrer · Centro de Acopio</span>
          <p class="location-address">Urb. El Marqués, Caracas</p>
          <a href="https://wa.me/584222494136" class="location-wa-num" target="_blank" rel="noopener noreferrer">📱 0422-2494136</a>
          <div class="location-horario">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>Lunes a Domingo · 6:00 AM – 10:00 PM</span>
          </div>
          <a href={WA_DIRECCION} class="btn-ubicacion" target="_blank" rel="noopener noreferrer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.119.553 4.107 1.516 5.836L.057 23.447a.5.5 0 00.611.612l5.638-1.471A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.891 0-3.666-.5-5.197-1.373l-.371-.22-3.847 1.003 1.022-3.737-.242-.384A9.942 9.942 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
            Ver ubicación por WhatsApp
          </a>
        </div>
      </section>

      <!-- Qué traer -->
      <section class="items-section">
        <h2 class="section-title">¿Qué traer?</h2>
        <p class="section-sub">Todo suma. Trae lo que puedas.</p>
        <ul class="items-list" role="list">
          {items.map((item) => (
            <li class="item-row">
              <span class="item-icon" aria-hidden="true">{item.icon}</span>
              <div class="item-text">
                <span class="item-label">{item.label}</span>
                <span class="item-note">{item.note}</span>
              </div>
            </li>
          ))}
        </ul>
      </section>

      <!-- Pago Móvil -->
      <section class="pagomovil-card">
        <div class="pm-header">
          <span class="pm-icon" aria-hidden="true">💳</span>
          <div>
            <h3 class="pm-title">Pago Móvil BDV</h3>
            <p class="pm-sub">Dona desde donde estés</p>
          </div>
        </div>
        <dl class="pm-data">
          <div class="pm-row">
            <dt>Teléfono</dt>
            <dd>04142494136</dd>
          </div>
          <div class="pm-row">
            <dt>Cédula</dt>
            <dd>V-11232469</dd>
          </div>
          <div class="pm-row">
            <dt>Banco</dt>
            <dd>BDV (0102)</dd>
          </div>
        </dl>
      </section>

      <!-- Voluntarios -->
      <section class="volunteer-section">
        <div class="volunteer-header">
          <h2 class="section-title">¿Quieres ser<br /><em>voluntario?</em></h2>
          <p class="section-sub">Necesitamos personas en el centro de acopio. Cualquier ayuda importa.</p>
        </div>

        <form id="volForm" class="vol-form" novalidate>
          <div class="field-group">
            <label class="field-label" for="vol-nombre">
              Tu nombre <span class="field-req" aria-hidden="true">*</span>
            </label>
            <input type="text" id="vol-nombre" name="nombre" class="form-input" placeholder="¿Cómo te llamamos?" autocomplete="given-name" required />
            <p class="field-error" id="err-vol-nombre" role="alert"></p>
          </div>

          <div class="field-group">
            <label class="field-label" for="vol-zona">
              Tu zona <span class="field-req" aria-hidden="true">*</span>
            </label>
            <input type="text" id="vol-zona" name="zona" class="form-input" placeholder="Ej: Porlamar, Pampatar…" autocomplete="off" required />
            <p class="field-error" id="err-vol-zona" role="alert"></p>
          </div>

          <div class="field-group">
            <label class="field-label" for="vol-disponibilidad">
              Disponibilidad
              <span class="field-note">Opcional</span>
            </label>
            <input type="text" id="vol-disponibilidad" name="disponibilidad" class="form-input" placeholder="Ej: Fines de semana, tardes…" autocomplete="off" />
          </div>

          <div class="field-group">
            <label class="field-label" for="vol-whatsapp">
              Tu WhatsApp <span class="field-req" aria-hidden="true">*</span>
              <span class="field-note">04XX-XXXXXXX</span>
            </label>
            <div class="wa-input-wrap" id="volWaWrap">
              <span class="wa-prefix" aria-hidden="true">🇻🇪</span>
              <input type="tel" id="vol-whatsapp" name="whatsapp" class="form-input wa-input" placeholder="04141234567" maxlength="11" autocomplete="tel" inputmode="numeric" required />
              <span class="wa-status" id="volWaStatus" aria-live="polite"></span>
            </div>
            <p class="field-error" id="err-vol-whatsapp" role="alert"></p>
          </div>

          <button type="submit" class="btn-submit" id="volSubmit">
            <span id="volBtnLabel">Quiero ser voluntario</span>
            <span id="volSpinner" class="spinner" aria-hidden="true" style="display:none"></span>
          </button>
          <p class="field-error form-error" id="volFormError" role="alert"></p>
        </form>

        <div id="volSuccess" class="success-banner" style="display:none" role="status">
          <span class="success-icon" aria-hidden="true">✓</span>
          <div>
            <strong>¡Gracias por ofrecerte!</strong>
            <p>Te contactamos pronto por WhatsApp para coordinar.</p>
          </div>
        </div>
      </section>

      <!-- WA fijo -->
      <div class="wa-footer">
        <a href={WA_GENERAL} class="btn-wa-general" target="_blank" rel="noopener noreferrer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.119.553 4.107 1.516 5.836L.057 23.447a.5.5 0 00.611.612l5.638-1.471A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.891 0-3.666-.5-5.197-1.373l-.371-.22-3.847 1.003 1.022-3.737-.242-.384A9.942 9.942 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
          WhatsApp 0414-2494136
        </a>
      </div>
    </main>
  </div>
</Base>

<style>
.page { min-height: 100dvh; display: flex; flex-direction: column; }

.page-header {
  display: flex; align-items: center; gap: 12px;
  padding: 14px 16px;
  background: var(--blanco); border-bottom: 1px solid var(--border);
  position: sticky; top: 0; z-index: 20;
}
.back-btn {
  width: 44px; height: 44px; display: flex; align-items: center; justify-content: center;
  border-radius: 10px; background: var(--gris-bg); color: var(--marron);
  text-decoration: none; transition: background .15s;
}
.back-btn:hover { background: var(--border); }
.brand { font-family: 'Fredoka', sans-serif; font-weight: 700; font-size: 17px; color: var(--marron); }

.content { padding: 0 16px 100px; max-width: 600px; margin: 0 auto; width: 100%; }

.hero-section { padding: 28px 0 24px; }
.page-title {
  font-family: 'Fredoka', sans-serif; font-weight: 700;
  font-size: clamp(28px, 7vw, 40px); line-height: 1.05;
  color: var(--marron); margin-bottom: 8px; text-wrap: balance;
}
.page-title em { font-style: normal; color: var(--amarillo); }
.page-sub { font-size: 15px; color: var(--gris-txt); }

/* Ubicación */
.location-card {
  background: var(--blanco); border-radius: 16px;
  border: 1.5px solid var(--border);
  padding: 20px 16px; display: flex; gap: 14px;
  margin-bottom: 32px;
}
.location-icon { font-size: 28px; flex-shrink: 0; margin-top: 2px; }
.location-body { flex: 1; display: flex; flex-direction: column; gap: 8px; }
.location-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--gris-txt); }
.location-address { font-size: 15px; font-weight: 600; color: var(--marron); line-height: 1.4; }
.location-horario { display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--gris-txt); }
.location-wa-num {
  display: inline-flex; align-items: center; gap: 4px;
  font-size: 15px; font-weight: 700; color: #25D366;
  text-decoration: none; letter-spacing: .01em;
}
.btn-ubicacion {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 11px 16px; border-radius: 12px;
  background: #25D366; color: #fff;
  font-size: 13px; font-weight: 700; text-decoration: none;
  min-height: 44px; margin-top: 4px;
  transition: opacity .15s; align-self: flex-start;
}
.btn-ubicacion:hover { opacity: .9; }

/* Qué traer */
.items-section { margin-bottom: 36px; }
.section-title {
  font-family: 'Fredoka', sans-serif; font-weight: 700;
  font-size: clamp(20px, 5vw, 26px); color: var(--marron);
  margin-bottom: 4px; line-height: 1.2; text-wrap: balance;
}
.section-title em { font-style: normal; color: var(--amarillo); }
.section-sub { font-size: 14px; color: var(--gris-txt); margin-bottom: 16px; }

.items-list { list-style: none; display: flex; flex-direction: column; gap: 2px; }
.item-row {
  display: flex; align-items: center; gap: 12px;
  padding: 12px 14px; border-radius: 12px;
  background: var(--blanco); border: 1px solid var(--border);
  transition: border-color .15s;
}
.item-row:hover { border-color: var(--amarillo); }
.item-icon { font-size: 22px; flex-shrink: 0; width: 28px; text-align: center; }
.item-text { display: flex; flex-direction: column; gap: 2px; }
.item-label { font-size: 14px; font-weight: 700; color: var(--marron); }
.item-note { font-size: 12px; color: var(--gris-txt); }

/* Voluntarios */
.volunteer-section { border-top: 1px solid var(--border); padding-top: 32px; }
.volunteer-header { margin-bottom: 22px; }

.vol-form { display: flex; flex-direction: column; gap: 18px; }
.field-group { display: flex; flex-direction: column; gap: 6px; }
.field-label {
  font-size: 13px; font-weight: 700; color: var(--marron);
  display: flex; align-items: center; gap: 4px; flex-wrap: wrap;
}
.field-req { color: var(--rojo); font-size: 14px; }
.field-note { font-size: 11px; font-weight: 500; color: var(--gris-txt); }
.form-input {
  width: 100%; padding: 13px 14px;
  border: 1.5px solid var(--border); border-radius: 12px;
  background: var(--blanco);
  font-family: 'Inter', sans-serif; font-size: 15px; color: var(--negro, #1A1A1A);
  outline: none; transition: border-color .15s;
  -webkit-appearance: none; appearance: none;
}
.form-input:focus { border-color: var(--marron); }
.form-input.error { border-color: var(--rojo); }

.wa-input-wrap {
  display: flex; align-items: center;
  border: 1.5px solid var(--border); border-radius: 12px;
  background: var(--blanco); overflow: hidden; transition: border-color .15s;
}
.wa-input-wrap:focus-within { border-color: var(--marron); }
.wa-input-wrap.valid { border-color: var(--verde); }
.wa-input-wrap.invalid { border-color: var(--rojo); }
.wa-prefix { padding: 0 10px 0 14px; font-size: 18px; flex-shrink: 0; }
.wa-input { flex: 1; border: none !important; border-radius: 0 !important; padding: 13px 0; background: transparent; }
.wa-input:focus { border: none; }
.wa-status { padding: 0 12px; font-size: 16px; flex-shrink: 0; }

.btn-submit {
  width: 100%; height: 54px;
  background: var(--marron); color: #fff; border: none; border-radius: 14px;
  font-family: 'Inter', sans-serif; font-size: 16px; font-weight: 700;
  cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px;
  transition: opacity .15s, transform .1s; -webkit-tap-highlight-color: transparent;
}
.btn-submit:disabled { opacity: .6; cursor: not-allowed; }
.btn-submit:active:not(:disabled) { transform: scale(.98); }
.spinner {
  width: 20px; height: 20px;
  border: 2.5px solid rgba(255,255,255,.35); border-top-color: #fff;
  border-radius: 50%; animation: spin .7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.field-error { font-size: 12px; font-weight: 600; color: var(--rojo); min-height: 16px; }
.form-error { font-size: 13px; text-align: center; padding: 10px; background: #fef2f2; border-radius: 10px; }

.success-banner {
  display: flex; align-items: flex-start; gap: 12px;
  padding: 16px; border-radius: 14px;
  background: #f0fdf4; border: 1.5px solid #bbf7d0; margin-top: 8px;
}
.success-icon {
  width: 32px; height: 32px; border-radius: 50%;
  background: var(--verde); color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 16px; font-weight: 700; flex-shrink: 0;
}
.success-banner strong { display: block; font-size: 15px; color: var(--verde); margin-bottom: 4px; }
.success-banner p { font-size: 13px; color: #166534; }

.wa-footer { margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--border); display: flex; justify-content: center; }
.btn-wa-general {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 14px 24px; border-radius: 14px;
  background: #25D366; color: #fff;
  font-size: 15px; font-weight: 700; text-decoration: none;
  min-height: 52px; transition: opacity .15s;
}
.btn-wa-general:hover { opacity: .9; }

@media (prefers-reduced-motion: reduce) {
  .spinner { animation: none; }
}

/* Pago Móvil */
.pagomovil-card {
  background: var(--blanco); border-radius: 16px;
  border: 1.5px solid var(--border);
  padding: 20px 16px; margin-bottom: 36px;
}
.pm-header { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
.pm-icon { font-size: 28px; }
.pm-title {
  font-family: 'Fredoka', sans-serif; font-weight: 700;
  font-size: 17px; color: var(--marron); margin: 0 0 2px;
}
.pm-sub { font-size: 13px; color: var(--gris-txt); margin: 0; }
.pm-data { display: flex; flex-direction: column; gap: 0; margin: 0; }
.pm-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 10px 0; border-bottom: 1px solid var(--border);
}
.pm-row:last-child { border-bottom: none; }
.pm-row dt { font-size: 13px; color: var(--gris-txt); font-weight: 500; }
.pm-row dd { font-size: 15px; font-weight: 700; color: var(--marron); margin: 0; }
</style>

<script>
(function () {
  const WA_RE = /^04[0-9]{2}[0-9]{7}$/
  const form = document.getElementById('volForm')
  const waInput = document.getElementById('vol-whatsapp')
  const waWrap = document.getElementById('volWaWrap')
  const waStatus = document.getElementById('volWaStatus')
  const btnSubmit = document.getElementById('volSubmit')
  const btnLabel = document.getElementById('volBtnLabel')
  const spinner = document.getElementById('volSpinner')
  const formError = document.getElementById('volFormError')
  const successBanner = document.getElementById('volSuccess')

  if (!form || !waInput || !waWrap) return

  waInput.addEventListener('input', () => {
    const val = waInput.value.replace(/\D/g, '').slice(0, 11)
    waInput.value = val
    if (!val) {
      waWrap.classList.remove('valid', 'invalid'); waStatus.textContent = ''
    } else if (WA_RE.test(val)) {
      waWrap.classList.remove('invalid'); waWrap.classList.add('valid')
      waStatus.textContent = '✓'; clearErr('vol-whatsapp')
    } else {
      waWrap.classList.remove('valid'); waWrap.classList.add('invalid')
      waStatus.textContent = ''
    }
  })

  function setErr(id, msg) {
    const el = document.getElementById('err-' + id)
    const inp = document.getElementById(id)
    if (el) el.textContent = msg
    if (inp) inp.classList.add('error')
  }
  function clearErr(id) {
    const el = document.getElementById('err-' + id)
    const inp = document.getElementById(id)
    if (el) el.textContent = ''
    if (inp) inp.classList.remove('error')
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    formError.textContent = ''
    ;['vol-nombre','vol-zona','vol-whatsapp'].forEach(clearErr)

    let ok = true
    const nombre = document.getElementById('vol-nombre').value.trim()
    if (!nombre) { setErr('vol-nombre', '¿Cómo te llamamos?'); ok = false }
    const zona = document.getElementById('vol-zona').value.trim()
    if (zona.length < 5) { setErr('vol-zona', 'Escribe la zona (mínimo 5 caracteres)'); ok = false }
    const wa = waInput.value.trim()
    if (!WA_RE.test(wa)) { setErr('vol-whatsapp', 'Número venezolano: 04XX + 7 dígitos'); ok = false }
    if (!ok) return

    btnSubmit.disabled = true
    btnLabel.style.display = 'none'
    spinner.style.display = ''

    const payload = {
      nombre,
      zona,
      disponibilidad: document.getElementById('vol-disponibilidad').value.trim() || null,
      whatsapp: wa
    }

    try {
      const res = await fetch('/api/voluntarios', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      })
      const data = await res.json().catch(() => ({}))
      if (!res.ok) throw new Error(data.error || 'Error al enviar. Intenta de nuevo.')
      form.style.display = 'none'
      successBanner.style.display = 'flex'
    } catch (err) {
      formError.textContent = err.message
      btnSubmit.disabled = false
      btnLabel.style.display = ''
      spinner.style.display = 'none'
    }
  })
})()
</script>
