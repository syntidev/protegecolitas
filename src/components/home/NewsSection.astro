---
import { supabase } from '../../lib/supabase'

const { data: notas } = await supabase
  .from('feed')
  .select('id, titulo, cuerpo, tipo, published_at')
  .order('published_at', { ascending: false })
  .limit(4)

type TipoCfg = { bg: string; stroke: string; pathD: string }
const TIPO: Record<string, TipoCfg> = {
  alerta:  { bg: 'var(--rojo-bg,#fee2e2)', stroke: 'var(--rojo)',   pathD: 'M22 12h-4l-3 9L9 3l-3 9H2' },
  rescate: { bg: 'var(--azul-bg)',          stroke: 'var(--azul)',   pathD: 'M22 12h-4l-3 9L9 3l-3 9H2' },
  buenas:  { bg: 'var(--verde-bg)',         stroke: 'var(--verde)',  pathD: 'M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z' },
  info:    { bg: 'var(--arena)',            stroke: 'var(--marron)', pathD: 'M12 2a10 10 0 100 20A10 10 0 0012 2zm0 9v4m0 4h.01' },
}

function fmtDate(d: string): { day: string; month: string } {
  const dt = new Date(d)
  return {
    day:   dt.getDate().toString(),
    month: dt.toLocaleDateString('es-VE', { month: 'short' }).toUpperCase().slice(0, 3),
  }
}
---
<section aria-labelledby="news-heading">
  <div class="section-header">
    <h2 id="news-heading" class="section-title">Noticias y actualizaciones</h2>
    <a href="/noticias" class="view-all">Ver todas</a>
  </div>

  {!notas?.length ? (
    <div class="news-list">
      <div class="news-item">
        <div class="news-date">
          <span class="date-day">25</span>
          <span class="date-month">JUN</span>
        </div>
        <div class="news-body">
          <div class="news-icon" style="background: var(--arena)" aria-hidden="true">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--marron)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
          </div>
          <div>
            <p class="news-title">Plataforma Protege Colitas en operación</p>
            <p class="news-desc">Activa 24 horas después del terremoto del 25 de junio.</p>
          </div>
        </div>
      </div>
    </div>
  ) : (
    <div class="news-list">
      {notas.map((n) => {
        const cfg = TIPO[n.tipo] ?? TIPO.info
        const { day, month } = n.published_at ? fmtDate(n.published_at) : { day: '–', month: '–' }
        return (
          <div class="news-item">
            <div class="news-date">
              <span class="date-day">{day}</span>
              <span class="date-month">{month}</span>
            </div>
            <div class="news-body">
              <div class="news-icon" style={`background: ${cfg.bg}`} aria-hidden="true">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke={cfg.stroke} stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d={cfg.pathD} />
                </svg>
              </div>
              <div>
                <p class="news-title">{n.titulo}</p>
                <p class="news-desc">{n.cuerpo}</p>
              </div>
            </div>
          </div>
        )
      })}
    </div>
  )}
</section>

<style>
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1rem;
}
.section-title {
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--texto);
  margin: 0;
}
.view-all {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--accion);
  text-decoration: none;
}
.view-all:hover { color: var(--accion-hover); }

.news-list {
  background: var(--card);
  border-radius: 1rem;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  overflow: hidden;
}
.news-item {
  display: flex;
  gap: 1rem;
  padding: 1rem;
  align-items: flex-start;
  border-bottom: 1px solid #F3EDE6;
  transition: background .15s;
}
.news-item:last-child { border-bottom: none; }
.news-item:hover { background: var(--fondo); }

.news-date {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  width: 40px;
}
.date-day {
  font-family: 'Nunito', 'Inter', sans-serif;
  font-weight: 800;
  font-size: 1.25rem;
  color: var(--marron);
  line-height: 1;
}
.date-month {
  font-size: 0.6875rem;
  font-weight: 700;
  color: var(--accion);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.news-body {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: flex-start;
  gap: 0.5rem;
}
.news-icon {
  width: 24px;
  height: 24px;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 1px;
}
.news-title {
  font-weight: 600;
  font-size: 0.875rem;
  color: var(--texto);
  line-height: 1.3;
  margin: 0 0 2px;
}
.news-desc {
  font-size: 0.75rem;
  color: var(--texto-sec);
  margin: 0;
}
</style>
