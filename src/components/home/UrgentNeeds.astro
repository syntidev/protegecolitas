---
// TODO: conectar con Supabase tabla necesidades
const centers = [
  {
    name: 'Centro de Acopio Caracas',
    location: 'Av. Principal Las Mercedes',
    needs: [
      { label: 'Alimento seco', pct: 80 },
      { label: 'Agua',          pct: 65 },
      { label: 'Antipulgas',    pct: 30 },
      { label: 'Mantas',        pct: 45 },
    ],
  },
  {
    name: 'Refugio Patas Seguras',
    location: 'La California, Miranda',
    needs: [
      { label: 'Alimento seco',  pct: 60 },
      { label: 'Medicinas',      pct: 25 },
      { label: 'Agua',           pct: 70 },
      { label: 'Transportadores',pct: 15 },
    ],
  },
  {
    name: 'Centro de Acopio Miranda',
    location: 'Los Teques, Miranda',
    needs: [
      { label: 'Alimento seco', pct: 40 },
      { label: 'Mantas',        pct: 20 },
      { label: 'Medicinas',     pct: 35 },
      { label: 'Collares',      pct: 50 },
    ],
  },
]

function barColor(pct: number) {
  if (pct > 70) return '#34A853'
  if (pct > 40) return '#F59E0B'
  return '#E5484D'
}
---
<section aria-labelledby="urgent-needs-heading">
  <div class="section-header">
    <h2 id="urgent-needs-heading" class="section-title">Necesidades urgentes</h2>
    <a href="/insumos" class="view-all">Ver todas</a>
  </div>
  <div class="grid-3">
    {centers.map((center) => (
      <div class="needs-card">
        <div class="center-meta">
          <div class="center-icon" aria-hidden="true">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--marron)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="7" width="9" height="14"/>
              <rect x="13" y="3" width="9" height="18"/>
              <line x1="2" y1="21" x2="22" y2="21"/>
            </svg>
          </div>
          <div>
            <h3 class="center-name">{center.name}</h3>
            <div class="center-loc">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <span>{center.location}</span>
            </div>
          </div>
        </div>
        <div class="needs-list">
          {center.needs.map((need) => (
            <div class="need-row">
              <div class="need-labels">
                <span class="need-label">{need.label}</span>
                <span class="need-pct">{need.pct}%</span>
              </div>
              <div class="progress-track">
                <div
                  class="progress-bar"
                  style={`width: ${need.pct}%; background: ${barColor(need.pct)}`}
                  role="progressbar"
                  aria-valuenow={need.pct}
                  aria-valuemin={0}
                  aria-valuemax={100}
                  aria-label={`${need.label}: ${need.pct}% cubierto`}
                ></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1rem;
}
.section-title {
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--texto);
  margin: 0;
}
.view-all {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--accion);
  text-decoration: none;
}
.view-all:hover { color: var(--accion-hover); }
.needs-card {
  background: var(--card);
  border-radius: 1rem;
  padding: 1.25rem;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
}
.center-meta {
  display: flex;
  align-items: flex-start;
  gap: 0.625rem;
  margin-bottom: 1rem;
}
.center-icon {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  background: var(--arena);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 1px;
}
.center-name {
  font-weight: 600;
  font-size: 0.875rem;
  color: var(--texto);
  line-height: 1.3;
  margin: 0 0 2px;
}
.center-loc {
  display: flex;
  align-items: center;
  gap: 3px;
  color: var(--texto-muted);
  font-size: 0.6875rem;
}
.needs-list { display: flex; flex-direction: column; gap: 0.75rem; }
.need-labels {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4px;
}
.need-label {
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--texto);
}
.need-pct { font-size: 0.75rem; color: var(--texto-muted); }
.progress-track {
  width: 100%;
  height: 6px;
  background: #F3EDE6;
  border-radius: 9999px;
  overflow: hidden;
}
.progress-bar {
  height: 100%;
  border-radius: 9999px;
  transition: width .3s ease;
}
</style>
