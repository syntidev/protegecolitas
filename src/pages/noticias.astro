---
import Base from '../layouts/Base.astro'
import { supabase } from '../lib/supabase'

const { data: notas } = await supabase
  .from('feed')
  .select('id, titulo, cuerpo, tipo, published_at')
  .order('published_at', { ascending: false })
  .neq('tipo', 'voluntario')

function tiempoRelativo(dateStr: string): string {
  if (!dateStr) return ''
  const ahora = Date.now()
  const pub = new Date(dateStr).getTime()
  const diff = Math.floor((ahora - pub) / 1000)
  if (diff < 60) return 'Hace un momento'
  if (diff < 3600) return `Hace ${Math.floor(diff / 60)} min`
  if (diff < 86400) return `Hace ${Math.floor(diff / 3600)} h`
  if (diff < 172800) return 'Ayer'
  const d = new Date(dateStr)
  return d.toLocaleDateString('es-VE', { day: 'numeric', month: 'short' })
}

const TIPO_META: Record<string, { label: string; color: string; bg: string; border: string }> = {
  alerta:  { label: 'Alerta',   color: '#DC2626', bg: '#fef2f2', border: '#fecaca' },
  rescate: { label: 'Rescate',  color: '#2563EB', bg: '#eff6ff', border: '#bfdbfe' },
  buenas:  { label: '¡Buenas!', color: '#16A34A', bg: '#f0fdf4', border: '#bbf7d0' },
  info:    { label: 'Info',     color: '#6B7280', bg: '#f9fafb', border: '#e5e7eb' },
}

const BASE_URL = 'https://protegecolitas.org'
---
<Base title="Noticias — Protege Colitas">
  <div class="page-inner">
    <div class="page-hero">
      <h1 class="page-title">Lo que está <em>pasando</em></h1>
      <p class="page-sub">Actualizaciones en tiempo real de la emergencia.</p>
    </div>

    {notas && notas.length > 0 ? (
      <div class="feed-glass">
        {notas.map((nota, i) => {
          const meta = TIPO_META[nota.tipo] ?? TIPO_META['info']
          const d = nota.published_at ? new Date(nota.published_at) : null
          const day = d ? d.getDate().toString().padStart(2, '0') : '--'
          const mon = d
            ? d.toLocaleDateString('es-VE', { month: 'short' }).toUpperCase().replace('.', '')
            : '---'
          const isLast = i === notas.length - 1
          return (
            <div class:list={['feed-item', { 'feed-item--last': isLast }]}>
              <div class="feed-date" aria-hidden="true">
                <span class="feed-day">{day}</span>
                <span class="feed-mon">{mon}</span>
              </div>
              <div class="feed-content">
                <span
                  class="feed-badge"
                  style={`color:${meta.color};background:${meta.bg};border:1px solid ${meta.border}`}
                >
                  {meta.label}
                </span>
                <h2 class="feed-title">{nota.titulo}</h2>
                <p class="feed-body">{nota.cuerpo}</p>
                <span class="feed-time">{tiempoRelativo(nota.published_at)}</span>
              </div>
            </div>
          )
        })}
      </div>
    ) : (
      <div class="empty-state">
        <span class="empty-icon">📋</span>
        <p class="empty-msg">Sin actualizaciones aún</p>
      </div>
    )}
  </div>
</Base>

<style>
.page-inner {
  max-width: 640px;
  margin: 0 auto;
  padding: 24px 16px;
  width: 100%;
}

.page-hero {
  padding-bottom: 24px;
}

.page-title {
  font-family: 'Fredoka', sans-serif;
  font-weight: 700;
  font-size: clamp(28px, 7vw, 40px);
  line-height: 1.05;
  color: var(--marron, #3D1C02);
  margin-bottom: 8px;
  text-wrap: balance;
}
.page-title em {
  font-style: normal;
  color: var(--amarillo, #F5A623);
}

.page-sub {
  font-family: 'Inter', sans-serif;
  font-size: 15px;
  color: var(--gris, #6B7280);
  line-height: 1.5;
}

/* Glass container */
.feed-glass {
  background: rgba(255, 255, 255, 0.75);
  backdrop-filter: blur(16px) saturate(180%);
  -webkit-backdrop-filter: blur(16px) saturate(180%);
  border: 1px solid rgba(255, 255, 255, 0.9);
  border-radius: 18px;
  box-shadow: 0 8px 32px rgba(61, 28, 2, 0.10);
  padding: 0 20px;
}

/* Feed items */
.feed-item {
  display: flex;
  gap: 16px;
  padding: 18px 0;
  border-bottom: 1px solid rgba(61, 28, 2, 0.08);
  align-items: flex-start;
}
.feed-item--last {
  border-bottom: none;
}

.feed-date {
  flex-shrink: 0;
  width: 52px;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 2px;
}

.feed-day {
  font-family: 'Fredoka', sans-serif;
  font-weight: 700;
  font-size: 24px;
  color: var(--amarillo, #F5A623);
  line-height: 1;
  display: block;
}

.feed-mon {
  font-family: 'Inter', sans-serif;
  font-weight: 700;
  font-size: 10px;
  color: var(--gris, #6B7280);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  display: block;
  margin-top: 2px;
}

.feed-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.feed-badge {
  font-family: 'Inter', sans-serif;
  font-weight: 700;
  font-size: 10px;
  padding: 3px 8px;
  border-radius: 20px;
  display: inline-flex;
  align-items: center;
  margin-bottom: 6px;
  letter-spacing: 0.03em;
}

.feed-title {
  font-family: 'Inter', sans-serif;
  font-weight: 600;
  font-size: 15px;
  color: var(--marron, #3D1C02);
  margin: 0 0 4px 0;
  line-height: 1.35;
}

.feed-body {
  font-family: 'Inter', sans-serif;
  font-weight: 400;
  font-size: 13px;
  color: var(--gris, #6B7280);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin: 0 0 6px 0;
}

.feed-time {
  font-family: 'Inter', sans-serif;
  font-weight: 400;
  font-size: 12px;
  color: var(--gris, #6B7280);
}

/* Empty state */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64px 20px;
  text-align: center;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 16px;
  display: block;
}

.empty-msg {
  font-family: 'Fredoka', sans-serif;
  font-weight: 700;
  font-size: 20px;
  color: var(--marron, #3D1C02);
  margin: 0;
}
</style>
