---
// TODO: conectar con Supabase — datos reales de mascotas, vets, centros
---
<section aria-labelledby="stats-heading">
  <h2 id="stats-heading" class="sr-only">Estadísticas globales de la emergencia</h2>
  <div class="stats-grid">

    <div class="stat-card">
      <div class="stat-icon" style="background: var(--fondo)">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--accion)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </div>
      <div class="stat-num" style="color: var(--marron)">487</div>
      <div class="stat-label">Mascotas reportadas</div>
    </div>

    <div class="stat-card">
      <div class="stat-icon" style="background: var(--verde-bg)">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--verde)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
      </div>
      <div class="stat-num" style="color: var(--verde)">162</div>
      <div class="stat-label">Encontradas</div>
    </div>

    <div class="stat-card">
      <div class="stat-icon" style="background: var(--rosa-bg)">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="var(--rosa)" stroke="var(--rosa)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
        </svg>
      </div>
      <div class="stat-num" style="color: var(--rosa)">78</div>
      <div class="stat-label">Reunidas con su familia</div>
    </div>

    <div class="stat-card">
      <div class="stat-icon" style="background: var(--azul-bg)">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--azul)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
        </svg>
      </div>
      <div class="stat-num" style="color: var(--azul)">43</div>
      <div class="stat-label">Veterinarios voluntarios</div>
    </div>

    <div class="stat-card stat-wide">
      <div class="stat-icon" style="background: var(--arena)">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--marron)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="7" width="9" height="14"/>
          <rect x="13" y="3" width="9" height="18"/>
          <line x1="2" y1="21" x2="22" y2="21"/>
        </svg>
      </div>
      <div class="stat-num" style="color: var(--marron)">12</div>
      <div class="stat-label">Centros de acopio activos</div>
    </div>

  </div>
</section>

<style>
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.75rem;
}
@media (min-width: 768px) {
  .stats-grid { grid-template-columns: repeat(5, 1fr); gap: 1rem; }
}
.stat-card {
  background: var(--card);
  border-radius: 1rem;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  padding: 1rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}
.stat-wide { grid-column: span 2; }
@media (min-width: 768px) { .stat-wide { grid-column: span 1; } }
.stat-icon {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 0.625rem;
  flex-shrink: 0;
}
.stat-num {
  font-family: 'Nunito', 'Inter', sans-serif;
  font-weight: 800;
  font-size: 1.75rem;
  line-height: 1;
}
@media (min-width: 768px) { .stat-num { font-size: 2rem; } }
.stat-label {
  font-size: 0.6875rem;
  color: var(--texto-sec);
  margin-top: 3px;
  line-height: 1.3;
}
</style>
