---
import { supabase } from '../../lib/supabase'

const { data: mascotas } = await supabase
  .from('mascotas')
  .select('id, nombre, especie, descripcion, zona, foto_url')
  .eq('status', 'reunido')
  .limit(3)
---
<section aria-labelledby="hope-stories-heading">
  <div class="section-header">
    <h2 id="hope-stories-heading" class="section-title">Historias de reencuentro</h2>
    <a href="/mascotas" class="view-all">Ver todas</a>
  </div>

  {!mascotas?.length ? (
    <p class="empty-msg">Los reencuentros vienen. Cada reporte acerca a las familias.</p>
  ) : (
    <div class="carousel-container">
      {mascotas.map((m) => (
        <div class="carousel-item story-card">
          <div class="story-img-wrap">
            {m.foto_url
              ? <img src={m.foto_url} alt={m.nombre ?? m.especie} class="story-img" loading="lazy" />
              : <div class="story-img" style="display:flex;align-items:center;justify-content:center;background:var(--arena);font-size:3rem;" aria-hidden="true">🐾</div>
            }
            <span class="story-badge">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="#15803d" stroke="none" aria-hidden="true">
                <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
              </svg>
              Reunidos
            </span>
          </div>
          <div class="story-body">
            <h3 class="story-title">{m.nombre ?? m.especie ?? 'Mascota reunida'}</h3>
            <div class="story-location">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <span>{m.zona}</span>
            </div>
            <p class="story-text">
              {m.descripcion ?? 'Reunida con su familia gracias a la comunidad de Protege Colitas.'}
            </p>
            <a href={`/mascota/${m.id}`} class="story-link">Ver historia</a>
          </div>
        </div>
      ))}
    </div>
  )}
</section>

<style>
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1rem;
}
.section-title {
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--texto);
  margin: 0;
}
.view-all {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--accion);
  text-decoration: none;
}
.view-all:hover { color: var(--accion-hover); }

.empty-msg {
  font-size: 0.875rem;
  color: var(--texto-sec);
  text-align: center;
  padding: 2rem;
  background: var(--card);
  border-radius: 1rem;
}

.story-card {
  background: var(--card);
  border-radius: 1rem;
  overflow: hidden;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  width: 85vw;
  max-width: 24rem;
  flex-shrink: 0;
}
@media (min-width: 480px) { .story-card { width: calc(50vw - 2rem); } }
@media (min-width: 1024px) { .story-card { width: 20rem; } }

.story-img-wrap { position: relative; }
.story-img {
  width: 100%;
  aspect-ratio: 4/3;
  object-fit: cover;
  display: block;
}
.story-badge {
  position: absolute;
  top: 12px;
  left: 12px;
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: rgba(255,255,255,0.9);
  color: #15803d;
  font-size: 0.6875rem;
  font-weight: 700;
  padding: 4px 10px;
  border-radius: 9999px;
  backdrop-filter: blur(4px);
}
.story-body { padding: 1rem; }
.story-title {
  font-weight: 600;
  color: var(--texto);
  line-height: 1.3;
  margin: 0 0 6px;
}
.story-location {
  display: flex;
  align-items: center;
  gap: 4px;
  color: var(--texto-muted);
  font-size: 0.6875rem;
  margin-bottom: 8px;
}
.story-text {
  font-size: 0.875rem;
  color: var(--texto-sec);
  line-height: 1.5;
  margin: 0 0 0.75rem;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.story-link {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--accion);
  text-decoration: none;
}
.story-link:hover { color: var(--accion-hover); }
</style>
