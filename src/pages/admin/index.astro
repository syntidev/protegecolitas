            <label class="modal-field"><span class="modal-lbl">Color</span><input type="text" name="color" id="em-color" class="modal-input" /></label>
            <label class="modal-field"><span class="modal-lbl">Tamaño</span><select name="tamanio" id="em-tamanio" class="modal-input"><option value="">— sin especificar —</option><option value="Pequeño">Pequeño</option><option value="Mediano">Mediano</option><option value="Grande">Grande</option></select></label>
            <label class="modal-field"><span class="modal-lbl">WhatsApp</span><input type="text" name="whatsapp" id="em-whatsapp" class="modal-input" /></label>
            <label class="modal-field modal-field--full"><span class="modal-lbl">Foto principal</span><input type="file" name="foto_nueva_1" id="em-fotonueva1" accept="image/*" class="upload-input" /><small class="modal-hint">Solo si quieres reemplazar la foto</small></label>
            <label class="modal-field"><span class="modal-lbl">Foto 2</span><input type="file" name="foto_nueva_2" id="em-fotonueva2" accept="image/*" class="upload-input" /></label>
            <label class="modal-field"><span class="modal-lbl">Foto 3</span><input type="file" name="foto_nueva_3" id="em-fotonueva3" accept="image/*" class="upload-input" /></label>
            <label class="modal-field modal-field--full"><span class="modal-lbl">Descripción</span><textarea name="descripcion" id="em-descripcion" class="modal-input modal-textarea" rows="3"></textarea></label>
          </div>
          <div class="modal-actions">
            <button type="submit" class="btn-submit">Guardar cambios</button>
            <button type="button" class="modal-cancel btn btn-outline">Cancelar</button>
          </div>
        </form>

        <form id="modal-vet" class="modal-form" style="display:none">
          <input type="hidden" name="action" value="editar_vet" />
          <input type="hidden" name="id" id="ev-id" />
          <div class="modal-grid">
            <label class="modal-field"><span class="modal-lbl">Nombre *</span><input type="text" name="nombre" id="ev-nombre" class="modal-input" required /></label>
            <label class="modal-field"><span class="modal-lbl">Zona *</span><input type="text" name="zona" id="ev-zona" class="modal-input" required /></label>
            <label class="modal-field"><span class="modal-lbl">WhatsApp *</span><input type="text" name="whatsapp" id="ev-whatsapp" class="modal-input" required /></label>
            <label class="modal-field"><span class="modal-lbl">Servicios</span><input type="text" name="servicios" id="ev-servicios" class="modal-input" /></label>
            <label class="modal-field modal-field--full"><span class="modal-lbl">Horario</span><input type="text" name="horario" id="ev-horario" class="modal-input" /></label>
          </div>
          <div class="modal-actions">
            <button type="submit" class="btn-submit">Guardar cambios</button>
            <button type="button" class="modal-cancel btn btn-outline">Cancelar</button>
          </div>
        </form>

        <form id="modal-insumo" class="modal-form" style="display:none">
          <input type="hidden" name="action" value="editar_insumo" />
          <input type="hidden" name="id" id="ei-id" />
          <div class="modal-grid">
            <label class="modal-field modal-field--full"><span class="modal-lbl">Nombre del insumo *</span><input type="text" name="item" id="ei-item" class="modal-input" required /></label>
            <label class="modal-field"><span class="modal-lbl">Cant. recibida</span><input type="number" name="cantidad_recibida" id="ei-recibida" class="modal-input" min="0" /></label>
            <label class="modal-field"><span class="modal-lbl">Cant. requerida *</span><input type="number" name="cantidad_requerida" id="ei-requerida" class="modal-input" min="1" required /></label>
            <label class="modal-field modal-field--full"><span class="modal-lbl">Prioridad</span><select name="prioridad" id="ei-prioridad" class="modal-input"><option value="critico">🔴 Crítico</option><option value="urgente">🟡 Urgente</option><option value="cubierto">🟢 Cubierto</option></select></label>
          </div>
          <div class="modal-actions">
            <button type="submit" class="btn-submit">Guardar cambios</button>
            <button type="button" class="modal-cancel btn btn-outline">Cancelar</button>
          </div>
        </form>

        <form id="modal-feed" class="modal-form" enctype="multipart/form-data" style="display:none">
          <input type="hidden" name="action" value="editar_feed" />
          <input type="hidden" name="id" id="ef-id" />
          <div class="modal-grid">
            <label class="modal-field"><span class="modal-lbl">Tipo</span><select name="tipo" id="ef-tipo" class="modal-input"><option value="info">Info</option><option value="alerta">Alerta</option><option value="rescate">Rescate</option><option value="buenas">Buenas</option><option value="voluntario">Voluntarios</option></select></label>
            <label class="modal-field"><span class="modal-lbl">Título *</span><input type="text" name="titulo" id="ef-titulo" class="modal-input" required maxlength="150" /></label>
            <label class="modal-field modal-field--full"><span class="modal-lbl">Texto *</span><textarea name="cuerpo" id="ef-cuerpo" class="modal-input modal-textarea" rows="4" required></textarea></label>
            <label class="modal-field modal-field--full"><span class="modal-lbl">Imagen nueva (opcional)</span><input type="file" name="feed_img_edit" accept="image/*" class="upload-input" /></label>
          </div>
          <div class="modal-actions">
            <button type="submit" class="btn-submit">Guardar cambios</button>
            <button type="button" class="modal-cancel btn btn-outline">Cancelar</button>
          </div>
        </form>
      </div>
    </div>

  </div>
)}

</body>
</html>

<style>
  :root {
    --bg:        #0C0906;
    --surface:   #1A1210;
    --surface2:  #221A16;
    --border:    rgba(255,255,255,0.08);
    --tx:        #F0E8DE;
    --tx-muted:  rgba(240,232,222,0.50);
    --verde:     #22C55E;
    --rojo:      #EF4444;
    --amarillo:  #F59E0B;
    --azul:      #3B82F6;
    --naranja:   #F97316;
    --morado:    #8B5CF6;
    --esmeralda: #10B981;
    --marron-claro: rgba(107,58,42,0.30);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--tx);
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 13px;
    line-height: 1.5;
    min-height: 100vh;
  }

  /* ── LOGIN ── */
  .login-wrap { min-height:100vh; display:grid; place-items:center; padding:1rem; }
  .login-box {
    background: var(--surface); border:1px solid var(--border); border-radius:12px;
    padding:2rem; width:min(100%,320px); display:flex; flex-direction:column; gap:.75rem;
  }
  .login-title { font-size:1.25rem; font-weight:700; text-align:center; }
  .login-sub   { font-size:.8rem; color:var(--tx-muted); text-align:center; }
  .login-err   { background:rgba(239,68,68,.12); color:var(--rojo); border:1px solid rgba(239,68,68,.35); border-radius:6px; padding:.625rem .875rem; font-size:.8rem; }
  .login-box form { display:flex; flex-direction:column; gap:.625rem; }
  .login-box input {
    background:var(--bg); border:1px solid var(--border); border-radius:6px;
    color:var(--tx); padding:.625rem .875rem; font-size:.875rem; width:100%; font-family:inherit;
  }
  .login-box input:focus { outline:none; border-color:var(--amarillo); }
  .btn-login {
    background:var(--amarillo); color:#1a1a1a; border:none; border-radius:8px;
    padding:.75rem; font-weight:700; font-size:.875rem; cursor:pointer;
  }
  .btn-login:hover { background:#e6b200; }

  /* ── PANEL ── */
  .panel { min-height:100vh; }

  /* ── HEADER ── */
  .hdr {
    display:flex; align-items:center; gap:.75rem; padding:.75rem 1rem;
    background:var(--surface); border-bottom:1px solid var(--border);
    position:sticky; top:0; z-index:10;
  }
  .hdr-left { display:flex; align-items:center; gap:.5rem; }
  .hdr-logo  { font-size:1.25rem; }
  .hdr-title { font-weight:700; font-size:.9rem; color:var(--tx); }
  .hdr-badges { display:flex; gap:.375rem; flex-wrap:wrap; flex:1; }
  .hdr-badge {
    font-size:.7rem; font-weight:600; padding:.2rem .5rem; border-radius:20px;
  }
  .badge-rojo  { background:rgba(239,68,68,.18); color:#f87171; }
  .badge-verde { background:rgba(34,197,94,.18);  color:#4ade80; }
  .badge-azul  { background:rgba(59,130,246,.18); color:#60a5fa; }
  .badge-gris  { background:rgba(255,255,255,.10); color:var(--tx-muted); }
  .hdr-right { display:flex; gap:.5rem; align-items:center; margin-left:auto; }
  .btn-sitio {
    font-size:.75rem; color:var(--amarillo); border:1px solid rgba(245,158,11,.35);
    border-radius:6px; padding:.3rem .7rem; text-decoration:none; white-space:nowrap;
  }
  .btn-sitio:hover { background:rgba(245,158,11,.12); }
  .btn-salir {
    font-size:.75rem; color:var(--tx-muted); border:1px solid var(--border);
    background:transparent; border-radius:6px; padding:.3rem .7rem; cursor:pointer;
    white-space:nowrap;
  }
  .btn-salir:hover { color:var(--rojo); border-color:rgba(239,68,68,.5); }

  /* ── TILE GRID ── */
  #home { padding:.75rem; }
  .tile-grid {
    display:grid;
    grid-template-columns:repeat(2, 1fr);
    gap:.625rem;
    max-width:680px;
    margin:0 auto;
  }
  @media (min-width:560px) {
    .tile-grid { grid-template-columns:repeat(3,1fr); }
    #home { padding:1rem; }
  }
  @media (min-width:800px) {
    .tile-grid { grid-template-columns:repeat(5,1fr); gap:.75rem; }
  }

  .tile {
    min-height:120px; border-radius:16px; border:1px solid rgba(255,255,255,0.10);
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    gap:.3rem; padding:.875rem .5rem; cursor:pointer; background:rgba(255,255,255,0.05);
    transition:transform .15s, background .15s; text-align:center; position:relative;
    font-family:inherit;
  }
  .tile:active { transform:scale(.96); }
  @media (hover:hover) { .tile:hover { transform:scale(1.03); } }
  @media (min-width:560px) { .tile { min-height:140px; } }

  .tile-icon  { font-size:2rem; line-height:1; }
  .tile-label { font-size:.75rem; font-weight:600; color:var(--tx); letter-spacing:.01em; }
  .tile-count { font-size:1.5rem; font-weight:700; color:var(--tx); }
  .tile-sub   { font-size:.65rem; color:var(--tx-muted); }

  .tile-pendiente  { background:rgba(220,38,38,0.14);  border-color:rgba(220,38,38,0.25); }
  .tile-publicadas { background:rgba(107,58,42,0.20);  border-color:rgba(107,58,42,0.40); }
  .tile-adopcion   { background:rgba(37,99,235,0.14);  border-color:rgba(37,99,235,0.30); }
  .tile-agregar    { background:rgba(107,58,42,0.75);  border-color:rgba(245,193,7,0.40); }
  .tile-agregar .tile-label,
  .tile-agregar .tile-sub { color:#F5EDE0; }
  .tile-gemini     { background:rgba(16,185,129,0.12); border-color:rgba(16,185,129,0.30); }
  .tile-vets       { background:rgba(22,163,74,0.12);  border-color:rgba(22,163,74,0.30); }
  .tile-feed       { background:rgba(59,130,246,0.12); border-color:rgba(59,130,246,0.30); }
  .tile-insumos    { background:rgba(245,158,11,0.12); border-color:rgba(245,158,11,0.30); }
  .tile-analiticas { background:rgba(139,92,246,0.12); border-color:rgba(139,92,246,0.30); }
  .tile-banners    { background:rgba(249,115,22,0.12); border-color:rgba(249,115,22,0.30); }

  /* Pulsating dot for pendientes */
  .pulse-dot {
    display:inline-block; width:8px; height:8px; border-radius:50%;
    background:var(--rojo); margin-left:4px; vertical-align:middle;
    animation:pulse 1.4s ease-in-out infinite;
  }
  @keyframes pulse {
    0%,100% { opacity:1; transform:scale(1); }
    50%      { opacity:.4; transform:scale(.6); }
  }
  @media (prefers-reduced-motion:reduce) { .pulse-dot { animation:none; } }

  /* Tile entrance animation */
  .tile { animation:tileIn .3s ease both; }
  .tile:nth-child(2) { animation-delay:.04s; }
  .tile:nth-child(3) { animation-delay:.08s; }
  .tile:nth-child(4) { animation-delay:.12s; }
  .tile:nth-child(5) { animation-delay:.16s; }
  .tile:nth-child(6) { animation-delay:.20s; }
  .tile:nth-child(7) { animation-delay:.24s; }
  .tile:nth-child(8) { animation-delay:.28s; }
  .tile:nth-child(9) { animation-delay:.32s; }
  .tile:nth-child(10){ animation-delay:.36s; }
  @keyframes tileIn {
    from { opacity:0; transform:translateY(10px); }
    to   { opacity:1; transform:translateY(0); }
  }
  @media (prefers-reduced-motion:reduce) { .tile { animation:none; } }

  /* ── MODULES ── */
  .module {
    position:fixed; inset:0; background:var(--bg); z-index:20;
    display:flex; flex-direction:column; overflow:hidden;
  }
  .module[hidden] { display:none; }

  .mod-hdr {
    display:flex; align-items:center; justify-content:space-between;
    padding:.75rem 1rem; background:var(--surface);
    border-bottom:1px solid var(--border); flex-shrink:0;
  }
  .mod-title { font-weight:700; font-size:.95rem; }

  .btn-back {
    background:transparent; border:1px solid var(--border); border-radius:8px;
    color:var(--tx-muted); padding:.4rem .8rem; cursor:pointer; font-size:.8rem;
    font-family:inherit; transition:color .15s, border-color .15s;
  }
  .btn-back:hover { color:var(--amarillo); border-color:rgba(245,158,11,.5); }

  .btn-mod-action {
    background:var(--amarillo); color:#1a1a1a; border:none; border-radius:8px;
    padding:.4rem .9rem; cursor:pointer; font-size:.8rem; font-weight:700; font-family:inherit;
  }

  .mod-body {
    flex:1; overflow-y:auto; padding:1rem;
    scrollbar-width:thin; scrollbar-color:var(--surface2) transparent;
  }

  /* ── CARDS ── */
  .card-list { display:flex; flex-direction:column; gap:.625rem; }

  .mcard {
    display:flex; align-items:flex-start; gap:.75rem;
    background:var(--surface); border:1px solid var(--border);
    border-radius:12px; padding:.75rem; transition:border-color .15s;
  }
  .mcard:hover { border-color:rgba(255,255,255,0.15); }
  .mcard-reunida { opacity:.65; }

  .mcard-media { flex-shrink:0; }
  .mcard-img {
    width:72px; height:72px; border-radius:8px; object-fit:cover;
    display:block; background:var(--surface2);
  }
  .mcard-nofoto {
    width:72px; height:72px; border-radius:8px; background:var(--surface2);
    display:flex; align-items:center; justify-content:center; font-size:1.75rem;
  }
  .mcard-tipo-icon {
    width:72px; height:72px; border-radius:8px; background:var(--surface2);
    display:flex; align-items:center; justify-content:center; font-size:1.75rem;
  }

  .mcard-info { flex:1; min-width:0; display:flex; flex-direction:column; gap:.25rem; }
  .mcard-name { font-weight:600; font-size:.875rem; color:var(--tx); }
  .mcard-meta { font-size:.75rem; color:var(--tx-muted); }
  .mcard-desc { font-size:.75rem; color:var(--tx-muted); }
  .mcard-badges { display:flex; gap:.375rem; flex-wrap:wrap; align-items:center; }

  .mcard-actions {
    display:flex; flex-direction:column; gap:.375rem; flex-shrink:0; align-items:flex-end;
  }
  @media (min-width:480px) {
    .mcard-actions { flex-direction:row; align-items:center; flex-wrap:wrap; justify-content:flex-end; }
  }

  .section-divider {
    font-size:.8rem; font-weight:600; color:var(--verde); padding:.75rem 0 .375rem;
    border-top:1px solid var(--border); margin-top:.75rem;
  }

  /* ── BADGES ── */
  .badge {
    display:inline-block; font-size:.65rem; font-weight:700;
    padding:.1rem .45rem; border-radius:10px; text-transform:lowercase;
  }
  .badge-rojo  { background:rgba(239,68,68,.18);  color:#f87171; }
  .badge-verde { background:rgba(34,197,94,.18);  color:#4ade80; }
  .badge-azul  { background:rgba(59,130,246,.18); color:#60a5fa; }
  .badge-gris  { background:rgba(255,255,255,.10); color:var(--tx-muted); }
  .badge-tipo-info      { background:rgba(59,130,246,.15);  color:#60a5fa; }
  .badge-tipo-alerta    { background:rgba(239,68,68,.15);   color:#f87171; }
  .badge-tipo-rescate   { background:rgba(107,58,42,.25);   color:#d09070; }
  .badge-tipo-buenas    { background:rgba(34,197,94,.15);   color:#4ade80; }
  .badge-tipo-voluntario{ background:rgba(139,92,246,.15);  color:#a78bfa; }

  /* ── BUTTONS ── */
  .btn {
    display:inline-flex; align-items:center; justify-content:center;
    border:none; border-radius:8px; padding:.4rem .75rem;
    font-size:.75rem; font-weight:600; cursor:pointer; font-family:inherit;
    min-height:36px; transition:opacity .15s, filter .15s; white-space:nowrap;
  }
  .btn:disabled { opacity:.5; cursor:not-allowed; }
  .btn-verde   { background:rgba(34,197,94,.2);  color:#4ade80;  border:1px solid rgba(34,197,94,.3); }
  .btn-rojo    { background:rgba(239,68,68,.2);  color:#f87171;  border:1px solid rgba(239,68,68,.3); }
  .btn-azul    { background:rgba(59,130,246,.2); color:#60a5fa;  border:1px solid rgba(59,130,246,.3); }
  .btn-amarillo{ background:rgba(245,158,11,.2); color:#fbbf24;  border:1px solid rgba(245,158,11,.3); }
  .btn-gris    { background:rgba(255,255,255,.08); color:var(--tx-muted); border:1px solid var(--border); }
  .btn-wa      { background:rgba(37,211,102,.18); color:#25D366; border:1px solid rgba(37,211,102,.3); text-decoration:none; }
  .btn-outline { background:transparent; border:1px solid var(--border); color:var(--tx-muted); }
  .btn-outline:hover { border-color:rgba(255,255,255,.25); color:var(--tx); }
  .btn-icon    { padding:.4rem .5rem; min-width:36px; }
  .btn-sm      { padding:.25rem .5rem; font-size:.7rem; min-height:28px; }

  .btn-submit {
    background:var(--amarillo); color:#1a1a1a; border:none; border-radius:8px;
    padding:.625rem 1.25rem; font-weight:700; font-size:.8rem; cursor:pointer;
    font-family:inherit; min-height:40px;
  }
  .btn-submit:hover { background:#e6b200; }
  .btn-submit:disabled { opacity:.5; cursor:not-allowed; }

  .btn-cf-link {
    display:inline-flex; align-items:center;
    background:rgba(249,115,22,.15); color:#fb923c; border:1px solid rgba(249,115,22,.3);
    border-radius:8px; padding:.5rem 1rem; font-size:.8rem; text-decoration:none;
  }
  .btn-cf-link:hover { background:rgba(249,115,22,.25); }

  /* ── FORMS ── */
  .form-wrap { max-width:680px; }
  .form-wrap--bordered {
    border:1px solid var(--border); border-radius:12px; padding:1.25rem;
    background:var(--surface);
  }
  .form-section-title { font-size:.875rem; font-weight:700; margin-bottom:1rem; color:var(--tx); }
  .form-hint { color:var(--tx-muted); font-size:.8rem; margin-bottom:1rem; }

  .nuevo-form { display:flex; flex-direction:column; gap:.75rem; }
  .nuevo-form-grid { display:flex; gap:.75rem; flex-wrap:wrap; }
  .form-field { display:flex; flex-direction:column; gap:.3rem; flex:1; min-width:140px; }
  .form-lbl   { font-size:.75rem; color:var(--tx-muted); font-weight:500; }
  .feed-input, .feed-select, .feed-textarea {
    background:var(--surface2); border:1px solid var(--border); border-radius:8px;
    color:var(--tx); padding:.5rem .75rem; font-size:.8rem; font-family:inherit; width:100%;
  }
  .feed-input:focus, .feed-select:focus, .feed-textarea:focus {
    outline:none; border-color:rgba(245,158,11,.5);
  }
  .feed-textarea { resize:vertical; min-height:80px; }
  .upload-input { font-size:.75rem; color:var(--tx-muted); }

  .nm-hint { font-size:.7rem; margin-top:-.375rem; }
  .nm-hint.valid   { color:var(--verde); }
  .nm-hint.invalid { color:var(--rojo); }
  .nm-success { font-size:.8rem; color:var(--verde); }
  .nm-preview-img { max-width:200px; border-radius:8px; border:1px solid var(--border); }

  /* ── SEARCH ── */
  .search-bar { margin-bottom:.75rem; }
  .search-input {
    background:var(--surface); border:1px solid var(--border); border-radius:8px;
    color:var(--tx); padding:.5rem .875rem; font-size:.8rem; font-family:inherit; width:100%;
  }
  .search-input:focus { outline:none; border-color:rgba(245,158,11,.5); }

  /* ── INSUMOS ── */
  .insumos-list { display:flex; flex-direction:column; gap:.5rem; }
  .insumo-row {
    display:flex; align-items:center; gap:.625rem; flex-wrap:wrap;
    background:var(--surface); border:1px solid var(--border); border-radius:10px; padding:.625rem .875rem;
  }
  .prio-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }
  .prio-critico { background:#EF4444; }
  .prio-urgente  { background:#F59E0B; }
  .prio-cubierto { background:#22C55E; }
  .insumo-name { flex:1; font-size:.8rem; font-weight:500; min-width:100px; }
  .insumo-form { display:flex; align-items:center; gap:.375rem; flex-wrap:wrap; }
  .insumo-lbl  { font-size:.7rem; color:var(--tx-muted); }
  .insumo-input { background:var(--surface2); border:1px solid var(--border); border-radius:6px; color:var(--tx); padding:.3rem .5rem; font-size:.75rem; width:60px; text-align:center; }

  /* ── ANALYTICS ── */
  .an-kpi-row { display:flex; gap:1rem; flex-wrap:wrap; margin-bottom:1.25rem; }
  .an-kpi {
    flex:1; min-width:120px; background:var(--surface); border:1px solid var(--border);
    border-radius:12px; padding:1rem; display:flex; flex-direction:column; gap:.2rem;
  }
  .an-kpi-label { font-size:.7rem; color:var(--tx-muted); font-weight:500; }
  .an-kpi-num   { font-size:1.75rem; font-weight:700; color:var(--tx); }
  .an-kpi-sub   { font-size:.65rem; color:var(--tx-muted); }
  .an-section { margin-bottom:1.25rem; }
  .an-section-title { font-size:.8rem; font-weight:700; color:var(--tx-muted); text-transform:uppercase; letter-spacing:.06em; margin-bottom:.625rem; }
  .an-two-col { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
  @media (max-width:440px) { .an-two-col { grid-template-columns:1fr; } }
  .an-bars, .an-list { display:flex; flex-direction:column; gap:.5rem; }
  .an-bar-row, .an-list-row { display:flex; align-items:center; gap:.5rem; }
  .an-bar-label, .an-list-name { font-size:.75rem; width:80px; flex-shrink:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  .an-bar-track { flex:1; height:8px; background:var(--surface2); border-radius:4px; overflow:hidden; }
  .an-bar-track--sm { height:6px; }
  .an-bar-fill  { height:100%; border-radius:4px; transition:width .3s ease; }
  .an-bar-pct   { font-size:.7rem; color:var(--tx-muted); width:32px; text-align:right; }
  .an-bar-count, .an-list-count { font-size:.7rem; color:var(--tx-muted); width:40px; text-align:right; }
  .an-empty { font-size:.75rem; color:var(--tx-muted); }

  /* ── GEMINI ── */
  .gemini-actions { display:flex; gap:.5rem; margin-bottom:1rem; flex-wrap:wrap; }
  .gem-action {
    flex:1; padding:.5rem 1rem; border-radius:8px; border:1px solid var(--border);
    background:var(--surface2); color:var(--tx-muted); cursor:pointer;
    font-family:inherit; font-size:.8rem; font-weight:500; transition:.15s;
  }
  .gem-action.active { background:rgba(245,158,11,.18); color:var(--amarillo); border-color:rgba(245,158,11,.4); }
  .gemini-preview {
    width:100%; aspect-ratio:4/3; max-height:280px; background:var(--surface2);
    border:2px dashed var(--border); border-radius:10px; display:flex;
    align-items:center; justify-content:center; cursor:pointer; overflow:hidden;
    position:relative;
  }
  .gemini-placeholder { font-size:.875rem; color:var(--tx-muted); }

  /* ── BANNER UPLOADS ── */
  .banner-uploads { display:flex; gap:.75rem; flex-wrap:wrap; margin-top:.75rem; }
  .upload-label { display:flex; flex-direction:column; gap:.375rem; flex:1; min-width:200px; }
  .upload-lbl-txt { font-size:.75rem; color:var(--tx-muted); font-weight:500; }

  /* ── MODAL ── */
  .modal-overlay {
    position:fixed; inset:0; background:rgba(0,0,0,.75); z-index:50;
    display:flex; align-items:flex-start; justify-content:center;
    padding:.75rem; overflow-y:auto;
  }
  .modal-box {
    background:var(--surface); border:1px solid var(--border); border-radius:14px;
    width:min(100%,560px); margin:auto; max-height:calc(100vh - 1.5rem); overflow-y:auto;
  }
  .modal-hdr {
    display:flex; align-items:center; justify-content:space-between;
    padding:1rem 1.25rem; border-bottom:1px solid var(--border); position:sticky; top:0;
    background:var(--surface); z-index:1;
  }
  .modal-title { font-weight:700; font-size:.9rem; }
  .modal-close {
    background:transparent; border:1px solid var(--border); border-radius:6px;
    color:var(--tx-muted); padding:.25rem .5rem; cursor:pointer; font-size:.875rem;
  }
  .modal-form  { display:none; flex-direction:column; padding:1.25rem; gap:1rem; }
  .modal-grid  { display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:.75rem; }
  .modal-field { display:flex; flex-direction:column; gap:.3rem; }
  .modal-field--full { grid-column:1/-1; }
  .modal-lbl   { font-size:.75rem; color:var(--tx-muted); font-weight:500; }
  .modal-hint  { font-size:.7rem; color:var(--tx-muted); }
  .modal-input {
    background:var(--bg); border:1px solid var(--border); border-radius:8px;
    color:var(--tx); padding:.5rem .75rem; font-size:.8rem; font-family:inherit; width:100%;
  }
  .modal-input:focus { outline:none; border-color:rgba(245,158,11,.5); }
  .modal-textarea { resize:vertical; min-height:80px; }
  .modal-actions { display:flex; gap:.625rem; flex-wrap:wrap; padding:0 1.25rem 1.25rem; }
  .modal-cancel { flex:1; }

  /* ── EMPTY ── */
  .empty-msg { color:var(--tx-muted); font-size:.875rem; padding:1rem 0; }
</style>

<script>
  // ── Navigation
  function showHome() {
    document.getElementById('home').removeAttribute('hidden')
    document.querySelectorAll('.module').forEach(function(m) { m.setAttribute('hidden','') })
    history.replaceState(null,'','/admin')
    window.scrollTo(0,0)
  }

  function showModule(id) {
    document.getElementById('home').setAttribute('hidden','')
    document.querySelectorAll('.module').forEach(function(m) { m.setAttribute('hidden','') })
    var mod = document.getElementById('mod-' + id)
    if (mod) {
      mod.removeAttribute('hidden')
      mod.querySelector('.mod-body').scrollTop = 0
    }
    history.replaceState(null,'','/admin#' + id)
    window.scrollTo(0,0)
  }

  // ── Handle initial hash
  ;(function() {
    var hash = location.hash.replace('#','')
    var validMods = ['pendientes','publicadas','adopcion','agregar','gemini','vets','feed','insumos','analiticas','banners']
    if (hash && validMods.includes(hash)) showModule(hash)
  })()

  // ── Card search filter
  function filterCards(inputId, cardClass) {
    var inp = document.getElementById(inputId)
    if (!inp) return
    var q = inp.value.toLowerCase()
    document.querySelectorAll('.' + cardClass).forEach(function(card) {
      card.style.display = card.textContent.toLowerCase().includes(q) ? '' : 'none'
    })
  }

  // ── Generic fetch action
  async function doAction(params, rowId, confirmMsg) {
    if (confirmMsg && !confirm(confirmMsg)) return false
    var fd = new FormData()
    Object.keys(params).forEach(function(k) { fd.append(k, String(params[k])) })
    try {
      var r = await fetch('/admin', { method:'POST', body:fd })
      var j = await r.json()
      if (!j.ok) { alert('Error: ' + (j.error || 'desconocido')); return false }
      if (rowId) {
        var el = document.getElementById(rowId)
        if (el) { el.style.transition='opacity .2s'; el.style.opacity='0'; setTimeout(function() { el.remove() }, 200) }
      }
      return true
    } catch(e) { alert('Error de red'); return false }
  }

  // ── Data-attribute buttons
  document.querySelectorAll('[data-action]').forEach(function(btn) {
    btn.addEventListener('click', async function() {
      var action = btn.dataset.action; var id = btn.dataset.id; var row = btn.dataset.row; var conf = btn.dataset.confirm
      if (!action || !id) return
      btn.disabled = true
      var params = { action:action, id:id }
      if (btn.dataset.activo !== undefined) params.activo = btn.dataset.activo
      var ok = await doAction(params, row, conf || null)
      if (ok && btn.dataset.reload) { location.reload() }
      else if (!ok) btn.disabled = false
    })
  })

  // ── Feed form
  var formFeed = document.getElementById('form-feed')
  if (formFeed) {
    formFeed.addEventListener('submit', async function(e) {
      e.preventDefault()
      var fd = new FormData(formFeed); fd.append('action','feed')
      var btn = formFeed.querySelector('button[type="submit"]')
      if (btn) btn.disabled = true
      try {
        var r = await fetch('/admin', {method:'POST',body:fd}); var j = await r.json()
        if (!j.ok) { alert('Error: '+(j.error||'desconocido')); if (btn) btn.disabled=false }
        else {
          formFeed.reset(); if (btn) btn.disabled=false
          var msg = document.createElement('p'); msg.textContent='✓ Publicado'
          msg.style.cssText='color:#22C55E;font-size:.8rem;margin-top:.375rem;'
          formFeed.appendChild(msg); setTimeout(function() { msg.remove() }, 2500)
        }
      } catch(e) { alert('Error de red'); if (btn) btn.disabled=false }
    })
  }

  // ── Insumo forms
  document.querySelectorAll('.insumo-form').forEach(function(form) {
    form.addEventListener('submit', async function(e) {
      e.preventDefault()
      var id=form.dataset.id; var inputRec=form.querySelector('input[name="cantidad_recibida"]'); var inputReq=form.querySelector('input[name="cantidad_requerida"]')
      var cantRec=inputRec?inputRec.value:'0'; var cantReq=inputReq?inputReq.value:'1'
      var btn=form.querySelector('button'); if (btn) btn.disabled=true
      var ok = await doAction({action:'insumo',id:id,cantidad_recibida:cantRec,cantidad_requerida:cantReq},null,null)
      if (btn) btn.disabled=false
    })
  })

  // ── Banner form
  var formBanner = document.getElementById('form-banner')
  if (formBanner) {
    formBanner.addEventListener('submit', async function(e) {
      e.preventDefault()
      var fd=new FormData(formBanner); fd.append('action','banner')
      var btn=formBanner.querySelector('button[type="submit"]'); if (btn) btn.disabled=true
      try {
        var r=await fetch('/admin',{method:'POST',body:fd}); var j=await r.json()
        if (!j.ok) { alert('Error: '+(j.error||'desconocido')); if (btn) btn.disabled=false }
        else { window.location.reload() }
      } catch(e) { alert('Error de red'); if (btn) btn.disabled=false }
    })
  }

  // ── Nueva mascota form
  var formNuevaMascota = document.getElementById('form-nueva-mascota')
  if (formNuevaMascota) {
    var nmWa=document.getElementById('nm-wa'); var nmHint=document.getElementById('nm-wa-hint')
    if (nmWa && nmHint) {
      nmWa.addEventListener('input', function() {
        var val=nmWa.value.replace(/\D/g,'')
        if (!val.length) { nmHint.textContent=''; nmHint.className='nm-hint' }
        else if (/^04[0-9]{9}$/.test(val)) { nmHint.textContent='✓ Formato válido'; nmHint.className='nm-hint valid' }
        else { nmHint.textContent='Debe ser 04XXXXXXXXX (11 dígitos)'; nmHint.className='nm-hint invalid' }
      })
    }
    var nmFoto=document.getElementById('nm-foto'); var nmPreviewWrap=document.getElementById('nm-preview-wrap'); var nmPreview=document.getElementById('nm-preview')
    if (nmFoto && nmPreviewWrap && nmPreview) {
      nmFoto.addEventListener('change', function() {
        var file=nmFoto.files&&nmFoto.files[0]
        if (file) { var reader=new FileReader(); reader.onload=function(e) { nmPreview.src=e.target.result; nmPreviewWrap.style.display='block' }; reader.readAsDataURL(file) }
        else nmPreviewWrap.style.display='none'
      })
    }
    formNuevaMascota.addEventListener('submit', async function(e) {
      e.preventDefault()
      var fd=new FormData(formNuevaMascota); fd.append('action','nueva_mascota')
      var btn=document.getElementById('nm-submit'); var msg=document.getElementById('nm-msg')
      if (btn) { btn.disabled=true; btn.textContent='Guardando…' }; if (msg) msg.textContent=''
      try {
        var r=await fetch('/admin',{method:'POST',body:fd}); var j=await r.json()
        if (!j.ok) { alert('Error: '+(j.error||'desconocido')); if (btn) { btn.disabled=false; btn.textContent='Crear mascota' } }
        else {
          formNuevaMascota.reset(); if (nmPreviewWrap) nmPreviewWrap.style.display='none'
          if (nmHint) { nmHint.textContent=''; nmHint.className='nm-hint' }
          if (btn) { btn.disabled=false; btn.textContent='Crear mascota' }
          if (msg) { msg.textContent='✓ Mascota creada'; setTimeout(function() { if (msg) msg.textContent='' }, 3000) }
        }
      } catch(err) { alert('Error de red'); if (btn) { btn.disabled=false; btn.textContent='Crear mascota' } }
    })
  }

  // ── Nuevo insumo
  var formNuevoInsumo = document.getElementById('form-nuevo-insumo')
  if (formNuevoInsumo) {
    formNuevoInsumo.addEventListener('submit', async function(e) {
      e.preventDefault()
      var fd=new FormData(formNuevoInsumo); fd.append('action','nuevo_insumo')
      var btn=formNuevoInsumo.querySelector('button[type="submit"]'); if (btn) btn.disabled=true
      try {
        var r=await fetch('/admin',{method:'POST',body:fd}); var j=await r.json()
        if (!j.ok) { alert('Error: '+(j.error||'desconocido')); if (btn) btn.disabled=false }
        else { window.location.reload() }
      } catch(e) { alert('Error de red'); if (btn) btn.disabled=false }
    })
  }

  // ── Nuevo vet
  var formNuevoVet = document.getElementById('form-nuevo-vet')
  if (formNuevoVet) {
    formNuevoVet.addEventListener('submit', async function(e) {
      e.preventDefault()
      var fd=new FormData(formNuevoVet); fd.append('action','nuevo_vet')
      var btn=formNuevoVet.querySelector('button[type="submit"]'); if (btn) btn.disabled=true
      try {
        var r=await fetch('/admin',{method:'POST',body:fd}); var j=await r.json()
        if (!j.ok) { alert('Error: '+(j.error||'desconocido')); if (btn) btn.disabled=false }
        else { window.location.reload() }
      } catch(e) { alert('Error de red'); if (btn) btn.disabled=false }
    })
  }

  // ── Edit Modal
  var modal=document.getElementById('edit-modal')
  var modalClose=document.getElementById('modal-close')
  var formMascota=document.getElementById('modal-mascota')
  var formVet=document.getElementById('modal-vet')
  var formInsumo=document.getElementById('modal-insumo')
  var formFeedEdit=document.getElementById('modal-feed')

  function openModal(type) {
    [formMascota,formVet,formInsumo,formFeedEdit].forEach(function(f){if(f)f.style.display='none'})
    if      (type==='mascota'&&formMascota)  formMascota.style.display='flex'
    else if (type==='vet'&&formVet)          formVet.style.display='flex'
    else if (type==='insumo'&&formInsumo)    formInsumo.style.display='flex'
    else if (type==='feed'&&formFeedEdit)    formFeedEdit.style.display='flex'
    modal.style.display='flex'
    var first=modal.querySelector('.modal-input,button'); if (first) first.focus()
  }

  function closeModal() {
    modal.style.display='none'
    ;[formMascota,formVet,formInsumo,formFeedEdit].forEach(function(f){if(f)f.style.display='none'})
  }

  if (modalClose) modalClose.addEventListener('click', closeModal)
  document.addEventListener('keydown', function(e) { if (e.key==='Escape'&&modal&&modal.style.display!=='none') closeModal() })
  document.querySelectorAll('.modal-cancel').forEach(function(b) { b.addEventListener('click', closeModal) })

  document.querySelectorAll('.btn-edit-mascota').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.getElementById('em-id').value=btn.dataset.id||''
      document.getElementById('em-nombre').value=btn.dataset.nombre||''
      document.getElementById('em-zona').value=btn.dataset.zona||''
      document.getElementById('em-color').value=btn.dataset.color||''
      document.getElementById('em-whatsapp').value=btn.dataset.whatsapp||''
      document.getElementById('em-descripcion').value=btn.dataset.descripcion||''
      var selEsp=document.getElementById('em-especie'); var selTip=document.getElementById('em-tipo'); var selTam=document.getElementById('em-tamanio')
      for (var i=0;i<selEsp.options.length;i++) { if (selEsp.options[i].value===btn.dataset.especie) { selEsp.selectedIndex=i; break } }
      for (var j=0;j<selTip.options.length;j++) { if (selTip.options[j].value===btn.dataset.tipo)   { selTip.selectedIndex=j; break } }
      for (var k=0;k<selTam.options.length;k++) { if (selTam.options[k].value===btn.dataset.tamanio){ selTam.selectedIndex=k; break } }
      openModal('mascota')
    })
  })

  document.querySelectorAll('.btn-edit-vet').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.getElementById('ev-id').value=btn.dataset.id||''
      document.getElementById('ev-nombre').value=btn.dataset.nombre||''
      document.getElementById('ev-zona').value=btn.dataset.zona||''
      document.getElementById('ev-whatsapp').value=btn.dataset.whatsapp||''
      document.getElementById('ev-servicios').value=btn.dataset.servicios||''
      document.getElementById('ev-horario').value=btn.dataset.horario||''
      openModal('vet')
    })
  })

  document.querySelectorAll('.btn-edit-insumo').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.getElementById('ei-id').value=btn.dataset.id||''
      document.getElementById('ei-item').value=btn.dataset.item||''
      document.getElementById('ei-recibida').value=btn.dataset.cantidad_recibida||'0'
      document.getElementById('ei-requerida').value=btn.dataset.cantidad_requerida||'1'
      var selPrio=document.getElementById('ei-prioridad')
      for (var i=0;i<selPrio.options.length;i++) { if (selPrio.options[i].value===btn.dataset.prioridad) { selPrio.selectedIndex=i; break } }
      openModal('insumo')
    })
  })

  document.querySelectorAll('.btn-edit-feed').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.getElementById('ef-id').value=btn.dataset.id||''
      document.getElementById('ef-titulo').value=btn.dataset.titulo||''
      document.getElementById('ef-cuerpo').value=btn.dataset.cuerpo||''
      var selTipo=document.getElementById('ef-tipo')
      for (var i=0;i<selTipo.options.length;i++) { if (selTipo.options[i].value===btn.dataset.tipo) { selTipo.selectedIndex=i; break } }
      openModal('feed')
    })
  })

  function handleModalForm(form) {
    if (!form) return
    form.addEventListener('submit', async function(e) {
      e.preventDefault()
      var fd=new FormData(form); var btn=form.querySelector('button[type="submit"]'); if (btn) btn.disabled=true
      try {
        var r=await fetch('/admin',{method:'POST',body:fd}); var j=await r.json()
        if (!j.ok) { alert('Error: '+(j.error||'desconocido')); if (btn) btn.disabled=false }
        else { window.location.reload() }
      } catch(err) { alert('Error de red'); if (btn) btn.disabled=false }
    })
  }
  handleModalForm(formMascota)
  handleModalForm(formVet)
  handleModalForm(formInsumo)
  handleModalForm(formFeedEdit)

  // ── Gemini Vision
  ;(function() {
    var geminiImg=document.getElementById('geminiImg'); if (!geminiImg) return
    var btnSel=document.getElementById('btnSeleccionar')
    var btnExtraer=document.getElementById('btnExtraer')
    var preview=document.getElementById('geminiPreview')
    var previewImg=document.getElementById('geminiPreviewImg')
    var placeholder=document.getElementById('geminiPlaceholder')
    var geminiMsg=document.getElementById('geminiMsg')
    var formMasc=document.getElementById('geminiFormMascota')
    var formFeedG=document.getElementById('geminiFormFeed')
    var formInsG=document.getElementById('geminiFormInsumo')
    var currentAction='mascota'

    function hideAllForms() { formMasc.style.display='none'; formFeedG.style.display='none'; formInsG.style.display='none' }

    document.querySelectorAll('.gem-action').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.gem-action').forEach(function(b) { b.classList.remove('active') })
        btn.classList.add('active'); currentAction=btn.dataset.action; hideAllForms()
        geminiMsg.style.display='none'
      })
    })

    function showMsg(text, ok) {
      geminiMsg.style.display='block'; geminiMsg.textContent=text
      geminiMsg.style.background=ok?'#064e3b':'#1f2937'
      geminiMsg.style.borderColor=ok?'#16a34a':'#374151'
    }

    function loadPreview(file) {
      var reader=new FileReader(); reader.onload=function(e) { previewImg.src=e.target.result; previewImg.style.display='block'; placeholder.style.display='none'; btnExtraer.disabled=false }; reader.readAsDataURL(file)
    }

    btnSel.addEventListener('click', function() { geminiImg.click() })
    preview.addEventListener('click', function() { geminiImg.click() })
    preview.addEventListener('keydown', function(e) { if (e.key==='Enter'||e.key===' ') { e.preventDefault(); geminiImg.click() } })
    geminiImg.addEventListener('change', function() { if (this.files[0]) loadPreview(this.files[0]) })

    function setVal(id, val) { if (val) { var el=document.getElementById(id); if (el) el.value=val } }
    function setSelect(id, val) {
      if (!val) return; var sel=document.getElementById(id); if (!sel) return
      for (var i=0;i<sel.options.length;i++) { if (sel.options[i].value===val) { sel.selectedIndex=i; break } }
    }

    btnExtraer.addEventListener('click', async function() {
      var file=geminiImg.files[0]; if (!file) return
      btnExtraer.disabled=true; showMsg('⏳ Analizando imagen con Gemini Vision...', false)
      var reader=new FileReader()
      reader.onload=async function(e) {
        var base64=e.target.result.split(',')[1]; var mime=file.type||'image/jpeg'
        try {
          var r=await fetch('/api/gemini-extract',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({base64:base64,mime:mime,action:currentAction})})
          var data=await r.json()
          if (!r.ok||data.error) { showMsg('❌ '+(data.error||'Error al extraer datos'),false); btnExtraer.disabled=false; return }
          hideAllForms()
          if (currentAction==='mascota') {
            setVal('g-nombre',data.nombre); setSelect('g-especie',data.especie); setVal('g-color',data.color)
            setVal('g-zona',data.zona); setVal('g-descripcion',data.descripcion); setVal('g-senias',data.senias)
            setVal('g-contacto-nombre',data.contacto_nombre); setVal('g-whatsapp',data.whatsapp); setSelect('g-tipo',data.tipo)
            formMasc.style.display='block'; formMasc.scrollIntoView({behavior:'smooth',block:'start'})
          } else if (currentAction==='feed') {
            setSelect('gf-tipo',data.tipo); setVal('gf-titulo',data.titulo); setVal('gf-cuerpo',data.cuerpo)
            formFeedG.style.display='block'; formFeedG.scrollIntoView({behavior:'smooth',block:'start'})
          } else if (currentAction==='insumo') {
            setVal('gi-item',data.item)
            if (data.cantidad_requerida) { var elReq=document.getElementById('gi-cantidad-req'); if (elReq) elReq.value=data.cantidad_requerida }
            if (data.cantidad_recibida!==undefined) { var elRec=document.getElementById('gi-cantidad-rec'); if (elRec) elRec.value=data.cantidad_recibida }
            setSelect('gi-prioridad',data.prioridad)
            formInsG.style.display='block'; formInsG.scrollIntoView({behavior:'smooth',block:'start'})
          }
          showMsg('✓ Datos extraídos. Revisa y edita antes de guardar.', true); btnExtraer.disabled=false
        } catch(err) { showMsg('❌ Error de red: '+err.message, false); btnExtraer.disabled=false }
      }
      reader.readAsDataURL(file)
    })
  })()
</script>
