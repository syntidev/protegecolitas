---
import Base from '../layouts/Base.astro'
import { supabaseAdmin } from '../lib/supabase'

const { data: vets } = await supabaseAdmin
  .from('vets')
  .select('id, nombre, zona, servicios, horario, whatsapp, gratuito')
  .order('created_at', { ascending: false })

const total = vets?.length ?? 0

const WA_BASE = 'https://wa.me/'

function initials(nombre: string): string {
  return nombre.split(' ').map((w: string) => w[0]).filter(Boolean).join('').slice(0, 2).toUpperCase()
}

function buildWaLink(whatsapp: string | null, nombre: string): string | null {
  if (!whatsapp) return null
  const num = whatsapp.replace(/\D/g, '')
  if (!num) return null
  const intl = num.startsWith('0') ? '58' + num.slice(1) : num
  const msg = encodeURIComponent(`Hola ${nombre}, vi tu info en Protege Colitas y necesito atención para mi mascota`)
  return `${WA_BASE}${intl}?text=${msg}`
}

// Extract simplified first-part zone for each vet → chip list
const zonas = [...new Set(
  (vets ?? [])
    .map(v => (v.zona ?? '').split(',')[0].trim())
    .filter(z => z.length > 2)
)].sort().slice(0, 12)
---

<Base title="Veterinarios voluntarios — Protege Colitas">
  <div class="vl-wrap">
    <div class="vl-page">

      <!-- ── LEFT: directorio ─────────────────────────────────── -->
      <section class="vl-left" aria-label="Directorio de veterinarios">

        <div class="vl-header">
          <h1 class="vl-title">Veterinarios <em>voluntarios</em></h1>
          <p class="vl-sub">{total} profesionales disponibles post-terremoto</p>
        </div>

        <!-- Search + filter chips -->
        <div class="vl-filters">
          <div class="vl-search-wrap">
            <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input
              type="search"
              id="searchVets"
              placeholder="Buscar por nombre o zona..."
              class="vl-search-input"
              autocomplete="off"
              aria-label="Buscar veterinarios"
            />
          </div>

          <div class="chip-row" role="group" aria-label="Filtros">
            <button class="chip chip-24h" id="chip24h" type="button" aria-pressed="false">Solo 24h</button>
            {zonas.map(zona => (
              <button class="chip chip-zona" data-zona={zona} type="button" aria-pressed="false">{zona}</button>
            ))}
          </div>
        </div>

        <!-- Grid -->
        {total > 0 ? (
          <div class="vets-grid" id="vetsGrid" role="list">
            {vets!.map(v => {
              const link   = buildWaLink(v.whatsapp, v.nombre)
              const has24  = /24/i.test(v.horario ?? '')
              const zonaKey = (v.zona ?? '').split(',')[0].trim().toLowerCase()
              return (
                <article
                  class="vet-card"
                  role="listitem"
                  data-nombre={(v.nombre ?? '').toLowerCase()}
                  data-zona={(v.zona ?? '').toLowerCase()}
                  data-zonakey={zonaKey}
                  data-is24h={has24 ? 'true' : 'false'}
                >
                  <div class="vc-top">
                    <div class="vc-avatar" aria-hidden="true">{initials(v.nombre)}</div>
                    <div class="vc-meta">
                      <span class="vc-name">{v.nombre}</span>
                      <div class="vc-zona">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
                          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/>
                        </svg>
                        <span>{v.zona}</span>
                      </div>
                    </div>
                    <div class="vc-badges">
                      <span class={`badge-horario ${has24 ? 'badge-24h' : 'badge-consultar'}`}>
                        {has24 ? '24h' : 'Consultar'}
                      </span>
                      {v.gratuito && (
                        <span class="badge-free">Gratuito ✓</span>
                      )}
                    </div>
                  </div>

                  {v.servicios && (
                    <p class="vc-servicios" title={v.servicios}>{v.servicios}</p>
                  )}

                  {link ? (
                    <a href={link} class="btn-wa" target="_blank" rel="noopener noreferrer" aria-label={`WhatsApp de ${v.nombre}`}>
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                        <path d="M12 0C5.373 0 0 5.373 0 12c0 2.119.553 4.107 1.516 5.836L.057 23.447a.5.5 0 00.611.612l5.638-1.471A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.891 0-3.666-.5-5.197-1.373l-.371-.22-3.847 1.003 1.022-3.737-.242-.384A9.942 9.942 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
                      </svg>
                      WhatsApp directo
                    </a>
                  ) : (
                    <p class="no-wa">Sin WhatsApp registrado</p>
                  )}
                </article>
              )
            })}
          </div>
        ) : (
          <div class="empty-state">
            <span class="empty-icon" aria-hidden="true">🩺</span>
            <p class="empty-msg">Sé el primero en registrarte como veterinario voluntario.</p>
          </div>
        )}

        <div id="noResults" class="no-results" style="display:none" role="status" aria-live="polite">
          <span class="no-results-icon" aria-hidden="true">🔍</span>
          <p>Sin resultados para esa búsqueda — prueba con otro nombre o zona.</p>
        </div>
      </section>

      <!-- ── RIGHT: formulario sticky ──────────────────────────── -->
      <aside class="vl-right" aria-label="Registrarse como veterinario voluntario">
        <div class="form-card">
          <div class="fc-header">
            <h2 class="fc-title">¿Eres veterinario?</h2>
            <p class="fc-sub">Únete al directorio de voluntarios</p>
          </div>

          <form id="vetForm" novalidate>
            <div class="form-fields">

              <div class="field-group">
                <label class="field-label" for="vet-nombre">
                  Nombre completo o clínica <span class="req" aria-hidden="true">*</span>
                </label>
                <input
                  type="text" id="vet-nombre" name="nombre"
                  class="form-input" placeholder="Dr. García / Clínica Las Mercedes"
                  autocomplete="name" required
                />
                <p class="field-error" id="err-nombre" role="alert"></p>
              </div>

              <div class="field-group">
                <label class="field-label" for="vet-zona">
                  Zona o dirección <span class="req" aria-hidden="true">*</span>
                </label>
                <input
                  type="text" id="vet-zona" name="zona"
                  class="form-input" placeholder="Ej: Porlamar, Nueva Esparta"
                  autocomplete="off" required
                />
                <p class="field-error" id="err-zona" role="alert"></p>
              </div>

              <div class="field-group">
                <label class="field-label" for="vet-whatsapp">
                  WhatsApp <span class="req" aria-hidden="true">*</span>
                  <span class="field-note">04XX-XXXXXXX</span>
                </label>
                <div class="wa-wrap" id="waWrap">
                  <span class="wa-prefix" aria-hidden="true">🇻🇪</span>
                  <input
                    type="tel" id="vet-whatsapp" name="whatsapp"
                    class="form-input wa-input"
                    placeholder="04141234567" maxlength="11"
                    autocomplete="tel" inputmode="numeric" required
                  />
                  <span class="wa-status" id="waStatus" aria-live="polite"></span>
                </div>
                <p class="field-error" id="err-whatsapp" role="alert"></p>
              </div>

              <div class="field-group">
                <label class="field-label" for="vet-servicios">Servicios que ofreces</label>
                <textarea
                  id="vet-servicios" name="servicios"
                  class="form-input form-textarea"
                  placeholder="Ej: Consulta general, vacunas, cirugía menor"
                  rows="3" autocomplete="off"
                ></textarea>
              </div>

              <div class="field-group">
                <label class="field-label" for="vet-horario">Horario disponible</label>
                <input
                  type="text" id="vet-horario" name="horario"
                  class="form-input" placeholder="Ej: Lun–Vie 8am–4pm / 24 horas"
                  autocomplete="off"
                />
              </div>

              <label class="checkbox-label">
                <input type="checkbox" name="gratuito" value="true" class="checkbox-input" id="vet-gratuito" />
                <span class="checkbox-box" aria-hidden="true"></span>
                <span>Ofrezco atención gratuita</span>
              </label>

            </div>

            <p class="field-error form-error" id="formError" role="alert"></p>

            <button type="submit" class="btn-submit" id="vetSubmit">
              <span id="btnLabel">Registrarme como voluntario →</span>
              <span id="btnSpinner" class="spinner" aria-hidden="true" style="display:none"></span>
            </button>
          </form>

          <div id="vetSuccess" class="success-banner" style="display:none" role="status">
            <span class="success-icon" aria-hidden="true">✓</span>
            <div>
              <strong>¡Gracias! Tu registro será revisado pronto.</strong>
              <p>Publicamos tu perfil en el directorio en menos de 24h.</p>
            </div>
          </div>
        </div>
      </aside>

    </div>
  </div>
</Base>

<style>
/* ── Wrapper & layout ─────────────────────────────────────────────── */
.vl-wrap {
  max-width: 1200px;
  margin: 0 auto;
  padding: 28px 16px 80px;
  width: 100%;
}

.vl-page {
  display: flex;
  flex-direction: column;
  gap: 48px;
}

@media (min-width: 1024px) {
  .vl-page {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 48px;
    align-items: start;
  }
}

/* ── Left column ─────────────────────────────────────────────────── */
.vl-left {
  display: flex;
  flex-direction: column;
  gap: 24px;
  min-width: 0;
}

.vl-header { display: flex; flex-direction: column; gap: 6px; }

.vl-title {
  font-family: 'Fredoka', sans-serif;
  font-weight: 700;
  font-size: clamp(24px, 5vw, 32px);
  line-height: 1.1;
  color: var(--marron);
  margin: 0;
  text-wrap: balance;
}
.vl-title em { font-style: normal; color: var(--amarillo); }

.vl-sub {
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  color: var(--gris-txt);
  margin: 0;
}

/* ── Filters ─────────────────────────────────────────────────────── */
.vl-filters { display: flex; flex-direction: column; gap: 10px; }

.vl-search-wrap {
  position: relative;
}
.search-icon {
  position: absolute;
  left: 14px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--gris-txt);
  pointer-events: none;
  flex-shrink: 0;
}
.vl-search-input {
  width: 100%;
  padding: 12px 14px 12px 42px;
  background: rgba(255,255,255,0.85);
  border: 1.5px solid rgba(255,255,255,0.9);
  border-radius: 12px;
  box-shadow: 0 2px 8px rgba(61,28,2,0.06);
  font-family: 'Inter', sans-serif;
  font-size: 15px;
  color: var(--marron);
  outline: none;
  transition: border-color .15s, box-shadow .15s;
  -webkit-appearance: none;
  appearance: none;
  box-sizing: border-box;
}
.vl-search-input::placeholder { color: var(--gris-txt); }
.vl-search-input:focus {
  border-color: var(--amarillo);
  box-shadow: 0 0 0 3px rgba(245,193,7,0.15);
}

/* chips */
.chip-row {
  display: flex;
  gap: 8px;
  overflow-x: auto;
  scrollbar-width: none;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 4px;
}
.chip-row::-webkit-scrollbar { display: none; }

.chip {
  padding: 6px 14px;
  border-radius: 20px;
  font-family: 'Inter', sans-serif;
  font-size: 12.5px;
  font-weight: 600;
  color: var(--marron);
  background: rgba(255,255,255,0.8);
  border: 1.5px solid var(--border);
  cursor: pointer;
  white-space: nowrap;
  flex-shrink: 0;
  transition: background .15s, border-color .15s, color .15s, transform .1s;
  min-height: 36px;
  display: inline-flex;
  align-items: center;
  -webkit-tap-highlight-color: transparent;
}
.chip:hover { background: rgba(255,255,255,0.98); border-color: var(--marron); }
.chip:active { transform: scale(.97); }

.chip--active.chip-zona,
.chip--active.chip-zona:hover {
  background: var(--amarillo);
  border-color: var(--amarillo);
  color: var(--marron);
}
.chip--active.chip-24h,
.chip--active.chip-24h:hover {
  background: var(--marron);
  border-color: var(--marron);
  color: #fff;
}

/* ── Vets grid ───────────────────────────────────────────────────── */
.vets-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14px;
}
@media (min-width: 600px) {
  .vets-grid { grid-template-columns: repeat(2, 1fr); }
}

/* ── Vet card ────────────────────────────────────────────────────── */
.vet-card {
  background: rgba(255,255,255,0.78);
  backdrop-filter: blur(18px) saturate(180%);
  -webkit-backdrop-filter: blur(18px) saturate(180%);
  border: 1px solid rgba(255,255,255,0.92);
  border-radius: 18px;
  box-shadow: 0 4px 20px rgba(61,28,2,0.08);
  padding: 18px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  transition: box-shadow .18s ease, transform .18s ease;
}
.vet-card:hover {
  box-shadow: 0 8px 32px rgba(61,28,2,0.13);
  transform: translateY(-2px);
}

.vc-top { display: flex; gap: 12px; align-items: flex-start; }

.vc-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: var(--amarillo);
  color: var(--marron);
  font-family: 'Fredoka', sans-serif;
  font-weight: 700;
  font-size: 17px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  letter-spacing: .02em;
}

.vc-meta {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.vc-name {
  font-family: 'Inter', sans-serif;
  font-weight: 600;
  font-size: 15px;
  color: var(--marron);
  line-height: 1.25;
  display: block;
}
.vc-zona {
  display: flex;
  align-items: flex-start;
  gap: 4px;
  font-family: 'Inter', sans-serif;
  font-size: 12.5px;
  color: var(--gris-txt);
  line-height: 1.4;
}
.vc-zona svg { margin-top: 2px; flex-shrink: 0; }

.vc-badges {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4px;
  flex-shrink: 0;
}

.badge-horario {
  font-family: 'Inter', sans-serif;
  font-size: 10.5px;
  font-weight: 700;
  padding: 3px 8px;
  border-radius: 20px;
  white-space: nowrap;
}
.badge-24h { background: var(--rojo); color: #fff; }
.badge-consultar { background: rgba(107,58,42,0.08); color: var(--marron); }

.badge-free {
  font-family: 'Inter', sans-serif;
  font-size: 10.5px;
  font-weight: 700;
  padding: 3px 8px;
  border-radius: 20px;
  background: rgba(22,163,74,0.12);
  color: #15803d;
  white-space: nowrap;
}

.vc-servicios {
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  color: var(--gris-txt);
  line-height: 1.5;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-wrap: pretty;
}

.btn-wa {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 100%;
  min-height: 44px;
  padding: 10px 16px;
  border-radius: 10px;
  background: #25D366;
  color: #fff;
  font-family: 'Inter', sans-serif;
  font-size: 13.5px;
  font-weight: 600;
  text-decoration: none;
  transition: opacity .15s;
  -webkit-tap-highlight-color: transparent;
  margin-top: auto;
}
.btn-wa:hover { opacity: .9; }
.btn-wa:active { opacity: .8; }

.no-wa {
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  color: var(--gris-txt);
  font-style: italic;
  text-align: center;
  margin: 0;
  padding: 8px 0 4px;
}

/* empty + no-results */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 20px;
  text-align: center;
  gap: 12px;
}
.empty-icon { font-size: 48px; line-height: 1; }
.empty-msg { font-family: 'Inter', sans-serif; font-size: 16px; font-weight: 600; color: var(--marron); margin: 0; }

.no-results {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40px 20px;
  text-align: center;
  gap: 10px;
}
.no-results-icon { font-size: 36px; line-height: 1; }
.no-results p { font-family: 'Inter', sans-serif; font-size: 14px; color: var(--gris-txt); margin: 0; }

/* ── Right column (sticky form) ─────────────────────────────────── */
.vl-right {
  width: 100%;
}
@media (min-width: 1024px) {
  .vl-right {
    position: sticky;
    top: 84px;
  }
}

/* form card */
.form-card {
  background: rgba(255,255,255,0.82);
  backdrop-filter: blur(20px) saturate(190%);
  -webkit-backdrop-filter: blur(20px) saturate(190%);
  border: 1px solid rgba(255,255,255,0.95);
  border-radius: 20px;
  box-shadow: 0 8px 40px rgba(61,28,2,0.11);
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.fc-header { display: flex; flex-direction: column; gap: 4px; }
.fc-title {
  font-family: 'Fredoka', sans-serif;
  font-weight: 700;
  font-size: 20px;
  color: var(--marron);
  margin: 0;
}
.fc-sub {
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  color: var(--gris-txt);
  margin: 0;
}

/* form fields */
.form-fields { display: flex; flex-direction: column; gap: 16px; }
.field-group { display: flex; flex-direction: column; gap: 5px; }

.field-label {
  font-family: 'Inter', sans-serif;
  font-size: 12.5px;
  font-weight: 700;
  color: var(--marron);
  display: flex;
  align-items: center;
  gap: 4px;
  flex-wrap: wrap;
}
.req { color: var(--rojo); font-size: 14px; }
.field-note { font-size: 11px; font-weight: 500; color: var(--gris-txt); }

.form-input {
  width: 100%;
  padding: 11px 13px;
  background: rgba(255,255,255,0.85);
  border: 1.5px solid rgba(255,255,255,0.9);
  border-radius: 10px;
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  color: var(--marron);
  outline: none;
  transition: border-color .15s;
  -webkit-appearance: none;
  appearance: none;
  box-sizing: border-box;
}
.form-input::placeholder { color: var(--gris-txt); }
.form-input:focus { border-color: var(--amarillo); }
.form-input.error { border-color: var(--rojo); }
.form-textarea { resize: vertical; min-height: 76px; }

/* WA input group */
.wa-wrap {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.85);
  border: 1.5px solid rgba(255,255,255,0.9);
  border-radius: 10px;
  overflow: hidden;
  transition: border-color .15s;
}
.wa-wrap:focus-within { border-color: var(--amarillo); }
.wa-wrap.valid   { border-color: var(--verde); }
.wa-wrap.invalid { border-color: var(--rojo); }
.wa-prefix { padding: 0 8px 0 12px; font-size: 18px; flex-shrink: 0; }
.wa-input  { flex: 1; border: none !important; border-radius: 0 !important; padding: 11px 0; background: transparent; }
.wa-input:focus { border: none; outline: none; }
.wa-status { padding: 0 10px; font-size: 16px; flex-shrink: 0; }

/* Checkbox */
.checkbox-label {
  display: flex;
  align-items: center;
  gap: 10px;
  cursor: pointer;
  font-family: 'Inter', sans-serif;
  font-size: 13.5px;
  color: var(--marron);
  user-select: none;
}
.checkbox-input { position: absolute; opacity: 0; width: 0; height: 0; }
.checkbox-box {
  width: 20px;
  height: 20px;
  border-radius: 6px;
  border: 1.5px solid rgba(255,255,255,0.9);
  background: rgba(255,255,255,0.85);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background .15s, border-color .15s;
}
.checkbox-input:checked + .checkbox-box {
  background: var(--amarillo);
  border-color: var(--amarillo);
}
.checkbox-input:checked + .checkbox-box::after {
  content: '';
  display: block;
  width: 5px;
  height: 9px;
  border: 2px solid var(--marron);
  border-top: none;
  border-left: none;
  transform: rotate(45deg) translate(-1px, -1px);
}
.checkbox-input:focus-visible + .checkbox-box {
  outline: 2px solid var(--amarillo);
  outline-offset: 2px;
}

/* errors */
.field-error { font-size: 11.5px; font-weight: 600; color: var(--rojo); min-height: 14px; }
.form-error  { font-size: 12.5px; text-align: center; padding: 10px; background: #fef2f2; border-radius: 10px; margin-bottom: 8px; }

/* submit */
.btn-submit {
  width: 100%;
  min-height: 48px;
  background: var(--marron);
  color: #fff;
  border: none;
  border-radius: 10px;
  font-family: 'Inter', sans-serif;
  font-size: 15px;
  font-weight: 700;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  transition: opacity .15s, transform .1s;
  -webkit-tap-highlight-color: transparent;
}
.btn-submit:hover:not(:disabled) { opacity: .88; }
.btn-submit:disabled { opacity: .6; cursor: not-allowed; }
.btn-submit:active:not(:disabled) { transform: scale(.98); }

.spinner {
  width: 18px;
  height: 18px;
  border: 2.5px solid rgba(255,255,255,.35);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin .7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* success */
.success-banner {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 16px;
  border-radius: 14px;
  background: #f0fdf4;
  border: 1.5px solid #bbf7d0;
}
.success-icon {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--verde);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 700;
  flex-shrink: 0;
}
.success-banner strong { display: block; font-size: 14px; color: #15803d; margin-bottom: 4px; }
.success-banner p { font-size: 12.5px; color: #166534; margin: 0; }

@media (prefers-reduced-motion: reduce) {
  .vet-card, .btn-wa, .chip { transition: none; }
  .vet-card:hover { transform: none; }
  .spinner { animation: none; }
}
</style>

<script>
(function () {
  /* ── Real-time search + filter ─────────────────────────────────── */
  const searchInput = document.getElementById('searchVets')
  const chip24h     = document.getElementById('chip24h')
  const noResults   = document.getElementById('noResults')
  const cards       = Array.from(document.querySelectorAll('.vet-card'))

  let activeZona = ''
  let only24h    = false

  function applyFilters () {
    const q = (searchInput ? searchInput.value.toLowerCase().trim() : '')
    let visible = 0
    cards.forEach(function (card) {
      const nombre  = card.dataset.nombre  || ''
      const zona    = card.dataset.zona    || ''
      const zonaKey = card.dataset.zonakey || ''
      const is24h   = card.dataset.is24h === 'true'
      const matchQ    = !q || nombre.includes(q) || zona.includes(q)
      const matchZona = !activeZona || zonaKey.includes(activeZona.toLowerCase())
      const match24h  = !only24h || is24h
      const show = matchQ && matchZona && match24h
      card.style.display = show ? '' : 'none'
      if (show) visible++
    })
    if (noResults) noResults.style.display = visible === 0 ? 'flex' : 'none'
  }

  if (searchInput) {
    searchInput.addEventListener('input', applyFilters)
  }

  // Zone chips
  document.querySelectorAll('.chip-zona').forEach(function (btn) {
    btn.addEventListener('click', function () {
      const zona = btn.dataset.zona || ''
      if (activeZona === zona) {
        activeZona = ''
        btn.classList.remove('chip--active')
        btn.setAttribute('aria-pressed', 'false')
      } else {
        activeZona = zona
        document.querySelectorAll('.chip-zona').forEach(function (b) {
          b.classList.remove('chip--active')
          b.setAttribute('aria-pressed', 'false')
        })
        btn.classList.add('chip--active')
        btn.setAttribute('aria-pressed', 'true')
      }
      applyFilters()
    })
  })

  // 24h chip
  if (chip24h) {
    chip24h.addEventListener('click', function () {
      only24h = !only24h
      chip24h.classList.toggle('chip--active', only24h)
      chip24h.setAttribute('aria-pressed', String(only24h))
      applyFilters()
    })
  }

  /* ── Form submission ───────────────────────────────────────────── */
  const WA_RE   = /^04[0-9]{2}[0-9]{7}$/
  const form    = document.getElementById('vetForm')
  const waInput = document.getElementById('vet-whatsapp')
  const waWrap  = document.getElementById('waWrap')
  const waStatus = document.getElementById('waStatus')
  const submit  = document.getElementById('vetSubmit')
  const btnLabel = document.getElementById('btnLabel')
  const spinner = document.getElementById('btnSpinner')
  const formErr = document.getElementById('formError')
  const success = document.getElementById('vetSuccess')

  if (!form || !waInput || !waWrap || !submit) return

  waInput.addEventListener('input', function () {
    const val = waInput.value.replace(/\D/g, '').slice(0, 11)
    waInput.value = val
    if (!val) {
      waWrap.classList.remove('valid', 'invalid')
      waStatus.textContent = ''
    } else if (WA_RE.test(val)) {
      waWrap.classList.remove('invalid'); waWrap.classList.add('valid')
      waStatus.textContent = '✓'
      clearErr('whatsapp')
    } else {
      waWrap.classList.remove('valid'); waWrap.classList.add('invalid')
      waStatus.textContent = ''
    }
  })

  function setErr (key, msg) {
    var el  = document.getElementById('err-' + key)
    var inp = document.getElementById('vet-' + key)
    if (el) el.textContent = msg
    if (inp) inp.classList.add('error')
  }
  function clearErr (key) {
    var el  = document.getElementById('err-' + key)
    var inp = document.getElementById('vet-' + key)
    if (el) el.textContent = ''
    if (inp) inp.classList.remove('error')
  }

  function validate () {
    var ok = true
    var nombre = document.getElementById('vet-nombre').value.trim()
    if (!nombre) { setErr('nombre', '¿Cuál es tu nombre o clínica?'); ok = false }
    var zona = document.getElementById('vet-zona').value.trim()
    if (zona.length < 5) { setErr('zona', 'Escribe la zona (mínimo 5 caracteres)'); ok = false }
    var wa = waInput.value.trim()
    if (!WA_RE.test(wa)) { setErr('whatsapp', 'Número venezolano: 04XX + 7 dígitos'); ok = false }
    return ok
  }

  form.addEventListener('submit', async function (e) {
    e.preventDefault()
    formErr.textContent = ''
    ;['nombre', 'zona', 'whatsapp'].forEach(clearErr)
    if (!validate()) return

    submit.disabled = true
    btnLabel.style.display = 'none'
    spinner.style.display = ''

    var payload = {
      nombre:    document.getElementById('vet-nombre').value.trim(),
      zona:      document.getElementById('vet-zona').value.trim(),
      servicios: document.getElementById('vet-servicios').value.trim() || null,
      horario:   document.getElementById('vet-horario').value.trim()   || null,
      whatsapp:  waInput.value.trim(),
      gratuito:  document.getElementById('vet-gratuito').checked
    }

    try {
      var res  = await fetch('/api/vets', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      })
      var data = await res.json().catch(function () { return {} })
      if (!res.ok) throw new Error(data.error || 'Error al enviar. Intenta de nuevo.')
      form.style.display = 'none'
      success.style.display = 'flex'
    } catch (err) {
      formErr.textContent = err.message
      submit.disabled = false
      btnLabel.style.display = ''
      spinner.style.display = 'none'
    }
  })
})()
</script>
