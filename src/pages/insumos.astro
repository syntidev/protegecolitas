---
import Base from '../layouts/Base.astro'
import { supabase } from '../lib/supabase'

const { data: necesidades } = await supabase
  .from('necesidades')
  .select('id, item, cantidad_requerida, cantidad_recibida, prioridad, updated_at')
  .order('prioridad', { ascending: true })

function getPct(recibida: number, requerida: number): number {
  if (!requerida) return 0
  return Math.min(Math.round((recibida / requerida) * 100), 100)
}

function getPrioridad(recibida: number, requerida: number, campo: string): string {
  const pct = getPct(recibida, requerida)
  if (campo === 'cubierto' || pct >= 100) return 'cubierto'
  if (campo === 'critico' || pct < 30) return 'critico'
  return 'urgente'
}

function fmtDate(dateStr: string): string {
  if (!dateStr) return ''
  const d = new Date(dateStr)
  return d.toLocaleDateString('es-VE', { day: 'numeric', month: 'short' })
}

const waBase = 'https://wa.me/584242042786'
---
<Base title="Necesidades urgentes — Protege Colitas">
  <div class="page">
    <header class="page-header">
      <a href="/" class="back-btn" aria-label="Volver al inicio">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M12 4L6 10l6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <div class="header-text">
        <span class="brand">Protege Colitas</span>
      </div>
    </header>

    <main class="content">
      <div class="hero-section">
        <h1 class="page-title">Lo que más<br /><em>necesitamos</em></h1>
        <p class="page-sub">Cada donación suma. Coordina por WhatsApp.</p>
      </div>

      {necesidades && necesidades.length > 0 ? (
        <div class="needs-list">
          {necesidades.map((n) => {
            const pct = getPct(n.cantidad_recibida ?? 0, n.cantidad_requerida)
            const prioridad = getPrioridad(n.cantidad_recibida ?? 0, n.cantidad_requerida, n.prioridad)
            const waText = encodeURIComponent(`Quiero donar ${n.item}`)
            return (
              <div class={`need-card need-${prioridad}`}>
                <div class="need-top">
                  <div class="need-info">
                    <span class={`badge badge-${prioridad}`}>
                      {prioridad === 'critico' ? 'Crítico' : prioridad === 'urgente' ? 'Urgente' : 'Cubierto'}
                    </span>
                    <h2 class="need-item">{n.item}</h2>
                    {n.updated_at && (
                      <span class="need-date">Actualizado {fmtDate(n.updated_at)}</span>
                    )}
                  </div>
                  <div class="need-pct">{pct}%</div>
                </div>

                <div class="progress-track">
                  <div
                    class={`progress-fill fill-${prioridad}`}
                    style={`width: ${pct}%`}
                    role="progressbar"
                    aria-valuenow={pct}
                    aria-valuemin={0}
                    aria-valuemax={100}
                    aria-label={`${n.item}: ${pct}% recibido`}
                  ></div>
                </div>

                <div class="need-bottom">
                  <span class="need-qty">
                    {n.cantidad_recibida ?? 0} / {n.cantidad_requerida} unidades
                  </span>
                  <a
                    href={`${waBase}?text=${waText}`}
                    class="btn-donar"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.119.553 4.107 1.516 5.836L.057 23.447a.5.5 0 00.611.612l5.638-1.471A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.891 0-3.666-.5-5.197-1.373l-.371-.22-3.847 1.003 1.022-3.737-.242-.384A9.942 9.942 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
                    Donar esto →
                  </a>
                </div>
              </div>
            )
          })}
        </div>
      ) : (
        <div class="empty-state">
          <div class="empty-icon">📦</div>
          <p class="empty-msg">Pronto publicaremos qué necesitamos.</p>
          <p class="empty-sub">Escríbenos y te avisamos.</p>
        </div>
      )}

      <div class="wa-footer">
        <p class="wa-footer-text">¿Tienes algo para donar y no ves tu item?</p>
        <a
          href={`${waBase}?text=${encodeURIComponent('Quiero donar insumos para las mascotas')}`}
          class="btn-wa-general"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.119.553 4.107 1.516 5.836L.057 23.447a.5.5 0 00.611.612l5.638-1.471A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.891 0-3.666-.5-5.197-1.373l-.371-.22-3.847 1.003 1.022-3.737-.242-.384A9.942 9.942 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
          Escríbenos por WhatsApp
        </a>
      </div>
    </main>
  </div>
</Base>

<style>
.page { min-height: 100dvh; display: flex; flex-direction: column; }

.page-header {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 16px;
  background: var(--blanco);
  border-bottom: 1px solid var(--border);
  position: sticky;
  top: 0;
  z-index: 20;
}
.back-btn {
  width: 44px; height: 44px;
  display: flex; align-items: center; justify-content: center;
  border-radius: 10px;
  background: var(--gris-bg);
  color: var(--marron);
  text-decoration: none;
  flex-shrink: 0;
  transition: background .15s;
}
.back-btn:hover { background: var(--border); }
.brand { font-family: 'Fredoka', sans-serif; font-weight: 700; font-size: 17px; color: var(--marron); }

.content { padding: 0 16px 100px; max-width: 600px; margin: 0 auto; width: 100%; }

.hero-section { padding: 28px 0 24px; }
.page-title {
  font-family: 'Fredoka', sans-serif;
  font-weight: 700;
  font-size: clamp(28px, 7vw, 40px);
  line-height: 1.05;
  color: var(--marron);
  margin-bottom: 8px;
  text-wrap: balance;
}
.page-title em { font-style: normal; color: var(--amarillo); }
.page-sub { font-size: 15px; color: var(--gris-txt); line-height: 1.5; }

.needs-list { display: flex; flex-direction: column; gap: 14px; }

.need-card {
  background: var(--blanco);
  border-radius: 16px;
  padding: 18px 16px;
  border: 1.5px solid var(--border);
  transition: box-shadow .15s;
}
.need-card:hover { box-shadow: 0 4px 16px rgba(107,58,42,.08); }

.need-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; gap: 12px; }
.need-info { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
.need-pct { font-family: 'Fredoka', sans-serif; font-weight: 700; font-size: 22px; color: var(--marron); flex-shrink: 0; }

.badge {
  display: inline-flex; align-items: center;
  padding: 3px 10px; border-radius: 20px;
  font-size: 11px; font-weight: 700; letter-spacing: .04em; text-transform: uppercase;
  width: fit-content;
}
.badge-critico  { background: #fef2f2; color: var(--rojo); }
.badge-urgente  { background: #fefce8; color: #92400e; }
.badge-cubierto { background: #f0fdf4; color: var(--verde); }

.need-item { font-size: 17px; font-weight: 700; color: var(--marron); line-height: 1.2; }
.need-date { font-size: 11px; color: var(--gris-txt); }

.progress-track {
  height: 8px; border-radius: 4px; background: var(--gris-bg);
  overflow: hidden; margin-bottom: 12px;
}
.progress-fill {
  height: 100%; border-radius: 4px;
  transition: width .6s cubic-bezier(.4,0,.2,1);
}
.fill-critico  { background: var(--rojo); }
.fill-urgente  { background: var(--amarillo); }
.fill-cubierto { background: var(--verde); }

.need-bottom { display: flex; justify-content: space-between; align-items: center; gap: 10px; flex-wrap: wrap; }
.need-qty { font-size: 13px; color: var(--gris-txt); font-weight: 500; }

.btn-donar {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 9px 16px; border-radius: 10px;
  background: #25D366; color: #fff;
  font-size: 13px; font-weight: 700; text-decoration: none;
  transition: opacity .15s, transform .1s;
  white-space: nowrap;
  min-height: 44px;
}
.btn-donar:hover { opacity: .9; }
.btn-donar:active { transform: scale(.97); }

.empty-state {
  display: flex; flex-direction: column; align-items: center;
  padding: 60px 20px; text-align: center;
}
.empty-icon { font-size: 56px; margin-bottom: 16px; }
.empty-msg { font-size: 17px; font-weight: 700; color: var(--marron); margin-bottom: 6px; }
.empty-sub { font-size: 14px; color: var(--gris-txt); }

.wa-footer {
  margin-top: 32px; padding: 24px 0;
  display: flex; flex-direction: column; align-items: center; gap: 12px;
  border-top: 1px solid var(--border);
}
.wa-footer-text { font-size: 14px; color: var(--gris-txt); text-align: center; }
.btn-wa-general {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 14px 24px; border-radius: 14px;
  background: #25D366; color: #fff;
  font-size: 15px; font-weight: 700; text-decoration: none;
  min-height: 52px;
  transition: opacity .15s;
}
.btn-wa-general:hover { opacity: .9; }

@media (prefers-reduced-motion: reduce) {
  .progress-fill { transition: none; }
}
</style>
