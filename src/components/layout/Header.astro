---
// Header — Protege Colitas
---
<header class="site-header">
  <div class="container header-row">
    <a href="/" class="brand" aria-label="Protege Colitas — Inicio">
      <span class="brand-icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#7A4A24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
        </svg>
      </span>
      <div class="brand-text">
        <span class="brand-name">Protege Colitas</span>
        <span class="brand-sub">Emergencia Animal · Venezuela 2026</span>
      </div>
    </a>

    <div class="search-wrap" role="search">
      <label for="hdr-search" class="sr-only">Buscar mascota</label>
      <span class="search-icon" aria-hidden="true">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </span>
      <input id="hdr-search" type="search" placeholder="Buscar por nombre, color, raza o zona..." class="search-input" aria-label="Buscar mascota" />
    </div>

    <div class="status-indicator">
      <div class="status-row">
        <span class="status-dot pulse-dot" aria-hidden="true"></span>
        <span class="status-text">ACTIVO</span>
      </div>
      <span class="status-date">Desde el 25 jun 2026</span>
    </div>
  </div>

  <div class="mobile-search container" role="search">
    <label for="hdr-search-mobile" class="sr-only">Buscar mascota</label>
    <span class="search-icon" aria-hidden="true">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/>
        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
    </span>
    <input id="hdr-search-mobile" type="search" placeholder="Buscar mascota por nombre o zona..." class="search-input" aria-label="Buscar mascota" />
  </div>
</header>

<style>
.site-header {
  position: sticky;
  top: 0;
  z-index: 50;
  background: #fff;
  border-bottom: 1px solid var(--border);
}
.header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  height: 56px;
}
@media (min-width: 768px) { .header-row { height: 64px; } }

.brand {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  text-decoration: none;
  flex-shrink: 0;
}
.brand-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 10px;
  background: var(--arena);
  flex-shrink: 0;
}
.brand-text { display: flex; flex-direction: column; }
.brand-name {
  font-size: 0.9375rem;
  font-weight: 700;
  color: var(--marron);
  line-height: 1.1;
}
.brand-sub {
  font-size: 0.6875rem;
  color: var(--texto-sec);
  line-height: 1.1;
  display: none;
}
@media (min-width: 480px) { .brand-sub { display: block; } }

.search-wrap {
  display: none;
  flex: 1;
  max-width: 32rem;
  position: relative;
}
@media (min-width: 768px) { .search-wrap { display: block; } }

.search-icon {
  position: absolute;
  left: 12px;
  top: 50%;
  transform: translateY(-50%);
  pointer-events: none;
  display: flex;
}
.search-input {
  width: 100%;
  padding: 9px 12px 9px 36px;
  border: 1px solid var(--border);
  border-radius: 14px;
  background: var(--fondo);
  font-size: 0.875rem;
  font-family: 'Inter', sans-serif;
  color: var(--texto);
  outline: none;
  transition: border-color .15s, box-shadow .15s;
  appearance: none;
}
.search-input::placeholder { color: var(--texto-muted); }
.search-input:focus {
  border-color: var(--accion);
  box-shadow: 0 0 0 3px rgba(201,106,27,0.12);
}

.status-indicator {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 2px;
  flex-shrink: 0;
}
.status-row { display: flex; align-items: center; gap: 5px; }
.status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--verde);
  display: inline-block;
}
.status-text {
  font-size: 0.6875rem;
  font-weight: 700;
  color: var(--verde);
  letter-spacing: 0.05em;
}
.status-date {
  font-size: 0.6875rem;
  color: var(--texto-sec);
  display: none;
}
@media (min-width: 480px) { .status-date { display: block; } }

.mobile-search {
  display: block;
  padding-bottom: 0.75rem;
  position: relative;
}
@media (min-width: 768px) { .mobile-search { display: none; } }
.mobile-search .search-input { width: 100%; }
</style>
