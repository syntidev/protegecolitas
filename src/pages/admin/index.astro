          <div class="an-section">
            <h3 class="an-section-title">Sistemas operativos</h3>
            {porOs.length > 0 ? (
              <div class="an-list">
                {(() => { const max = porOs[0]?.count ?? 1; return porOs.map(item => (
                  <div class="an-list-row">
                    <span class="an-list-name">{item.key}</span>
                    <div class="an-bar-track an-bar-track--sm"><div class="an-bar-fill" style={`width:${Math.round((item.count/max)*100)}%;background:#3B82F6`}></div></div>
                    <span class="an-list-count">{item.count}</span>
                  </div>
                ))})()}
              </div>
            ) : <p class="an-empty">Sin datos</p>}
