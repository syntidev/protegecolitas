---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
}

const { title = 'Protege Colitas', description = 'Plataforma de emergencia para reunir mascotas perdidas con sus familias tras el terremoto de Venezuela 2026.' } = Astro.props
const path = Astro.url?.pathname ?? '/'

function active(href: string) {
  return href === '/' ? path === '/' : path.startsWith(href)
}
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Nunito:wght@800;900&display=swap" rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com"></script>
  <title>{title}</title>
</head>
<body class="pb-20">
  <slot />

  <nav class="bottom-nav" role="navigation" aria-label="Navegación principal">
    <a href="/" class={`nav-item${active('/') ? ' nav-active' : ''}`} aria-current={active('/') ? 'page' : undefined} aria-label="Inicio">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
        <polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
      <span class="nav-label">Inicio</span>
    </a>

    <a href="/reportar" class={`nav-item${active('/reportar') ? ' nav-active' : ''}`} aria-current={active('/reportar') ? 'page' : undefined} aria-label="Reportar mascota">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="16"/>
        <line x1="8" y1="12" x2="16" y2="12"/>
      </svg>
      <span class="nav-label">Reportar</span>
    </a>

    <a href="/insumos" class={`nav-item${active('/insumos') ? ' nav-active' : ''}`} aria-current={active('/insumos') ? 'page' : undefined} aria-label="Insumos y necesidades">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
        <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
        <line x1="12" y1="22.08" x2="12" y2="12"/>
      </svg>
      <span class="nav-label">Insumos</span>
    </a>

    <a href="/veterinarios" class={`nav-item${active('/veterinarios') ? ' nav-active' : ''}`} aria-current={active('/veterinarios') ? 'page' : undefined} aria-label="Veterinarios voluntarios">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
      </svg>
      <span class="nav-label">Vets</span>
    </a>

    <a href="/acopio" class={`nav-item${active('/acopio') ? ' nav-active' : ''}`} aria-current={active('/acopio') ? 'page' : undefined} aria-label="Centros de acopio">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="2" y="7" width="9" height="14"/>
        <rect x="13" y="3" width="9" height="18"/>
        <line x1="2" y1="21" x2="22" y2="21"/>
      </svg>
      <span class="nav-label">Acopio</span>
    </a>

    <a href="/noticias" class={`nav-item${active('/noticias') ? ' nav-active' : ''}`} aria-current={active('/noticias') ? 'page' : undefined} aria-label="Noticias y actualizaciones">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/>
        <path d="M13.73 21a2 2 0 01-3.46 0"/>
      </svg>
      <span class="nav-label">Noticias</span>
    </a>
  </nav>
</body>
</html>

<style>
.bottom-nav {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  display: flex;
  background: #FFFFFF;
  border-top: 1px solid #E8E1D6;
  z-index: 100;
  padding-bottom: env(safe-area-inset-bottom, 0);
}
.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 3px;
  padding: 8px 4px 10px;
  text-decoration: none;
  color: #9CA3AF;
  min-height: 56px;
  transition: color .15s;
  -webkit-tap-highlight-color: transparent;
}
.nav-item:hover { color: #7A4A24; }
.nav-active { color: #C96A1B; }
.nav-label {
  font-family: 'Inter', sans-serif;
  font-size: 10px;
  font-weight: 600;
  line-height: 1;
  text-align: center;
}
.nav-active .nav-label { font-weight: 700; }

@media (min-width: 640px) {
  .bottom-nav {
    max-width: 640px;
    left: 50%;
    right: auto;
    transform: translateX(-50%);
    border-radius: 20px 20px 0 0;
    border-left: 1px solid #E8E1D6;
    border-right: 1px solid #E8E1D6;
  }
}
</style>
