---
import { supabaseAdmin } from '../lib/supabase'

const [
  { count: totalMascotas },
  { count: perdidas },
  { count: encontradas },
  { count: reunidas },
  { count: totalVets },
  { data: ultimasPerdidas },
  { data: ultimasEncontradas },
  { data: necesidades },
  { data: vets },
  { data: feedItems },
  { data: bannerActivo },
  { count: adopcion }
] = await Promise.all([
  supabaseAdmin.from('mascotas').select('*', { count: 'exact', head: true }).neq('status', 'descartado'),
  supabaseAdmin.from('mascotas').select('*', { count: 'exact', head: true }).eq('status', 'publicado').eq('tipo', 'perdido'),
  supabaseAdmin.from('mascotas').select('*', { count: 'exact', head: true }).eq('status', 'publicado').eq('tipo', 'encontrado'),
  supabaseAdmin.from('mascotas').select('*', { count: 'exact', head: true }).eq('status', 'reunido'),
  supabaseAdmin.from('vets').select('*', { count: 'exact', head: true }),
  supabaseAdmin.from('mascotas').select('id, nombre, especie, zona, foto_url, whatsapp, created_at').eq('status', 'publicado').eq('tipo', 'perdido').order('created_at', { ascending: false }).limit(6),
  supabaseAdmin.from('mascotas').select('id, nombre, especie, zona, foto_url, whatsapp, created_at').eq('status', 'publicado').eq('tipo', 'encontrado').order('created_at', { ascending: false }).limit(6),
  supabaseAdmin.from('necesidades').select('*').order('prioridad', { ascending: true }).limit(4),
  supabaseAdmin.from('vets').select('id, nombre, zona, whatsapp, servicios').limit(4),
  supabaseAdmin.from('feed').select('id, tipo, titulo, cuerpo, published_at, imagen_url, slug').order('published_at', { ascending: false }).limit(5),
  supabaseAdmin.from('banners').select('*').eq('activo', true).order('created_at', { ascending: false }).limit(1),
  supabaseAdmin.from('mascotas').select('*', { count: 'exact', head: true }).eq('status', 'publicado').eq('tipo', 'adopcion'),
])

const banner = bannerActivo?.[0] ?? null
const diasActivos = Math.floor((Date.now() - new Date('2026-06-24').getTime()) / 86400000) + 1

function waUrl(whatsapp: string | null, msg = ''): string | null {
  if (!whatsapp) return null
  const num = `58${whatsapp.slice(1)}`
  return msg ? `https://wa.me/${num}?text=${encodeURIComponent(msg)}` : `https://wa.me/${num}`
}

function getInitials(nombre: string): string {
  return nombre.split(' ').map(w => w[0]).filter(Boolean).join('').slice(0, 2).toUpperCase()
}

function progColor(pct: number): string {
  if (pct < 30) return '#CC1F1F'
  if (pct < 70) return '#F5A623'
  return '#16A34A'
}

function feedDate(iso: string | null): { day: string; mon: string } {
  if (!iso) return { day: '--', mon: '---' }
  const d = new Date(iso)
  return {
    day: d.getDate().toString().padStart(2, '0'),
    mon: d.toLocaleDateString('es-VE', { month: 'short' }).toUpperCase().replace('.', ''),
  }
}
