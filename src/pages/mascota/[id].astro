---
import Base from '../../layouts/Base.astro'
import { supabaseAdmin } from '../../lib/supabase'

const { id } = Astro.params

if (!id) return Astro.redirect('/mascotas')

const { data: m } = await supabaseAdmin
  .from('mascotas')
  .select('id, nombre, especie, descripcion, color, tamanio, zona, tipo, status, foto_url, foto_url_2, foto_url_3, whatsapp, contacto_nombre, senias, created_at, latitud, longitud')
  .eq('id', id)
  .eq('status', 'publicado')
  .maybeSingle()

if (!m) return Astro.redirect('/mascotas')

const waNum = m.whatsapp ? `58${m.whatsapp.slice(1)}` : null
const waText = m.tipo === 'adopcion'
  ? encodeURIComponent(`Hola, vi a ${m.nombre ?? 'esta mascota'} en protegecolitas.org/adoptar y me gustaría adoptarlo. ¿Podría darme más información?`)
  : encodeURIComponent(`Hola, vi el reporte de ${m.nombre ?? 'una mascota'} (${m.especie}, zona ${m.zona}) en protegecolitas.org y quiero ayudar.`)
const waHref = waNum ? `https://wa.me/${waNum}?text=${waText}` : null

const fechaStr = new Date(m.created_at).toLocaleDateString('es-VE', {
  day: 'numeric', month: 'long', year: 'numeric'
})

const reunido = m.status === 'reunido'
const mapsHref = (m.latitud && m.longitud)
  ? `https://www.google.com/maps?q=${m.latitud},${m.longitud}`
  : null
---
<Base
  title={`${m.nombre ?? 'Mascota'} — Protege Colitas`}
  ogTitle={`${m.nombre ?? 'Mascota'} · ${m.tipo === 'perdido' ? 'Se busca' : 'Encontrada'} en ${m.zona}`}
  ogDescription={m.descripcion ?? `${m.especie} ${m.tipo === 'perdido' ? 'perdido' : 'encontrado'} en ${m.zona}. ¿Lo has visto?`}
  ogImage={m.foto_url ?? 'https://protegecolitas.org/banner_mobile.png'}
  ogUrl={`https://protegecolitas.org/mascota/${m.id}`}
>
  <div class="detail-page">

    <!-- Back link (non-sticky, top of content) -->
    <a href="/mascotas" class="back-link">← Volver a mascotas</a>

    <!-- Reunido banner -->
    {reunido && (
      <div class="banner-reunido" role="status">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        Ya fue reunido con su familia
      </div>
    )}

    <!-- Adopción banner -->
    {m.tipo === 'adopcion' && (
      <div class="banner-adopcion" role="status">
        🏠 Esta mascota busca hogar permanente
      </div>
    )}

    <!-- Photo hero -->
    {m.foto_url
      ? (
        <img id="foto-principal" class="hero-photo" src={m.foto_url} alt={m.nombre ?? 'mascota'} style="cursor:zoom-in" />
      ) : (
        <div class="foto-placeholder" aria-label="Sin foto">🐾</div>
      )
    }

    <!-- Thumbnail row -->
    {(m.foto_url_2 || m.foto_url_3) && (
      <div class="thumbnail-row">
        {m.foto_url_2 && (
          <img src={m.foto_url_2} alt="Foto adicional 2" class="thumb-mini" loading="lazy" />
        )}
        {m.foto_url_3 && (
          <img src={m.foto_url_3} alt="Foto adicional 3" class="thumb-mini" loading="lazy" />
        )}
      </div>
    )}

    <!-- Content card (glass) -->
    <div class="content-card">

      <!-- Badge estado -->
      <span class={`badge-estado badge-${m.tipo === 'adopcion' ? 'adopcion' : m.tipo ?? 'perdido'}`}>
        {m.tipo === 'adopcion' ? 'En adopción' : m.tipo === 'encontrado' ? 'Encontrado' : 'Perdido'}
      </span>

      <!-- Nombre -->
      <h1 class="pet-nombre">{m.nombre ?? 'Sin nombre'}</h1>

      <!-- Data table -->
      <dl class="data-table glass-card">
        <div class="data-row">
          <dt class="data-label">Especie</dt>
          <dd class="data-val">{m.especie}</dd>
        </div>
        {m.color && (
          <div class="data-row">
            <dt class="data-label">Color</dt>
            <dd class="data-val">{m.color}</dd>
          </div>
        )}
        {m.senias && (
          <div class="data-row">
            <dt class="data-label">Señas particulares</dt>
            <dd class="data-val">{m.senias}</dd>
          </div>
        )}
        {m.contacto_nombre && (
          <div class="data-row">
            <dt class="data-label">Contacto</dt>
            <dd class="data-val">{m.contacto_nombre}</dd>
          </div>
        )}
        {m.tamanio && (
          <div class="data-row">
            <dt class="data-label">Tamaño</dt>
            <dd class="data-val">{m.tamanio}</dd>
          </div>
        )}
        <div class="data-row">
            <dt class="data-label">WhatsApp</dt>
            <dd class="data-val"><a href={"https://wa.me/58" + (m.whatsapp?.slice(1) ?? "")} style="color:#16A34A;font-weight:700">{m.whatsapp}</a></dd>
          </div>
          <div class="data-row">
            <dt class="data-label">Zona</dt>
          <dd class="data-val">{m.zona}</dd>
        </div>
        {mapsHref && (
          <div class="data-row">
            <dt class="data-label">Mapa</dt>
            <dd class="data-val">
              <a href={mapsHref} target="_blank" rel="noopener noreferrer" class="maps-link">Ver en Google Maps →</a>
            </dd>
          </div>
        )}
        {m.descripcion && (
          <div class="data-row data-row--desc">
            <dt class="data-label">Descripción</dt>
            <dd class="data-val data-val--desc">{m.descripcion}</dd>
          </div>
        )}
      </dl>

      <!-- Actions -->
      <div class="actions">
        {waHref && (
          <a href={waHref} class={`btn-wa${m.tipo === 'adopcion' ? ' btn-wa-adopt' : ''}`} target="_blank" rel="noopener noreferrer">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.119.553 4.107 1.516 5.836L.057 23.447a.5.5 0 00.611.612l5.638-1.471A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.891 0-3.666-.5-5.197-1.373l-.371-.22-3.847 1.003 1.022-3.737-.242-.384A9.942 9.942 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
            {m.tipo === 'adopcion' ? '🏠 Quiero adoptarlo' : 'WhatsApp directo'}
          </a>
        )}
        <button
          class="btn-share"
          id="btnCompartir"
          type="button"
          data-url={`https://protegecolitas.org/mascota/${m.id}`}
          data-nombre={m.nombre ?? 'Mascota'}
          data-zona={m.zona ?? ''}
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          <span id="compartirLabel">Compartir este reporte</span>
        </button>
      </div>

      <!-- Fecha -->
      <p class="fecha-reporte">Reportado el {fechaStr}</p>

    </div><!-- /content-card -->

  </div><!-- /detail-page -->

  <!-- Menú de compartir propio — funciona en TODOS los navegadores (no depende de navigator.share) -->
  <dialog id="share-dialog" class="share-dialog" aria-label="Compartir mascota">
    <div class="share-sheet">
      <p class="share-sheet-title">Compartir este reporte</p>
      <div class="share-options">
        <a id="sh-wa" class="share-opt share-link" target="_blank" rel="noopener noreferrer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="#25D366" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.119.553 4.107 1.516 5.836L.057 23.447a.5.5 0 00.611.612l5.638-1.471A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
          WhatsApp
        </a>
        <a id="sh-tg" class="share-opt share-link" target="_blank" rel="noopener noreferrer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="#229ED9" aria-hidden="true"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
          Telegram
        </a>
        <a id="sh-fb" class="share-opt share-link" target="_blank" rel="noopener noreferrer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="#1877F2" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          Facebook
        </a>
        <a id="sh-tw" class="share-opt share-link" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="#000" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.631 5.905-5.631zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          X
        </a>
        <button id="sh-copy" type="button" class="share-opt share-opt--full">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          <span id="sh-copy-label">Copiar enlace</span>
        </button>
      </div>
      <button id="sh-close" type="button" class="share-close">Cerrar</button>
    </div>
  </dialog>
</Base>

<style>
/* ─── Layout ─── */
.detail-page {
  max-width: 600px;
  margin: 0 auto;
  padding: 0 0 80px;
  width: 100%;
}

/* ─── Back link ─── */
.back-link {
  display: block;
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  color: var(--marron);
  text-decoration: none;
  padding: 16px;
}
.back-link:hover { text-decoration: underline; }

/* ─── Reunido banner ─── */
.banner-reunido {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 14px 16px;
  margin: 0 16px 12px;
  background: #f0fdf4;
  border: 1px solid #bbf7d0;
  border-radius: var(--radius-sm);
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  font-weight: 700;
  color: var(--verde);
}
.banner-adopcion {
  padding: 14px 16px;
  margin: 0 16px 12px;
  background: #f0fdf4;
  border: 1px solid #bbf7d0;
  border-radius: var(--radius-sm);
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  font-weight: 700;
  color: var(--verde);
}

/* ─── Hero photo ─── */
.hero-photo {
  width: 100%;
  aspect-ratio: 1/1;
  object-fit: cover;
  border-radius: var(--radius);
  margin-bottom: 12px;
  display: block;
}

.foto-placeholder {
  width: 100%;
  height: 220px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64px;
  background: var(--gris-bg);
  border-radius: var(--radius);
  margin-bottom: 12px;
}

/* ─── Thumbnail row ─── */
.thumbnail-row {
  display: flex;
  flex-direction: row;
  gap: 8px;
  padding: 0 0 12px;
}

.thumb-mini {
  width: 80px;
  height: 80px;
  object-fit: cover;
  border-radius: 8px;
  cursor: pointer;
  border: 2px solid transparent;
  transition: border-color 0.15s;
  flex-shrink: 0;
  display: block;
}
.thumb-mini:hover,
.thumb-mini--active { border-color: var(--amarillo); }

/* ─── Content card (glass) ─── */
.content-card {
  background: var(--card);
  backdrop-filter: var(--card-blur);
  -webkit-backdrop-filter: var(--card-blur);
  border: var(--card-border);
  box-shadow: var(--card-shadow);
  border-radius: var(--radius);
  padding: 20px 16px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

/* ─── Badge estado ─── */
.badge-estado {
  display: inline-block;
  align-self: flex-start;
  font-family: 'Inter', sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  padding: 4px 10px;
  border-radius: 6px;
}
.badge-perdido    { background: var(--rojo); color: #fff; }
.badge-encontrado { background: var(--azul); color: #fff; }
.badge-adopcion   { background: var(--verde); color: #fff; }
.btn-wa-adopt     { background: var(--verde); }

/* ─── Nombre ─── */
.pet-nombre {
  font-family: 'Fredoka', sans-serif;
  font-weight: 700;
  font-size: 28px;
  color: var(--marron);
  line-height: 1.15;
  margin: 0;
  text-wrap: balance;
}

/* ─── Data table ─── */
.data-table {
  margin: 0;
  padding: 0;
  list-style: none;
}

.glass-card {
  background: var(--card);
  backdrop-filter: var(--card-blur);
  -webkit-backdrop-filter: var(--card-blur);
  border: var(--card-border);
  box-shadow: var(--card-shadow);
  border-radius: var(--radius-sm);
  overflow: hidden;
}

.data-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
  padding: 12px 14px;
  border-bottom: 1px solid rgba(229, 221, 208, 0.6);
}
.data-row:last-child { border-bottom: none; }

.data-row--desc { flex-direction: column; gap: 6px; }

.data-label {
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  font-weight: 500;
  color: var(--gris-txt);
  flex-shrink: 0;
}
.data-val {
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  font-weight: 700;
  color: var(--marron);
  text-align: right;
}
.data-val--desc {
  text-align: left;
  font-weight: 400;
  font-size: 14px;
  line-height: 1.6;
  color: var(--marron);
}
.maps-link {
  color: var(--azul);
  text-decoration: none;
  font-size: 13px;
  font-weight: 600;
}
.maps-link:hover { text-decoration: underline; }

/* ─── Actions ─── */
.actions {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.btn-wa {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  width: 100%;
  min-height: 48px;
  border-radius: var(--radius-sm);
  background: #25D366;
  color: #fff;
  font-family: 'Inter', sans-serif;
  font-size: 16px;
  font-weight: 700;
  text-decoration: none;
  border: none;
  cursor: pointer;
  transition: var(--transition);
  -webkit-tap-highlight-color: transparent;
}
.btn-wa:hover { opacity: 0.9; }
.btn-wa:active { transform: scale(0.98); }

.btn-share {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  width: 100%;
  min-height: 48px;
  border-radius: var(--radius-sm);
  background: rgba(255, 255, 255, 0.80);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1.5px solid var(--marron);
  color: var(--marron);
  font-family: 'Inter', sans-serif;
  font-size: 16px;
  font-weight: 700;
  cursor: pointer;
  transition: var(--transition);
  -webkit-tap-highlight-color: transparent;
}
.btn-share:hover { opacity: 0.85; }
.btn-share:active { transform: scale(0.98); }

/* ─── Fecha ─── */
.fecha-reporte {
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  color: var(--gris-txt);
  text-align: center;
  margin: 0;
}

/* ─── Share dialog (menú propio, funciona en todos los navegadores) ─── */
.share-dialog {
  border: none; padding: 0; background: transparent;
  width: min(100%, 440px); margin: auto auto 0;
}
.share-dialog::backdrop {
  background: rgba(61,28,2,0.45);
  backdrop-filter: blur(2px); -webkit-backdrop-filter: blur(2px);
}
.share-sheet {
  background: #fff; border-radius: 20px 20px 0 0;
  padding: 18px 16px calc(16px + env(safe-area-inset-bottom, 0px));
  box-shadow: 0 -10px 44px rgba(61,28,2,0.28);
}
@media (min-width: 560px) {
  .share-dialog { margin: auto; }
  .share-sheet  { border-radius: 20px; }
}
.share-sheet-title {
  font-family: 'Fredoka', sans-serif; font-weight: 700; font-size: 16px;
  color: var(--marron); margin: 0 0 14px; text-align: center;
}
.share-options { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 12px; }
.share-opt {
  display: flex; align-items: center; gap: 10px;
  min-height: 52px; padding: 0 14px; border-radius: 12px;
  border: 1px solid var(--border, #E8DDD0); background: #fff;
  font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600;
  color: var(--marron); text-decoration: none; cursor: pointer;
  transition: background 0.15s, border-color 0.15s;
  -webkit-tap-highlight-color: transparent;
}
.share-opt:hover, .share-opt:active { background: var(--crema, #FDF8F0); border-color: var(--amarillo); }
.share-opt--full { grid-column: 1 / -1; justify-content: center; }
.share-close {
  width: 100%; min-height: 48px; border: none; border-radius: 12px;
  background: var(--marron); color: #fff;
  font-family: 'Inter', sans-serif; font-weight: 700; font-size: 15px;
  cursor: pointer; transition: opacity 0.15s;
}
.share-close:hover { opacity: 0.88; }

@media (prefers-reduced-motion: reduce) {
  .btn-wa, .btn-share, .thumb-mini { transition: none; }
}
</style>

<script>
  // Astro procesa este <script> como módulo ES (scope propio, defer). SIN IIFE:
  // dos IIFEs adyacentes sin ';' se concatenaban -> "(...)() is not a function".

  // ── Galería: miniaturas + lightbox ──
  const principal = document.getElementById('foto-principal') as HTMLImageElement | null;
  if (principal) {
    principal.addEventListener('click', () => {
      const overlay = document.createElement('div');
      overlay.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.92);z-index:9999;display:flex;align-items:center;justify-content:center;cursor:zoom-out';
      overlay.setAttribute('role', 'dialog');
      overlay.setAttribute('aria-label', 'Vista ampliada de la foto');
      const img = document.createElement('img');
      img.src = principal.src;
      img.style.cssText = 'max-width:95vw;max-height:95vh;object-fit:contain;border-radius:8px';
      overlay.appendChild(img);
      const close = () => overlay.remove();
      overlay.addEventListener('click', close);
      const onKey = (e: KeyboardEvent) => { if (e.key === 'Escape') { close(); document.removeEventListener('keydown', onKey); } };
      document.addEventListener('keydown', onKey);
      document.body.appendChild(overlay);
    });

    document.querySelectorAll<HTMLImageElement>('.thumb-mini').forEach((thumb) => {
      thumb.addEventListener('click', () => {
        principal.src = thumb.src;
        document.querySelectorAll('.thumb-mini').forEach((t) => t.classList.remove('thumb-mini--active'));
        thumb.classList.add('thumb-mini--active');
      });
    });
  }

  // ── Compartir: menú propio que funciona en TODOS los navegadores ──
  const dlg = document.getElementById('share-dialog') as HTMLDialogElement | null;
  let shareUrl = '';

  const setHref = (id: string, href: string) => {
    const el = document.getElementById(id) as HTMLAnchorElement | null;
    if (el) el.href = href;
  };

  const openShare = (data: { url: string; text: string }) => {
    shareUrl = data.url;
    const u = encodeURIComponent(data.url);
    const txt = encodeURIComponent(data.text);
    const both = encodeURIComponent(data.text + ' ' + data.url);
    setHref('sh-wa', 'https://wa.me/?text=' + both);
    setHref('sh-tg', 'https://t.me/share/url?url=' + u + '&text=' + txt);
    setHref('sh-fb', 'https://www.facebook.com/sharer/sharer.php?u=' + u);
    setHref('sh-tw', 'https://twitter.com/intent/tweet?text=' + txt + '&url=' + u);
    if (!dlg) { window.prompt('Copia y comparte este enlace:', data.url); return; }
    if (typeof dlg.showModal === 'function') { try { dlg.showModal(); return; } catch (_) {} }
    dlg.setAttribute('open', '');
  };

  const closeShare = () => {
    if (!dlg) return;
    if (typeof dlg.close === 'function' && dlg.open) dlg.close();
    else dlg.removeAttribute('open');
  };

  const copiado = () => {
    const lbl = document.getElementById('sh-copy-label');
    if (!lbl) return;
    const prev = lbl.textContent;
    lbl.textContent = '✓ ¡Enlace copiado!';
    setTimeout(() => { lbl.textContent = prev; }, 1800);
  };

  const legacyCopy = (url: string) => {
    try {
      const ta = document.createElement('textarea');
      ta.value = url;
      ta.setAttribute('readonly', '');
      ta.style.position = 'fixed';
      ta.style.top = '-1000px';
      document.body.appendChild(ta);
      ta.select();
      ta.setSelectionRange(0, url.length);
      document.execCommand('copy');
      document.body.removeChild(ta);
      copiado();
    } catch (_) {
      window.prompt('Copia este enlace:', url);
    }
  };

  const copyLink = (url: string) => {
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(url).then(copiado, () => legacyCopy(url));
    } else {
      legacyCopy(url);
    }
  };

  document.addEventListener('click', (e) => {
    const t = e.target as HTMLElement;
    const shareBtn = t.closest('#btnCompartir');
    if (shareBtn) {
      e.preventDefault();
      const nombre = shareBtn.getAttribute('data-nombre') || 'esta mascota';
      const zona = shareBtn.getAttribute('data-zona') || '';
      openShare({
        url: shareBtn.getAttribute('data-url') || window.location.href,
        text: '¿La has visto? ' + (zona ? 'Vista en ' + zona + '. ' : '') + 'Ayuda a reunir a ' + nombre + ' con su familia.'
      });
      return;
    }
    if (t.closest('#sh-copy')) { e.preventDefault(); copyLink(shareUrl); return; }
    if (t.closest('#sh-close')) { closeShare(); return; }
    if (t.closest('.share-link')) { closeShare(); return; }
  });

  if (dlg) {
    dlg.addEventListener('click', (e) => { if (e.target === dlg) closeShare(); });
    dlg.addEventListener('cancel', () => closeShare());
  }
</script>
