---
import '../styles/global.css'
export interface Props {
  title?: string
  ogTitle?: string
  ogDescription?: string
  ogImage?: string
  ogUrl?: string
}
const { title = 'Protege Colitas', ogTitle, ogDescription, ogImage, ogUrl } = Astro.props
const path = Astro.url?.pathname ?? '/'
const active = (href: string) => href === '/' ? path === '/' : path.startsWith(href)
const _ogTitle = ogTitle ?? 'Protege Colitas · Emergencia Venezuela 2026'
const _ogDesc  = ogDescription ?? 'Reporta mascotas perdidas o encontradas tras el terremoto. Juntos los reunimos.'
const _ogImg   = ogImage ?? 'https://protegecolitas.org/banner.png'
const _ogUrl   = ogUrl ?? 'https://protegecolitas.org'
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta property="og:title" content={_ogTitle} />
  <meta property="og:description" content={_ogDesc} />
  <meta property="og:image" content={_ogImg} />
  <meta property="og:url" content={_ogUrl} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="description" content={_ogDesc} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
  <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>

  <a href="#main-content" class="skip-link">Saltar al contenido principal</a>

  <!-- Top nav -->
  <header class="top-nav" role="banner">
    <div class="top-nav__inner">
      <a href="/" class="top-nav__brand" aria-label="Protege Colitas — Inicio">
        <img src="/logo.png" alt="" width="28" height="28" class="brand-logo" aria-hidden="true" />
        <span class="brand-name">Protege Colitas</span>
      </a>
      <nav class="top-nav__links" aria-label="Navegación principal">
        <a href="/mascotas"    class={`top-link${active('/mascotas')    ? ' top-link--on' : ''}`} aria-current={active('/mascotas')    ? 'page' : undefined}>Mascotas</a>
        <a href="/veterinarios" class={`top-link${active('/veterinarios') ? ' top-link--on' : ''}`} aria-current={active('/veterinarios') ? 'page' : undefined}>Vets</a>
        <a href="/insumos"     class={`top-link${active('/insumos')     ? ' top-link--on' : ''}`} aria-current={active('/insumos')     ? 'page' : undefined}>Insumos</a>
        <a href="/acopio"      class={`top-link${active('/acopio')      ? ' top-link--on' : ''}`} aria-current={active('/acopio')      ? 'page' : undefined}>Acopio</a>
        <a href="/noticias"    class={`top-link${active('/noticias')    ? ' top-link--on' : ''}`} aria-current={active('/noticias')    ? 'page' : undefined}>Noticias</a>
        <a href="/reportar" class="top-cta">Reportar</a>
      </nav>
      <div class="nav-badge" role="status" aria-live="polite">
        <span class="nav-badge-dot" aria-hidden="true"></span>
        <span class="nav-badge-txt">EMERGENCIA ACTIVA</span>
      </div>
    </div>
  </header>

  <div id="main-content" tabindex="-1">
    <slot />
  </div>

  <footer class="site-footer">
    🐾 Protege Colitas · Centro de Emergencia Animal · Venezuela 2026<br>
    <a href="https://synti.dev" target="_blank" rel="noopener" class="footer-link">
      Desarrollado por SyntiDev como servicio social · synti.dev
    </a>
  </footer>

  <!-- Bottom nav — mobile only -->
  <nav class="bottom-nav" aria-label="Secciones">

    <a href="/" class={`bnav-item${active('/') ? ' bnav-on' : ''}`} aria-label="Inicio" aria-current={active('/') ? 'page' : undefined}>
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 10.5L12 3l9 7.5V20a1 1 0 01-1 1H5a1 1 0 01-1-1v-9.5z"/><path d="M9 21v-8h6v8"/></svg>
      <span class="bnav-label">Inicio</span>
    </a>

    <a href="/mascotas" class={`bnav-item${active('/mascotas') ? ' bnav-on' : ''}`} aria-label="Mascotas" aria-current={active('/mascotas') ? 'page' : undefined}>
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      <span class="bnav-label">Buscar</span>
    </a>

    <div class="bnav-center">
      <a href="/reportar" class="bnav-cta" aria-label="Reportar mascota">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      </a>
    </div>

    <a href="/veterinarios" class={`bnav-item${active('/veterinarios') ? ' bnav-on' : ''}`} aria-label="Veterinarios" aria-current={active('/veterinarios') ? 'page' : undefined}>
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
      <span class="bnav-label">Vets</span>
    </a>

    <a href="/insumos" class={`bnav-item${active('/insumos') ? ' bnav-on' : ''}`} aria-label="Insumos" aria-current={active('/insumos') ? 'page' : undefined}>
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 8L12 3 4 8v8l8 5 8-5V8z"/><path d="M4 8l8 5 8-5M12 13v8"/></svg>
      <span class="bnav-label">Insumos</span>
    </a>

  </nav>

</body>
</html>

<style>
  /* Body offsets */
  body { padding-top: 60px; padding-bottom: 140px; }
  @media (min-width: 640px) { body { padding-bottom: 0; } }

  /* Skip link */
  .skip-link {
    position: fixed; top: -120%; left: 1rem; z-index: 9999;
    background: var(--marron); color: #fff;
    padding: 0.5rem 1.25rem; border-radius: 0 0 8px 8px;
    font-family: 'Inter', sans-serif; font-size: 0.875rem; font-weight: 600;
    text-decoration: none; transition: top 0.15s ease-out; white-space: nowrap;
  }
  .skip-link:focus-visible { top: 0; }
  #main-content { outline: none; }

  /* Top nav */
  .top-nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 200;
    height: 60px;
    background: rgba(255,255,255,0.85);
    backdrop-filter: blur(12px) saturate(160%);
    -webkit-backdrop-filter: blur(12px) saturate(160%);
    border-bottom: 1px solid rgba(255,255,255,0.5);
  }
  .top-nav__inner {
    max-width: 1200px; margin: 0 auto; padding: 0 1.25rem;
    height: 100%; display: flex; align-items: center; gap: 1rem;
  }

  /* Brand */
  .top-nav__brand {
    display: flex; align-items: center; gap: 8px;
    text-decoration: none; flex-shrink: 0;
    min-height: 44px; transition: opacity 0.15s;
  }
  .top-nav__brand:hover { opacity: 0.75; }
  .brand-logo { border-radius: 6px; width: 28px; height: 28px; object-fit: cover; }
  .brand-name {
    font-family: 'Fredoka', sans-serif; font-weight: 700;
    font-size: 1.05rem; color: var(--marron); white-space: nowrap;
  }

  /* Desktop nav links */
  .top-nav__links { display: none; align-items: center; gap: 2px; flex: 1; }
  @media (min-width: 640px) { .top-nav__links { display: flex; } }

  .top-link {
    font-family: 'Inter', sans-serif; font-weight: 600; font-size: 0.875rem;
    color: var(--marron); text-decoration: none;
    padding: 0.375rem 0.65rem; border-radius: 8px; min-height: 36px;
    display: flex; align-items: center;
    transition: background 0.15s;
  }
  .top-link:hover     { background: rgba(61,28,2,0.07); }
  .top-link--on       { color: var(--amarillo); font-weight: 700; }

  /* CTA */
  .top-cta {
    margin-left: auto; flex-shrink: 0;
    background: var(--marron); color: #fff;
    font-family: 'Inter', sans-serif; font-weight: 700; font-size: 0.875rem;
    text-decoration: none; padding: 0 1rem; height: 36px; border-radius: 8px;
    display: flex; align-items: center; transition: opacity 0.15s;
    white-space: nowrap;
  }
  .top-cta:hover { opacity: 0.85; }

  /* Emergency badge */
  .nav-badge {
    display: none; align-items: center; gap: 6px;
    font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 700;
    color: var(--rojo); white-space: nowrap; flex-shrink: 0;
  }
  @media (min-width: 640px) { .nav-badge { display: flex; } }
  @keyframes blink { 0%,100%{opacity:1}50%{opacity:.4} }
  .nav-badge-dot {
    width: 7px; height: 7px; border-radius: 50%; background: #22c55e;
    animation: blink 2s ease-in-out infinite; flex-shrink: 0;
  }

  /* Bottom nav */
  .bottom-nav {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 100;
    height: 64px;
    display: flex; align-items: stretch;
    background: rgba(61,28,2,0.95);
    backdrop-filter: blur(8px) saturate(140%);
    -webkit-backdrop-filter: blur(8px) saturate(140%);
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-bottom: env(safe-area-inset-bottom, 0);
    overflow: visible;
  }
  @media (min-width: 640px) { .bottom-nav { display: none; } }

  .bnav-item {
    flex: 1; display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 3px;
    text-decoration: none; color: rgba(255,255,255,0.5);
    padding: 8px 4px 10px; min-height: 44px;
    -webkit-tap-highlight-color: transparent; transition: color 0.15s;
  }
  .bnav-item:hover, .bnav-on { color: var(--amarillo); }
  .bnav-label {
    font-family: 'Inter', sans-serif; font-size: 10px; font-weight: 600;
    line-height: 1; text-align: center;
  }

  .bnav-center {
    flex: 1; display: flex; align-items: center; justify-content: center;
    position: relative; overflow: visible;
  }
  .bnav-cta {
    position: absolute; bottom: 10px;
    width: 52px; height: 52px; border-radius: 50%;
    background: var(--amarillo); color: var(--marron);
    display: flex; align-items: center; justify-content: center;
    text-decoration: none;
    box-shadow: 0 -2px 8px rgba(0,0,0,0.15), 0 4px 20px rgba(245,166,35,0.5);
    transition: transform 0.15s, box-shadow 0.15s;
    -webkit-tap-highlight-color: transparent;
  }
  .bnav-cta:hover, .bnav-cta:focus-visible {
    transform: scale(1.08);
    box-shadow: 0 -2px 8px rgba(0,0,0,0.2), 0 6px 24px rgba(245,166,35,0.6);
  }

  /* Footer */
  .site-footer {
    text-align: center;
    padding: 20px 16px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    line-height: 1.7;
    color: #6B7280;
    border-top: 1px solid #E5E7EB;
    margin-bottom: 70px;
  }
  @media (min-width: 640px) { .site-footer { margin-bottom: 0; } }
  .footer-link {
    color: var(--amarillo);
    text-decoration: none;
    font-weight: 600;
  }
  .footer-link:hover { text-decoration: underline; }

  @media (prefers-reduced-motion: reduce) {
    .skip-link, .top-nav__brand, .top-link, .top-cta, .bnav-item, .bnav-cta { transition: none; }
    .nav-badge-dot { animation: none; }
  }
</style>
