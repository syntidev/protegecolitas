---
import { supabaseAdmin } from '../../lib/supabase'
import { createHmac, timingSafeEqual } from 'crypto'
import * as dotenv from 'dotenv'
import { resolve } from 'path'

dotenv.config({ path: resolve(process.cwd(), '.env') })

const SALT      = process.env.ADMIN_SALT ?? 'protegecolitas2026'
const COOKIE_MS = 8 * 60 * 60 * 1000
const COOKIE_AGE = 8 * 60 * 60

function sign(s: string): string {
  return createHmac('sha256', SALT).update(s).digest('hex')
}

function validSession(raw: string): boolean {
  try {
    const parts = decodeURIComponent(raw).split('|')
    if (parts.length !== 3) return false
    const [email, exp, sig] = parts
    if (Date.now() > Number(exp)) return false
    const expected = sign(`${email}|${exp}`)
    return timingSafeEqual(Buffer.from(sig, 'hex'), Buffer.from(expected, 'hex'))
  } catch { return false }
}

function getCookie(header: string, name: string): string | null {
  return header.match(new RegExp(`(?:^|;\\s*)${name}=([^;]+)`))?.[1] ?? null
}

function rel(iso: string): string {
  const m = Math.floor((Date.now() - new Date(iso).getTime()) / 60000)
  if (m < 60) return `${m}m`
  if (m < 1440) return `${Math.floor(m / 60)}h`
  return `${Math.floor(m / 1440)}d`
}

const cookies  = Astro.request.headers.get('cookie') ?? ''
const ck       = getCookie(cookies, 'admin_session')
const isAuth   = !!ck && validSession(ck)
const isSecure = Astro.url.protocol === 'https:'
let loginError = ''

if (Astro.request.method === 'POST') {
  const form   = await Astro.request.formData()
  const action = form.get('action')?.toString()

  if (action === 'login') {
    const email = form.get('email')?.toString().trim() ?? ''
    const pass  = form.get('password')?.toString() ?? ''
    const hash  = createHmac('sha256', SALT).update(pass).digest('hex')
    const { data: mod } = await supabaseAdmin
      .from('moderadores')
      .select('id, nombre, rol')
      .eq('email', email)
      .eq('password_hash', hash)
      .eq('activo', true)
      .maybeSingle()
    if (!mod) {
      loginError = 'Email o contraseña incorrectos'
    } else {
      const exp = Date.now() + COOKIE_MS
      const pl  = `${email}|${exp}`
      const val = encodeURIComponent(`${pl}|${sign(pl)}`)
      return new Response(null, {
        status: 302,
        headers: {
          Location: '/admin',
          'Set-Cookie': `admin_session=${val}; HttpOnly; Path=/; SameSite=Strict; Max-Age=${COOKIE_AGE}${isSecure ? '; Secure' : ''}`
        }
      })
    }
  }

  if (action === 'logout') {
    return new Response(null, {
      status: 302,
      headers: { Location: '/admin', 'Set-Cookie': 'admin_session=; HttpOnly; Path=/; Max-Age=0' }
    })
  }

  if (!isAuth) {
    return new Response(JSON.stringify({ ok: false, error: 'No autorizado' }), {
      status: 401, headers: { 'Content-Type': 'application/json' }
    })
  }

  const getId = (): string => form.get('id')?.toString() ?? ''
  const J = (ok: boolean, error?: string): Response =>
    new Response(JSON.stringify({ ok, error }), { headers: { 'Content-Type': 'application/json' } })

  if (action === 'aprobar') {
    const { error } = await supabaseAdmin.from('mascotas').update({ status: 'publicado', moderado_at: new Date().toISOString() }).eq('id', getId())
    return J(!error, error?.message)
  }
  if (action === 'rechazar') {
    const { error } = await supabaseAdmin.from('mascotas').update({ status: 'descartado', moderado_at: new Date().toISOString() }).eq('id', getId())
    return J(!error, error?.message)
  }
  if (action === 'reunir') {
    const { error } = await supabaseAdmin.from('mascotas').update({ status: 'reunido', moderado_at: new Date().toISOString() }).eq('id', getId())
    return J(!error, error?.message)
  }
  if (action === 'eliminar_mascota') {
    const { error } = await supabaseAdmin.from('mascotas').delete().eq('id', getId())
    return J(!error, error?.message)
  }
  if (action === 'aprobar_vet') {
    const { error } = await supabaseAdmin.from('vets').update({ aprobado: true }).eq('id', getId())
    return J(!error, error?.message)
  }
  if (action === 'rechazar_vet') {
    const { error } = await supabaseAdmin.from('vets').delete().eq('id', getId())
    return J(!error, error?.message)
  }
  if (action === 'feed') {
    const tipo   = form.get('tipo')?.toString() ?? 'info'
    const titulo = form.get('titulo')?.toString().trim() ?? ''
    const cuerpo = form.get('cuerpo')?.toString().trim() ?? ''
    if (!titulo || !cuerpo) return J(false, 'Faltan datos')
    const { error } = await supabaseAdmin.from('feed').insert({ tipo, titulo, cuerpo, published_at: new Date().toISOString() })
    return J(!error, error?.message)
  }
  if (action === 'eliminar_feed') {
    const { error } = await supabaseAdmin.from('feed').delete().eq('id', getId())
    return J(!error, error?.message)
  }
  if (action === 'insumo') {
    const recibida  = parseInt(form.get('cantidad_recibida')?.toString() ?? '0', 10)
    const requerida = parseInt(form.get('cantidad_requerida')?.toString() ?? '1', 10)
    if (isNaN(recibida) || isNaN(requerida)) return J(false, 'Cantidades inválidas')
    const { error } = await supabaseAdmin.from('necesidades').update({
      cantidad_recibida: recibida,
      cantidad_requerida: requerida,
      updated_at: new Date().toISOString()
    }).eq('id', getId())
    return J(!error, error?.message)
  }
  if (action === 'nuevo_insumo') {
    const item      = form.get('item')?.toString().trim() ?? ''
    const requerida = parseInt(form.get('cantidad_requerida')?.toString() ?? '0', 10)
    const prioridad = form.get('prioridad')?.toString() ?? 'urgente'
    if (!item || isNaN(requerida) || requerida < 1) return J(false, 'Datos inválidos')
    const { error } = await supabaseAdmin.from('necesidades').insert({
      item, cantidad_requerida: requerida, cantidad_recibida: 0, prioridad
    })
    return J(!error, error?.message)
  }
  if (action === 'nuevo_vet') {
    const nombre    = form.get('nombre')?.toString().trim() ?? ''
    const zona      = form.get('zona')?.toString().trim() ?? ''
    const whatsapp  = form.get('whatsapp')?.toString().trim() ?? ''
    const servicios = form.get('servicios')?.toString().trim() || null
    const horario   = form.get('horario')?.toString().trim() || null
    if (!nombre || !zona || !whatsapp) return J(false, 'Faltan datos requeridos')
    const { error } = await supabaseAdmin.from('vets').insert({
      nombre, zona, whatsapp, servicios, horario, gratuito: true
    })
    return J(!error, error?.message)
  }
  // IMPORTANTE: crear bucket 'banners' en Supabase Storage → public
  // IMPORTANTE: crear bucket 'mascotas' en Supabase Storage → public
  if (action === 'banner') {
    const titulo      = form.get('titulo')?.toString().trim() ?? ''
    const descripcion = form.get('descripcion')?.toString().trim() || null
    const link        = form.get('link')?.toString().trim() || null
    const activo      = form.get('activo') === 'on'
    if (!titulo) return J(false, 'Título requerido')

    const uploadImg = async (field: string): Promise<string | null> => {
      const file = form.get(field) as File | null
      if (!file || file.size === 0) return null
      const ext = file.name.split('.').pop() ?? 'jpg'
      const filename = `${field}-${Date.now()}.${ext}`
      const buffer = await file.arrayBuffer()
      const { data: upload } = await supabaseAdmin.storage
        .from('banners')
        .upload(filename, buffer, { contentType: file.type, upsert: true })
      if (!upload) return null
      const { data: urlData } = supabaseAdmin.storage.from('banners').getPublicUrl(filename)
      return urlData.publicUrl
    }

    const imagen_url        = await uploadImg('banner_img')
    const imagen_url_mobile = await uploadImg('banner_img_mobile')

    const { error } = await supabaseAdmin.from('banners').insert({
      titulo, descripcion, link, imagen_url, imagen_url_mobile, activo
    })
    return J(!error, error?.message)
  }
  if (action === 'toggle_banner') {
    const activo = form.get('activo') === 'true'
    const { error } = await supabaseAdmin.from('banners').update({ activo }).eq('id', getId())
    return J(!error, error?.message)
  }
  if (action === 'eliminar_banner') {
    const { error } = await supabaseAdmin.from('banners').delete().eq('id', getId())
    return J(!error, error?.message)
  }
}

type Mascota = {
  id: string; nombre: string | null; especie: string; zona: string
  tipo: string | null; whatsapp: string | null; foto_url: string | null
  status: string; created_at: string; moderado_at: string | null
}
type Vet = {
  id: string; nombre: string; zona: string; whatsapp: string | null
  servicios: string | null; horario: string | null; gratuito: boolean; created_at: string
}
type FeedItem = { id: string; tipo: string; titulo: string; cuerpo: string; published_at: string }
type Necesidad = { id: string; item: string; cantidad_requerida: number; cantidad_recibida: number; prioridad: string }
type Banner    = { id: string; titulo: string; descripcion: string | null; imagen_url: string | null; imagen_url_mobile: string | null; link: string | null; activo: boolean; created_at: string }

let pendientes:  Mascota[]   = []
let publicadas:  Mascota[]   = []
let reunidas:    Mascota[]   = []
let vets:        Vet[]       = []
let feedItems:   FeedItem[]  = []
let necesidades: Necesidad[] = []
let banners:     Banner[]    = []
let stats = { pendientes: 0, publicadas: 0, reunidas: 0, vets: 0 }

if (isAuth) {
  const [mp, mpub, mreu, mv, mf, mn, sp, spub, sreu, sv, mb] = await Promise.all([
    supabaseAdmin.from('mascotas').select('id,nombre,especie,zona,tipo,whatsapp,foto_url,status,created_at,moderado_at').eq('status','pendiente').order('created_at',{ascending:true}),
    supabaseAdmin.from('mascotas').select('id,nombre,especie,zona,tipo,whatsapp,foto_url,status,created_at,moderado_at').eq('status','publicado').order('created_at',{ascending:false}).limit(50),
    supabaseAdmin.from('mascotas').select('id,nombre,especie,zona,tipo,foto_url,status,created_at,moderado_at').eq('status','reunido').order('moderado_at',{ascending:false}).limit(20),
    supabaseAdmin.from('vets').select('id,nombre,zona,whatsapp,servicios,horario,gratuito,created_at').order('created_at',{ascending:false}),
    supabaseAdmin.from('feed').select('id,tipo,titulo,cuerpo,published_at').order('published_at',{ascending:false}).limit(50),
    supabaseAdmin.from('necesidades').select('*').order('prioridad'),
    supabaseAdmin.from('mascotas').select('*',{count:'exact',head:true}).eq('status','pendiente'),
    supabaseAdmin.from('mascotas').select('*',{count:'exact',head:true}).eq('status','publicado'),
    supabaseAdmin.from('mascotas').select('*',{count:'exact',head:true}).eq('status','reunido'),
    supabaseAdmin.from('vets').select('*',{count:'exact',head:true}),
    supabaseAdmin.from('banners').select('id,titulo,descripcion,imagen_url,imagen_url_mobile,link,activo,created_at').order('created_at',{ascending:false}),
  ])
  pendientes  = (mp.data   ?? []) as Mascota[]
  publicadas  = (mpub.data ?? []) as Mascota[]
  reunidas    = (mreu.data ?? []) as Mascota[]
  vets        = (mv.data   ?? []) as Vet[]
  feedItems   = (mf.data   ?? []) as FeedItem[]
  necesidades = (mn.data   ?? []) as Necesidad[]
  banners     = (mb.data   ?? []) as Banner[]
  stats = { pendientes: sp.count ?? 0, publicadas: spub.count ?? 0, reunidas: sreu.count ?? 0, vets: sv.count ?? 0 }
}
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin — Protege Colitas</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>

{!isAuth ? (
  <div class="login-wrap">
    <div class="login-box">
      <img src="/logo.png" alt="Protege Colitas" width="80" style="display:block;margin:0 auto 16px" />
      <h1 class="login-title">Protege Colitas</h1>
      <p class="login-sub">Centro de control</p>
      {loginError && <p class="login-err" role="alert">{loginError}</p>}
      <form method="POST" autocomplete="off">
        <input type="hidden" name="action" value="login" />
        <input type="email" name="email" placeholder="Email" required autocomplete="email" />
        <input type="password" name="password" placeholder="Contraseña" required autofocus />
        <button type="submit" class="btn-login">Entrar →</button>
      </form>
    </div>
  </div>
) : (
  <div class="panel">

    <header class="hdr">
      <span class="hdr-title">🐾 Centro de Control</span>
      <div class="hdr-stats">
        <span class="stat-pill stat-naranja">{stats.pendientes} pendientes</span>
        <span class="stat-pill stat-verde">{stats.publicadas} publicadas</span>
        <span class="stat-pill stat-azul">{stats.reunidas} reunidas</span>
        <span class="stat-pill stat-gris">{stats.vets} vets</span>
      </div>
      <form method="POST" class="logout-form">
        <input type="hidden" name="action" value="logout" />
        <button type="submit" class="btn-logout">Salir</button>
      </form>
    </header>

    <nav class="tabs-nav" role="tablist" aria-label="Secciones del panel">
      <button class="tab active" data-tab="pendientes" role="tab" aria-selected="true">
        Mascotas pendientes
        {pendientes.length > 0 && <span class="tab-count">{pendientes.length}</span>}
      </button>
      <button class="tab" data-tab="publicadas" role="tab" aria-selected="false">Publicadas</button>
      <button class="tab" data-tab="vets" role="tab" aria-selected="false">Veterinarios</button>
      <button class="tab" data-tab="feed" role="tab" aria-selected="false">Feed</button>
      <button class="tab" data-tab="insumos" role="tab" aria-selected="false">Insumos</button>
      <button class="tab" data-tab="banners" role="tab" aria-selected="false">Banners</button>
    </nav>

    <!-- TAB 1: PENDIENTES -->
    <div id="tab-pendientes" class="tab-pane active">
      {pendientes.length === 0
        ? <p class="empty-msg">No hay mascotas pendientes ✓</p>
        : <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Foto</th><th>Nombre</th><th>Animal</th><th>Tipo</th>
                  <th>Zona</th><th>WA</th><th>Hace</th><th>Acciones</th>
                </tr>
              </thead>
              <tbody>
                {pendientes.map(m => (
                  <tr id={`row-${m.id}`}>
                    <td>
                      {m.foto_url
                        ? <img src={m.foto_url} alt="" class="thumb" loading="lazy" />
                        : <span class="thumb-empty">🐾</span>
                      }
                    </td>
                    <td class="td-name">{m.nombre ?? 'Sin nombre'}</td>
                    <td>{m.especie}</td>
                    <td>
                      {m.tipo === 'perdido'
                        ? <span class="badge badge-rojo">perdido</span>
                        : m.tipo === 'encontrado'
                          ? <span class="badge badge-verde">encontrado</span>
                          : <span class="badge badge-gris">—</span>
                      }
                    </td>
                    <td class="td-zona">{m.zona}</td>
                    <td>
                      {m.whatsapp
                        ? <a href={`https://wa.me/58${m.whatsapp.slice(1)}`} class="link-wa" target="_blank" rel="noreferrer">💬</a>
                        : <span>—</span>
                      }
                    </td>
                    <td class="td-time">{rel(m.created_at)}</td>
                    <td class="td-actions">
                      <button class="btn btn-verde" data-action="aprobar" data-id={m.id} data-row={`row-${m.id}`}>✓ Aprobar</button>
                      <button class="btn btn-rojo"  data-action="rechazar" data-id={m.id} data-row={`row-${m.id}`} data-confirm="¿Rechazar este reporte?">✗ Rechazar</button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
      }
    </div>

    <!-- TAB 2: PUBLICADAS -->
    <div id="tab-publicadas" class="tab-pane">
      {publicadas.length > 0 && (
        <Fragment>
          <h3 class="sub-title">Publicadas ({publicadas.length})</h3>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Foto</th><th>Nombre</th><th>Animal</th><th>Tipo</th>
                  <th>Zona</th><th>Hace</th><th>Acciones</th>
                </tr>
              </thead>
              <tbody>
                {publicadas.map(m => (
                  <tr id={`row-${m.id}`}>
                    <td>
                      {m.foto_url
                        ? <img src={m.foto_url} alt="" class="thumb" loading="lazy" />
                        : <span class="thumb-empty">🐾</span>
                      }
                    </td>
                    <td class="td-name">{m.nombre ?? 'Sin nombre'}</td>
                    <td>{m.especie}</td>
                    <td>
                      {m.tipo === 'perdido'
                        ? <span class="badge badge-rojo">perdido</span>
                        : m.tipo === 'encontrado'
                          ? <span class="badge badge-verde">encontrado</span>
                          : <span class="badge badge-gris">—</span>
                      }
                    </td>
                    <td class="td-zona">{m.zona}</td>
                    <td class="td-time">{rel(m.created_at)}</td>
                    <td class="td-actions">
                      <button class="btn btn-azul" data-action="reunir" data-id={m.id} data-row={`row-${m.id}`}>✓ Reunida</button>
                      <button class="btn btn-rojo btn-icon" data-action="eliminar_mascota" data-id={m.id} data-row={`row-${m.id}`} data-confirm="¿Eliminar mascota?">✕</button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </Fragment>
      )}
      {reunidas.length > 0 && (
        <Fragment>
          <h3 class={`sub-title${publicadas.length > 0 ? ' mt' : ''}`}>Reunidas ({reunidas.length})</h3>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Foto</th><th>Nombre</th><th>Animal</th><th>Zona</th><th>Reunida hace</th><th>Eliminar</th>
                </tr>
              </thead>
              <tbody>
                {reunidas.map(m => (
                  <tr id={`row-${m.id}`}>
                    <td>
                      {m.foto_url
                        ? <img src={m.foto_url} alt="" class="thumb" loading="lazy" />
                        : <span class="thumb-empty">🐾</span>
                      }
                    </td>
                    <td class="td-name">{m.nombre ?? 'Sin nombre'}</td>
                    <td>{m.especie}</td>
                    <td class="td-zona">{m.zona}</td>
                    <td class="td-time">{m.moderado_at ? rel(m.moderado_at) : '—'}</td>
                    <td>
                      <button class="btn btn-rojo btn-icon" data-action="eliminar_mascota" data-id={m.id} data-row={`row-${m.id}`} data-confirm="¿Eliminar mascota reunida?">✕</button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </Fragment>
      )}
      {publicadas.length === 0 && reunidas.length === 0 && (
        <p class="empty-msg">No hay mascotas publicadas</p>
      )}
    </div>

    <!-- TAB 3: VETERINARIOS -->
    <div id="tab-vets" class="tab-pane">
      <div class="nuevo-section">
        <h4 class="form-section-title">Registrar veterinario</h4>
        <form id="form-nuevo-vet" class="nuevo-form">
          <div class="nuevo-form-grid">
            <input type="text" name="nombre" placeholder="Nombre *" required class="feed-input" />
            <input type="text" name="zona" placeholder="Zona *" required class="feed-input" />
            <input type="tel" name="whatsapp" placeholder="WhatsApp 04XX... *" required class="feed-input" />
            <input type="text" name="servicios" placeholder="Servicios (opcional)" class="feed-input" />
            <input type="text" name="horario" placeholder="Horario (opcional)" class="feed-input" />
          </div>
          <button type="submit" class="btn btn-verde" style="margin-top:.625rem">+ Registrar vet</button>
        </form>
      </div>
      {vets.length === 0
        ? <p class="empty-msg mt-sm">No hay veterinarios registrados aún</p>
        : <div class="table-wrap mt">
            <table>
              <thead>
                <tr>
                  <th>Nombre</th><th>Zona</th><th>WhatsApp</th>
                  <th>Servicios</th><th>Horario</th><th>Hace</th><th>Acciones</th>
                </tr>
              </thead>
              <tbody>
                {vets.map(v => (
                  <tr id={`row-${v.id}`}>
                    <td class="td-name">{v.nombre}</td>
                    <td class="td-zona">{v.zona}</td>
                    <td>
                      {v.whatsapp
                        ? <a href={`https://wa.me/58${v.whatsapp.slice(1)}`} class="link-wa-txt" target="_blank" rel="noreferrer">💬 {v.whatsapp}</a>
                        : <span class="td-gris">—</span>
                      }
                    </td>
                    <td class="td-truncate">{v.servicios ?? '—'}</td>
                    <td class="td-gris">{v.horario ?? '—'}</td>
                    <td class="td-time">{rel(v.created_at)}</td>
                    <td class="td-actions">
                      <button class="btn btn-verde"    data-action="aprobar_vet" data-id={v.id} data-row={`row-${v.id}`}>✓ Aprobar</button>
                      <button class="btn btn-rojo btn-icon" data-action="rechazar_vet" data-id={v.id} data-row={`row-${v.id}`} data-confirm="¿Eliminar veterinario?">✕</button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
      }
    </div>

    <!-- TAB 4: FEED -->
    <div id="tab-feed" class="tab-pane">
      <form id="form-feed" class="feed-form">
        <div class="feed-row">
          <select name="tipo" class="feed-select">
            <option value="info">ℹ️ Info</option>
            <option value="alerta">🔴 Alerta</option>
            <option value="rescate">🐾 Rescate</option>
            <option value="buenas">✅ Buenas noticias</option>
            <option value="voluntario">🙌 Voluntarios</option>
          </select>
          <input type="text" name="titulo" placeholder="Título *" required maxlength="150" class="feed-input" />
        </div>
        <textarea name="cuerpo" placeholder="Texto *" required rows="3" class="feed-textarea"></textarea>
        <button type="submit" class="btn btn-azul">Publicar en feed</button>
      </form>

      {feedItems.length > 0 && (
        <div class="table-wrap mt">
          <table>
            <thead>
              <tr><th>Tipo</th><th>Título</th><th>Texto</th><th>Hace</th><th>Eliminar</th></tr>
            </thead>
            <tbody>
              {feedItems.map(f => (
                <tr id={`row-${f.id}`}>
                  <td><span class={`badge badge-tipo-${f.tipo}`}>{f.tipo}</span></td>
                  <td class="td-name">{f.titulo}</td>
                  <td class="td-truncate">{f.cuerpo.slice(0, 80)}{f.cuerpo.length > 80 ? '…' : ''}</td>
                  <td class="td-time">{rel(f.published_at)}</td>
                  <td>
                    <button class="btn btn-rojo btn-icon" data-action="eliminar_feed" data-id={f.id} data-row={`row-${f.id}`} data-confirm="¿Eliminar publicación?">✕</button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
      {feedItems.length === 0 && <p class="empty-msg mt-sm">No hay publicaciones en el feed</p>}
    </div>

    <!-- TAB 5: INSUMOS -->
    <div id="tab-insumos" class="tab-pane">
      {necesidades.length === 0
        ? <p class="empty-msg">No hay insumos registrados</p>
        : <div class="insumos-list">
            {necesidades.map(n => (
              <div class="insumo-row" id={`insumo-${n.id}`}>
                <span class={`prio-dot prio-${n.prioridad}`}></span>
                <span class="insumo-name">{n.item}</span>
                <form class="insumo-form" data-id={n.id}>
                  <label class="insumo-lbl">Rec.</label>
                  <input type="number" name="cantidad_recibida" value={n.cantidad_recibida} min="0" max="9999" class="insumo-input" aria-label={`Recibida ${n.item}`} />
                  <label class="insumo-lbl">Req.</label>
                  <input type="number" name="cantidad_requerida" value={n.cantidad_requerida} min="1" max="9999" class="insumo-input" aria-label={`Requerida ${n.item}`} />
                  <button type="submit" class="btn btn-amarillo btn-sm">✓ Guardar</button>
                </form>
              </div>
            ))}
          </div>
      }
      <div class="nuevo-section mt-sm">
        <h4 class="form-section-title">Agregar insumo</h4>
        <form id="form-nuevo-insumo" class="nuevo-form">
          <div class="nuevo-form-grid">
            <input type="text" name="item" placeholder="Nombre del insumo *" required class="feed-input" />
            <input type="number" name="cantidad_requerida" placeholder="Cantidad req. *" min="1" required class="insumo-input insumo-input-lg" />
            <select name="prioridad" class="feed-select">
              <option value="critico">🔴 Crítico</option>
              <option value="urgente" selected>🟡 Urgente</option>
              <option value="cubierto">🟢 Cubierto</option>
            </select>
          </div>
          <button type="submit" class="btn btn-verde" style="margin-top:.625rem">+ Agregar insumo</button>
        </form>
      </div>
    </div>

    <!-- TAB 6: BANNERS -->
    <div id="tab-banners" class="tab-pane">
      <h4 class="form-section-title" style="margin-bottom:.75rem">Nuevo banner</h4>
      <form id="form-banner" class="nuevo-form" enctype="multipart/form-data">
        <div class="nuevo-form-grid">
          <input type="text" name="titulo" placeholder="Título *" required class="feed-input" />
          <input type="text" name="descripcion" placeholder="Descripción (opcional)" class="feed-input" />
          <input type="text" name="link" placeholder="Link (opcional)" class="feed-input" />
        </div>
        <div class="banner-uploads">
          <label class="upload-label">
            <span class="upload-lbl-txt">Banner Desktop (1200×400)</span>
            <input type="file" name="banner_img" accept="image/*" class="upload-input" />
          </label>
          <label class="upload-label">
            <span class="upload-lbl-txt">Banner Mobile (390×200)</span>
            <input type="file" name="banner_img_mobile" accept="image/*" capture="environment" class="upload-input" />
          </label>
        </div>
        <div style="display:flex;align-items:center;gap:.5rem;margin-top:.375rem">
          <input type="checkbox" name="activo" id="banner-activo" checked />
          <label for="banner-activo" style="font-size:.8rem;color:var(--gris)">Activar inmediatamente</label>
        </div>
        <button type="submit" class="btn btn-azul" style="margin-top:.625rem">+ Publicar banner</button>
      </form>

      {banners.length > 0 && (
        <div class="table-wrap mt">
          <table>
            <thead>
              <tr><th>Img</th><th>Título</th><th>Link</th><th>Estado</th><th>Hace</th><th>Eliminar</th></tr>
            </thead>
            <tbody>
              {banners.map(b => (
                <tr id={`row-${b.id}`}>
                  <td>
                    {b.imagen_url
                      ? <img src={b.imagen_url} alt={b.titulo} style="height:50px;object-fit:cover;border-radius:4px;max-width:80px;display:block" loading="lazy" />
                      : <span class="td-gris">—</span>
                    }
                  </td>
                  <td class="td-name">{b.titulo}</td>
                  <td class="td-truncate">{b.link ?? '—'}</td>
                  <td>
                    <button
                      class={`btn btn-sm ${b.activo ? 'btn-verde' : 'btn-gris'}`}
                      data-action="toggle_banner"
                      data-id={b.id}
                      data-activo={b.activo ? 'false' : 'true'}
                    >
                      {b.activo ? '● Activo' : '○ Inactivo'}
                    </button>
                  </td>
                  <td class="td-time">{rel(b.created_at)}</td>
                  <td>
                    <button class="btn btn-rojo btn-icon" data-action="eliminar_banner" data-id={b.id} data-row={`row-${b.id}`} data-confirm="¿Eliminar banner?">✕</button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
      {banners.length === 0 && <p class="empty-msg mt-sm">No hay banners creados</p>}
    </div>

  </div>
)}

</body>
</html>

<style>
  :root {
    --bg:       #0F1117;
    --surface:  #1A1D27;
    --border:   #2D3148;
    --texto:    #F1F5F9;
    --gris:     #94A3B8;
    --verde:    #22C55E;
    --rojo:     #EF4444;
    --amarillo: #F59E0B;
    --azul:     #3B82F6;
    --naranja:  #F97316;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--texto);
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 13px;
    line-height: 1.5;
    min-height: 100vh;
  }

  /* ── Login ────────────────────────────────────────────────────────── */
  .login-wrap {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 1rem;
  }
  .login-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem;
    width: min(100%, 320px);
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }
  .login-logo  { font-size: 2rem; text-align: center; }  /* fallback, replaced by img */
  .login-title { font-size: 1.25rem; font-weight: 700; text-align: center; }
  .login-sub   { font-size: .8rem; color: var(--gris); text-align: center; }
  .login-err   { background: rgba(239,68,68,.12); color: var(--rojo); border: 1px solid rgba(239,68,68,.35); border-radius: 6px; padding: .625rem .875rem; font-size: .8rem; }
  .login-box form { display: flex; flex-direction: column; gap: .625rem; }
  .login-box input {
    background: var(--bg); border: 1px solid var(--border); border-radius: 6px;
    color: var(--texto); padding: .625rem .875rem; font-size: .875rem;
    width: 100%; font-family: inherit;
  }
  .login-box input:focus { outline: none; border-color: var(--azul); }
  .btn-login {
    background: var(--azul); color: #fff; border: none; border-radius: 6px;
    padding: .625rem; font-size: .875rem; font-weight: 600; cursor: pointer;
    font-family: inherit; transition: opacity .15s;
  }
  .btn-login:hover { opacity: .85; }

  /* ── Header ───────────────────────────────────────────────────────── */
  .hdr {
    display: flex; align-items: center; gap: .75rem;
    padding: .625rem 1rem;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
  }
  .hdr-title  { font-weight: 700; font-size: .875rem; flex-shrink: 0; }
  .hdr-stats  { display: flex; gap: .375rem; flex-wrap: wrap; flex: 1; min-width: 0; }
  .stat-pill  { font-size: .7rem; font-weight: 600; padding: .2rem .625rem; border-radius: 999px; }
  .stat-naranja { background: rgba(249,115,22,.2);  color: #FB923C; }
  .stat-verde   { background: rgba(34,197,94,.2);   color: #4ADE80; }
  .stat-azul    { background: rgba(59,130,246,.2);  color: #60A5FA; }
  .stat-gris    { background: rgba(148,163,184,.15); color: var(--gris); }
  .logout-form  { flex-shrink: 0; }
  .btn-logout {
    background: transparent; border: 1px solid var(--border); color: var(--gris);
    border-radius: 6px; padding: .3rem .75rem; cursor: pointer;
    font-size: .75rem; font-family: inherit; transition: border-color .15s, color .15s;
  }
  .btn-logout:hover { border-color: var(--rojo); color: var(--rojo); }

  /* ── Tabs nav ─────────────────────────────────────────────────────── */
  .tabs-nav {
    display: flex; background: var(--surface);
    border-bottom: 1px solid var(--border);
    overflow-x: auto; scrollbar-width: none;
  }
  .tabs-nav::-webkit-scrollbar { display: none; }
  .tab {
    background: transparent; border: none;
    border-bottom: 2px solid transparent;
    color: var(--gris); padding: .625rem 1rem;
    font-size: .8rem; font-weight: 600; cursor: pointer;
    font-family: inherit; white-space: nowrap;
    transition: color .15s, border-color .15s;
    display: flex; align-items: center; gap: .35rem;
  }
  .tab:hover { color: var(--texto); }
  .tab.active { color: var(--azul); border-bottom-color: var(--azul); }
  .tab-count {
    background: var(--naranja); color: #fff;
    border-radius: 999px; padding: .1rem .4rem; font-size: .65rem;
  }

  /* ── Tab panes ────────────────────────────────────────────────────── */
  .tab-pane { display: none; padding: 1rem; }
  .tab-pane.active { display: block; }

  /* ── Tables ───────────────────────────────────────────────────────── */
  .table-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; font-size: .8rem; }
  th {
    text-align: left; padding: .5rem .75rem;
    font-size: .68rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: .05em; color: var(--gris);
    border-bottom: 1px solid var(--border);
    background: var(--bg); white-space: nowrap;
  }
  td { padding: .5rem .75rem; border-bottom: 1px solid var(--border); vertical-align: middle; }
  tr:nth-child(even) td { background: var(--surface); }
  tr:hover td { background: rgba(59,130,246,.05); }

  .thumb { width: 40px; height: 40px; object-fit: cover; border-radius: 4px; display: block; }
  .thumb-empty {
    display: inline-flex; align-items: center; justify-content: center;
    width: 40px; height: 40px; font-size: 1.2rem;
  }
  .td-name     { font-weight: 600; max-width: 130px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .td-zona     { max-width: 100px; color: var(--gris); font-size: .75rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .td-time     { color: var(--gris); font-size: .72rem; white-space: nowrap; }
  .td-gris     { color: var(--gris); }
  .td-truncate { max-width: 160px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: var(--gris); }
  .td-actions  { white-space: nowrap; }
  .link-wa     { font-size: 1.1rem; text-decoration: none; }
  .link-wa-txt { font-size: .75rem; color: #4ADE80; text-decoration: none; white-space: nowrap; }
  .link-wa-txt:hover { text-decoration: underline; }

  /* ── Buttons ──────────────────────────────────────────────────────── */
  .btn {
    border: none; border-radius: 4px;
    padding: .3rem .625rem; font-size: .75rem; font-weight: 600;
    cursor: pointer; font-family: inherit; transition: opacity .15s;
    min-height: 28px;
  }
  .btn + .btn { margin-left: .25rem; }
  .btn:hover    { opacity: .8; }
  .btn:disabled { opacity: .35; cursor: not-allowed; }
  .btn-verde   { background: var(--verde);   color: #fff; }
  .btn-rojo    { background: var(--rojo);    color: #fff; }
  .btn-azul    { background: var(--azul);    color: #fff; }
  .btn-amarillo { background: var(--amarillo); color: #000; }
  .btn-icon    { padding: .3rem .5rem; }
  .btn-sm      { padding: .25rem .5rem; min-height: 26px; font-size: .72rem; }

  /* ── Badges ───────────────────────────────────────────────────────── */
  .badge {
    display: inline-block; font-size: .65rem; font-weight: 700;
    padding: .15rem .45rem; border-radius: 4px; text-transform: capitalize;
  }
  .badge-rojo  { background: rgba(239,68,68,.2);  color: #FCA5A5; }
  .badge-verde { background: rgba(34,197,94,.2);  color: #86EFAC; }
  .badge-azul  { background: rgba(59,130,246,.2); color: #93C5FD; }
  .badge-gris  { background: rgba(148,163,184,.1); color: var(--gris); }
  .badge-tipo-info       { background: rgba(59,130,246,.2);  color: #93C5FD; }
  .badge-tipo-alerta     { background: rgba(239,68,68,.2);   color: #FCA5A5; }
  .badge-tipo-rescate    { background: rgba(245,158,11,.2);  color: #FCD34D; }
  .badge-tipo-buenas     { background: rgba(34,197,94,.2);   color: #86EFAC; }
  .badge-tipo-voluntario { background: rgba(139,92,246,.2);  color: #C4B5FD; }

  /* ── Sub-titles ───────────────────────────────────────────────────── */
  .sub-title {
    font-size: .72rem; font-weight: 700; color: var(--gris);
    text-transform: uppercase; letter-spacing: .05em; margin-bottom: .75rem;
  }
  .mt    { margin-top: 1.5rem; }
  .mt-sm { margin-top: .75rem; }
  .empty-msg { color: var(--gris); padding: 2rem; text-align: center; font-size: .875rem; }

  /* ── Feed form ────────────────────────────────────────────────────── */
  .feed-form { display: flex; flex-direction: column; gap: .625rem; max-width: 640px; }
  .feed-row  { display: flex; gap: .5rem; }
  .feed-select, .feed-input, .feed-textarea {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 6px; color: var(--texto);
    padding: .5rem .75rem; font-size: .875rem; font-family: inherit;
  }
  .feed-select { flex-shrink: 0; }
  .feed-input  { flex: 1; }
  .feed-textarea { resize: vertical; width: 100%; }
  .feed-select:focus, .feed-input:focus, .feed-textarea:focus { outline: none; border-color: var(--azul); }

  /* ── Insumos ──────────────────────────────────────────────────────── */
  .insumos-list { display: flex; flex-direction: column; gap: .25rem; max-width: 520px; }
  .insumo-row {
    display: flex; align-items: center; gap: .75rem;
    padding: .5rem .25rem; border-bottom: 1px solid var(--border);
  }
  .prio-dot    { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .prio-critico  { background: var(--rojo); }
  .prio-urgente  { background: var(--amarillo); }
  .prio-cubierto { background: var(--verde); }
  .insumo-name     { flex: 1; font-weight: 500; font-size: .85rem; }
  .insumo-progress { font-size: .75rem; color: var(--gris); white-space: nowrap; }
  .insumo-form     { display: flex; align-items: center; gap: .375rem; }
  .insumo-input {
    width: 64px; background: var(--surface); border: 1px solid var(--border);
    border-radius: 4px; color: var(--texto); padding: .3rem .5rem;
    font-family: inherit; font-size: .8rem; text-align: center;
  }
  .insumo-input:focus { outline: none; border-color: var(--azul); }

  /* ── Banners ─────────────────────────────────────────────────────── */
  .btn-gris { background: rgba(148,163,184,.2); color: var(--gris); }
  .banner-uploads { display: flex; flex-wrap: wrap; gap: .75rem; margin-top: .5rem; }
  .upload-label { display: flex; flex-direction: column; gap: .25rem; flex: 1; min-width: 200px; }
  .upload-lbl-txt { font-size: .72rem; font-weight: 600; color: var(--gris); }
  .upload-input {
    background: var(--surface); border: 1px dashed var(--border);
    border-radius: 6px; color: var(--gris);
    padding: .5rem; font-size: .8rem; font-family: inherit; cursor: pointer;
    width: 100%;
  }
  .upload-input:hover { border-color: var(--azul); }

  /* ── Nuevo forms ─────────────────────────────────────────────────── */
  .nuevo-section { border-top: 1px solid var(--border); padding-top: .875rem; }
  .form-section-title {
    font-size: .7rem; font-weight: 700; color: var(--gris);
    text-transform: uppercase; letter-spacing: .05em; margin-bottom: .5rem;
  }
  .nuevo-form { display: flex; flex-direction: column; gap: .5rem; max-width: 640px; }
  .nuevo-form-grid { display: flex; flex-wrap: wrap; gap: .5rem; }
  .nuevo-form-grid .feed-input { flex: 1; min-width: 140px; }
  .insumo-lbl {
    font-size: .7rem; font-weight: 600; color: var(--gris);
    white-space: nowrap; align-self: center;
  }
  .insumo-input-lg { width: 100px; }

  /* ── Responsive ───────────────────────────────────────────────────── */
  @media (max-width: 480px) {
    .hdr { gap: .5rem; }
    .tab { padding: .5rem .625rem; font-size: .75rem; }
    .feed-row { flex-direction: column; }
  }
</style>

<script>
  // ── Tab switching
  document.querySelectorAll('.tab').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.tab').forEach(function(b) {
        b.classList.remove('active')
        b.setAttribute('aria-selected', 'false')
      })
      document.querySelectorAll('.tab-pane').forEach(function(p) {
        p.classList.remove('active')
      })
      btn.classList.add('active')
      btn.setAttribute('aria-selected', 'true')
      var pane = document.getElementById('tab-' + btn.dataset.tab)
      if (pane) pane.classList.add('active')
    })
  })

  // ── Generic fetch action
  async function doAction(params, rowId, confirmMsg) {
    if (confirmMsg && !confirm(confirmMsg)) return false
    var fd = new FormData()
    Object.keys(params).forEach(function(k) { fd.append(k, String(params[k])) })
    try {
      var r = await fetch('/admin', { method: 'POST', body: fd })
      var j = await r.json()
      if (!j.ok) { alert('Error: ' + (j.error || 'desconocido')); return false }
      if (rowId) {
        var el = document.getElementById(rowId)
        if (el) {
          el.style.transition = 'opacity .2s'
          el.style.opacity = '0'
          setTimeout(function() { el.remove() }, 200)
        }
      }
      return true
    } catch(e) {
      alert('Error de red')
      return false
    }
  }

  // ── Data-attribute buttons
  document.querySelectorAll('[data-action]').forEach(function(btn) {
    btn.addEventListener('click', async function() {
      var action = btn.dataset.action
      var id     = btn.dataset.id
      var row    = btn.dataset.row
      var conf   = btn.dataset.confirm
      if (!action || !id) return
      btn.disabled = true
      var params = { action: action, id: id }
      if (btn.dataset.activo !== undefined) params.activo = btn.dataset.activo
      var ok = await doAction(params, row, conf || null)
      if (!ok) btn.disabled = false
    })
  })

  // ── Feed form
  var formFeed = document.getElementById('form-feed')
  if (formFeed) {
    formFeed.addEventListener('submit', async function(e) {
      e.preventDefault()
      var fd  = new FormData(formFeed)
      fd.append('action', 'feed')
      var btn = formFeed.querySelector('button[type="submit"]')
      if (btn) btn.disabled = true
      try {
        var r = await fetch('/admin', { method: 'POST', body: fd })
        var j = await r.json()
        if (!j.ok) {
          alert('Error: ' + (j.error || 'desconocido'))
          if (btn) btn.disabled = false
        } else {
          formFeed.reset()
          if (btn) btn.disabled = false
          var msg = document.createElement('p')
          msg.textContent = '✓ Publicado'
          msg.style.cssText = 'color:#22C55E;font-size:.8rem;margin-top:.375rem;'
          formFeed.appendChild(msg)
          setTimeout(function() { msg.remove() }, 2500)
        }
      } catch(e) {
        alert('Error de red')
        if (btn) btn.disabled = false
      }
    })
  }

  // ── Insumo forms (editar cantidad_recibida Y cantidad_requerida)
  document.querySelectorAll('.insumo-form').forEach(function(form) {
    form.addEventListener('submit', async function(e) {
      e.preventDefault()
      var id       = form.dataset.id
      var inputRec = form.querySelector('input[name="cantidad_recibida"]')
      var inputReq = form.querySelector('input[name="cantidad_requerida"]')
      var cantRec  = inputRec ? inputRec.value : '0'
      var cantReq  = inputReq ? inputReq.value : '1'
      var btn      = form.querySelector('button')
      if (btn) btn.disabled = true
      var ok = await doAction({ action: 'insumo', id: id, cantidad_recibida: cantRec, cantidad_requerida: cantReq }, null, null)
      if (btn) btn.disabled = false
    })
  })

  // ── Banner form (multipart con archivo)
  var formBanner = document.getElementById('form-banner')
  if (formBanner) {
    formBanner.addEventListener('submit', async function(e) {
      e.preventDefault()
      var fd  = new FormData(formBanner)
      fd.append('action', 'banner')
      var btn = formBanner.querySelector('button[type="submit"]')
      if (btn) btn.disabled = true
      try {
        var r = await fetch('/admin', { method: 'POST', body: fd })
        var j = await r.json()
        if (!j.ok) { alert('Error: ' + (j.error || 'desconocido')); if (btn) btn.disabled = false }
        else { window.location.reload() }
      } catch(e) { alert('Error de red'); if (btn) btn.disabled = false }
    })
  }

  // ── Nuevo insumo
  var formNuevoInsumo = document.getElementById('form-nuevo-insumo')
  if (formNuevoInsumo) {
    formNuevoInsumo.addEventListener('submit', async function(e) {
      e.preventDefault()
      var fd  = new FormData(formNuevoInsumo)
      fd.append('action', 'nuevo_insumo')
      var btn = formNuevoInsumo.querySelector('button[type="submit"]')
      if (btn) btn.disabled = true
      try {
