        </div>
        <div class="modal-actions">
          <button type="submit" class="btn-submit">Guardar cambios</button>
          <button type="button" class="modal-cancel btn btn-outline">Cancelar</button>
        </div>
      </form>

      <!-- Veterinario -->
      <form id="modal-vet" class="modal-form" style="display:none">
        <input type="hidden" name="action" value="editar_vet" />
        <input type="hidden" name="id" id="ev-id" />
        <div class="modal-grid">
          <label class="modal-field">
            <span class="modal-lbl">Nombre *</span>
            <input type="text" name="nombre" id="ev-nombre" class="modal-input" required />
          </label>
          <label class="modal-field">
            <span class="modal-lbl">Zona *</span>
            <input type="text" name="zona" id="ev-zona" class="modal-input" required />
          </label>
          <label class="modal-field">
            <span class="modal-lbl">WhatsApp *</span>
            <input type="text" name="whatsapp" id="ev-whatsapp" class="modal-input" required />
          </label>
          <label class="modal-field">
            <span class="modal-lbl">Servicios</span>
            <input type="text" name="servicios" id="ev-servicios" class="modal-input" />
          </label>
          <label class="modal-field modal-field--full">
            <span class="modal-lbl">Horario</span>
            <input type="text" name="horario" id="ev-horario" class="modal-input" />
          </label>
        </div>
        <div class="modal-actions">
          <button type="submit" class="btn-submit">Guardar cambios</button>
          <button type="button" class="modal-cancel btn btn-outline">Cancelar</button>
        </div>
      </form>

      <!-- Insumo -->
      <form id="modal-insumo" class="modal-form" style="display:none">
        <input type="hidden" name="action" value="editar_insumo" />
        <input type="hidden" name="id" id="ei-id" />
        <div class="modal-grid">
          <label class="modal-field modal-field--full">
            <span class="modal-lbl">Nombre del insumo *</span>
            <input type="text" name="item" id="ei-item" class="modal-input" required />
          </label>
          <label class="modal-field">
            <span class="modal-lbl">Cant. recibida</span>
            <input type="number" name="cantidad_recibida" id="ei-recibida" class="modal-input" min="0" />
          </label>
          <label class="modal-field">
            <span class="modal-lbl">Cant. requerida *</span>
            <input type="number" name="cantidad_requerida" id="ei-requerida" class="modal-input" min="1" required />
          </label>
          <label class="modal-field modal-field--full">
            <span class="modal-lbl">Prioridad</span>
            <select name="prioridad" id="ei-prioridad" class="modal-input">
              <option value="critico">🔴 Crítico</option>
              <option value="urgente">🟡 Urgente</option>
              <option value="cubierto">🟢 Cubierto</option>
            </select>
          </label>
        </div>
        <div class="modal-actions">
          <button type="submit" class="btn-submit">Guardar cambios</button>
          <button type="button" class="modal-cancel btn btn-outline">Cancelar</button>
        </div>
      </form>

    </div>

  </div>

  </div>

)}

</body>
</html>

<style>
  :root {
    --bg:       #0F1117;
    --surface:  #1A1D27;
    --border:   #2D3148;
    --texto:    #F1F5F9;
    --gris:     #94A3B8;
    --verde:    #22C55E;
    --rojo:     #EF4444;
    --amarillo: #F59E0B;
    --azul:     #3B82F6;
    --naranja:  #F97316;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--texto);
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 13px;
    line-height: 1.5;
    min-height: 100vh;
  }

  /* ── Login ────────────────────────────────────────────────────────── */
  .login-wrap {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 1rem;
  }
  .login-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem;
    width: min(100%, 320px);
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }
  .login-logo  { font-size: 2rem; text-align: center; }  /* fallback, replaced by img */
  .login-title { font-size: 1.25rem; font-weight: 700; text-align: center; }
  .login-sub   { font-size: .8rem; color: var(--gris); text-align: center; }
  .login-err   { background: rgba(239,68,68,.12); color: var(--rojo); border: 1px solid rgba(239,68,68,.35); border-radius: 6px; padding: .625rem .875rem; font-size: .8rem; }
  .login-box form { display: flex; flex-direction: column; gap: .625rem; }
  .login-box input {
    background: var(--bg); border: 1px solid var(--border); border-radius: 6px;
    color: var(--texto); padding: .625rem .875rem; font-size: .875rem;
    width: 100%; font-family: inherit;
  }
  .login-box input:focus { outline: none; border-color: var(--azul); }
  .btn-login {
    background: var(--azul); color: #fff; border: none; border-radius: 6px;
    padding: .625rem; font-size: .875rem; font-weight: 600; cursor: pointer;
    font-family: inherit; transition: opacity .15s;
  }
  .btn-login:hover { opacity: .85; }

  /* ── Header ───────────────────────────────────────────────────────── */
  .hdr {
    display: flex; align-items: center; gap: .75rem;
    padding: .875rem 1.5rem;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
  }
  .hdr-title  { font-weight: 700; font-size: 1rem; flex-shrink: 0; }
  .hdr-stats  { display: flex; gap: .375rem; flex-wrap: wrap; flex: 1; min-width: 0; }
  .stat-pill  { font-size: .7rem; font-weight: 600; padding: .2rem .625rem; border-radius: 999px; }
  .stat-naranja { background: rgba(249,115,22,.2);  color: #FB923C; }
  .stat-verde   { background: rgba(34,197,94,.2);   color: #4ADE80; }
  .stat-azul    { background: rgba(59,130,246,.2);  color: #60A5FA; }
  .stat-gris    { background: rgba(148,163,184,.15); color: var(--gris); }
  .logout-form  { flex-shrink: 0; }
  .btn-logout {
    background: transparent; border: 1px solid var(--border); color: var(--gris);
    border-radius: 6px; padding: .3rem .75rem; cursor: pointer;
    font-size: .75rem; font-family: inherit; transition: border-color .15s, color .15s;
  }
  .btn-logout:hover { border-color: var(--rojo); color: var(--rojo); }

  /* ── Tabs nav ─────────────────────────────────────────────────────── */
  .tabs-nav {
    display: flex; background: var(--surface);
    border-bottom: 1px solid var(--border);
    overflow-x: auto; scrollbar-width: none;
    padding: 0 1.5rem;
  }
  .tabs-nav::-webkit-scrollbar { display: none; }
  .tab {
    background: transparent; border: none;
    border-bottom: 2px solid transparent;
    color: var(--gris); padding: .875rem 1rem;
    font-size: .85rem; font-weight: 600; cursor: pointer;
    font-family: inherit; white-space: nowrap;
    transition: color .15s, border-color .15s;
    display: flex; align-items: center; gap: .35rem;
  }
  .tab:hover { color: var(--texto); }
  .tab.active { color: var(--azul); border-bottom-color: var(--azul); }
  .tab-badge {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 22px; height: 22px; border-radius: 11px;
    font-size: 11px; font-weight: 700;
    background: #EF4444; color: white;
    animation: pulse-badge 2s infinite;
  }
  @keyframes pulse-badge {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: .8; transform: scale(1.1); }
  }
  .tab-badge.zero { background: #22C55E; animation: none; }
  @media (prefers-reduced-motion: reduce) {
    .tab-badge { animation: none; }
  }

  /* ── Tab panes ────────────────────────────────────────────────────── */
  .tab-pane { display: none; padding: 1.5rem; }
  .tab-pane.active { display: block; }

  /* ── Tables ───────────────────────────────────────────────────────── */
  .table-wrap { overflow-x: auto; border-radius: 10px; border: 1px solid var(--border); }
  table { width: 100%; border-collapse: collapse; font-size: .85rem; }
  th {
    text-align: left; padding: .75rem 1rem;
    font-size: .7rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: .05em; color: var(--gris);
    border-bottom: 1px solid var(--border);
    background: #0d1117; white-space: nowrap;
  }
  tr:last-child td { border-bottom: none; }
  tr:nth-child(even) td { background: rgba(255,255,255,.02); }
  tr:hover td { background: rgba(59,130,246,.05); }

  .td-photo { width: 88px; padding: .875rem 1rem; }
  .thumb {
    width: 72px; height: 72px; object-fit: cover; border-radius: 8px;
    display: block; cursor: zoom-in; transition: opacity .15s;
  }
  .thumb:hover { opacity: .85; }
  .thumb-empty {
    display: flex; align-items: center; justify-content: center;
    width: 72px; height: 72px; border-radius: 8px;
    background: #1f2937; font-size: 1.75rem; flex-shrink: 0;
  }
  td { padding: 1rem; border-bottom: 1px solid var(--border); vertical-align: middle; height: 88px; }
  .td-name     { font-weight: 700; font-size: 15px; max-width: 200px; }
  .td-zona     { max-width: 140px; color: var(--gris); font-size: .8rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .td-time     { color: var(--gris); font-size: .75rem; white-space: nowrap; }
  .td-gris     { color: var(--gris); }
  .td-truncate { max-width: 160px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: var(--gris); }
  .td-actions  { white-space: nowrap; }
  .link-wa     { font-size: 1.1rem; text-decoration: none; }
  .link-wa-txt { font-size: .8rem; color: #4ADE80; text-decoration: none; white-space: nowrap; }
  .link-wa-txt:hover { text-decoration: underline; }

  /* ── Buttons ──────────────────────────────────────────────────────── */
  .btn {
    border: none; border-radius: 6px;
    padding: .5rem .875rem; font-size: .8rem; font-weight: 600;
    cursor: pointer; font-family: inherit; transition: opacity .15s;
    min-height: 36px; min-width: 80px;
    display: inline-flex; align-items: center; justify-content: center;
    text-decoration: none; white-space: nowrap;
  }
  .btn + .btn { margin-left: .375rem; }
  .btn:hover    { opacity: .8; }
  .btn:disabled { opacity: .35; cursor: not-allowed; }
  .btn-verde    { background: var(--verde);   color: #fff; }
  .btn-rojo     { background: var(--rojo);    color: #fff; }
  .btn-azul     { background: var(--azul);    color: #fff; }
  .btn-amarillo { background: var(--amarillo); color: #000; }
  .btn-gris     { background: rgba(148,163,184,.2); color: var(--gris); }
  .btn-outline  { background: transparent; border: 1px solid var(--border); color: var(--gris); }
  .btn-outline:hover { border-color: var(--gris); color: var(--texto); opacity: 1; }
  .btn-icon     { min-width: auto; padding: .5rem .625rem; }
  .btn-sm       { padding: .3rem .625rem; min-height: 30px; min-width: 60px; font-size: .75rem; }

  /* ── Badges ───────────────────────────────────────────────────────── */
  .badge {
    display: inline-block; font-size: .65rem; font-weight: 700;
    padding: .15rem .45rem; border-radius: 4px; text-transform: capitalize;
  }
  .badge-rojo  { background: rgba(239,68,68,.2);  color: #FCA5A5; }
  .badge-verde { background: rgba(34,197,94,.2);  color: #86EFAC; }
  .badge-azul  { background: rgba(59,130,246,.2); color: #93C5FD; }
  .badge-gris  { background: rgba(148,163,184,.1); color: var(--gris); }
  .badge-tipo-info       { background: rgba(59,130,246,.2);  color: #93C5FD; }
  .badge-tipo-alerta     { background: rgba(239,68,68,.2);   color: #FCA5A5; }
  .badge-tipo-rescate    { background: rgba(245,158,11,.2);  color: #FCD34D; }
  .badge-tipo-buenas     { background: rgba(34,197,94,.2);   color: #86EFAC; }
  .badge-tipo-voluntario { background: rgba(139,92,246,.2);  color: #C4B5FD; }

  /* ── Sub-titles ───────────────────────────────────────────────────── */
  .sub-title {
    font-size: .72rem; font-weight: 700; color: var(--gris);
    text-transform: uppercase; letter-spacing: .05em; margin-bottom: .75rem;
  }
  .mt    { margin-top: 1.5rem; }
  .mt-sm { margin-top: .75rem; }
  .empty-msg { color: var(--gris); padding: 2rem; text-align: center; font-size: .875rem; }

  /* ── Feed form ────────────────────────────────────────────────────── */
  .feed-form {
    display: flex; flex-direction: column; gap: .75rem; max-width: 680px;
    background: #111827; border: 1px solid var(--border);
    border-radius: 12px; padding: 20px;
  }
  .feed-row  { display: flex; gap: .625rem; }
  .feed-select, .feed-input, .feed-textarea {
    background: #1f2937; border: 1px solid #374151;
    border-radius: 8px; color: #fff;
    padding: 10px 12px; font-size: .875rem; font-family: inherit;
  }
  .feed-select { flex-shrink: 0; }
  .feed-input  { flex: 1; }
  .feed-textarea { resize: vertical; width: 100%; }
  .feed-select:focus, .feed-input:focus, .feed-textarea:focus { outline: none; border-color: #F5A623; }
  .feed-select option { background: #1f2937; }

  /* Label encima de cada campo */
  .form-field { display: flex; flex-direction: column; gap: .3rem; flex: 1; min-width: 160px; }
  .form-field .form-lbl {
    font-size: .7rem; font-weight: 700; color: #94A3B8;
    text-transform: uppercase; letter-spacing: .05em;
  }
  .form-field .feed-input,
  .form-field .feed-select { width: 100%; }

  /* "Ver ficha" link en celdas */
  .ficha-link {
    display: block; margin-top: 3px;
    color: #F5A623; font-size: .72rem; font-weight: 600; text-decoration: none;
  }
  .ficha-link:hover { text-decoration: underline; }

  /* Botón submit amarillo */
  .btn-submit {
    background: #F5A623; color: #3D1C02; font-weight: 700;
    border: none; border-radius: 6px;
    padding: .45rem .875rem; font-size: .8rem; font-family: inherit;
    cursor: pointer; min-height: 36px; transition: opacity .15s;
  }
  .btn-submit:hover { opacity: .85; }

  /* ── Insumos ──────────────────────────────────────────────────────── */
  .insumos-list { display: flex; flex-direction: column; gap: .25rem; max-width: 520px; }
  .insumo-row {
    display: flex; align-items: center; gap: .75rem;
    padding: .5rem .25rem; border-bottom: 1px solid var(--border);
  }
  .prio-dot    { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .prio-critico  { background: var(--rojo); }
  .prio-urgente  { background: var(--amarillo); }
  .prio-cubierto { background: var(--verde); }
  .insumo-name     { flex: 1; font-weight: 500; font-size: .85rem; }
  .insumo-progress { font-size: .75rem; color: var(--gris); white-space: nowrap; }
  .insumo-form     { display: flex; align-items: center; gap: .375rem; }
  .insumo-input {
    width: 64px; background: var(--surface); border: 1px solid var(--border);
    border-radius: 4px; color: var(--texto); padding: .3rem .5rem;
    font-family: inherit; font-size: .8rem; text-align: center;
  }
  .insumo-input:focus { outline: none; border-color: var(--azul); }

  /* ── Banners ─────────────────────────────────────────────────────── */
  .btn-gris { background: rgba(148,163,184,.2); color: var(--gris); }
  .banner-uploads { display: flex; flex-wrap: wrap; gap: .75rem; margin-top: .5rem; }
  .upload-label { display: flex; flex-direction: column; gap: .25rem; flex: 1; min-width: 200px; }
  .upload-lbl-txt { font-size: .72rem; font-weight: 600; color: var(--gris); }
  .upload-input {
    background: var(--surface); border: 1px dashed var(--border);
    border-radius: 6px; color: var(--gris);
    padding: .5rem; font-size: .8rem; font-family: inherit; cursor: pointer;
    width: 100%;
  }
  .upload-input:hover { border-color: var(--azul); }

  /* ── Nuevo forms ─────────────────────────────────────────────────── */
  .nuevo-section {
    background: #111827; border: 1px solid var(--border);
    border-radius: 12px; padding: 20px; max-width: 680px;
  }
  .form-section-title {
    font-size: 1rem; font-weight: 700; color: #F5A623; margin-bottom: 1rem;
  }
  .nuevo-form { display: flex; flex-direction: column; gap: .625rem; }
  .nuevo-form-grid { display: flex; flex-wrap: wrap; gap: .625rem; }
  .nuevo-form-grid .feed-input { flex: 1; min-width: 140px; }
  .insumo-lbl {
    font-size: .72rem; font-weight: 600; color: var(--gris);
    white-space: nowrap; align-self: center;
  }
  .insumo-input-lg { width: 100px; }

  /* ── Panel wrapper ────────────────────────────────────────────────── */
  .panel { max-width: 1200px; margin: 0 auto; }

  /* ── Responsive ───────────────────────────────────────────────────── */
  @media (max-width: 767px) {
    .tab-pane { padding: 1rem; }
    .hdr      { padding: .75rem 1rem; }
    .tabs-nav { padding: 0; }

    /* Ocultar columnas Animal(3) y Hace(7) en mobile */
    #tbl-pendientes th:nth-child(3), #tbl-pendientes td:nth-child(3),
    #tbl-pendientes th:nth-child(7), #tbl-pendientes td:nth-child(7),
    #tbl-publicadas th:nth-child(3), #tbl-publicadas td:nth-child(3),
    #tbl-publicadas th:nth-child(7), #tbl-publicadas td:nth-child(7),
    #tbl-reunidas   th:nth-child(3), #tbl-reunidas   td:nth-child(3),
    #tbl-reunidas   th:nth-child(5), #tbl-reunidas   td:nth-child(5) { display: none; }

    .td-photo { width: 68px; padding: .75rem .5rem; }
    .thumb     { width: 56px !important; height: 56px !important; }
    .thumb-empty { width: 56px !important; height: 56px !important; font-size: 1.4rem; }
    td { height: 72px; }
    .btn { min-width: 60px; font-size: .75rem; }
    .nuevo-section { max-width: 100%; }
    .feed-form { max-width: 100%; }
  }

  @media (max-width: 480px) {
    .hdr { gap: .5rem; }
    .tab { padding: .625rem .75rem; font-size: .75rem; }
    .feed-row { flex-direction: column; }
  }

  /* ── Admin search bar ────────────────────────────────────── */
  .admin-search-bar { margin-bottom: .75rem; }
  .admin-search-input {
    width: 100%; padding: 10px 14px;
    background: #1f2937; border: 1px solid #374151;
    color: #fff; border-radius: 8px; font-size: .875rem;
    font-family: inherit; outline: none; transition: border-color .15s;
  }
  .admin-search-input:focus { border-color: #F5A623; }
  .admin-search-input::placeholder { color: #6B7280; }

  /* ── Urgente (días sin resolver) ─────────────────────────── */
  .td-urgente { color: #EF4444 !important; font-weight: 700; }

  /* ── Edit Modal ──────────────────────────────────────────── */
  .modal-overlay {
    position: fixed; inset: 0; z-index: 200;
    background: rgba(0,0,0,.65); backdrop-filter: blur(3px);
    display: flex; align-items: center; justify-content: center;
    padding: 1rem;
    animation: fadeIn .15s ease;
  }
  @keyframes fadeIn { from { opacity: 0 } to { opacity: 1 } }
  .modal-box {
    background: #1a1d27; border: 1px solid #2d3148; border-radius: 12px;
    padding: 20px; width: min(100%, 560px); max-height: 90dvh;
    overflow-y: auto; display: flex; flex-direction: column; gap: .75rem;
    animation: slideUp .18s ease;
  }
  @keyframes slideUp { from { transform: translateY(10px); opacity: 0 } to { transform: none; opacity: 1 } }
  .modal-hdr {
    display: flex; align-items: center; justify-content: space-between;
    gap: .75rem;
  }
  .modal-title {
    font-size: .975rem; font-weight: 700; color: #F5A623;
  }
  .modal-close {
    background: transparent; border: none; color: var(--gris);
    font-size: 1.1rem; cursor: pointer; padding: .25rem .375rem; line-height: 1;
    border-radius: 4px; transition: color .15s, background .15s;
  }
  .modal-close:hover { color: var(--texto); background: rgba(255,255,255,.06); }
  .modal-form { display: flex; flex-direction: column; gap: .75rem; }
  .modal-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .625rem; }
  .modal-field { display: flex; flex-direction: column; gap: .3rem; }
  .modal-field--full { grid-column: 1 / -1; }
  .modal-lbl {
    font-size: .68rem; font-weight: 700; color: #94A3B8;
    text-transform: uppercase; letter-spacing: .05em;
  }
  .modal-input {
    background: #0f1117; border: 1px solid #374151; border-radius: 8px;
    color: #fff; padding: 10px 12px; font-size: .875rem;
    font-family: inherit; width: 100%; transition: border-color .15s;
  }
  .modal-input:focus { outline: none; border-color: #F5A623; }
  .modal-input option { background: #0f1117; }
  .modal-textarea { resize: vertical; min-height: 76px; }
  .modal-hint { font-size: .7rem; color: #94A3B8; margin-top: 2px; }
  .modal-actions { display: flex; gap: .5rem; margin-top: .125rem; }

  @media (max-width: 480px) {
    .modal-grid { grid-template-columns: 1fr; }
    .modal-field--full { grid-column: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .modal-overlay, .modal-box { animation: none; }
  }

  /* ── Gemini Vision tab ───────────────────────────────────────── */
  .gemini-preview {
    height: 200px;
    background: #1f2937;
    border: 2px dashed #374151;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    overflow: hidden;
    transition: border-color .15s;
  }
  .gemini-preview:hover { border-color: #F5A623; }
  .gemini-preview:focus-visible { outline: 2px solid #F5A623; outline-offset: 2px; }
  .gemini-placeholder { color: #9ca3af; font-size: .875rem; text-align: center; pointer-events: none; }
</style>

<script>
  // ── Tab switching
  document.querySelectorAll('.tab').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.tab').forEach(function(b) {
        b.classList.remove('active')
        b.setAttribute('aria-selected', 'false')
      })
      document.querySelectorAll('.tab-pane').forEach(function(p) {
        p.classList.remove('active')
      })
      btn.classList.add('active')
      btn.setAttribute('aria-selected', 'true')
      var pane = document.getElementById('tab-' + btn.dataset.tab)
      if (pane) pane.classList.add('active')
    })
  })

  // ── Generic fetch action
  async function doAction(params, rowId, confirmMsg) {
    if (confirmMsg && !confirm(confirmMsg)) return false
    var fd = new FormData()
    Object.keys(params).forEach(function(k) { fd.append(k, String(params[k])) })
    try {
      var r = await fetch('/admin', { method: 'POST', body: fd })
      var j = await r.json()
      if (!j.ok) { alert('Error: ' + (j.error || 'desconocido')); return false }
      if (rowId) {
        var el = document.getElementById(rowId)
        if (el) {
          el.style.transition = 'opacity .2s'
          el.style.opacity = '0'
          setTimeout(function() { el.remove() }, 200)
        }
      }
      return true
    } catch(e) {
      alert('Error de red')
      return false
    }
  }

  // ── Data-attribute buttons
  document.querySelectorAll('[data-action]').forEach(function(btn) {
    btn.addEventListener('click', async function() {
      var action = btn.dataset.action
      var id     = btn.dataset.id
      var row    = btn.dataset.row
      var conf   = btn.dataset.confirm
      if (!action || !id) return
      btn.disabled = true
      var params = { action: action, id: id }
      if (btn.dataset.activo !== undefined) params.activo = btn.dataset.activo
      var ok = await doAction(params, row, conf || null)
      if (!ok) btn.disabled = false
    })
  })

  // ── Feed form
  var formFeed = document.getElementById('form-feed')
  if (formFeed) {
    formFeed.addEventListener('submit', async function(e) {
      e.preventDefault()
      var fd  = new FormData(formFeed)
      fd.append('action', 'feed')
      var btn = formFeed.querySelector('button[type="submit"]')
      if (btn) btn.disabled = true
      try {
        var r = await fetch('/admin', { method: 'POST', body: fd })
        var j = await r.json()
        if (!j.ok) {
          alert('Error: ' + (j.error || 'desconocido'))
          if (btn) btn.disabled = false
        } else {
          formFeed.reset()
          if (btn) btn.disabled = false
          var msg = document.createElement('p')
          msg.textContent = '✓ Publicado'
          msg.style.cssText = 'color:#22C55E;font-size:.8rem;margin-top:.375rem;'
          formFeed.appendChild(msg)
          setTimeout(function() { msg.remove() }, 2500)
        }
      } catch(e) {
        alert('Error de red')
        if (btn) btn.disabled = false
      }
    })
  }

  // ── Insumo forms (editar cantidad_recibida Y cantidad_requerida)
  document.querySelectorAll('.insumo-form').forEach(function(form) {
    form.addEventListener('submit', async function(e) {
      e.preventDefault()
      var id       = form.dataset.id
      var inputRec = form.querySelector('input[name="cantidad_recibida"]')
      var inputReq = form.querySelector('input[name="cantidad_requerida"]')
      var cantRec  = inputRec ? inputRec.value : '0'
      var cantReq  = inputReq ? inputReq.value : '1'
      var btn      = form.querySelector('button')
      if (btn) btn.disabled = true
      var ok = await doAction({ action: 'insumo', id: id, cantidad_recibida: cantRec, cantidad_requerida: cantReq }, null, null)
      if (btn) btn.disabled = false
    })
  })

  // ── Banner form (multipart con archivo)
  var formBanner = document.getElementById('form-banner')
  if (formBanner) {
    formBanner.addEventListener('submit', async function(e) {
      e.preventDefault()
      var fd  = new FormData(formBanner)
      fd.append('action', 'banner')
      var btn = formBanner.querySelector('button[type="submit"]')
      if (btn) btn.disabled = true
      try {
        var r = await fetch('/admin', { method: 'POST', body: fd })
        var j = await r.json()
        if (!j.ok) { alert('Error: ' + (j.error || 'desconocido')); if (btn) btn.disabled = false }
        else { window.location.reload() }
      } catch(e) { alert('Error de red'); if (btn) btn.disabled = false }
    })
  }

  // ── Nuevo insumo
  var formNuevoInsumo = document.getElementById('form-nuevo-insumo')
  if (formNuevoInsumo) {
    formNuevoInsumo.addEventListener('submit', async function(e) {
      e.preventDefault()
      var fd  = new FormData(formNuevoInsumo)
      fd.append('action', 'nuevo_insumo')
      var btn = formNuevoInsumo.querySelector('button[type="submit"]')
      if (btn) btn.disabled = true
      try {
        var r = await fetch('/admin', { method: 'POST', body: fd })
        var j = await r.json()
        if (!j.ok) { alert('Error: ' + (j.error || 'desconocido')); if (btn) btn.disabled = false }
        else { window.location.reload() }
      } catch(e) { alert('Error de red'); if (btn) btn.disabled = false }
    })
  }

  // ── Nuevo vet
  var formNuevoVet = document.getElementById('form-nuevo-vet')
  if (formNuevoVet) {
    formNuevoVet.addEventListener('submit', async function(e) {
      e.preventDefault()
      var fd  = new FormData(formNuevoVet)
      fd.append('action', 'nuevo_vet')
      var btn = formNuevoVet.querySelector('button[type="submit"]')
      if (btn) btn.disabled = true
      try {
        var r = await fetch('/admin', { method: 'POST', body: fd })
        var j = await r.json()
        if (!j.ok) { alert('Error: ' + (j.error || 'desconocido')); if (btn) btn.disabled = false }
        else { window.location.reload() }
      } catch(e) { alert('Error de red'); if (btn) btn.disabled = false }
    })
  }

  // ── Edit Modal ────────────────────────────────────────────
  var modal        = document.getElementById('edit-modal')
  var modalClose   = document.getElementById('modal-close')
  var formMascota  = document.getElementById('modal-mascota')
  var formVet      = document.getElementById('modal-vet')
  var formInsumo   = document.getElementById('modal-insumo')

  function openModal(type) {
    [formMascota, formVet, formInsumo].forEach(function(f) { if (f) f.style.display = 'none' })
    if      (type === 'mascota' && formMascota) formMascota.style.display = 'flex'
    else if (type === 'vet'     && formVet)     formVet.style.display     = 'flex'
    else if (type === 'insumo'  && formInsumo)  formInsumo.style.display  = 'flex'
    modal.style.display = 'flex'
    var first = modal.querySelector('.modal-input, button')
    if (first) first.focus()
  }

  function closeModal() {
    modal.style.display = 'none'
    ;[formMascota, formVet, formInsumo].forEach(function(f) { if (f) f.style.display = 'none' })
  }

  if (modalClose) modalClose.addEventListener('click', closeModal)
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal && modal.style.display !== 'none') closeModal()
  })
  document.querySelectorAll('.modal-cancel').forEach(function(b) {
    b.addEventListener('click', closeModal)
  })

  // Abrir modal de mascota
  document.querySelectorAll('.btn-edit-mascota').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.getElementById('em-id').value          = btn.dataset.id        || ''
      document.getElementById('em-nombre').value      = btn.dataset.nombre    || ''
      document.getElementById('em-zona').value        = btn.dataset.zona      || ''
      document.getElementById('em-color').value       = btn.dataset.color     || ''
      document.getElementById('em-whatsapp').value    = btn.dataset.whatsapp  || ''

      document.getElementById('em-descripcion').value = btn.dataset.descripcion || ''
      var selEsp = document.getElementById('em-especie')
      var selTip = document.getElementById('em-tipo')
      for (var i = 0; i < selEsp.options.length; i++) {
        if (selEsp.options[i].value === btn.dataset.especie) { selEsp.selectedIndex = i; break }
      }
      for (var j = 0; j < selTip.options.length; j++) {
        if (selTip.options[j].value === btn.dataset.tipo) { selTip.selectedIndex = j; break }
      }
      openModal('mascota')
    })
  })

  // Abrir modal de vet
  document.querySelectorAll('.btn-edit-vet').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.getElementById('ev-id').value        = btn.dataset.id        || ''
      document.getElementById('ev-nombre').value    = btn.dataset.nombre    || ''
      document.getElementById('ev-zona').value      = btn.dataset.zona      || ''
      document.getElementById('ev-whatsapp').value  = btn.dataset.whatsapp  || ''
      document.getElementById('ev-servicios').value = btn.dataset.servicios || ''
      document.getElementById('ev-horario').value   = btn.dataset.horario   || ''
      openModal('vet')
    })
  })

  // Abrir modal de insumo
  document.querySelectorAll('.btn-edit-insumo').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.getElementById('ei-id').value        = btn.dataset.id                 || ''
      document.getElementById('ei-item').value      = btn.dataset.item               || ''
      document.getElementById('ei-recibida').value  = btn.dataset.cantidad_recibida  || '0'
      document.getElementById('ei-requerida').value = btn.dataset.cantidad_requerida || '1'
      var selPrio = document.getElementById('ei-prioridad')
      for (var i = 0; i < selPrio.options.length; i++) {
        if (selPrio.options[i].value === btn.dataset.prioridad) { selPrio.selectedIndex = i; break }
      }
      openModal('insumo')
    })
  })

  // Submit handler genérico para los tres formularios del modal
  function handleModalForm(form) {
    if (!form) return
    form.addEventListener('submit', async function(e) {
      e.preventDefault()
      var fd  = new FormData(form)
      var btn = form.querySelector('button[type="submit"]')
      if (btn) btn.disabled = true
      try {
        var r = await fetch('/admin', { method: 'POST', body: fd })
        var j = await r.json()
        if (!j.ok) {
          alert('Error: ' + (j.error || 'desconocido'))
          if (btn) btn.disabled = false
        } else {
          closeModal()
          window.location.reload()
        }
      } catch(err) {
        alert('Error de red')
        if (btn) btn.disabled = false
      }
    })
  }
  handleModalForm(formMascota)
  handleModalForm(formVet)
  handleModalForm(formInsumo)

  // ── Search filters (tiempo real, sin reload)
  function setupSearch(inputId, tbodyId, rowClass) {
    var inp = document.getElementById(inputId)
    if (!inp) return
    inp.addEventListener('input', function() {
      var q = this.value.toLowerCase()
      document.querySelectorAll('#' + tbodyId + ' tr.' + rowClass).forEach(function(row) {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none'
      })
    })
  }
  setupSearch('searchPendientes', 'tablaPendientes', 'pendiente-row')
  setupSearch('searchPublicadas', 'tablaPublicadas', 'mascota-row')
  setupSearch('searchVets',       'tablaVets',       'vet-row')

  // ── Gemini Vision tab
  ;(function() {
    var geminiImg   = document.getElementById('geminiImg')
    if (!geminiImg) return
    var btnSel      = document.getElementById('btnSeleccionar')
    var btnExtraer  = document.getElementById('btnExtraer')
    var preview     = document.getElementById('geminiPreview')
    var previewImg  = document.getElementById('geminiPreviewImg')
    var placeholder = document.getElementById('geminiPlaceholder')
    var geminiMsg   = document.getElementById('geminiMsg')
    var geminiForm  = document.getElementById('geminiForm')

    function showMsg(text, ok) {
      geminiMsg.style.display     = 'block'
      geminiMsg.textContent       = text
      geminiMsg.style.background  = ok ? '#064e3b' : '#1f2937'
      geminiMsg.style.borderColor = ok ? '#16a34a' : '#374151'
    }

    function loadPreview(file) {
      var reader = new FileReader()
      reader.onload = function(e) {
        previewImg.src            = e.target.result
        previewImg.style.display  = 'block'
        placeholder.style.display = 'none'
        btnExtraer.disabled       = false
      }
      reader.readAsDataURL(file)
    }

    btnSel.addEventListener('click', function() { geminiImg.click() })
    preview.addEventListener('click', function() { geminiImg.click() })
    preview.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); geminiImg.click() }
    })
    geminiImg.addEventListener('change', function() {
      if (this.files[0]) loadPreview(this.files[0])
    })

    btnExtraer.addEventListener('click', async function() {
      var file = geminiImg.files[0]
      if (!file) return
      btnExtraer.disabled = true
      showMsg('⏳ Analizando imagen con Gemini Vision...', false)

      var reader = new FileReader()
      reader.onload = async function(e) {
        var base64 = e.target.result.split(',')[1]
        var mime   = file.type || 'image/jpeg'
        try {
          var r = await fetch('/api/gemini-extract', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ base64: base64, mime: mime })
          })
          var data = await r.json()
          if (!r.ok || data.error) {
            showMsg('❌ ' + (data.error || 'Error al extraer datos'), false)
            btnExtraer.disabled = false
            return
          }
          if (data.nombre)      document.getElementById('g-nombre').value = data.nombre
          if (data.especie) {
            var selEsp = document.getElementById('g-especie')
            for (var i = 0; i < selEsp.options.length; i++) {
              if (selEsp.options[i].value === data.especie) { selEsp.selectedIndex = i; break }
            }
          }
          if (data.color)       document.getElementById('g-color').value = data.color
          if (data.zona)        document.getElementById('g-zona').value = data.zona
          if (data.descripcion) document.getElementById('g-descripcion').value = data.descripcion
          if (data.whatsapp)    document.getElementById('g-whatsapp').value = data.whatsapp
          if (data.tipo) {
            var selTip = document.getElementById('g-tipo')
            for (var j = 0; j < selTip.options.length; j++) {
              if (selTip.options[j].value === data.tipo) { selTip.selectedIndex = j; break }
            }
          }
          showMsg('✓ Datos extraídos. Revisa y edita antes de guardar.', true)
          geminiForm.style.display = 'block'
          geminiForm.scrollIntoView({ behavior: 'smooth', block: 'start' })
          btnExtraer.disabled = false
        } catch(err) {
          showMsg('❌ Error de red: ' + err.message, false)
          btnExtraer.disabled = false
        }
      }
      reader.readAsDataURL(file)
    })
  })()
</script>
