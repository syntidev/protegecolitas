---
import Base from '../../layouts/Base.astro'
import { supabaseAdmin } from '../../lib/supabase'

const { id } = Astro.params
if (!id) return Astro.redirect('/noticias')

const { data: n } = await supabaseAdmin
  .from('feed')
  .select('id, tipo, titulo, cuerpo, imagen_url, published_at')
  .eq('id', id)
  .maybeSingle()

if (!n) return Astro.redirect('/noticias')

const TIPO_META: Record<string, { label: string; color: string; bg: string; border: string }> = {
  alerta:    { label: 'Alerta',      color: '#EF4444', bg: '#fef2f2', border: '#fecaca' },
  rescate:   { label: 'Rescate',     color: '#16A34A', bg: '#f0fdf4', border: '#bbf7d0' },
  buenas:    { label: '¡Buenas!',    color: '#16A34A', bg: '#f0fdf4', border: '#bbf7d0' },
  info:      { label: 'Info',        color: '#3B82F6', bg: '#eff6ff', border: '#bfdbfe' },
  voluntario:{ label: 'Voluntarios', color: '#F59E0B', bg: '#fffbeb', border: '#fde68a' },
}

const meta = TIPO_META[n.tipo] ?? TIPO_META['info']

const fechaStr = n.published_at
  ? new Date(n.published_at).toLocaleDateString('es-VE', { day: 'numeric', month: 'long', year: 'numeric' })
  : ''

const pageUrl = `https://protegecolitas.org/noticia/${n.id}`
const ogImage = n.imagen_url ?? 'https://protegecolitas.org/banner_mobile.png'
---
<Base
  title={`${n.titulo} — Protege Colitas`}
  ogTitle={n.titulo}
  ogDescription={n.cuerpo?.slice(0, 150) ?? ''}
  ogImage={ogImage}
  ogUrl={pageUrl}
>
  <div class="noticia-wrap">
    <a href="/noticias" class="back-link">← Noticias</a>

    {n.imagen_url && (
      <img
        src={n.imagen_url}
        alt={n.titulo}
        class="noticia-hero"
        loading="eager"
      />
    )}

    <article class="noticia-card">
      <span
        class="noticia-badge"
        style={`color:${meta.color};background:${meta.bg};border:1px solid ${meta.border}`}
      >{meta.label}</span>

      <h1 class="noticia-titulo">{n.titulo}</h1>

      {fechaStr && <p class="noticia-fecha">{fechaStr}</p>}

      <p class="noticia-cuerpo">{n.cuerpo}</p>

      <button class="btn-compartir" id="btnCompartir" data-url={pageUrl} data-titulo={n.titulo}>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
          <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
        </svg>
        <span id="compartirLabel">Compartir</span>
      </button>
    </article>
  </div>
</Base>

<style>
.noticia-wrap {
  max-width: 680px;
  margin: 0 auto;
  padding: 24px 16px 48px;
}

.back-link {
  display: inline-block;
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  font-weight: 600;
  color: var(--marron, #6B3A2A);
  text-decoration: none;
  margin-bottom: 20px;
  opacity: 0.75;
  transition: opacity 0.15s;
}
.back-link:hover { opacity: 1; }

.noticia-hero {
  width: 100%;
  max-height: 600px;
  object-fit: contain;
  background: var(--crema, #FDF8F0);
  border-radius: 12px;
  display: block;
  margin-bottom: 24px;
}

.noticia-card {
  background: #fff;
  border: 1px solid var(--border, #E5DDD0);
  border-radius: 12px;
  padding: 24px;
  box-shadow: 0 2px 8px rgba(61, 28, 2, 0.06);
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.noticia-badge {
  font-family: 'Inter', sans-serif;
  font-weight: 700;
  font-size: 11px;
  padding: 3px 12px;
  border-radius: 20px;
  display: inline-flex;
  align-items: center;
  align-self: flex-start;
  letter-spacing: 0.03em;
}

.noticia-titulo {
  font-family: 'Fredoka', sans-serif;
  font-weight: 700;
  font-size: clamp(22px, 5vw, 28px);
  color: var(--marron, #6B3A2A);
  line-height: 1.2;
  margin: 0;
  text-wrap: balance;
}

.noticia-fecha {
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  color: var(--gris-txt, #6B7280);
  margin: 0;
}

.noticia-cuerpo {
  font-family: 'Inter', sans-serif;
  font-size: 16px;
  line-height: 1.7;
  color: #374151;
  margin: 0;
  white-space: pre-wrap;
}

.btn-compartir {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin-top: 8px;
  align-self: flex-start;
  background: var(--amarillo, #F5C107);
  color: var(--marron, #6B3A2A);
  border: none;
  border-radius: 8px;
  padding: 10px 18px;
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  font-weight: 700;
  cursor: pointer;
  transition: opacity 0.15s;
}
.btn-compartir:hover { opacity: 0.88; }
.btn-compartir:active { transform: scale(0.98); }

@media (prefers-reduced-motion: reduce) {
  .back-link, .btn-compartir { transition: none; }
  .btn-compartir:active { transform: none; }
}
</style>

<script>
  (function() {
    var btn = document.getElementById('btnCompartir')
    if (!btn) return
    btn.addEventListener('click', function() {
      var url    = btn.dataset.url    || window.location.href
      var titulo = btn.dataset.titulo || document.title
      var label  = document.getElementById('compartirLabel')
      if (navigator.share) {
        navigator.share({ title: titulo, url: url }).catch(function() {})
      } else {
        navigator.clipboard.writeText(url).then(function() {
          if (label) label.textContent = 'Copiado'
          setTimeout(function() { if (label) label.textContent = 'Compartir' }, 2000)
        }).catch(function() {})
      }
    })
  })()
</script>
