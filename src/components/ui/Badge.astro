---
const { variant = 'found', size = 'md' } = Astro.props;

const variantClasses = {
  found: 'bg-green-100 text-green-700 border border-green-200',
  lost: 'bg-red-100 text-red-700 border border-red-200',
  need: 'bg-orange-100 text-orange-700 border border-orange-200',
  vet: 'bg-blue-100 text-blue-700 border border-blue-200',
  reunion: 'bg-pink-100 text-pink-700 border border-pink-200',
};

const sizeClasses = {
  sm: 'text-xs px-2 py-0.5',
  md: 'text-xs px-3 py-1',
};

const labels = {
  found: 'Encontrado',
  lost: 'Perdido',
  need: 'Necesidad',
  vet: 'Veterinario',
  reunion: 'Reunión ❤️',
};
---
<span class={`inline-flex items-center font-medium rounded-full ${variantClasses[variant]} ${sizeClasses[size]}`}>
  {labels[variant]}
</span>
