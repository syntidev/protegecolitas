---
import Base from '../layouts/Base.astro'
import { supabase } from '../lib/supabase'

const { data: vets } = await supabase
  .from('vets')
  .select('id, nombre, zona, servicios, horario, whatsapp, gratuito, created_at')
  .order('created_at', { ascending: false })

const WA_BASE = 'https://wa.me/'
---
<Base title="Veterinarios — Protege Colitas">
  <div class="page">
    <header class="page-header">
      <a href="/" class="back-btn" aria-label="Volver al inicio">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M12 4L6 10l6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <div class="header-text">
        <span class="brand">Protege Colitas</span>
      </div>
    </header>

    <main class="content">
      <div class="hero-section">
        <h1 class="page-title">Veterinarios que<br /><em>están ayudando</em></h1>
        <p class="page-sub">Atención voluntaria durante la emergencia.</p>
      </div>

      {vets && vets.length > 0 ? (
        <div class="vets-list">
          {vets.map((v) => {
            const waNum = v.whatsapp?.replace(/\D/g, '')
            const waLink = waNum ? `${WA_BASE}58${waNum.slice(1)}?text=${encodeURIComponent(`Hola ${v.nombre}, vi tu info en Protege Colitas y necesito atención para mi mascota`)}` : null
            return (
              <div class="vet-card">
                <div class="vet-top">
                  <div class="vet-avatar" aria-hidden="true">🩺</div>
                  <div class="vet-main">
                    <div class="vet-name-row">
                      <h2 class="vet-name">{v.nombre}</h2>
                      {v.gratuito && <span class="badge-free">Gratuito</span>}
                    </div>
                    <div class="vet-zona">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
                      {v.zona}
                    </div>
                  </div>
                </div>

                {v.servicios && (
                  <div class="vet-detail">
                    <span class="detail-label">Servicios</span>
                    <span class="detail-val">{v.servicios}</span>
                  </div>
                )}
                {v.horario && (
                  <div class="vet-detail">
                    <span class="detail-label">Horario</span>
                    <span class="detail-val">{v.horario}</span>
                  </div>
                )}

                {waLink && (
                  <a href={waLink} class="btn-wa-vet" target="_blank" rel="noopener noreferrer">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.119.553 4.107 1.516 5.836L.057 23.447a.5.5 0 00.611.612l5.638-1.471A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.891 0-3.666-.5-5.197-1.373l-.371-.22-3.847 1.003 1.022-3.737-.242-.384A9.942 9.942 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
                    Contactar por WhatsApp
                  </a>
                )}
              </div>
            )
          })}
        </div>
      ) : (
        <div class="empty-state">
          <div class="empty-icon">🩺</div>
          <p class="empty-msg">Pronto habrá veterinarios disponibles.</p>
          <p class="empty-sub">¿Eres vet? Regístrate abajo y te publicamos.</p>
        </div>
      )}

      <!-- Formulario registro veterinario -->
      <section class="register-section">
        <div class="register-header">
          <h2 class="register-title">¿Eres veterinario y<br /><em>quieres ayudar?</em></h2>
          <p class="register-sub">Te publicamos gratis. El proceso toma 2 minutos.</p>
        </div>

        <form id="vetForm" class="vet-form" novalidate>
          <div class="field-group">
            <label class="field-label" for="vet-nombre">
              Tu nombre completo <span class="field-req" aria-hidden="true">*</span>
            </label>
            <input type="text" id="vet-nombre" name="nombre" class="form-input" placeholder="Dr. Pérez González" autocomplete="name" required />
            <p class="field-error" id="err-vet-nombre" role="alert"></p>
          </div>

          <div class="field-group">
            <label class="field-label" for="vet-zona">
              Zona donde atiendes <span class="field-req" aria-hidden="true">*</span>
            </label>
            <input type="text" id="vet-zona" name="zona" class="form-input" placeholder="Ej: Porlamar, Nueva Esparta" autocomplete="off" required />
            <p class="field-error" id="err-vet-zona" role="alert"></p>
          </div>

          <div class="field-group">
            <label class="field-label" for="vet-servicios">
              Servicios que ofreces
              <span class="field-note">Opcional</span>
            </label>
            <input type="text" id="vet-servicios" name="servicios" class="form-input" placeholder="Ej: Consulta general, cirugía menor, vacunas" autocomplete="off" />
          </div>

          <div class="field-group">
            <label class="field-label" for="vet-horario">
              Horario disponible
              <span class="field-note">Opcional</span>
            </label>
            <input type="text" id="vet-horario" name="horario" class="form-input" placeholder="Ej: Lun–Vie 8am–4pm" autocomplete="off" />
          </div>

          <div class="field-group">
            <label class="field-label" for="vet-whatsapp">
              Tu WhatsApp <span class="field-req" aria-hidden="true">*</span>
              <span class="field-note">04XX-XXXXXXX</span>
            </label>
            <div class="wa-input-wrap" id="waWrap">
              <span class="wa-prefix" aria-hidden="true">🇻🇪</span>
              <input type="tel" id="vet-whatsapp" name="whatsapp" class="form-input wa-input" placeholder="04141234567" maxlength="11" autocomplete="tel" inputmode="numeric" required />
              <span class="wa-status" id="waStatus" aria-live="polite"></span>
            </div>
            <p class="field-error" id="err-vet-whatsapp" role="alert"></p>
          </div>

          <div class="submit-wrap">
            <button type="submit" class="btn-submit" id="vetSubmit">
              <span id="vetBtnLabel">Registrarme como veterinario</span>
              <span id="vetSpinner" class="spinner" aria-hidden="true" style="display:none"></span>
            </button>
          </div>

          <p class="field-error form-error" id="vetFormError" role="alert"></p>
        </form>

        <div id="vetSuccess" class="success-banner" style="display:none" role="status">
          <span class="success-icon" aria-hidden="true">✓</span>
          <div>
            <strong>¡Recibimos tu registro!</strong>
            <p>Lo revisamos y te publicamos pronto. Gracias por ayudar.</p>
          </div>
        </div>
      </section>
    </main>
  </div>
</Base>

<style>
.page { min-height: 100dvh; display: flex; flex-direction: column; }

.page-header {
  display: flex; align-items: center; gap: 12px;
  padding: 14px 16px;
  background: var(--blanco); border-bottom: 1px solid var(--border);
  position: sticky; top: 0; z-index: 20;
}
.back-btn {
  width: 44px; height: 44px;
  display: flex; align-items: center; justify-content: center;
  border-radius: 10px; background: var(--gris-bg);
  color: var(--marron); text-decoration: none;
  transition: background .15s;
}
.back-btn:hover { background: var(--border); }
.brand { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 17px; color: var(--marron); }

.content { padding: 0 16px 100px; max-width: 600px; margin: 0 auto; width: 100%; }

.hero-section { padding: 28px 0 24px; }
.page-title {
  font-family: 'Syne', sans-serif; font-weight: 800;
  font-size: clamp(28px, 7vw, 40px); line-height: 1.05;
  color: var(--marron); margin-bottom: 8px; text-wrap: balance;
}
.page-title em { font-style: normal; color: var(--amarillo); }
.page-sub { font-size: 15px; color: var(--gris-txt); }

.vets-list { display: flex; flex-direction: column; gap: 12px; margin-bottom: 40px; }

.vet-card {
  background: var(--blanco); border-radius: 16px;
  padding: 16px; border: 1.5px solid var(--border);
  display: flex; flex-direction: column; gap: 10px;
  transition: box-shadow .15s;
}
.vet-card:hover { box-shadow: 0 4px 16px rgba(107,58,42,.08); }

.vet-top { display: flex; gap: 12px; align-items: flex-start; }
.vet-avatar {
  width: 48px; height: 48px; border-radius: 12px;
  background: var(--gris-bg); display: flex; align-items: center; justify-content: center;
  font-size: 22px; flex-shrink: 0;
}
.vet-main { flex: 1; min-width: 0; }
.vet-name-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; margin-bottom: 4px; }
.vet-name { font-size: 16px; font-weight: 700; color: var(--marron); }
.badge-free {
  display: inline-flex; align-items: center;
  padding: 2px 8px; border-radius: 20px;
  font-size: 11px; font-weight: 700;
  background: #f0fdf4; color: var(--verde);
}
.vet-zona {
  display: flex; align-items: center; gap: 4px;
  font-size: 13px; color: var(--gris-txt);
}

.vet-detail { display: flex; flex-direction: column; gap: 2px; }
.detail-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--gris-txt); }
.detail-val { font-size: 14px; color: var(--marron); }

.btn-wa-vet {
  display: flex; align-items: center; justify-content: center; gap: 8px;
  padding: 12px 16px; border-radius: 12px;
  background: #25D366; color: #fff;
  font-size: 14px; font-weight: 700; text-decoration: none;
  min-height: 44px; transition: opacity .15s;
}
.btn-wa-vet:hover { opacity: .9; }

.empty-state {
  display: flex; flex-direction: column; align-items: center;
  padding: 48px 20px; text-align: center; margin-bottom: 32px;
}
.empty-icon { font-size: 52px; margin-bottom: 14px; }
.empty-msg { font-size: 17px; font-weight: 700; color: var(--marron); margin-bottom: 6px; }
.empty-sub { font-size: 14px; color: var(--gris-txt); }

.register-section {
  border-top: 1px solid var(--border);
  padding-top: 32px; margin-top: 8px;
}
.register-header { margin-bottom: 24px; }
.register-title {
  font-family: 'Syne', sans-serif; font-weight: 800;
  font-size: clamp(22px, 5vw, 30px); line-height: 1.1;
  color: var(--marron); margin-bottom: 6px; text-wrap: balance;
}
.register-title em { font-style: normal; color: var(--amarillo); }
.register-sub { font-size: 14px; color: var(--gris-txt); }

.vet-form { display: flex; flex-direction: column; gap: 18px; }
.field-group { display: flex; flex-direction: column; gap: 6px; }
.field-label {
  font-size: 13px; font-weight: 700; color: var(--marron);
  display: flex; align-items: center; gap: 4px; flex-wrap: wrap;
}
.field-req { color: var(--rojo); font-size: 14px; }
.field-note { font-size: 11px; font-weight: 500; color: var(--gris-txt); }
.form-input {
  width: 100%; padding: 13px 14px;
  border: 1.5px solid var(--border); border-radius: 12px;
  background: var(--blanco);
  font-family: 'Inter', sans-serif; font-size: 15px; color: var(--negro, #1A1A1A);
  outline: none; transition: border-color .15s;
  -webkit-appearance: none; appearance: none;
}
.form-input:focus { border-color: var(--marron); }
.form-input.error { border-color: var(--rojo); }

.wa-input-wrap {
  display: flex; align-items: center;
  border: 1.5px solid var(--border); border-radius: 12px;
  background: var(--blanco); overflow: hidden;
  transition: border-color .15s;
}
.wa-input-wrap:focus-within { border-color: var(--marron); }
.wa-input-wrap.valid { border-color: var(--verde); }
.wa-input-wrap.invalid { border-color: var(--rojo); }
.wa-prefix { padding: 0 10px 0 14px; font-size: 18px; flex-shrink: 0; }
.wa-input { flex: 1; border: none !important; border-radius: 0 !important; padding: 13px 0; background: transparent; }
.wa-input:focus { border: none; }
.wa-status { padding: 0 12px; font-size: 16px; flex-shrink: 0; }

.submit-wrap { margin-top: 4px; }
.btn-submit {
  width: 100%; height: 54px;
  background: var(--marron); color: #fff;
  border: none; border-radius: 14px;
  font-family: 'Inter', sans-serif; font-size: 16px; font-weight: 700;
  cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px;
  transition: opacity .15s, transform .1s;
  -webkit-tap-highlight-color: transparent;
}
.btn-submit:disabled { opacity: .6; cursor: not-allowed; }
.btn-submit:active:not(:disabled) { transform: scale(.98); }
.spinner {
  width: 20px; height: 20px;
  border: 2.5px solid rgba(255,255,255,.35); border-top-color: #fff;
  border-radius: 50%; animation: spin .7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

.field-error { font-size: 12px; font-weight: 600; color: var(--rojo); min-height: 16px; }
.form-error { font-size: 13px; text-align: center; padding: 10px; background: #fef2f2; border-radius: 10px; }

.success-banner {
  display: flex; align-items: flex-start; gap: 12px;
  padding: 16px; border-radius: 14px;
  background: #f0fdf4; border: 1.5px solid #bbf7d0;
  margin-top: 8px;
}
.success-icon {
  width: 32px; height: 32px; border-radius: 50%;
  background: var(--verde); color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 16px; font-weight: 700; flex-shrink: 0;
}
.success-banner strong { display: block; font-size: 15px; color: var(--verde); margin-bottom: 4px; }
.success-banner p { font-size: 13px; color: #166534; }

@media (prefers-reduced-motion: reduce) {
  .spinner { animation: none; }
}
</style>

<script>
(function () {
  const WA_RE = /^04[0-9]{2}[0-9]{7}$/
  const form = document.getElementById('vetForm')
  const waInput = document.getElementById('vet-whatsapp')
  const waWrap = document.getElementById('waWrap')
  const waStatus = document.getElementById('waStatus')
  const btnSubmit = document.getElementById('vetSubmit')
  const btnLabel = document.getElementById('vetBtnLabel')
  const spinner = document.getElementById('vetSpinner')
  const formError = document.getElementById('vetFormError')
  const successBanner = document.getElementById('vetSuccess')

  if (!form || !waInput || !waWrap || !btnSubmit) return

  waInput.addEventListener('input', () => {
    const val = waInput.value.replace(/\D/g, '').slice(0, 11)
    waInput.value = val
    if (!val) {
      waWrap.classList.remove('valid', 'invalid')
      waStatus.textContent = ''
    } else if (WA_RE.test(val)) {
      waWrap.classList.remove('invalid'); waWrap.classList.add('valid')
      waStatus.textContent = '✓'
      clearErr('vet-whatsapp')
    } else {
      waWrap.classList.remove('valid'); waWrap.classList.add('invalid')
      waStatus.textContent = ''
    }
  })

  function setErr(id, msg) {
    const el = document.getElementById('err-' + id)
    const inp = document.getElementById(id)
    if (el) el.textContent = msg
    if (inp) inp.classList.add('error')
  }
  function clearErr(id) {
    const el = document.getElementById('err-' + id)
    const inp = document.getElementById(id)
    if (el) el.textContent = ''
    if (inp) inp.classList.remove('error')
  }

  function validate() {
    let ok = true
    const nombre = document.getElementById('vet-nombre').value.trim()
    if (!nombre) { setErr('vet-nombre', '¿Cuál es tu nombre?'); ok = false }
    const zona = document.getElementById('vet-zona').value.trim()
    if (zona.length < 5) { setErr('vet-zona', 'Escribe la zona (mínimo 5 caracteres)'); ok = false }
    const wa = waInput.value.trim()
    if (!WA_RE.test(wa)) { setErr('vet-whatsapp', 'Número venezolano: 04XX + 7 dígitos'); ok = false }
    return ok
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    formError.textContent = ''
    ;['vet-nombre','vet-zona','vet-whatsapp'].forEach(clearErr)
    if (!validate()) return

    btnSubmit.disabled = true
    btnLabel.style.display = 'none'
    spinner.style.display = ''

    const payload = {
      nombre: document.getElementById('vet-nombre').value.trim(),
      zona: document.getElementById('vet-zona').value.trim(),
      servicios: document.getElementById('vet-servicios').value.trim() || null,
      horario: document.getElementById('vet-horario').value.trim() || null,
      whatsapp: waInput.value.trim()
    }

    try {
      const res = await fetch('/api/vets', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      })
      const data = await res.json().catch(() => ({}))
      if (!res.ok) throw new Error(data.error || 'Error al enviar. Intenta de nuevo.')
      form.style.display = 'none'
      successBanner.style.display = 'flex'
    } catch (err) {
      formError.textContent = err.message
      btnSubmit.disabled = false
      btnLabel.style.display = ''
      spinner.style.display = 'none'
    }
  })
})()
</script>
