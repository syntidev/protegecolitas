---
import Base from '../layouts/Base.astro'

const WA_LLAMADAS = 'https://wa.me/584142494136'
const WA_MENSAJES = 'https://wa.me/584222494136'
const WA_DIRECCION = `${WA_MENSAJES}?text=${encodeURIComponent('Necesito la dirección del centro de acopio')}`
const WA_GENERAL = `${WA_LLAMADAS}?text=${encodeURIComponent('Quiero ser voluntario en Protege Colitas')}`

const items = [
  { icon: '🥫', label: 'Alimento húmedo', note: 'Para perros y gatos' },
  { icon: '🩹', label: 'Gasas', note: 'Para tratar heridas' },
  { icon: '🩺', label: 'Vendas', note: 'Para heridas y lesiones' },
  { icon: '💊', label: 'Cremas antibiótico', note: 'Cualquier presentación' },
  { icon: '🧴', label: 'Cremas cicatrizantes', note: 'Cualquier presentación' },
  { icon: '💧', label: 'Solución salina 0.9%', note: 'Para limpiar heridas' },
  { icon: '🚰', label: 'Agua', note: 'Botellones o botellas' },
  { icon: '🧣', label: 'Cobijas', note: 'Para abrigo de los animales' },
  { icon: '🛏️', label: 'Sábanas', note: 'Para camillas y colchonetas' },
]
---
<Base
  title="Acopio — Protege Colitas"
  ogTitle="Centro de Acopio — Protege Colitas"
  ogDescription="Centro de acopio activo en Urb. El Marqués, Caracas. Recibimos donaciones."
  ogImage="https://protegecolitas.org/banner_mobile.png"
  ogUrl="https://protegecolitas.org/acopio"
>
  <div class="page-inner">

    <div class="page-hero">
      <h1 class="page-title">Centro de <em>Acopio</em></h1>
      <p class="page-sub">Punto de recepción de donaciones para mascotas afectadas.</p>
    </div>

    <!-- HERO INFO CARD -->
    <div class="info-card">
      <div class="info-card-head">
        <p class="card-name">Rita Ferrer</p>
        <p class="card-role">Centro de Acopio</p>
      </div>
      <hr class="info-divider" />
      <div class="info-rows">
        <div class="info-row">
          <span class="info-row-icon" aria-hidden="true">📍</span>
          <span class="info-row-text">Urb. El Marqués, Caracas</span>
        </div>
        <div class="info-row">
          <span class="info-row-icon" aria-hidden="true">🕐</span>
          <span class="info-row-text">Lunes a Domingo · 6:00 AM – 10:00 PM</span>
        </div>
        <div class="info-row">
          <span class="info-row-icon" aria-hidden="true">📱</span>
          <a href={WA_MENSAJES} class="phone-link" target="_blank" rel="noopener noreferrer">0422-2494136</a>
        </div>
      </div>
      <a href={WA_DIRECCION} class="btn-ubicacion" target="_blank" rel="noopener noreferrer">
        Ver ubicación por WhatsApp
      </a>
    </div>

    <!-- ITEMS SECTION -->
    <section class="items-section">
      <h2 class="section-title">¿Qué traer?</h2>
      <p class="section-sub">Todo suma. Trae lo que puedas.</p>
      <div class="items-grid">
        {items.map((item) => (
          <div class="item-card">
            <div class="item-icon" aria-hidden="true">{item.icon}</div>
            <div class="item-text">
              <span class="item-label">{item.label}</span>
              <span class="item-note">{item.note}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- VOLUNTEER SECTION -->
    <section class="volunteer-section">
      <h2 class="section-title">¿Quieres ser voluntario/a?</h2>
      <p class="section-sub">Necesitamos ayuda en el centro.</p>
      <div class="vol-card">
        <form class="vol-form" action="/api/voluntarios" method="POST">
          <div class="field-group">
            <label class="field-label" for="vol-nombre">Nombre completo</label>
            <input
              type="text"
              id="vol-nombre"
              name="nombre"
              class="glass-input"
              placeholder="¿Cómo te llamamos?"
              autocomplete="given-name"
              required
            />
          </div>
          <div class="field-group">
            <label class="field-label" for="vol-whatsapp">WhatsApp</label>
            <input
              type="tel"
              id="vol-whatsapp"
              name="whatsapp"
              class="glass-input"
              placeholder="04141234567"
              maxlength="11"
              inputmode="numeric"
              required
            />
          </div>
          <div class="field-group">
            <label class="field-label" for="vol-ayuda">¿En qué puedes ayudar?</label>
            <textarea
              id="vol-ayuda"
              name="ayuda"
              class="glass-input glass-textarea"
              placeholder="Cuéntanos cómo puedes colaborar…"
              rows="3"
            ></textarea>
          </div>
          <button type="submit" class="btn-submit">Quiero ayudar →</button>
        </form>
      </div>
    </section>

  </div>
</Base>

<style>
.page-inner {
  max-width: 600px;
  margin: 0 auto;
  padding: 24px 16px;
}

/* PAGE HERO */
.page-hero {
  padding-bottom: 24px;
}
.page-title {
  font-family: 'Fredoka', sans-serif;
  font-weight: 700;
  font-size: clamp(28px, 7vw, 40px);
  line-height: 1.1;
  color: var(--marron);
  margin: 0 0 8px;
  text-wrap: balance;
}
.page-title em {
  font-style: normal;
  color: var(--amarillo);
}
.page-sub {
  font-family: 'Inter', sans-serif;
  font-size: 15px;
  color: var(--gris);
  margin: 0;
}

/* HERO INFO CARD */
.info-card {
  background: rgba(255, 255, 255, 0.75);
  backdrop-filter: blur(16px) saturate(180%);
  -webkit-backdrop-filter: blur(16px) saturate(180%);
  border: 1px solid rgba(255, 255, 255, 0.9);
  border-radius: 18px;
  box-shadow: 0 8px 32px rgba(61, 28, 2, 0.10);
  padding: 24px;
  margin-bottom: 24px;
}
.info-card-head {
  margin-bottom: 16px;
}
.card-name {
  font-family: 'Fredoka', sans-serif;
  font-weight: 700;
  font-size: 22px;
  color: var(--marron);
  margin: 0 0 4px;
}
.card-role {
  font-family: 'Inter', sans-serif;
  font-weight: 500;
  font-size: 14px;
  color: var(--gris);
  margin: 0;
}
.info-divider {
  border: none;
  border-top: 1px solid rgba(61, 28, 2, 0.08);
  margin: 0 0 16px;
}
.info-rows {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-bottom: 20px;
}
.info-row {
  display: flex;
  align-items: center;
  gap: 10px;
}
.info-row-icon {
  font-size: 18px;
  flex-shrink: 0;
  width: 24px;
  text-align: center;
}
.info-row-text {
  font-family: 'Inter', sans-serif;
  font-weight: 500;
  font-size: 14px;
  color: var(--marron);
}
.phone-link {
  font-family: 'Inter', sans-serif;
  font-weight: 500;
  font-size: 14px;
  color: #25D366;
  text-decoration: none;
}
.phone-link:hover {
  text-decoration: underline;
}
.btn-ubicacion {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 48px;
  background: #25D366;
  color: #fff;
  font-family: 'Inter', sans-serif;
  font-size: 15px;
  font-weight: 700;
  text-decoration: none;
  border-radius: 12px;
  transition: opacity 0.15s;
  box-sizing: border-box;
}
.btn-ubicacion:hover {
  opacity: 0.9;
}

/* ITEMS SECTION */
.items-section {
  margin-bottom: 32px;
}
.section-title {
  font-family: 'Fredoka', sans-serif;
  font-weight: 700;
  font-size: 20px;
  color: var(--marron);
  margin: 0 0 4px;
}
.section-sub {
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  color: var(--gris);
  margin: 0 0 16px;
}
.items-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}
.item-card {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.85);
  border-radius: 12px;
  padding: 14px;
  display: flex;
  align-items: center;
  gap: 12px;
}
.item-icon {
  width: 40px;
  height: 40px;
  background: rgba(245, 166, 35, 0.12);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  flex-shrink: 0;
}
.item-text {
  display: flex;
  flex-direction: column;
  gap: 2px;
  min-width: 0;
}
.item-label {
  font-family: 'Inter', sans-serif;
  font-weight: 600;
  font-size: 14px;
  color: var(--marron);
}
.item-note {
  font-family: 'Inter', sans-serif;
  font-weight: 400;
  font-size: 12px;
  color: var(--gris);
}

/* VOLUNTEER SECTION */
.volunteer-section {
  margin-bottom: 40px;
}
.vol-card {
  background: rgba(255, 255, 255, 0.75);
  backdrop-filter: blur(16px) saturate(180%);
  -webkit-backdrop-filter: blur(16px) saturate(180%);
  border: 1px solid rgba(255, 255, 255, 0.9);
  border-radius: 18px;
  box-shadow: 0 8px 32px rgba(61, 28, 2, 0.10);
  padding: 24px;
  margin-top: 16px;
}
.vol-form {
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.field-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.field-label {
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  font-weight: 600;
  color: var(--marron);
}
.glass-input {
  width: 100%;
  padding: 13px 16px;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1.5px solid rgba(255, 255, 255, 0.9);
  border-radius: 10px;
  font-family: 'Inter', sans-serif;
  font-size: 15px;
  color: var(--marron);
  outline: none;
  transition: border-color 0.15s;
  -webkit-appearance: none;
  appearance: none;
  box-sizing: border-box;
}
.glass-input:focus {
  border-color: var(--amarillo);
}
.glass-textarea {
  resize: vertical;
  min-height: 80px;
}
.btn-submit {
  width: 100%;
  min-height: 48px;
  background: var(--marron);
  color: #fff;
  border: none;
  border-radius: 12px;
  font-family: 'Inter', sans-serif;
  font-size: 16px;
  font-weight: 700;
  cursor: pointer;
  transition: opacity 0.15s, transform 0.1s;
  -webkit-tap-highlight-color: transparent;
}
.btn-submit:hover {
  opacity: 0.9;
}
.btn-submit:active {
  transform: scale(0.98);
}
</style>
