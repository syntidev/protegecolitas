---
import Base from '../layouts/Base.astro'
import { supabase } from '../lib/supabase'

// ── KPIs ──────────────────────────────────────────────────────────────────────
const [
  { count: totalReportadas },
  { count: totalEncontradas },
  { count: totalReunidas },
  { count: totalVets },
] = await Promise.all([
  supabase.from('mascotas').select('*', { count: 'exact', head: true }),
  supabase.from('mascotas').select('*', { count: 'exact', head: true }).eq('tipo', 'encontrado'),
  supabase.from('mascotas').select('*', { count: 'exact', head: true }).eq('status', 'reunido'),
  supabase.from('vets').select('*', { count: 'exact', head: true }),
])

const diasActivos = Math.max(1, Math.floor(
  (Date.now() - new Date('2026-06-25').getTime()) / 86_400_000
))

const ahoraStr = new Date().toLocaleTimeString('es-VE', { hour: '2-digit', minute: '2-digit' })

// ── Actividad ─────────────────────────────────────────────────────────────────
const { data: actividad } = await supabase
  .from('feed')
  .select('id, titulo, tipo, published_at')
  .neq('tipo', 'voluntario')
  .order('published_at', { ascending: false })
  .limit(5)

// ── Mascotas ──────────────────────────────────────────────────────────────────
const { data: encontradas } = await supabase
  .from('mascotas')
  .select('id, nombre, especie, zona, foto_url, whatsapp, created_at')
  .eq('tipo', 'encontrado')
  .eq('status', 'publicado')
  .order('created_at', { ascending: false })
  .limit(8)

const { data: perdidas } = await supabase
  .from('mascotas')
  .select('id, nombre, especie, zona, foto_url, whatsapp, created_at')
  .eq('tipo', 'perdido')
  .eq('status', 'publicado')
  .order('created_at', { ascending: false })
  .limit(8)

// ── Necesidades ───────────────────────────────────────────────────────────────
const { data: necesidades } = await supabase
  .from('necesidades')
  .select('id, item, cantidad_requerida, cantidad_recibida, prioridad')
  .order('prioridad', { ascending: true })
  .limit(3)

// ── Vets ──────────────────────────────────────────────────────────────────────
const { data: vets } = await supabase
  .from('vets')
  .select('id, nombre, zona, servicios, gratuito, whatsapp')
  .order('created_at', { ascending: false })
  .limit(3)

// ── Helpers ───────────────────────────────────────────────────────────────────
function tiempoRel(d: string): string {
  const s = Math.floor((Date.now() - new Date(d).getTime()) / 1000)
  if (s < 60)     return 'Ahora'
  if (s < 3600)   return `Hace ${Math.floor(s / 60)}m`
  if (s < 86400)  return `Hace ${Math.floor(s / 3600)}h`
  if (s < 172800) return 'Ayer'
  return new Date(d).toLocaleDateString('es-VE', { day: 'numeric', month: 'short' })
}

function getPct(rec: number, req: number): number {
  return !req ? 0 : Math.min(100, Math.round((rec / req) * 100))
}

function needPrioridad(rec: number, req: number, campo: string): 'critico' | 'urgente' | 'cubierto' {
  const p = getPct(rec, req)
  if (campo === 'cubierto' || p >= 100) return 'cubierto'
  if (campo === 'critico'  || p < 30)  return 'critico'
  return 'urgente'
}

const FEED_META: Record<string, { label: string; color: string; bg: string; icon: string }> = {
  alerta:  { label: 'Alerta',    color: '#DC2626', bg: '#fef2f2', icon: 'warning-octagon' },
  rescate: { label: 'Rescate',   color: '#2563EB', bg: '#eff6ff', icon: 'first-aid-kit'   },
  buenas:  { label: '¡Buenas!',  color: '#16A34A', bg: '#f0fdf4', icon: 'check-circle'    },
  info:    { label: 'Info',      color: '#6B7280', bg: '#f9fafb', icon: 'info'             },
}

const KPIs = [
  { label: 'Reportadas',   value: totalReportadas  ?? 0, icon: 'paw-print',     color: 'var(--marron)'  },
  { label: 'Encontradas',  value: totalEncontradas ?? 0, icon: 'map-pin',       color: 'var(--azul)'    },
  { label: 'Reunidas',     value: totalReunidas    ?? 0, icon: 'heart',         color: 'var(--verde)'   },
  { label: 'Veterinarios', value: totalVets        ?? 0, icon: 'stethoscope',   color: 'var(--azul)'    },
  { label: 'Centros',      value: 1,                     icon: 'buildings',     color: 'var(--naranja)' },
  { label: 'Días activos', value: diasActivos,            icon: 'calendar-check',color: 'var(--amarillo)'},
]

const ACCIONES = [
  { href: '/reportar?tipo=perdido',   titulo: 'Perdí mi mascota',    sub: 'La vi por última vez antes del sismo', icon: 'paw-print',   accentBg: '#fff0f0', accentColor: '#DC2626', btnBg: '#DC2626', btnColor: '#fff', btnLabel: 'Reportar pérdida' },
  { href: '/reportar?tipo=encontrado',titulo: 'Encontré una mascota',sub: 'La tengo o la vi en mi zona',          icon: 'map-pin',     accentBg: '#f0fdf4', accentColor: '#16A34A', btnBg: '#16A34A', btnColor: '#fff', btnLabel: 'Reportar hallazgo' },
  { href: '/veterinarios',            titulo: 'Soy veterinario',     sub: 'Quiero ofrecer atención voluntaria',   icon: 'stethoscope', accentBg: '#eff6ff', accentColor: '#2563EB', btnBg: '#2563EB', btnColor: '#fff', btnLabel: 'Registrarme' },
  { href: '/insumos',                 titulo: 'Quiero donar',        sub: 'Insumos, alimentos, medicamentos',     icon: 'heart',       accentBg: '#fff7ed', accentColor: '#EA580C', btnBg: '#EA580C', btnColor: '#fff', btnLabel: 'Ver necesidades' },
]

function especieIcon(especie: string): string {
  if (especie === 'Gato') return 'cat'
  if (especie === 'Ave')  return 'bird'
  return 'dog'
}
---

<Base title="Protege Colitas — Centro de Emergencia Animal">

<!-- ═══ 1. HEADER ═══════════════════════════════════════════════════════════ -->
<header class="site-header">
  <div class="header-inner">
    <div class="header-brand">
      <img src="/logo.png" alt="" class="header-logo" onerror="this.style.display='none'" aria-hidden="true" />
      <div>
        <div class="header-name">Protege Colitas</div>
        <div class="header-sub">Centro de Emergencia Animal</div>
      </div>
    </div>

    <div class="header-search" role="search">
      <i class="ph-bold ph-magnifying-glass search-icon" aria-hidden="true"></i>
      <input
        type="search"
        placeholder="Buscar mascota o zona…"
        class="search-input"
        aria-label="Buscar mascota o zona"
        disabled
        title="Búsqueda próximamente"
      />
    </div>

    <div class="header-status">
      <span class="badge-emergencia">
        <span class="pulse-dot" aria-hidden="true"></span>
        Emergencia activa
      </span>
      <span class="header-date">Desde 25 jun 2026</span>
    </div>
  </div>

  <!-- Mobile badge row -->
  <div class="header-mobile-status">
    <span class="badge-emergencia">
      <span class="pulse-dot" aria-hidden="true"></span>
      Emergencia activa · Desde 25 jun 2026
    </span>
  </div>
</header>

<!-- ═══ 2. BARRA DE ESTADO ═══════════════════════════════════════════════════ -->
<div class="status-bar" role="status" aria-live="polite">
  <div class="status-inner">
    <span class="status-text">
      <i class="ph-bold ph-map-pin" aria-hidden="true"></i>
      Operativo en: Caracas · Miranda · Aragua · Carabobo · Lara
    </span>
    <span class="status-time">Actualizado {ahoraStr}</span>
  </div>
</div>

<!-- ═══ 3. KPIs ══════════════════════════════════════════════════════════════ -->
<section class="kpi-section" aria-label="Indicadores en tiempo real">
  <div class="kpi-grid">
    {KPIs.map(k => (
      <div class="kpi-card">
        <i class={`ph-bold ph-${k.icon} kpi-icon`} style={`color: ${k.color}`} aria-hidden="true"></i>
        <span class="kpi-num" style={`color: ${k.color}`}>{k.value.toLocaleString('es-VE')}</span>
        <span class="kpi-label">{k.label}</span>
      </div>
    ))}
  </div>
</section>

<!-- ═══ 4. ACCIONES RÁPIDAS ══════════════════════════════════════════════════ -->
<section class="actions-section" aria-label="Acciones principales">
  <h2 class="section-title">¿Qué necesitas?</h2>
  <div class="actions-grid">
    {ACCIONES.map(a => (
      <a href={a.href} class="action-card" style={`--accent-bg: ${a.accentBg}; --accent-color: ${a.accentColor}; --btn-bg: ${a.btnBg}; --btn-color: ${a.btnColor};`}>
        <div class="action-icon-wrap">
          <i class={`ph-bold ph-${a.icon} action-icon`} aria-hidden="true"></i>
        </div>
        <div class="action-body">
          <span class="action-titulo">{a.titulo}</span>
          <span class="action-sub">{a.sub}</span>
        </div>
        <span class="action-btn">{a.btnLabel}</span>
      </a>
    ))}
  </div>
</section>

<!-- ═══ 5. ACTIVIDAD EN VIVO ═════════════════════════════════════════════════ -->
<section class="feed-section" aria-label="Actividad reciente">
  <div class="section-head">
    <h2 class="section-title">Actividad en vivo</h2>
    <a href="/noticias" class="ver-todos">
      Ver todo
      <i class="ph-bold ph-arrow-right" aria-hidden="true"></i>
    </a>
  </div>

  {actividad && actividad.length > 0 ? (
    <ul class="feed-list" role="list">
      {actividad.map(n => {
        const meta = FEED_META[n.tipo] ?? FEED_META['info']
        return (
          <li class="feed-item">
            <div class="feed-icon-wrap" style={`background: ${meta.bg}; color: ${meta.color};`}>
              <i class={`ph-bold ph-${meta.icon}`} aria-hidden="true"></i>
            </div>
            <div class="feed-body">
              <span class="feed-titulo">{n.titulo}</span>
              {n.published_at && (
                <span class="feed-time">{tiempoRel(n.published_at)}</span>
              )}
            </div>
            <span class="feed-badge" style={`color: ${meta.color}; background: ${meta.bg};`}>
              {meta.label}
            </span>
          </li>
        )
      })}
    </ul>
  ) : (
    <div class="empty-inline">
      <i class="ph-bold ph-megaphone empty-icon" aria-hidden="true"></i>
      <span>Pronto publicaremos actualizaciones.</span>
    </div>
  )}
</section>

<!-- ═══ 6. MASCOTAS ENCONTRADAS ══════════════════════════════════════════════ -->
<section class="pets-section" aria-label="Mascotas encontradas recientemente">
  <div class="section-head">
    <h2 class="section-title">Encontradas recientemente</h2>
    <a href="/mascotas?status=encontrado" class="ver-todos">
      Ver todas
      <i class="ph-bold ph-arrow-right" aria-hidden="true"></i>
    </a>
  </div>

  {encontradas && encontradas.length > 0 ? (
    <div class="pets-scroll" role="list" aria-label="Mascotas encontradas">
      {encontradas.map(m => {
        const wa = m.whatsapp
          ? `https://wa.me/58${m.whatsapp.slice(1)}?text=${encodeURIComponent(`Hola, vi a ${m.nombre || 'esta mascota'} en Protege Colitas`)}`
          : 'https://wa.me/584242042786'
        return (
          <div class="pet-card" role="listitem">
            <div class="pet-photo">
              {m.foto_url
                ? <img src={m.foto_url} alt={m.nombre || 'Mascota encontrada'} loading="lazy" />
                : <i class={`ph-bold ph-${especieIcon(m.especie)}`} aria-label={m.especie} style="font-size:36px; color: var(--gris-txt);"></i>
              }
              <span class="pet-badge-found">Encontrada</span>
            </div>
            <div class="pet-info">
              <span class="pet-name">{m.nombre || 'Sin nombre'}</span>
              <span class="pet-zona">
                <i class="ph-bold ph-map-pin" aria-hidden="true"></i>
                {m.zona}
              </span>
              {m.created_at && <span class="pet-time">{tiempoRel(m.created_at)}</span>}
            </div>
            <a href={wa} class="pet-wa" target="_blank" rel="noopener noreferrer" aria-label={`Contactar por WhatsApp sobre ${m.nombre || 'esta mascota'}`}>
              <i class="ph-bold ph-whatsapp-logo" aria-hidden="true"></i>
              Contactar
            </a>
          </div>
        )
      })}
    </div>
  ) : (
    <div class="empty-inline">
      <i class="ph-bold ph-paw-print empty-icon" aria-hidden="true"></i>
      <span>Aún no hay mascotas encontradas publicadas.</span>
    </div>
  )}
</section>

<!-- ═══ 7. MASCOTAS PERDIDAS ═════════════════════════════════════════════════ -->
<section class="pets-section" aria-label="Mascotas perdidas recientemente">
  <div class="section-head">
    <h2 class="section-title">Perdidas recientemente</h2>
    <a href="/mascotas?status=perdido" class="ver-todos">
      Ver todas
      <i class="ph-bold ph-arrow-right" aria-hidden="true"></i>
    </a>
  </div>

  {perdidas && perdidas.length > 0 ? (
    <div class="pets-scroll" role="list" aria-label="Mascotas perdidas">
      {perdidas.map(m => {
        const wa = m.whatsapp
          ? `https://wa.me/58${m.whatsapp.slice(1)}?text=${encodeURIComponent(`Hola, creo que vi a ${m.nombre || 'tu mascota'} en Protege Colitas`)}`
          : 'https://wa.me/584242042786'
        return (
          <div class="pet-card pet-card-lost" role="listitem">
            <div class="pet-photo">
              {m.foto_url
                ? <img src={m.foto_url} alt={m.nombre || 'Mascota perdida'} loading="lazy" />
                : <i class={`ph-bold ph-${especieIcon(m.especie)}`} aria-label={m.especie} style="font-size:36px; color: var(--gris-txt);"></i>
              }
              <span class="pet-badge-lost">Perdida</span>
            </div>
            <div class="pet-info">
              <span class="pet-name">{m.nombre || 'Sin nombre'}</span>
              <span class="pet-zona">
                <i class="ph-bold ph-map-pin" aria-hidden="true"></i>
                {m.zona}
              </span>
              {m.created_at && <span class="pet-time">{tiempoRel(m.created_at)}</span>}
            </div>
            <a href={wa} class="pet-wa pet-wa-lost" target="_blank" rel="noopener noreferrer" aria-label={`Contactar por WhatsApp sobre ${m.nombre || 'esta mascota'}`}>
              <i class="ph-bold ph-whatsapp-logo" aria-hidden="true"></i>
              Contactar
            </a>
          </div>
        )
      })}
    </div>
  ) : (
    <div class="empty-inline">
      <i class="ph-bold ph-paw-print empty-icon" aria-hidden="true"></i>
      <span>Aún no hay mascotas perdidas publicadas.</span>
    </div>
  )}
</section>

<!-- ═══ 8. NECESIDADES URGENTES ══════════════════════════════════════════════ -->
{necesidades && necesidades.length > 0 && (
  <section class="needs-section" aria-label="Necesidades urgentes">
    <div class="section-head">
      <h2 class="section-title">Lo que más necesitamos</h2>
      <a href="/insumos" class="ver-todos">
        Ver todo
        <i class="ph-bold ph-arrow-right" aria-hidden="true"></i>
      </a>
    </div>
    <div class="needs-grid">
      {necesidades.map(n => {
        const pct = getPct(n.cantidad_recibida ?? 0, n.cantidad_requerida)
        const pri = needPrioridad(n.cantidad_recibida ?? 0, n.cantidad_requerida, n.prioridad)
        return (
          <div class={`need-card need-${pri}`}>
            <div class="need-top">
              <span class="need-item">{n.item}</span>
              <span class={`need-pct need-pct-${pri}`}>{pct}%</span>
            </div>
            <div class="need-track">
              <div
                class={`need-fill need-fill-${pri}`}
                style={`width:${pct}%`}
                role="progressbar"
                aria-valuenow={pct}
                aria-valuemin={0}
                aria-valuemax={100}
                aria-label={`${n.item}: ${pct}% cubierto`}
              ></div>
            </div>
            <a
              href={`https://wa.me/584242042786?text=${encodeURIComponent(`Quiero donar ${n.item}`)}`}
              class="need-cta"
              target="_blank"
              rel="noopener noreferrer"
            >
              <i class="ph-bold ph-whatsapp-logo" aria-hidden="true"></i>
              Donar esto
            </a>
          </div>
        )
      })}
    </div>
  </section>
)}

<!-- ═══ 9. VETERINARIOS ══════════════════════════════════════════════════════ -->
{vets && vets.length > 0 && (
  <section class="vets-section" aria-label="Veterinarios voluntarios">
    <div class="section-head">
      <h2 class="section-title">Veterinarios disponibles</h2>
      <a href="/veterinarios" class="ver-todos">
        Ver todos
        <i class="ph-bold ph-arrow-right" aria-hidden="true"></i>
      </a>
    </div>
    <div class="vets-list">
      {vets.map(v => {
        const waNum = v.whatsapp?.replace(/\D/g, '')
        const waLink = waNum
          ? `https://wa.me/58${waNum.slice(1)}?text=${encodeURIComponent(`Hola ${v.nombre}, vi tu info en Protege Colitas`)}`
          : null
        return (
          <div class="vet-row">
            <div class="vet-avatar" aria-hidden="true">
              <i class="ph-bold ph-stethoscope"></i>
            </div>
            <div class="vet-info">
              <div class="vet-name-row">
                <span class="vet-name">{v.nombre}</span>
                {v.gratuito && <span class="vet-free-badge">Gratuito</span>}
              </div>
              <span class="vet-zona">
                <i class="ph-bold ph-map-pin" aria-hidden="true"></i>
                {v.zona}
              </span>
              {v.servicios && <span class="vet-servicios">{v.servicios}</span>}
            </div>
            {waLink && (
              <a href={waLink} class="vet-wa" target="_blank" rel="noopener noreferrer" aria-label={`WhatsApp de ${v.nombre}`}>
                <i class="ph-bold ph-whatsapp-logo" aria-hidden="true"></i>
              </a>
            )}
          </div>
        )
      })}
    </div>
  </section>
)}

<!-- ═══ 10. BANNER EMOCIONAL ═════════════════════════════════════════════════ -->
<section class="banner-section" aria-label="Comparte la iniciativa">
  <div class="banner-inner">
    <i class="ph-bold ph-paw-print banner-icon" aria-hidden="true"></i>
    <blockquote class="banner-quote">
      "Cada publicación puede<br />significar un reencuentro."
    </blockquote>
    <a
      href={`https://wa.me/?text=${encodeURIComponent('Ayuda a reunir mascotas perdidas en Venezuela → protegecolitas.org #MascotasPerdidasVenezuela')}`}
      class="banner-share"
      target="_blank"
      rel="noopener noreferrer"
    >
      <i class="ph-bold ph-share-network" aria-hidden="true"></i>
      Compartir en WhatsApp
    </a>
  </div>
</section>

<!-- ═══ 11. FOOTER ════════════════════════════════════════════════════════════ -->
<footer class="site-footer" role="contentinfo">
  <div class="footer-inner">
    <div class="footer-brand">
      <img src="/logo.png" alt="Protege Colitas" class="footer-logo" onerror="this.style.display='none'" />
      <div>
        <div class="footer-name">Protege Colitas</div>
        <div class="footer-domain">protegecolitas.org</div>
      </div>
    </div>

    <div class="footer-social">
      <a href="https://wa.me/584242042786" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
        <i class="ph-bold ph-whatsapp-logo" aria-hidden="true"></i>
      </a>
      <a href="https://instagram.com/protegecolitas" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
        <i class="ph-bold ph-instagram-logo" aria-hidden="true"></i>
      </a>
      <a href="https://facebook.com/protegecolitas" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
        <i class="ph-bold ph-facebook-logo" aria-hidden="true"></i>
      </a>
    </div>

    <nav class="footer-nav" aria-label="Páginas del sitio">
      <a href="/reportar">Reportar</a>
      <a href="/insumos">Insumos</a>
      <a href="/veterinarios">Vets</a>
      <a href="/acopio">Acopio</a>
      <a href="/noticias">Noticias</a>
    </nav>

    <a href="mailto:protegecolitas@gmail.com" class="footer-email">
      <i class="ph-bold ph-envelope" aria-hidden="true"></i>
      protegecolitas@gmail.com
    </a>

    <p class="footer-copy">&copy; 2026 Protege Colitas · #MascotasPerdidasVenezuela</p>
  </div>
</footer>

</Base>

<style>
/* ═══ HEADER ══════════════════════════════════════════════════════════════════ */
.site-header {
  background: var(--blanco);
  border-bottom: 1px solid var(--border);
  position: sticky;
  top: 0;
  z-index: 50;
}
.header-inner {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  max-width: 1200px;
  margin: 0 auto;
}
.header-brand {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
}
.header-logo { width: 36px; height: 36px; object-fit: contain; }
.header-name {
  font-family: 'Nunito', sans-serif;
  font-weight: 900;
  font-size: 16px;
  color: var(--marron);
  line-height: 1.1;
}
.header-sub {
  font-size: 10px;
  font-weight: 600;
  color: var(--gris-txt);
  text-transform: uppercase;
  letter-spacing: .06em;
}
.header-search {
  flex: 1;
  display: none;
  align-items: center;
  gap: 8px;
  background: var(--gris-bg);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 0 12px;
  height: 38px;
}
.search-icon { color: var(--gris-txt); font-size: 16px; }
.search-input {
  flex: 1;
  border: none;
  background: transparent;
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  color: var(--negro);
  outline: none;
}
.search-input::placeholder { color: var(--gris-txt); }
.header-status {
  display: none;
  flex-direction: column;
  align-items: flex-end;
  gap: 2px;
  flex-shrink: 0;
}
.header-date { font-size: 11px; color: var(--gris-txt); font-weight: 500; }
.badge-emergencia {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 5px 10px;
  background: #f0fdf4;
  color: var(--verde);
  border: 1px solid #bbf7d0;
  border-radius: 20px;
  font-size: 11px;
