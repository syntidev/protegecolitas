---
import { supabaseAdmin } from '../lib/supabase'

const [
  { count: perdidos },
  { count: encontrados },
  { count: reunidos },
  { data: mascotas }
] = await Promise.all([
  supabaseAdmin.from('mascotas').select('*', { count: 'exact', head: true }).eq('status', 'publicado').eq('tipo', 'perdido'),
  supabaseAdmin.from('mascotas').select('*', { count: 'exact', head: true }).eq('status', 'publicado').eq('tipo', 'encontrado'),
  supabaseAdmin.from('mascotas').select('*', { count: 'exact', head: true }).eq('status', 'reunido'),
  supabaseAdmin.from('mascotas').select('id, nombre, especie, zona, tipo, foto_url, whatsapp, created_at').eq('status', 'publicado').order('created_at', { ascending: false }).limit(20),
])
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Plataforma de emergencia para reunir mascotas perdidas con sus familias tras el terremoto de Venezuela 2026." />
  <meta property="og:title" content="Protege Colitas" />
  <meta property="og:description" content="Reuniendo mascotas con sus familias. Terremoto Venezuela 2026." />
  <meta property="og:type" content="website" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@800&family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
  <title>Protege Colitas — Reuniendo mascotas con sus familias</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:      #0A0E1A;
      --card:    #111827;
      --border:  #1F2937;
      --white:   #FFFFFF;
      --gray:    #9CA3AF;
      --rojo:    #FF3B3B;
      --verde:   #22C55E;
    }

    html { background: var(--bg); }
    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--white);
      min-height: 100dvh;
      padding-bottom: 72px;
      -webkit-font-smoothing: antialiased;
    }

    /* ─── Ribbon ─── */
    .ribbon {
      background: var(--rojo);
      color: #fff;
      font-size: 13px;
      font-weight: 600;
      text-align: center;
      padding: 0 16px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* ─── Header ─── */
    .site-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 18px 20px;
      background: var(--bg);
    }
    .site-logo {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 20px;
      color: var(--white);
      text-decoration: none;
    }
    .header-admin {
      font-size: 12px;
      color: var(--gray);
      text-decoration: none;
      opacity: 0.5;
      transition: opacity .15s;
    }
    .header-admin:hover { opacity: 1; }

    /* ─── Hero ─── */
    .hero {
      padding: 32px 16px 28px;
      text-align: center;
      max-width: 480px;
      margin: 0 auto;
    }
    .hero-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 4px;
      margin-bottom: 20px;
    }
    .hero-stat-num {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(36px, 9vw, 56px);
      line-height: 1;
      display: block;
    }
    .stat-perdido   { color: var(--rojo); }
    .stat-encontrado { color: var(--white); }
    .stat-reunido   { color: var(--verde); }
    .hero-stat-label {
      font-size: 11px;
      color: var(--gray);
      font-weight: 600;
      display: block;
      margin-top: 4px;
    }
    .hero-line {
      font-size: 15px;
      color: var(--gray);
      line-height: 1.5;
      margin: 0 0 24px;
    }
    .hero-ctas {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .cta {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      height: 52px;
      border-radius: 12px;
      font-family: 'Inter', sans-serif;
      font-size: 15px;
      font-weight: 700;
      text-decoration: none;
      transition: opacity .15s, transform .1s;
      -webkit-tap-highlight-color: transparent;
    }
    .cta:active { transform: scale(.98); }
    .cta-perdido   { background: var(--rojo);  color: #fff; }
    .cta-encontrado { background: var(--verde); color: #000; }
    .cta:hover { opacity: .88; }

    /* ─── Lista reportes ─── */
    .lista-section {
      padding: 0 16px;
      max-width: 640px;
      margin: 0 auto;
    }
    .lista-title {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 18px;
      color: var(--white);
      margin-bottom: 14px;
    }
    .pet-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 12px 14px;
      background: var(--card);
      border-radius: 8px;
      margin-bottom: 8px;
      border-left: 3px solid transparent;
    }
    .pet-row-perdido   { border-left-color: var(--rojo); }
    .pet-row-encontrado { border-left-color: var(--verde); }
    .pet-row-info { flex: 1; min-width: 0; }
    .pet-row-top {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 3px;
    }
    .pet-row-nombre {
      font-size: 15px;
      font-weight: 700;
      color: var(--white);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .badge {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: .06em;
      text-transform: uppercase;
      padding: 2px 6px;
      border-radius: 4px;
      flex-shrink: 0;
      white-space: nowrap;
    }
    .badge-perdido    { background: rgba(255,59,59,.15);  color: var(--rojo); }
    .badge-encontrado { background: rgba(34,197,94,.15);  color: var(--verde); }
    .pet-row-meta {
      font-size: 13px;
      color: var(--gray);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .btn-wa-mini {
      display: flex;
      align-items: center;
      gap: 5px;
      padding: 7px 12px;
      background: #25D366;
      color: #fff;
      border-radius: 7px;
      font-size: 12px;
      font-weight: 700;
      text-decoration: none;
      white-space: nowrap;
      flex-shrink: 0;
      min-height: 34px;
      transition: opacity .15s;
    }
    .btn-wa-mini:hover { opacity: .9; }

    /* ─── Empty state ─── */
    .empty-state {
      text-align: center;
      padding: 40px 16px;
      color: var(--gray);
    }
    .empty-state a {
      color: var(--gray);
      text-decoration: none;
      font-weight: 600;
    }
    .empty-state a:hover { color: var(--white); }

    /* ─── Ver todos ─── */
    .ver-todos {
      text-align: center;
      padding: 20px 16px 32px;
    }
    .ver-todos a {
      font-size: 14px;
      color: var(--gray);
      text-decoration: none;
      transition: color .15s;
    }
    .ver-todos a:hover { color: var(--white); }

    /* ─── Nav bottom ─── */
    .bottom-nav {
      position: fixed;
      bottom: 0; left: 0; right: 0;
      background: var(--card);
      border-top: 1px solid var(--border);
      display: flex;
      z-index: 100;
      padding-bottom: env(safe-area-inset-bottom, 0);
    }
    .nav-item {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 4px;
      padding: 8px 4px 10px;
      text-decoration: none;
      color: var(--gray);
      min-height: 60px;
      transition: color .15s;
      -webkit-tap-highlight-color: transparent;
    }
    .nav-item:hover { color: var(--white); }
    .nav-active     { color: var(--white); }
    .nav-label {
      font-size: 10px;
      font-weight: 600;
      line-height: 1;
    }

    @media (min-width: 640px) {
      .bottom-nav {
        max-width: 640px;
        left: 50%; right: auto;
        transform: translateX(-50%);
        border-radius: 16px 16px 0 0;
        border-left: 1px solid var(--border);
        border-right: 1px solid var(--border);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .cta, .btn-wa-mini { transition: none; }
    }
  </style>
</head>
<body>

  <!-- 1. RIBBON -->
  <div class="ribbon">🔴 Emergencia activa · Terremoto Venezuela · 24 jun 2026</div>

  <!-- 2. HEADER -->
  <header class="site-header">
    <span class="site-logo">🐾 Protege Colitas</span>
    <a href="/admin" class="header-admin">Admin</a>
  </header>

  <!-- 3. HERO -->
  <section class="hero">
    <div class="hero-stats">
      <div>
        <span class="hero-stat-num stat-perdido">{perdidos ?? 0}</span>
        <span class="hero-stat-label">Buscando familia</span>
      </div>
      <div>
        <span class="hero-stat-num stat-encontrado">{encontrados ?? 0}</span>
        <span class="hero-stat-label">Encontrados</span>
      </div>
      <div>
        <span class="hero-stat-num stat-reunido">{reunidos ?? 0}</span>
        <span class="hero-stat-label">Reunidos ✓</span>
      </div>
    </div>

    <p class="hero-line">Cada número es una familia esperando.</p>

    <div class="hero-ctas">
      <a href="/reportar?tipo=perdido" class="cta cta-perdido">🐾 Perdí a mi mascota</a>
      <a href="/reportar?tipo=encontrado" class="cta cta-encontrado">📍 Encontré una mascota</a>
    </div>
  </section>

  <!-- 4. LISTA -->
  <section class="lista-section">
    <h2 class="lista-title">Reportes activos</h2>

    {mascotas && mascotas.length > 0 ? (
      mascotas.map((m) => {
        const tipo = m.tipo ?? 'perdido'
        const waNum = m.whatsapp ? `58${m.whatsapp.slice(1)}` : null
        const waHref = waNum
          ? `https://wa.me/${waNum}?text=${encodeURIComponent(`Hola, vi el reporte de ${m.nombre ?? 'una mascota'} en protegecolitas.org`)}`
          : null
        return (
          <div class={`pet-row pet-row-${tipo}`}>
            <div class="pet-row-info">
              <div class="pet-row-top">
                <span class="pet-row-nombre">{m.nombre ?? 'Sin nombre'}</span>
                <span class={`badge badge-${tipo}`}>{tipo}</span>
              </div>
              <p class="pet-row-meta">{m.especie} · {m.zona}</p>
            </div>
            {waHref && (
              <a href={waHref} class="btn-wa-mini" target="_blank" rel="noopener noreferrer">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.119.553 4.107 1.516 5.836L.057 23.447a.5.5 0 00.611.612l5.638-1.471A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.891 0-3.666-.5-5.197-1.373l-.371-.22-3.847 1.003 1.022-3.737-.242-.384A9.942 9.942 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
                WA
              </a>
            )}
          </div>
        )
      })
    ) : (
      <div class="empty-state">
        <a href="/reportar">Sé el primero en reportar →</a>
      </div>
    )}
  </section>

  <!-- 5. VER TODOS -->
  <div class="ver-todos">
    <a href="/mascotas">Ver todos los reportes →</a>
  </div>

  <!-- 6. NAV BOTTOM -->
  <nav class="bottom-nav" role="navigation" aria-label="Navegación principal">
    <!-- Inicio (activo) -->
    <a href="/" class="nav-item nav-active" aria-current="page" aria-label="Inicio">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
        <polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
      <span class="nav-label">Inicio</span>
    </a>
    <!-- Mascotas -->
    <a href="/mascotas" class="nav-item" aria-label="Mascotas">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="4" r="2"/><circle cx="18" cy="8" r="2"/><circle cx="20" cy="16" r="2"/>
        <path d="M9 10a5 5 0 005 5v3.5a1.5 1.5 0 01-3 0V16c-3-.5-5-2.7-5-5a5 5 0 012-4"/>
      </svg>
      <span class="nav-label">Mascotas</span>
    </a>
    <!-- Reportar -->
    <a href="/reportar" class="nav-item" aria-label="Reportar">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="16"/>
        <line x1="8" y1="12" x2="16" y2="12"/>
      </svg>
      <span class="nav-label">Reportar</span>
    </a>
    <!-- Vets -->
    <a href="/veterinarios" class="nav-item" aria-label="Veterinarios">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
      </svg>
      <span class="nav-label">Vets</span>
    </a>
    <!-- Insumos -->
    <a href="/insumos" class="nav-item" aria-label="Insumos">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
        <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
        <line x1="12" y1="22.08" x2="12" y2="12"/>
      </svg>
      <span class="nav-label">Insumos</span>
    </a>
  </nav>

</body>
</html>
