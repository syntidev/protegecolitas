---
import Base from '../layouts/Base.astro'
import { supabaseAdmin } from '../lib/supabase'

const { data: notas } = await supabaseAdmin
  .from('feed')
  .select('id, titulo, cuerpo, tipo, published_at, imagen_url, slug')
  .order('published_at', { ascending: false })
  .neq('tipo', 'voluntario')

function tiempoRelativo(dateStr: string): string {
  if (!dateStr) return ''
  const ahora = Date.now()
  const pub = new Date(dateStr).getTime()
  const diff = Math.floor((ahora - pub) / 1000)
  if (diff < 60) return 'Hace un momento'
  if (diff < 3600) return `Hace ${Math.floor(diff / 60)} min`
  if (diff < 86400) return `Hace ${Math.floor(diff / 3600)} h`
  if (diff < 172800) return 'Ayer'
  const d = new Date(dateStr)
  return d.toLocaleDateString('es-VE', { day: 'numeric', month: 'short' })
}

const TIPO_META: Record<string, { label: string; color: string; bg: string; border: string }> = {
  alerta:    { label: 'Alerta',    color: '#EF4444', bg: '#fef2f2', border: '#fecaca' },
  rescate:   { label: 'Rescate',   color: '#16A34A', bg: '#f0fdf4', border: '#bbf7d0' },
  buenas:    { label: '¡Buenas!',  color: '#16A34A', bg: '#f0fdf4', border: '#bbf7d0' },
  info:      { label: 'Info',      color: '#3B82F6', bg: '#eff6ff', border: '#bfdbfe' },
  voluntario:{ label: 'Voluntarios',color: '#F59E0B', bg: '#fffbeb', border: '#fde68a' },
}
---
<Base
  title="Noticias — Protege Colitas"
  ogTitle="Lo que está pasando — Protege Colitas"
  ogDescription="Actualizaciones en tiempo real de la emergencia animal post-terremoto."
  ogImage="https://protegecolitas.org/banner_mobile.png"
  ogUrl="https://protegecolitas.org/noticias"
>
  <div class="page-inner">
    <div class="page-hero">
      <h1 class="page-title">Lo que está <em>pasando</em></h1>
      <p class="page-sub">Actualizaciones en tiempo real de la emergencia.</p>
    </div>

    {notas && notas.length > 0 ? (
      <div class="notas-grid">
        {notas.map(nota => {
          const meta = TIPO_META[nota.tipo] ?? TIPO_META['info']
          const hasImg = !!nota.imagen_url
          const notaUrl = `https://protegecolitas.org/noticia/${nota.slug ?? nota.id}`
          return (
            <a
              href={`/noticia/${nota.slug ?? nota.id}`}
              class={`nota-card ${hasImg ? 'nota-card--img' : 'nota-card--text'}`}
              style={!hasImg ? `border-top: 3px solid ${meta.color}` : ''}
            >
              {hasImg && (
                <div class="nota-img-wrap">
                  <img
                    src={nota.imagen_url}
                    alt={nota.titulo}
                    class="nota-img"
                    loading="lazy"
                  />
                  <span
                    class="nota-badge nota-badge--overlay"
                    style={`background:${meta.color}`}
                  >{meta.label}</span>
                </div>
              )}
              <div class="nota-body">
                {!hasImg && (
                  <span
                    class="nota-badge"
                    style={`color:${meta.color};background:${meta.bg};border:1px solid ${meta.border}`}
                  >{meta.label}</span>
                )}
                <h2 class="nota-titulo">{nota.titulo}</h2>
                <p class="nota-cuerpo">{nota.cuerpo}</p>
                <div class="nota-footer">
                  <span class="nota-fecha">{tiempoRelativo(nota.published_at)}</span>
                  <button
                    class="btn-compartir-noticia"
                    data-url={notaUrl}
                    data-titulo={nota.titulo}
                    aria-label={`Compartir: ${nota.titulo}`}
                  >Compartir</button>
                </div>
              </div>
            </a>
          )
        })}
      </div>
    ) : (
      <div class="empty-state">
        <span class="empty-icon">📋</span>
        <p class="empty-msg">Sin actualizaciones aún</p>
      </div>
    )}
  </div>
</Base>

<style>
.page-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 24px 16px 40px;
  width: 100%;
}

.page-hero {
  padding-bottom: 28px;
  max-width: 560px;
}

.page-title {
  font-family: 'Fredoka', sans-serif;
  font-weight: 700;
  font-size: clamp(28px, 7vw, 40px);
  line-height: 1.05;
  color: var(--marron, #3D1C02);
  margin-bottom: 8px;
  text-wrap: balance;
}
.page-title em {
  font-style: normal;
  color: var(--amarillo, #F5A623);
}

.page-sub {
  font-family: 'Inter', sans-serif;
  font-size: 15px;
  color: var(--gris, #6B7280);
  line-height: 1.5;
}

/* ── Grid ── */
.notas-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
  align-items: start;
}
@media (min-width: 640px) {
  .notas-grid { grid-template-columns: repeat(2, 1fr); gap: 18px; }
}
@media (min-width: 1024px) {
  .notas-grid { grid-template-columns: repeat(3, 1fr); gap: 20px; }
}

/* ── Card base ── */
.nota-card {
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid var(--border, #E5DDD0);
  box-shadow: 0 2px 8px rgba(61, 28, 2, 0.06);
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
  transition: box-shadow 0.18s ease, transform 0.18s ease;
}
.nota-card:hover {
  box-shadow: 0 6px 20px rgba(61, 28, 2, 0.12);
  transform: translateY(-2px);
}

/* ── Image card ── */
.nota-card--img { border-top: none; }

.nota-img-wrap {
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
}
.nota-img {
  width: 100%;
  aspect-ratio: 1 / 1;
  object-fit: cover;
  display: block;
  transition: transform 0.3s ease;
}
.nota-card--img:hover .nota-img { transform: scale(1.03); }

.nota-badge--overlay {
  position: absolute;
  top: 10px;
  left: 10px;
  color: #fff;
  font-family: 'Inter', sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.04em;
  padding: 4px 10px;
  border-radius: 20px;
  text-shadow: 0 1px 2px rgba(0,0,0,0.15);
}

/* ── Text card ── */
.nota-card--text {
  border-top-width: 3px;
}

/* ── Card body ── */
.nota-body {
  padding: 14px 16px 16px;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 6px;
  flex: 1;
}

/* ── Inline badge (text cards) ── */
.nota-badge {
  font-family: 'Inter', sans-serif;
  font-weight: 700;
  font-size: 10px;
  padding: 3px 10px;
  border-radius: 20px;
  display: inline-flex;
  align-items: center;
  letter-spacing: 0.03em;
  flex-shrink: 0;
}

/* ── Typography ── */
.nota-titulo {
  font-family: 'Fredoka', sans-serif;
  font-weight: 700;
  font-size: 16px;
  color: var(--marron, #3D1C02);
  margin: 0;
  line-height: 1.3;
  text-wrap: balance;
}

.nota-cuerpo {
  font-family: 'Inter', sans-serif;
  font-weight: 400;
  font-size: 13.5px;
  color: var(--gris, #6B7280);
  line-height: 1.55;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-wrap: pretty;
}

.nota-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  margin-top: auto;
  padding-top: 4px;
}

.nota-fecha {
  font-family: 'Inter', sans-serif;
  font-size: 11.5px;
  color: var(--gris, #6B7280);
}

.btn-compartir-noticia {
  background: none;
  border: 1px solid var(--border, #E5DDD0);
  border-radius: 6px;
  padding: 4px 10px;
  font-family: 'Inter', sans-serif;
  font-size: 11px;
  font-weight: 600;
  color: var(--gris-txt, #6B7280);
  cursor: pointer;
  transition: background 0.15s, color 0.15s;
  white-space: nowrap;
  flex-shrink: 0;
}
.btn-compartir-noticia:hover {
  background: var(--gris-bg, #F9F6F0);
  color: var(--marron, #6B3A2A);
}

/* ── Empty state ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64px 20px;
  text-align: center;
}
.empty-icon { font-size: 48px; margin-bottom: 16px; display: block; }
.empty-msg {
  font-family: 'Fredoka', sans-serif;
  font-weight: 700;
  font-size: 20px;
  color: var(--marron, #3D1C02);
  margin: 0;
}

@media (prefers-reduced-motion: reduce) {
  .nota-card, .nota-img, .btn-compartir-noticia { transition: none; }
  .nota-card:hover { transform: none; }
}
</style>

<script>
  document.querySelectorAll('.btn-compartir-noticia').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.preventDefault()
      e.stopPropagation()
      var url    = btn.dataset.url    || window.location.href
      var titulo = btn.dataset.titulo || ''
      if (navigator.share) {
        navigator.share({ title: titulo, url: url }).catch(function() {})
      } else {
        navigator.clipboard.writeText(url).then(function() {
          var prev = btn.textContent
          btn.textContent = 'Copiado'
          setTimeout(function() { btn.textContent = prev }, 2000)
        }).catch(function() {})
      }
    })
  })
</script>
