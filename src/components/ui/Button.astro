---
const { variant = 'orange', size = 'md', href, fullWidth = false, ariaLabel } = Astro.props;

const variantClasses = {
  red: 'bg-[#E5484D] hover:bg-[#c73d42] text-white',
  green: 'bg-[#34A853] hover:bg-[#2d9247] text-white',
  blue: 'bg-[#4285F4] hover:bg-[#3574db] text-white',
  orange: 'bg-[#C96A1B] hover:bg-[#A85514] text-white',
  outline: 'bg-transparent border border-[#E8E1D6] text-[#3B2A1A] hover:bg-[#F7E8BF]',
  ghost: 'bg-transparent text-[#C96A1B] hover:text-[#A85514] hover:bg-[#FFF8EA]',
};

const sizeClasses = {
  sm: 'text-xs px-3 py-1.5 rounded-[10px]',
  md: 'text-sm px-4 py-2 rounded-[14px]',
  lg: 'text-base px-6 py-3 rounded-[14px]',
};

const widthClass = fullWidth ? 'w-full justify-center' : '';
const baseClasses = `inline-flex items-center font-semibold transition-colors duration-150 ${variantClasses[variant]} ${sizeClasses[size]} ${widthClass}`;
---
{href ? (
  <a href={href} class={baseClasses} aria-label={ariaLabel}><slot /></a>
) : (
  <button class={baseClasses} aria-label={ariaLabel}><slot /></button>
)}
