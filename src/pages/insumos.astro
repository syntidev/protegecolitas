---
import Base from '../layouts/Base.astro'
import { supabaseAdmin } from '../lib/supabase'

const { data: necesidades } = await supabaseAdmin
  .from('necesidades')
  .select('id, item, cantidad_requerida, cantidad_recibida, prioridad, updated_at')
  .order('prioridad', { ascending: true })

function getPct(recibida: number, requerida: number): number {
  if (!requerida) return 0
  return Math.min(Math.round((recibida / requerida) * 100), 100)
}

function getPrioridad(recibida: number, requerida: number, campo: string): string {
  const pct = getPct(recibida, requerida)
  if (campo === 'cubierto' || pct >= 100) return 'cubierto'
  if (campo === 'critico' || pct < 30) return 'critico'
  return 'urgente'
}

function fmtDate(dateStr: string): string {
  if (!dateStr) return ''
  const d = new Date(dateStr)
  return d.toLocaleDateString('es-VE', { day: 'numeric', month: 'short' })
}

const waBase = 'https://wa.me/584222494136'
---
<Base title="Insumos — Protege Colitas">
  <div class="page-inner">

    <div class="page-hero">
      <h1 class="page-title">Necesidades <em>urgentes</em></h1>
      <p class="page-sub">Cada donación suma. Coordiná directamente por WhatsApp.</p>
    </div>

    {necesidades && necesidades.length > 0 ? (
      <div class="cards-grid">
        {necesidades.map((n) => {
          const pct = getPct(n.cantidad_recibida ?? 0, n.cantidad_requerida)
          const prioridad = getPrioridad(n.cantidad_recibida ?? 0, n.cantidad_requerida, n.prioridad)
          const waText = encodeURIComponent(`Hola Rita, quiero donar ${n.item}`)
          return (
            <div class="glass-card">

              <div class="card-top">
                <span class="item-name">{n.item}</span>
                <span class={`pct-label pct-${prioridad}`}>{pct}%</span>
              </div>

              <span class={`badge badge-${prioridad}`}>
                {prioridad === 'critico' ? 'Crítico' : prioridad === 'urgente' ? 'Urgente' : 'Cubierto'}
              </span>

              <div class="progress-track" role="presentation">
                <div
                  class={`progress-fill fill-${prioridad}`}
                  style={`width: ${pct}%`}
                  role="progressbar"
                  aria-valuenow={pct}
                  aria-valuemin={0}
                  aria-valuemax={100}
                  aria-label={`${n.item}: ${pct}% recibido`}
                ></div>
              </div>

              <a
                href={`https://wa.me/5804222494136?text=${waText}`}
                class="btn-donar"
                target="_blank"
                rel="noopener noreferrer"
              >
                Donar esto →
              </a>

            </div>
          )
        })}
      </div>
    ) : (
      <div class="empty-state">
        <span class="empty-icon" aria-hidden="true">📦</span>
        <p class="empty-msg">Pronto publicaremos qué necesitamos.</p>
        <p class="empty-sub">
          <a
            href={`${waBase}?text=${encodeURIComponent('Hola Rita, quiero donar insumos para las mascotas')}`}
            target="_blank"
            rel="noopener noreferrer"
          >Escríbenos y te avisamos.</a>
        </p>
      </div>
    )}

  </div>
</Base>

<style>
.page-inner {
  max-width: 720px;
  margin: 0 auto;
  padding: 24px 16px 80px;
  width: 100%;
}

/* ── Hero ── */
.page-hero {
  padding-bottom: 24px;
}
.page-title {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: clamp(28px, 7vw, 42px);
  line-height: 1.05;
  color: var(--marron);
  margin: 0 0 8px;
  text-wrap: balance;
}
.page-title em {
  font-style: normal;
  color: var(--amarillo);
}
.page-sub {
  font-family: 'Inter', sans-serif;
  font-size: 15px;
  color: var(--gris);
  line-height: 1.5;
  margin: 0;
}

/* ── Grid ── */
.cards-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14px;
}
@media (min-width: 640px) {
  .cards-grid {
    grid-template-columns: 1fr 1fr;
  }
}

/* ── Glass card ── */
.glass-card {
  background: var(--card, rgba(255, 255, 255, 0.75));
  backdrop-filter: blur(16px) saturate(180%);
  -webkit-backdrop-filter: blur(16px) saturate(180%);
  border: 1px solid rgba(255, 255, 255, 0.9);
  border-radius: 18px;
  box-shadow: 0 8px 32px rgba(61, 28, 2, 0.10);
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  transition: box-shadow 0.18s ease, transform 0.15s ease;
}
.glass-card:hover {
  box-shadow: 0 12px 40px rgba(61, 28, 2, 0.15);
  transform: translateY(-2px);
}

/* ── Top row: name + pct ── */
.card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
}
.item-name {
  font-family: 'Inter', sans-serif;
  font-weight: 600;
  font-size: 16px;
  color: var(--marron);
  line-height: 1.3;
  flex: 1;
  min-width: 0;
}
.pct-label {
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: 22px;
  line-height: 1;
  flex-shrink: 0;
}
.pct-critico  { color: var(--rojo); }
.pct-urgente  { color: var(--amarillo); }
.pct-cubierto { color: var(--verde); }

/* ── Priority badge ── */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 3px 10px;
  border-radius: 20px;
  font-family: 'Inter', sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  width: fit-content;
  line-height: 1.4;
}
.badge-critico  { background: rgba(220, 38, 38, 0.12); color: var(--rojo); }
.badge-urgente  { background: rgba(245, 166, 35, 0.12); color: #C17B00; }
.badge-cubierto { background: rgba(22, 163, 74, 0.12);  color: var(--verde); }

/* ── Progress bar ── */
.progress-track {
  height: 8px;
  border-radius: 4px;
  background: rgba(61, 28, 2, 0.08);
  overflow: hidden;
  margin-top: 2px;
}
.progress-fill {
  height: 100%;
  border-radius: 4px;
  transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}
.fill-critico  { background: var(--rojo); }
.fill-urgente  { background: var(--amarillo); }
.fill-cubierto { background: var(--verde); }

/* ── Donate button ── */
.btn-donar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 44px;
  padding: 10px 16px;
  margin-top: 4px;
  background: #25D366;
  color: #ffffff;
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  font-weight: 600;
  text-decoration: none;
  border: none;
  border-radius: 10px;
  cursor: pointer;
  transition: opacity 0.15s ease, transform 0.1s ease;
}
.btn-donar:hover  { opacity: 0.9; }
.btn-donar:active { transform: scale(0.97); }

/* ── Empty state ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 64px 24px;
  gap: 8px;
}
.empty-icon {
  font-size: 56px;
  line-height: 1;
  margin-bottom: 8px;
}
.empty-msg {
  font-family: 'Inter', sans-serif;
  font-size: 17px;
  font-weight: 700;
  color: var(--marron);
  margin: 0;
}
.empty-sub {
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  color: var(--gris);
  margin: 0;
}
.empty-sub a {
  color: var(--amarillo);
  font-weight: 600;
  text-decoration: underline;
  text-underline-offset: 2px;
}

@media (prefers-reduced-motion: reduce) {
  .progress-fill       { transition: none; }
  .glass-card          { transition: none; }
  .glass-card:hover    { transform: none; }
}
</style>
